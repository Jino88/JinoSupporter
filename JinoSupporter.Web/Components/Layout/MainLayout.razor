@inherits LayoutComponentBase
@inject ConnectedUsersService UsersService
@inject UserCircuitHandler    CircuitHandler
@inject WebRepository         Repo
@inject NavigationManager     Nav
@implements IDisposable

<div class="page">
    <div class="sidebar">
        <NavMenu />

        <!-- Connected users panel -->
        <div class="connected-panel">
            <div class="connected-label">
                <span class="dot"></span>
                <span>@UsersService.Count connected</span>
            </div>
            @foreach (UserInfo u in UsersService.Users)
            {
                <div class="user-row">@u.Name</div>
            }
        </div>
    </div>

    <main>
        <AuthorizeView>
            <Authorized>
                <article class="content px-4">
                    @Body
                </article>
            </Authorized>
            <NotAuthorized>
                @{ RedirectToLogin(); }
            </NotAuthorized>
        </AuthorizeView>
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthState { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        UsersService.Changed += OnUsersChanged;

        var auth = await AuthState;
        string username = auth.User.Identity?.Name ?? string.Empty;
        if (!string.IsNullOrEmpty(username))
        {
            var record = Repo.GetUser(username);
            string displayName = record?.DisplayName ?? string.Empty;
            CircuitHandler.Register(username, displayName);
        }
    }

    private void RedirectToLogin()
    {
        string encoded = Uri.EscapeDataString(Nav.Uri);
        Nav.NavigateTo($"/login?returnUrl={encoded}", forceLoad: true);
    }

    private void OnUsersChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => UsersService.Changed -= OnUsersChanged;
}
