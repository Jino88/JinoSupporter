    protected override void OnInitialized() => RefreshJsonFiles();

    // ── Model Files helpers ───────────────────────────────────────────────────────

    private void RefreshJsonFiles()
    {
        _jsonFiles.Clear();
        _jsonFolderExists = Directory.Exists(JsonFolderPath);
        if (!_jsonFolderExists) return;

        _jsonFiles = Directory
            .GetFiles(JsonFolderPath, "*.json", SearchOption.TopDirectoryOnly)
            .OrderByDescending(File.GetLastWriteTime)
            .Select(p => new JsonFileEntry(
                Path.GetFileName(p),
                File.GetLastWriteTime(p).ToString("yy-MM-dd HH:mm"),
                p,
                ReadPgFromFile(p)))
            .ToList();

        // Remove stale selections
        _selectedFiles.RemoveWhere(p => !_jsonFiles.Any(f => f.FullPath == p));

        // If the current tab is empty, jump to the first tab
        if (!_jsonFiles.Any(f => f.ProductGroup == _activePg))
            _activePg = FileProductGroups.FirstOrDefault() ?? "ETC";
    }

    private static string ReadPgFromFile(string path)
    {
        try
        {
            using var stream = File.OpenRead(path);
            using var doc    = JsonDocument.Parse(stream);
            var root = doc.RootElement;
            if (root.ValueKind == JsonValueKind.Object &&
                root.TryGetProperty("ProductGroup", out var pg))
            {
                string v = pg.GetString() ?? "ETC";
                return Array.IndexOf(new[] { "SPK", "UNIT", "MODULE", "TWS", "ETC" }, v) >= 0 ? v : "ETC";
            }
        }
        catch { }
        return "ETC";
    }

    private void ToggleFile(string fullPath)
    {
        if (!_selectedFiles.Remove(fullPath))
            _selectedFiles.Add(fullPath);
    }

    // ── Delete selected files ─────────────────────────────────────────────────────
    private void CancelDeleteFiles()
    {
        _showDeleteFiles  = false;
        _deleteFilesError = null;
    }

    private void ExecuteDeleteFiles()
    {
        _deleteFilesError = null;
        var targets = _selectedFiles.ToList();
        var failed  = new List<string>();

        foreach (string path in targets)
        {
            try
            {
                if (File.Exists(path)) File.Delete(path);
                _selectedFiles.Remove(path);
            }
            catch (Exception ex)
            {
                failed.Add($"{Path.GetFileName(path)}: {ex.Message}");
            }
        }

        RefreshJsonFiles();
        _showDeleteFiles = false;

        if (failed.Count > 0)
        {
            _deleteFilesError = $"{failed.Count}개 삭제 실패:\n" + string.Join("\n", failed);
            _showDeleteFiles  = true;
        }
    }

    // ── Get Data ──────────────────────────────────────────────────────────────────

    private void SetToday()
    {
        _startDate = DateTime.Today;
        _endDate   = DateTime.Today;
    }

    private async Task GetDataAsync()
    {
        if (_endDate < _startDate)
        {
            _errorMessage = "End date must be on or after start date.";
            return;
        }

        _isBusy       = true;
        _errorMessage = null;
        _savedDbPath  = null;
        _logs.Clear();

        var progress = new Progress<string>(msg =>
        {
            _logs.Add($"[{DateTime.Now:HH:mm:ss}] {msg}");
            InvokeAsync(StateHasChanged);
        });

        try
        {
            string? dbPath = await NgRate.FetchAndSaveAsync(
                _startDate, _endDate, progress);

            if (string.IsNullOrEmpty(dbPath))
                _errorMessage = "Data fetch or save failed — check the log.";
            else
            {
                _savedDbPath = dbPath;
                RefreshJsonFiles();
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Exception: {ex.Message}";
            _logs.Add($"[{DateTime.Now:HH:mm:ss}] [ERROR] {ex}");
        }
        finally
        {
            _isBusy = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void ClearResult()
    {
        _savedDbPath  = null;
        _errorMessage = null;
    }

    // ── Get Report ────────────────────────────────────────────────────────────────

    private async Task GetReportAsync()
    {
        _reportError     = string.Empty;
        await DestroyAllChartsAsync();
        _reports.Clear();
        _activeSection = "summary";
        _isReportBusy    = true;
        _logs.Clear();
        _expandedSummary.Clear();
        _expandedProcess.Clear();
        _expandedNg.Clear();
        _expandedReason.Clear();
        _dateExpanded  = false;
        _weekExpanded  = false;
        _monthExpanded = false;
        await InvokeAsync(StateHasChanged);

        IProgress<string> progress = new Progress<string>(msg =>
        {
            _logs.Add($"[{DateTime.Now:HH:mm:ss}] {msg}");
            InvokeAsync(StateHasChanged);
        });

        try
        {
            string? dbPath = _savedDbPath ?? NgRateReport.FindMostRecentDb();
            if (string.IsNullOrEmpty(dbPath) || !File.Exists(dbPath))
            {
                _reportError = "No .db file found. Run Get Data first.";
                return;
            }

            progress.Report($"Using DB: {Path.GetFileName(dbPath)}");

            if (_selectedFiles.Count <= 1)
            {
                var r   = await NgRateReport.GenerateReportAsync(dbPath, _selectedFiles, progress);
                string lbl = _selectedFiles.Count == 1
                    ? Path.GetFileNameWithoutExtension(_selectedFiles.First())
                    : "All";
                _reports.Add((lbl, r));
            }
            else
            {
                foreach (var file in _selectedFiles.OrderBy(f => f))
                {
                    progress.Report($"─── {Path.GetFileNameWithoutExtension(file)}");
                    var r = await NgRateReport.GenerateReportAsync(
                        dbPath, new HashSet<string> { file }, progress);
                    _reports.Add((Path.GetFileNameWithoutExtension(file), r));
                }
            }

            _pendingChartRender = true;
        }
        catch (Exception ex)
        {
            _reportError = $"Error: {ex.Message}";
            _logs.Add($"[{DateTime.Now:HH:mm:ss}] [ERROR] {ex}");
        }
        finally
        {
            _isReportBusy = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task ExportExcelAsync()
    {
        if (_reports.Count == 0 || _isExporting) return;
        _isExporting = true;
        try
        {
            var bytes   = await Task.Run(() => NgRateExcelExporter.Export(_reports));
            string b64  = Convert.ToBase64String(bytes);
            string name = $"NgRate_{DateTime.Now:yyyyMMdd_HHmmss}.xlsx";
            await JS.InvokeVoidAsync("downloadBase64File", name, b64,
                "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
        }
        finally
        {
            _isExporting = false;
        }
    }

    private async Task SwitchSectionAsync(string section)
    {
        if (_activeSection == section) return;
        if (_activeSection == "summary")
            await DestroyAllChartsAsync();
        _activeSection = section;
        if (section == "summary")
            _pendingChartRender = true;
    }

    // ── Utilities ─────────────────────────────────────────────────────────────────

    private static string GetLogClass(string line)
    {
        if (line.Contains("[ERROR]")) return "text-danger";
        if (line.Contains("[WARN]"))  return "text-warning";
        if (line.Contains("───")) return "text-info fw-semibold";
        if (line.Contains("Done") || line.Contains("done") ||
            line.Contains("complete", StringComparison.OrdinalIgnoreCase) ||
            line.Contains("Report"))
            return "text-success";
        return string.Empty;
    }
