    private const int DateVisibleLimit  = 14;
    private const int WeekVisibleLimit  = 4;
    private const int MonthVisibleLimit = 3;

    private bool _dateExpanded  = false;
    private bool _weekExpanded  = false;
    private bool _monthExpanded = false;

    private IEnumerable<NgRateReportService.PeriodColumn> GetVisibleDateCols(NgRateReportService.NgRateReport rpt)
        => !_dateExpanded && rpt.DateCols.Count > DateVisibleLimit
            ? rpt.DateCols.Take(DateVisibleLimit)
            : rpt.DateCols;

