@code {
    private static readonly string JsonFolderPath =
        @"D:\000. MyWorks\000. 일일업무\04. DB\01. NGRATE\ModelBmes";

    private sealed record JsonFileEntry(string Name, string Modified, string FullPath, string ProductGroup);

    private static readonly string[] AllProductGroups = ["SPK", "UNIT", "MODULE", "TWS", "ETC"];

    // ── Get Data state ────────────────────────────────────────────────────────────
    private DateTime     _startDate    = DateTime.Today;
    private DateTime     _endDate      = DateTime.Today;
    private bool         _isBusy       = false;
    private string?      _savedDbPath  = null;
    private string?      _errorMessage = null;
    private List<string> _logs         = new();

    // ── Model Files state ─────────────────────────────────────────────────────────
    private List<JsonFileEntry> _jsonFiles        = new();
    private bool                _jsonFolderExists = false;
    private HashSet<string>     _selectedFiles    = new();
    private string              _activePg         = "ETC";
    private bool                _showDeleteFiles  = false;
    private string?             _deleteFilesError = null;

    /// <summary>Only ProductGroups that actually have files (preserves AllProductGroups order)</summary>
    private IEnumerable<string> FileProductGroups =>
        AllProductGroups.Where(pg => _jsonFiles.Any(f => f.ProductGroup == pg));

    // ── Report state ──────────────────────────────────────────────────────────────
    private bool   _isReportBusy = false;
    private string _reportError  = string.Empty;
    private List<(string Label, NgRateReportService.NgRateReport Report)> _reports = new();

    // Section tabs (defect report type)
    private static readonly (string Key, string Label)[] SectionTabs = new[]
    {
        ("summary", "Summary"),
        ("process", "Process 10 NG"),
        ("ng",      "Worst 10 NG"),
        ("reason",  "Reason"),
    };
    private string _activeSection = "summary";

    // ── Chart state ───────────────────────────────────────────────────────────────
    private bool _pendingChartRender = false;

    // ── Export state ──────────────────────────────────────────────────────────────
    private bool _isExporting = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_pendingChartRender && _activeSection == "summary" && _reports.Count > 0)
        {
            _pendingChartRender = false;
            for (int i = 0; i < _reports.Count; i++)
                await RenderSummaryChartAsync(i);
        }
    }

    private async Task RenderSummaryChartAsync(int modelIdx)
    {
        if (modelIdx < 0 || modelIdx >= _reports.Count) return;
        var rpt = _reports[modelIdx].Report;

        var dateCols  = GetVisibleDateCols(rpt).ToList();
        var weekCols  = GetVisibleWeekCols(rpt).ToList();
        var monthCols = GetVisibleMonthCols(rpt).ToList();
        bool hasWeek  = weekCols.Count > 0;
        bool hasMonth = monthCols.Count > 0;

        // Insert empty label ("") as separator between sections
        var labels = new List<string>();
        labels.AddRange(dateCols.Select(c => c.Header));
        if (hasWeek)  { labels.Add(""); labels.AddRange(weekCols.Select(c  => c.Header)); }
        if (hasMonth) { labels.Add(""); labels.AddRange(monthCols.Select(c => c.Header)); }

        // Data array builder — insert null at separator positions
        double?[] BuildData(Dictionary<string, double> ppm)
        {
            var d = new List<double?>();
            foreach (var c in dateCols)  d.Add(GetChartVal(ppm, c.Key));
            if (hasWeek)  { d.Add(null); foreach (var c in weekCols)  d.Add(GetChartVal(ppm, c.Key)); }
            if (hasMonth) { d.Add(null); foreach (var c in monthCols) d.Add(GetChartVal(ppm, c.Key)); }
            return d.ToArray();
        }

        // TOTAL line chart
        var totalRow = rpt.Summary.FirstOrDefault(r => r.IsTotal);
        object? totalDs = totalRow is null ? null : new
        {
            label           = "TOTAL",
            data            = BuildData(totalRow.Ppm),
            borderColor     = "#3b82f6",
            backgroundColor = "rgba(59,130,246,0.08)",
            borderWidth     = 2,
            pointRadius     = 3,
            tension         = 0.1,
            fill            = false,
            yAxisID         = "y1",
            order           = 0,
            spanGaps        = false,
        };

        // ProcessType bars
        int fi = 0;
        var barDatasets = rpt.Summary
            .Where(r => !r.IsTotal)
            .Select(r =>
            {
                var ds = (object)new
                {
                    type            = "bar",
                    label           = r.ProcessType,
                    data            = BuildData(r.Ppm),
                    backgroundColor = GetPtColor(r.ProcessType, fi),
                    stack           = "pt",
                    order           = 1,
                };
                fi++;
                return ds;
            })
            .ToArray();

        await JS.InvokeVoidAsync("ngRateChart.render", $"summaryChart_m{modelIdx}", labels.ToArray(), barDatasets, totalDs);
    }

    private static double? GetChartVal(Dictionary<string, double> ppm, string key)
        => ppm.TryGetValue(key, out double v) && v > 0 ? v : null;

    private static string GetPtColor(string pt, int fi)
    {
        if (pt.StartsWith("SUB",    StringComparison.OrdinalIgnoreCase)) return "rgba(239,68,68,0.85)";
        if (pt == "MAIN")                                                 return "rgba(34,197,94,0.85)";
        if (pt == "FUNCTION")                                             return "rgba(168,85,247,0.85)";
        if (pt.StartsWith("VISUAL", StringComparison.OrdinalIgnoreCase)) return "rgba(6,182,212,0.85)";
        string[] fb = ["rgba(249,115,22,0.85)", "rgba(234,179,8,0.85)", "rgba(99,102,241,0.85)", "rgba(236,72,153,0.85)"];
        return fb[fi % fb.Length];
    }

    private async Task DestroyAllChartsAsync()
    {
        for (int i = 0; i < _reports.Count; i++)
            try { await JS.InvokeVoidAsync("ngRateChart.destroy", $"summaryChart_m{i}"); } catch { }
    }

    private async Task ClearReportAsync()
    {
        await DestroyAllChartsAsync();
        _reports.Clear();
        _activeSection = "summary";
        _expandedSummary.Clear();
        _expandedProcess.Clear();
        _expandedNg.Clear();
        _expandedReason.Clear();
    }

    public async ValueTask DisposeAsync() => await DestroyAllChartsAsync();

