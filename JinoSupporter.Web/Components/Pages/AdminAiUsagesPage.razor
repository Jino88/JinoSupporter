@page "/admin/ai-usages"
@rendermode InteractiveServer
@using JinoSupporter.Web.Services
@inject WebRepository       Repo
@inject ClaudeUsageScraper  Scraper

<PageTitle>AI Usages</PageTitle>

<AuthorizeView Roles="Admin">
    <NotAuthorized>
        <div class="alert alert-danger">Access denied.</div>
    </NotAuthorized>
    <Authorized>

<div class="d-flex align-items-center justify-content-between mb-3">
    <h5 class="fw-bold mb-0">💳 AI Usages</h5>
</div>

<!-- ══ Browser Session ═══════════════════════════════════════════════════════ -->
<div class="card mb-4" style="max-width:720px;">
    <div class="card-header d-flex align-items-center">
        <span class="fw-semibold">🔐 Browser Session</span>
        <span class="ms-auto">
            @if (Scraper.SessionProfileExists)
            {
                <span class="badge bg-success">Session saved</span>
            }
            else
            {
                <span class="badge bg-secondary">No session</span>
            }
        </span>
    </div>
    <div class="card-body">
        <div class="d-flex gap-2 flex-wrap align-items-center">
            <button class="btn btn-primary btn-sm" @onclick="LoginAsync"
                    disabled="@(_loginBusy || _scrapeBusy)">
                @if (_loginBusy) { <span class="spinner-border spinner-border-sm me-1"></span> }
                🔐 Login (browser 열기)
            </button>
            <button class="btn btn-success btn-sm" @onclick="RefreshAsync"
                    disabled="@(_loginBusy || _scrapeBusy || !Scraper.SessionProfileExists)">
                @if (_scrapeBusy) { <span class="spinner-border spinner-border-sm me-1"></span> }
                ↻ Refresh (자동 가져오기)
            </button>
            <button class="btn btn-outline-danger btn-sm" @onclick="DeleteSession"
                    disabled="@(_loginBusy || _scrapeBusy || !Scraper.SessionProfileExists)"
                    title="세션 프로필 삭제">
                🗑 세션 삭제
            </button>
        </div>

        @if (!string.IsNullOrEmpty(_sessionStatus))
        {
            <div class="mt-2 small @(_sessionError ? "text-danger" : "text-success")">@_sessionStatus</div>
        }

        <div class="form-text mt-2">
            최초 1회만 <strong>Login</strong> 을 클릭 → 브라우저 창이 열리고 <strong>탭이 2개</strong> 뜹니다
            (platform.claude.com, claude.ai). <strong>두 탭 모두</strong> 각각 로그인한 뒤 창을 닫으면 세션 저장 →
            이후 <strong>Refresh</strong> 로 값 자동 갱신.
        </div>
        <div class="form-text" style="color:#b45309;">
            ⚠ 두 도메인은 별도 로그인이 필요합니다. 한쪽만 로그인하면 다른 쪽은 "로그인 풀림" 으로 표시됩니다.
        </div>
        <div class="form-text">
            프로필 경로: <code class="small">@Scraper.ProfileDirectory</code>
        </div>
    </div>
</div>

@if (_imported)
{
    <div class="alert alert-info d-flex align-items-center" role="alert">
        <span class="me-2">↻</span>
        <div>
            <strong>자동 수집한 값이 채워졌습니다.</strong> 값이 맞는지 확인 후 각 섹션의 <kbd>Save</kbd> 를 누르세요.
        </div>
    </div>
}

<!-- ══ API Credits (platform.claude.com) ═══════════════════════════════════════ -->
<div class="card mb-4" style="max-width:720px;">
    <div class="card-header d-flex align-items-center">
        <span class="fw-semibold">🔑 API Credits</span>
        <a href="https://platform.claude.com/settings/billing" target="_blank"
           class="ms-auto small text-decoration-none">
            platform.claude.com/settings/billing ↗
        </a>
    </div>
    <div class="card-body">

        <div class="row g-3 align-items-end">
            <div class="col-sm-6">
                <label class="form-label small text-muted mb-1">API 크레딧 잔액 (USD)</label>
                <div class="input-group">
                    <span class="input-group-text">$</span>
                    <input type="text" class="form-control font-monospace text-end"
                           placeholder="0.00"
                           @bind="_apiCreditBalance" />
                </div>
            </div>
            <div class="col-sm-6">
                <div class="small text-muted">Last updated</div>
                <div class="font-monospace small">@FormatTs(_apiUpdatedAt)</div>
            </div>
        </div>

        <div class="mt-3">
            <button class="btn btn-primary btn-sm" @onclick="SaveApiAsync" disabled="@_apiSaving">
                @(_apiSaving ? "Saving…" : "Save")
            </button>
            @if (_apiSaved) { <span class="ms-2 text-success fw-semibold small">Saved.</span> }
            @if (!string.IsNullOrEmpty(_apiError)) { <span class="ms-2 text-danger small">@_apiError</span> }
        </div>

        @if (!string.IsNullOrEmpty(_billingScrapeError))
        {
            <div class="alert alert-warning mt-2 mb-0 small">⚠ @_billingScrapeError</div>
        }
        @if (!string.IsNullOrEmpty(_billingSnippet))
        {
            <details class="mt-2 small">
                <summary class="text-muted" style="cursor:pointer;">📄 Raw page snippet (디버그)</summary>
                <pre class="small mt-2"
                     style="max-height:220px; overflow:auto; background:#f8fafc; padding:8px; border:1px solid #e2e8f0; font-size:11px; white-space:pre-wrap; word-break:break-word;">@_billingSnippet</pre>
            </details>
        }
    </div>
</div>

<!-- ══ Plan Usage (claude.ai) ═════════════════════════════════════════════════ -->
<div class="card mb-4" style="max-width:720px;">
    <div class="card-header d-flex align-items-center">
        <span class="fw-semibold">📊 Plan Usage</span>
        <a href="https://claude.ai/settings/usage" target="_blank"
           class="ms-auto small text-decoration-none">
            claude.ai/settings/usage ↗
        </a>
    </div>
    <div class="card-body">

        <!-- 현재 세션 -->
        <div class="mb-3">
            <label class="form-label small text-muted mb-1">현재 세션 사용률</label>
            <div class="input-group input-group-sm">
                <span class="input-group-text small">현재 세션</span>
                <input type="text" class="form-control form-control-sm font-monospace text-end"
                       placeholder="예: 42%"
                       @bind="_sessionUsage" />
            </div>
            @if (TryParsePct(_sessionUsage) is double su)
            {
                <div class="progress mt-2" style="height:8px;">
                    <div class="progress-bar bg-primary" style="width:@(su.ToString("0.#"))%"></div>
                </div>
            }
        </div>

        <!-- 주간 한도 -->
        <div class="mb-3">
            <label class="form-label small text-muted mb-1">주간 한도 사용률</label>

            <div class="input-group input-group-sm mb-1">
                <span class="input-group-text small" style="width:120px;">모든 모델</span>
                <input type="text" class="form-control form-control-sm font-monospace text-end"
                       placeholder="예: 41%" @bind="_weeklyAllModels" />
            </div>
            @if (TryParsePct(_weeklyAllModels) is double wa)
            {
                <div class="progress mb-2" style="height:6px;">
                    <div class="progress-bar bg-success" style="width:@(wa.ToString("0.#"))%"></div>
                </div>
            }

            <div class="input-group input-group-sm mb-1">
                <span class="input-group-text small" style="width:120px;">Sonnet만</span>
                <input type="text" class="form-control form-control-sm font-monospace text-end"
                       placeholder="예: 27%" @bind="_weeklySonnet" />
            </div>
            @if (TryParsePct(_weeklySonnet) is double ws)
            {
                <div class="progress mb-2" style="height:6px;">
                    <div class="progress-bar bg-info" style="width:@(ws.ToString("0.#"))%"></div>
                </div>
            }

            <div class="input-group input-group-sm mb-1">
                <span class="input-group-text small" style="width:120px;">Claude Design</span>
                <input type="text" class="form-control form-control-sm font-monospace text-end"
                       placeholder="예: 0%" @bind="_weeklyClaudeDesign" />
            </div>
            @if (TryParsePct(_weeklyClaudeDesign) is double wd)
            {
                <div class="progress mb-2" style="height:6px;">
                    <div class="progress-bar bg-secondary" style="width:@(wd.ToString("0.#"))%"></div>
                </div>
            }
        </div>

        <!-- 추가 사용량 / 잔액 -->
        <div class="mb-3">
            <label class="form-label small text-muted mb-1">추가 사용량 / 잔액 (USD)</label>
            <div class="row g-2">
                <div class="col-sm-5">
                    <div class="input-group input-group-sm">
                        <span class="input-group-text small">추가 사용</span>
                        <span class="input-group-text">$</span>
                        <input type="text" class="form-control form-control-sm font-monospace text-end"
                               placeholder="0.00"
                               @bind="_extraUsage" />
                    </div>
                </div>
                <div class="col-sm-2 text-center align-self-center text-muted">/</div>
                <div class="col-sm-5">
                    <div class="input-group input-group-sm">
                        <span class="input-group-text small">잔액</span>
                        <span class="input-group-text">$</span>
                        <input type="text" class="form-control form-control-sm font-monospace text-end"
                               placeholder="0.00"
                               @bind="_extraBalance" />
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-3 align-items-end mt-2">
            <div class="col-sm-6">
                <button class="btn btn-primary btn-sm" @onclick="SavePlanAsync" disabled="@_planSaving">
                    @(_planSaving ? "Saving…" : "Save")
                </button>
                @if (_planSaved) { <span class="ms-2 text-success fw-semibold small">Saved.</span> }
                @if (!string.IsNullOrEmpty(_planError)) { <span class="ms-2 text-danger small">@_planError</span> }
            </div>
            <div class="col-sm-6 text-sm-end">
                <div class="small text-muted">Last updated</div>
                <div class="font-monospace small">@FormatTs(_planUpdatedAt)</div>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(_usageScrapeError))
        {
            <div class="alert alert-warning mt-2 mb-0 small">⚠ @_usageScrapeError</div>
        }
        @if (!string.IsNullOrEmpty(_usageSnippet))
        {
            <details class="mt-2 small">
                <summary class="text-muted" style="cursor:pointer;">📄 Raw page snippet (디버그)</summary>
                <pre class="small mt-2"
                     style="max-height:220px; overflow:auto; background:#f8fafc; padding:8px; border:1px solid #e2e8f0; font-size:11px; white-space:pre-wrap; word-break:break-word;">@_usageSnippet</pre>
            </details>
        }
        <div class="form-text mt-2">
            디버그 덤프 폴더: <code class="small">@Scraper.DebugDirectory</code> (스크린샷 + 전체 텍스트)
        </div>
    </div>
</div>

    </Authorized>
</AuthorizeView>

@code {
    // ── API credits ───────────────────────────────────────────────────────────
    private string  _apiCreditBalance = string.Empty;
    private string? _apiUpdatedAt;
    private bool    _apiSaving;
    private bool    _apiSaved;
    private string  _apiError = string.Empty;

    // ── Plan usage ────────────────────────────────────────────────────────────
    private string  _sessionUsage       = string.Empty;   // 현재 세션
    private string  _weeklyAllModels    = string.Empty;   // 주간: 모든 모델
    private string  _weeklySonnet       = string.Empty;   // 주간: Sonnet만
    private string  _weeklyClaudeDesign = string.Empty;   // 주간: Claude Design
    private string  _extraUsage         = string.Empty;
    private string  _extraBalance       = string.Empty;
    private string? _planUpdatedAt;
    private bool    _planSaving;
    private bool    _planSaved;
    private string  _planError          = string.Empty;

    // ── Session / scrape ──────────────────────────────────────────────────────
    private bool   _loginBusy;
    private bool   _scrapeBusy;
    private string _sessionStatus       = string.Empty;
    private bool   _sessionError;
    private bool   _imported;
    private string _billingScrapeError  = string.Empty;
    private string _usageScrapeError    = string.Empty;
    private string _billingSnippet      = string.Empty;
    private string _usageSnippet        = string.Empty;

    protected override void OnInitialized()
    {
        _apiCreditBalance = Repo.GetSetting("AiUsages:ApiCreditBalance") ?? string.Empty;
        _apiUpdatedAt     = Repo.GetSetting("AiUsages:ApiUpdatedAt");

        _sessionUsage       = Repo.GetSetting("AiUsages:SessionUsage")       ?? string.Empty;
        _weeklyAllModels    = Repo.GetSetting("AiUsages:WeeklyAllModels")    ?? string.Empty;
        _weeklySonnet       = Repo.GetSetting("AiUsages:WeeklySonnet")       ?? string.Empty;
        _weeklyClaudeDesign = Repo.GetSetting("AiUsages:WeeklyClaudeDesign") ?? string.Empty;
        _extraUsage         = Repo.GetSetting("AiUsages:ExtraUsage")         ?? string.Empty;
        _extraBalance       = Repo.GetSetting("AiUsages:ExtraBalance")       ?? string.Empty;
        _planUpdatedAt      = Repo.GetSetting("AiUsages:PlanUpdatedAt");
    }

    private async Task LoginAsync()
    {
        _loginBusy = true; _sessionError = false;
        _sessionStatus = "브라우저를 여는 중… (최초 실행 시 Chromium 다운로드 ~300MB)";
        StateHasChanged();
        try
        {
            await Scraper.OpenLoginBrowserAsync();
            _sessionStatus = "✓ 세션이 저장되었습니다. 이제 Refresh 를 눌러 값을 가져오세요.";
        }
        catch (Exception ex)
        {
            _sessionError = true;
            _sessionStatus = $"Login 실패: {ex.Message}";
        }
        finally { _loginBusy = false; }
    }

    private async Task RefreshAsync()
    {
        _scrapeBusy = true; _sessionError = false;
        _sessionStatus = "자동 수집 중…";
        _billingScrapeError = _usageScrapeError = string.Empty;
        StateHasChanged();
        try
        {
            var result = await Scraper.ScrapeAsync();

            if (!string.IsNullOrEmpty(result.ApiCreditBalance))
                _apiCreditBalance = result.ApiCreditBalance;
            if (!string.IsNullOrEmpty(result.SessionUsage))       _sessionUsage       = result.SessionUsage;
            if (!string.IsNullOrEmpty(result.WeeklyAllModels))    _weeklyAllModels    = result.WeeklyAllModels;
            if (!string.IsNullOrEmpty(result.WeeklySonnet))       _weeklySonnet       = result.WeeklySonnet;
            if (!string.IsNullOrEmpty(result.WeeklyClaudeDesign)) _weeklyClaudeDesign = result.WeeklyClaudeDesign;
            if (!string.IsNullOrEmpty(result.ExtraUsage))         _extraUsage         = result.ExtraUsage;
            if (!string.IsNullOrEmpty(result.ExtraBalance))       _extraBalance       = result.ExtraBalance;

            _billingScrapeError = result.BillingError ?? string.Empty;
            _usageScrapeError   = result.UsageError   ?? string.Empty;
            _billingSnippet     = result.BillingRawSnippet;
            _usageSnippet       = result.UsageRawSnippet;

            _imported = true;
            _sessionStatus = result.BillingError is null && result.UsageError is null
                ? "✓ 자동 수집 완료 — 값 확인 후 Save"
                : "⚠ 일부 페이지를 가져오지 못했습니다 (아래 경고 참조)";
            _sessionError = result.BillingError is not null || result.UsageError is not null;
        }
        catch (Exception ex)
        {
            _sessionError = true;
            _sessionStatus = $"Refresh 실패: {ex.Message}";
        }
        finally { _scrapeBusy = false; }
    }

    private void DeleteSession()
    {
        Scraper.DeleteSession();
        _sessionStatus = "세션이 삭제되었습니다. 다시 Login 하세요.";
        _sessionError = false;
        _imported = false;
    }

    private async Task SaveApiAsync()
    {
        _apiSaving = true; _apiSaved = false; _apiError = string.Empty;
        try
        {
            string ts = DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss");
            Repo.SetSetting("AiUsages:ApiCreditBalance", (_apiCreditBalance ?? "").Trim());
            Repo.SetSetting("AiUsages:ApiUpdatedAt", ts);
            _apiUpdatedAt = ts;
            _apiSaved = true;
        }
        catch (Exception ex) { _apiError = ex.Message; }
        finally { _apiSaving = false; }
        await Task.CompletedTask;
    }

    private async Task SavePlanAsync()
    {
        _planSaving = true; _planSaved = false; _planError = string.Empty;
        try
        {
            string ts = DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss");
            Repo.SetSetting("AiUsages:SessionUsage",       (_sessionUsage       ?? "").Trim());
            Repo.SetSetting("AiUsages:WeeklyAllModels",    (_weeklyAllModels    ?? "").Trim());
            Repo.SetSetting("AiUsages:WeeklySonnet",       (_weeklySonnet       ?? "").Trim());
            Repo.SetSetting("AiUsages:WeeklyClaudeDesign", (_weeklyClaudeDesign ?? "").Trim());
            Repo.SetSetting("AiUsages:ExtraUsage",         (_extraUsage         ?? "").Trim());
            Repo.SetSetting("AiUsages:ExtraBalance",       (_extraBalance       ?? "").Trim());
            Repo.SetSetting("AiUsages:PlanUpdatedAt", ts);
            _planUpdatedAt = ts;
            _planSaved = true;
        }
        catch (Exception ex) { _planError = ex.Message; }
        finally { _planSaving = false; }
        await Task.CompletedTask;
    }

    private static string FormatTs(string? ts)
        => string.IsNullOrWhiteSpace(ts) ? "(기록 없음)" : ts;

    private static double? TryParsePct(string? s)
    {
        if (string.IsNullOrWhiteSpace(s)) return null;
        string t = s.Trim().TrimEnd('%').Trim();
        return double.TryParse(t, System.Globalization.NumberStyles.Float,
                               System.Globalization.CultureInfo.InvariantCulture, out double v)
            ? v : null;
    }
}
