                {
                    <div class="text-muted small mt-2">← 왼쪽에서 변경할 태그를 선택하세요.</div>
                }
                else
                {
                    <div>
                        <div class="small text-muted mb-1">현재 태그</div>
                        <span class="badge text-bg-secondary fs-6">@_renamingTagOld</span>
                    </div>
                    <div>
                        <label class="form-label small fw-semibold mb-1">변경할 이름</label>
                        <div class="input-group">
                            <input class="form-control form-control-sm"
                                   placeholder="새 태그 이름 입력…"
                                   @bind="_renamingTagNew"
                                   @bind:event="oninput" />
                            <button class="btn btn-primary btn-sm"
                                    @onclick="RenameTagAsync"
                                    disabled="@(_isBusy || string.IsNullOrWhiteSpace(_renamingTagNew) || _renamingTagNew.Trim() == _renamingTagOld)">
