    private async Task ReTagAsync()
    {
        if (_selectedDbDataset is null || !Claude.IsConfigured) return;
        _isBusy = true; _busyStep = "retag"; StateHasChanged();
        try
        {
            List<string> cols = _dbTables.SelectMany(t => t.Columns).Select(c => c.Label).Distinct().ToList();
            string memo       = Repo.GetMemo(_selectedDbDataset);
            _dbTags           = await Claude.ExtractTagsAsync(_selectedDbDataset, memo, string.Join(" ", cols));
            await Task.Run(() => Repo.SaveTags(_selectedDbDataset, _dbTags));
            SetStatus($"Re-tagged '{_selectedDbDataset}' with {_dbTags.Count} tag(s).", false);
        }
        catch (Exception ex) { SetStatus($"Re-tag error: {ex.Message}", true); }
        finally { _isBusy = false; _busyStep = string.Empty; }
    }

