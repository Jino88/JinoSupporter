@code {
    // ── Types ─────────────────────────────────────────────────────────────────
    private sealed class PendingTable
    {
        public string TableName { get; set; } = "";
        public List<ColumnDef> Columns { get; init; } = [];
        public List<Dictionary<string, string>> Rows { get; init; } = [];
        public bool IsExisting { get; init; }   // loaded from DB — skip on save
    }

    private sealed record ImageEntry(string Name, string MediaType, string Base64, string DataUrl, long SizeBytes);

    private sealed class DocBlock
    {
        public string        Kind  { get; init; } = "";   // "table" | "image"
        public PendingTable? Table { get; init; }
        public ImageEntry?   Image { get; init; }
        public int           Span  { get; set; }  = 2;   // 1=절반, 2=전체
    }

    // ── Input state ───────────────────────────────────────────────────────────
    private string       _datasetName = string.Empty;
    private string       _purpose     = string.Empty;
    private string       _memo        = string.Empty;
    private List<string> _allDatasets = [];
    private string _rawInput    = string.Empty;
    private bool   _useAi       = true;

    private List<PendingTable> _pendingTables    = [];
    private List<ImageEntry>   _images           = [];
    private List<DocBlock>     _docBlocks        = [];
    private int                _dropZoneActive   = -1;
    private string?            _dragKind;
    private PendingTable?      _dragTable;
    private ImageEntry?        _dragImage;
    private bool               _includeImagesInAi;

    private bool CanOrganize =>
        !string.IsNullOrWhiteSpace(_rawInput) ||
        (_includeImagesInAi && _images.Count > 0);

    // ── UI state ──────────────────────────────────────────────────────────────
    private bool   _isBusy;
    private string _busyStep       = string.Empty;
    private string _statusMessage  = string.Empty;
    private bool   _statusIsError;
    private string _activeTab      = "results";

    private string _dbPath      = string.Empty;
    private int    _totalRecords;

    // ── Auth ──────────────────────────────────────────────────────────────────
    [CascadingParameter] private Task<AuthenticationState> AuthState { get; set; } = default!;
    private System.Security.Claims.ClaimsPrincipal _user = new();
    private bool CanEdit => AppRoles.CanEdit(_user);

    // ── Clipboard ─────────────────────────────────────────────────────────────
    private bool _showCaptureOverlay;
    private DotNetObjectReference<DataInferencePage>? _dotnetRef;

    // ── DB Data tab state ────────────────────────────────────────────────────
    private List<(string Name, int TableCount)> _dbSummary      = [];
    private string?           _selectedDbDataset;
    private List<DataTableInfo> _dbTables                       = [];
    private DataTableInfo?    _selectedDbTable;
    private List<Dictionary<string, string>> _dbRows            = [];
    private List<Dictionary<string, string>> _dbDisplayRows     = [];
    private List<string>      _dbTags                           = [];
    private string            _dbMemo                           = string.Empty;
    private string            _dbPurpose                        = string.Empty;
    // 모든 테이블 행을 미리 로드 (스택 뷰용)
    private Dictionary<long, (List<Dictionary<string,string>> Raw, List<Dictionary<string,string>> Display)>
        _allDbTableRows = new();
    private List<(string FileName, string MediaType, string Base64)> _dbImages = [];

    // ── Tag filter ────────────────────────────────────────────────────────────
    private List<string>                     _allDbTagsForFilter = [];
    private HashSet<string>                  _selectedTagFilters  = new(StringComparer.OrdinalIgnoreCase);
    private Dictionary<string, List<string>> _datasetTagsCache    = new();

    // ── Tag rename panel ──────────────────────────────────────────────────────
    private bool   _showTagRenamePanel;
    private string _renamingTagOld  = "";
    private string _renamingTagNew  = "";
    private string _renameTagStatus = "";
    private bool   _renameTagError;

    // ── Table rename ──────────────────────────────────────────────────────────
    private long   _renamingTableId = -1;
    private string _renameValue     = "";

    // ── Context menu ──────────────────────────────────────────────────────────
    private bool          _showCtxMenu;
    private double        _ctxX, _ctxY;
    private string        _ctxMode  = "";      // "row" | "col"
    private bool          _ctxIsDb;
    private PendingTable? _ctxTable;
    private int           _ctxRowIndex = -1;
    private int           _ctxColIndex = -1;

    // ── Inline cell editing ───────────────────────────────────────────────────
    private bool          _editIsDb;
    private PendingTable? _editTable;
    private int           _editRowIndex  = -1;
    private string        _editColField  = "";
    private string        _editValue     = "";
    private bool          _editNeedFocus;
    private ElementReference _editRef;
    private bool          _renameNeedFocus;
    private ElementReference _renameRef;

    private IEnumerable<(string Name, int TableCount)> FilteredSummary =>
        _selectedTagFilters.Count == 0
            ? _dbSummary
            : _dbSummary.Where(s =>
                _datasetTagsCache.TryGetValue(s.Name, out var tags) &&
                _selectedTagFilters.All(f => tags.Any(t =>
                    string.Equals(t, f, StringComparison.OrdinalIgnoreCase))));

    [Parameter] public string? InitialTab { get; set; }

    // ── Lifecycle ─────────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        _user = (await AuthState).User;
        ApplyInitialTab();
        RefreshDbInfo();
    }

    protected override Task OnParametersSetAsync()
    {
        // 같은 컴포넌트 재사용 시 (예: /data-inference ↔ /data-inference/db) 탭 동기화
        ApplyInitialTab();
        return Task.CompletedTask;
    }

    private void ApplyInitialTab()
    {
        var target = string.IsNullOrEmpty(InitialTab) ? "results" : InitialTab.ToLowerInvariant();
        if (_activeTab != target)
            SetTab(target);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotnetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("pasteImageHandler.init", _dotnetRef);
        }
        if (_editNeedFocus)
        {
            _editNeedFocus = false;
            try { await JS.InvokeVoidAsync("eval", "document.querySelector('.di-cell-input')?.focus()"); } catch { }
        }
        if (_renameNeedFocus)
        {
            _renameNeedFocus = false;
            try { await _renameRef.FocusAsync(); } catch { }
        }
    }

    private void RefreshDbInfo()
    {
        _dbPath       = Repo.GetDbPath();
        _totalRecords = Repo.GetTotalRowCount();
        _allDatasets  = Repo.GetAllDatasets();
    }

    // ── Tab switching ─────────────────────────────────────────────────────────
    private void SetTab(string tab)
    {
        _activeTab = tab;
        if (tab == "db") RefreshDbTab();
    }

    private void SetMode(bool useAi) => _useAi = useAi;

    // ── Organize ──────────────────────────────────────────────────────────────
    private async Task OrganizeAsync()
    {
        if (!CanOrganize)
        {
            SetStatus("Paste data or add an image first.", true);
            return;
        }

        if (_includeImagesInAi && _images.Count > 0 && !_useAi)
        {
            SetStatus("Image analysis requires AI Extract mode.", true);
            return;
        }

        _isBusy = true; _busyStep = "organize"; _statusMessage = string.Empty;
        StateHasChanged();

        try
        {
            List<PendingTable> newTables;

            if (_useAi)
            {
                List<(string MediaType, string Base64)>? imageList = null;
                if (_includeImagesInAi && _images.Count > 0)
                    imageList = _images.Select(i => (i.MediaType, i.Base64)).ToList();

                List<ExtractedTable> extracted = await Claude.ExtractTablesAsync(_rawInput, imageList);
                if (extracted.Count == 0)
                {
                    SetStatus("No tables extracted. Check the input format.", true);
                    return;
                }
                newTables = extracted.Select(t => new PendingTable
                {
                    TableName = t.TableName,
                    Columns   = t.Columns,
                    Rows      = t.Rows
                }).ToList();
            }
            else
            {
                var (cols, rows) = ParseDirect(_rawInput);
                if (rows.Count == 0)
                {
                    SetStatus("No rows found. Make sure the first row contains headers.", true);
                    return;
                }
                newTables = [new PendingTable
                {
                    TableName = $"Table {_pendingTables.Count + 1}",
                    Columns   = cols,
                    Rows      = rows
                }];
            }

            _pendingTables.AddRange(newTables);
            foreach (var t in newTables)
                _docBlocks.Add(new DocBlock { Kind = "table", Table = t, Span = 2 });
            _rawInput  = string.Empty;
            _activeTab = "results";
            SetStatus($"Organized {newTables.Count} table(s). Total: {_pendingTables.Count}.", false);
        }
        catch (Exception ex) { SetStatus($"Error: {ex.Message}", true); }
        finally { _isBusy = false; _busyStep = string.Empty; }
    }

