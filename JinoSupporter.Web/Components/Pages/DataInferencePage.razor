    [JSInvokable]
    public void OnImagePasted(string mediaType, string dataUrl)
    {
        string ext    = mediaType.Split('/').LastOrDefault() ?? "png";
        int commaIdx  = dataUrl.IndexOf(',');
        string base64 = commaIdx >= 0 ? dataUrl[(commaIdx + 1)..] : dataUrl;
        long sizeBytes = (long)(base64.Length * 3L / 4);
        _images.Add(new ImageEntry($"clipboard-{DateTime.Now:HHmmss}.{ext}", mediaType, base64, dataUrl, sizeBytes));
        _showCaptureOverlay = false;
        InvokeAsync(StateHasChanged);
    }

    // ── Direct parse (no AI) ──────────────────────────────────────────────────
    private static (List<ColumnDef> Cols, List<Dictionary<string, string>> Rows) ParseDirect(string text)
    {
        string[] lines = text.Split('\n', StringSplitOptions.RemoveEmptyEntries);
        if (lines.Length < 2) return ([], []);

        string[] headers = lines[0].Split('\t');
        var seen = new Dictionary<string, int>(StringComparer.OrdinalIgnoreCase);
        var cols = new List<ColumnDef>();
        for (int i = 0; i < headers.Length; i++)
        {
            string label = headers[i].Trim();
            string baseF = string.IsNullOrWhiteSpace(label) ? $"col{i}"
                : System.Text.RegularExpressions.Regex.Replace(label, @"[^a-zA-Z0-9가-힣]", "_");
            string field = seen.TryGetValue(baseF, out int n)
                ? (seen[baseF] = n + 1, $"{baseF}_{n + 1}").Item2
                : (seen[baseF] = 1, baseF).Item2;
            cols.Add(new ColumnDef { Field = field, Label = label });
        }

        var rows = new List<Dictionary<string, string>>();
        for (int li = 1; li < lines.Length; li++)
        {
            string line = lines[li].TrimEnd('\r');
            if (string.IsNullOrWhiteSpace(line)) continue;
            string[] cells = line.Split('\t');
            var dict = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
            for (int ci = 0; ci < cols.Count; ci++)
                dict[cols[ci].Field] = ci < cells.Length ? cells[ci] : string.Empty;
            rows.Add(dict);
        }
        return (cols, rows);
    }

