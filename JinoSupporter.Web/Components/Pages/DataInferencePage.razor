        _renamingTagNew  = tag;
        _renameTagStatus = "";
    }

    private async Task RenameTagAsync()
    {
        if (string.IsNullOrWhiteSpace(_renamingTagOld) || string.IsNullOrWhiteSpace(_renamingTagNew)) return;
        string newTag = _renamingTagNew.Trim();
        if (string.Equals(newTag, _renamingTagOld, StringComparison.OrdinalIgnoreCase)) return;

        _isBusy = true; StateHasChanged();
        try
        {
            int updated = await Task.Run(() => Repo.RenameTag(_renamingTagOld, newTag));
            _renameTagStatus = $"'{_renamingTagOld}' → '{newTag}' ({updated}개 데이터셋 업데이트됨)";
            _renameTagError  = false;
            _renamingTagOld  = newTag;
            _renamingTagNew  = newTag;
            // 캐시 및 현재 데이터셋 태그 갱신
            RefreshDbTab();
            if (_selectedDbDataset is not null)
                _dbTags = Repo.GetTags(_selectedDbDataset);
        }
        catch (Exception ex) { _renameTagStatus = $"오류: {ex.Message}"; _renameTagError = true; }
        finally { _isBusy = false; }
    }

    private void SelectDbDataset(string name)
    {
        _selectedDbDataset = name;
        _dbTables          = Repo.GetTablesForDataset(name);
        _selectedDbTable   = null;
        _dbRows            = [];
        _dbDisplayRows     = [];
        _dbTags            = Repo.GetTags(name);
        _dbMemo            = Repo.GetMemo(name);
        _dbPurpose         = Repo.GetPurpose(name);
        // 모든 테이블 행 미리 로드
        _allDbTableRows = new();
        foreach (var t in _dbTables)
        {
            var raw     = Repo.GetTableRows(t.Id);
            var display = ForwardFill(t, raw);
            _allDbTableRows[t.Id] = (raw, display);
        }
        _dbImages = Repo.GetImages(name);
    }

    private void SelectDbTable(DataTableInfo table)
    {
        _selectedDbTable = table;
        _dbRows          = Repo.GetTableRows(table.Id);
        _dbDisplayRows   = ForwardFill(table, _dbRows);
    }

    // 스택 뷰에서 셀 클릭/컨텍스트메뉴 전에 호출 — _selectedDbTable + _dbRows/_dbDisplayRows 동기화
    private void SelectTableForEdit(DataTableInfo t)
    {
        if (_selectedDbTable?.Id == t.Id) return;
        _selectedDbTable = t;
        if (_allDbTableRows.TryGetValue(t.Id, out var entry))
        {
            _dbRows        = entry.Raw;
            _dbDisplayRows = entry.Display;
        }
    }

