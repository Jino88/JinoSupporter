    // ── Drag-and-drop ─────────────────────────────────────────────────────────

    private void StartDragTable(PendingTable t) => StartDrag("table", t, null);
    private void StartDragImage(ImageEntry i)   => StartDrag("image", null, i);

    private void StartDrag(string kind, PendingTable? table, ImageEntry? image)
    {
        _dragKind  = kind;
        _dragTable = table;
        _dragImage = image;
    }

    private void DropAt(int dropZoneIndex)
    {
        if (_dragKind is null) return;
        var block = new DocBlock
        {
            Kind  = _dragKind,
            Table = _dragTable,
            Image = _dragImage,
            Span  = _dragKind == "image" ? 1 : 2
        };
        int insertAt = Math.Min(dropZoneIndex, _docBlocks.Count);
        _docBlocks.Insert(insertAt, block);
        _dragKind = null; _dragTable = null; _dragImage = null;
        _dropZoneActive = -1;
    }

    private void MoveBlock(DocBlock blk, int delta)
    {
        int idx    = _docBlocks.IndexOf(blk);
        int newIdx = idx + delta;
        if (newIdx < 0 || newIdx >= _docBlocks.Count) return;
        _docBlocks.RemoveAt(idx);
        _docBlocks.Insert(newIdx, blk);
    }


    // ── Dataset dropdown selection ────────────────────────────────────────────
    private void OnDatasetSelected(ChangeEventArgs e)
    {
        string ds = e.Value?.ToString() ?? string.Empty;
        if (string.IsNullOrEmpty(ds)) return;

        _datasetName = ds;
        _memo        = Repo.GetMemo(ds);
        _purpose     = Repo.GetPurpose(ds);

        // Backwards compat: if no purpose saved yet, pre-fill from existing tags
        if (string.IsNullOrEmpty(_purpose))
        {
            var existingTags = Repo.GetTags(ds);
            if (existingTags.Count > 0)
                _purpose = string.Join(", ", existingTags);
        }

        // Load existing tables into the results panel
        var tables = Repo.GetTablesForDataset(ds);
        _pendingTables = tables.Select(t => new PendingTable
        {
            TableName  = t.TableName,
            Columns    = t.Columns,
            Rows       = Repo.GetTableRows(t.Id),
            IsExisting = true,
        }).ToList();

        SetTab("results");
    }

    // ── Extract Purpose tags ──────────────────────────────────────────────────
    private async Task ExtractPurposeAsync()
    {
        _isBusy = true; _busyStep = "purpose";
        StateHasChanged();
        try
        {
            // Build context: table names + all distinct column labels + sample values
            var tableNames = _pendingTables.Select(t => t.TableName);
            var colLabels  = _pendingTables.SelectMany(t => t.Columns).Select(c => c.Label).Distinct();

            // Sample up to 3 rows per table — non-numeric strings only
            var sampleValues = _pendingTables
                .SelectMany(t => t.Rows.Take(3)
                    .SelectMany(r => r.Values)
                    .Where(v => !string.IsNullOrWhiteSpace(v)
                             && !double.TryParse(v, out _)))
                .Distinct()
                .Take(60);

            // Words from Description (numbers allowed)
            var memoWords = _memo
                .Split([' ', ',', '.', '\n', '\r', '\t', ';', ':', '(', ')'], StringSplitOptions.RemoveEmptyEntries)
                .Where(w => w.Length > 1)
                .Distinct(StringComparer.OrdinalIgnoreCase);

            string context = string.Join(" | ",
                tableNames
                .Concat(colLabels)
                .Concat(sampleValues)
                .Concat(memoWords));

            var existingTags = Repo.GetAllDistinctTags();
            var tags = await Claude.ExtractPurposeTagsAsync(
                _datasetName, context, existingTags);

            if (tags.Count > 0)
                _purpose = string.Join(", ", tags);

            SetStatus($"Extracted {tags.Count} purpose tag(s).", false);
        }
        catch (Exception ex) { SetStatus($"Extract error: {ex.Message}", true); }
        finally { _isBusy = false; _busyStep = string.Empty; }
    }

    // ── Save to DB ────────────────────────────────────────────────────────────
    private async Task SaveToDbAsync()
    {
        if (string.IsNullOrWhiteSpace(_datasetName))
        {
            SetStatus("Dataset name is required.", true);
            return;
        }

        _isBusy = true; _busyStep = "save"; _statusMessage = string.Empty;
        StateHasChanged();
        try
        {
            string dsName  = _datasetName.Trim();
            var tables     = _pendingTables.Where(t => !t.IsExisting).ToList();
            var tags       = _purpose.Split(',')
                                 .Select(s => s.Trim())
                                 .Where(s => !string.IsNullOrEmpty(s))
                                 .ToList();
            string memo    = _memo;
            string purpose = _purpose;

            await Task.Run(() =>
            {
                foreach (PendingTable t in tables)
                    Repo.SaveTable(dsName, t.TableName, t.Columns, t.Rows);
                if (tags.Count > 0) Repo.SaveTags(dsName, tags);
                if (!string.IsNullOrWhiteSpace(memo))    Repo.SaveMemo(dsName, memo);
                if (!string.IsNullOrWhiteSpace(purpose)) Repo.SavePurpose(dsName, purpose);
            });

            int rows = tables.Sum(t => t.Rows.Count);
            SetStatus($"Saved '{dsName}' — {rows:N0} rows.", false);

            _pendingTables = [];
            _images        = [];
            _datasetName   = string.Empty;
            _purpose       = string.Empty;
            _memo          = string.Empty;
            RefreshDbInfo();
        }
        catch (Exception ex) { SetStatus($"Save error: {ex.Message}", true); }
        finally { _isBusy = false; _busyStep = string.Empty; }
    }

    // ── DB Data tab ───────────────────────────────────────────────────────────
    private void RefreshDbTab()
    {
        _dbSummary = Repo.GetDatasetSummary();
        if (_selectedDbDataset is not null && !_dbSummary.Any(s => s.Name == _selectedDbDataset))
            _selectedDbDataset = null;
        if (_selectedDbDataset is null)
        {
            _dbTables         = [];
            _selectedDbTable  = null;
            _dbRows           = [];
            _dbDisplayRows    = [];
        }
        // 태그 필터용 캐시 갱신
        _datasetTagsCache = _dbSummary
            .ToDictionary(s => s.Name, s => Repo.GetTags(s.Name));
        _allDbTagsForFilter = _datasetTagsCache.Values
            .SelectMany(t => t)
            .Where(t => !string.IsNullOrWhiteSpace(t))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(t => t)
            .ToList();
        // 삭제된 태그는 선택에서 제거
        _selectedTagFilters.IntersectWith(_allDbTagsForFilter);
    }

