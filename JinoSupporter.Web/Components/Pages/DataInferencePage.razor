         @onclick="() => _showTagRenamePanel = false"></div>
    <div style="position:fixed; top:50%; left:50%; transform:translate(-50%,-50%); z-index:1051;
                background:#fff; border-radius:12px; box-shadow:0 8px 40px rgba(0,0,0,.2);
                width:580px; max-width:95vw; max-height:80vh;
