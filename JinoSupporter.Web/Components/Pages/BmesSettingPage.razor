    private void ImportRoutingFromFile()
    {
        int count = NgRateSettings.ImportRoutingFromFile(NgRateSettings.RoutingFilePath);
        _routingRows = NgRateSettings.GetRoutingRows();
        _editRoutingId = -1;
        SetStatus(count > 0 ? $"Imported {count} routing rows from file." : "File not found or empty.", count == 0);
    }

    // ── Refresh Routing raw dump from BMES ────────────────────────────────────
    private bool   _routingScrapeBusy;
    private string _routingScrapeMsg   = string.Empty;
    private bool   _routingScrapeError;

    private async Task RefreshRoutingFromBmes()
    {
        if (_routingScrapeBusy) return;
        _routingScrapeBusy  = true;
        _routingScrapeMsg   = string.Empty;
        _routingScrapeError = false;
        StateHasChanged();

        try
        {
            var progress = new Progress<string>(msg =>
            {
                _routingScrapeMsg = msg;
                InvokeAsync(StateHasChanged);
            });

            int saved = await BmesRoutingScrape.FetchAllAsync(progress);
            if (saved < 0)
            {
                _routingScrapeError = true;
            }
            else
            {
                _routingRows  = NgRateSettings.GetRoutingRows();
                _editRoutingId = -1;
            }
        }
        catch (Exception ex)
        {
            _routingScrapeError = true;
            _routingScrapeMsg   = $"✗ {ex.Message}";
        }
        finally
        {
            _routingScrapeBusy = false;
            StateHasChanged();
        }
    }

