    // ── Reason: model (Material) scan ────────────────────────────────────────

    private async Task OnModelSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await RunModelScan();
    }

    private async Task RunModelScan()
    {
        if (_modelScanBusy) return;
        if (string.IsNullOrWhiteSpace(_rsqModel)) { ClearModelScan(); return; }

        _modelScanBusy   = true;
        _modelScanActive = true;
        _modelPairs      = new();
        StateHasChanged();

        try
        {
            string pattern = _rsqModel;
            var pairs = await Task.Run(() => NgRateSettings.GetProcessNgPairsByMaterial(pattern));
            _modelPairs = pairs;
        }
        catch (Exception ex)
        {
            SetStatus($"Model scan failed: {ex.Message}", true);
        }
        finally
        {
            _modelScanBusy = false;
            StateHasChanged();
        }
    }

    private void ClearModelScan()
    {
        _modelScanActive = false;
        _modelPairs.Clear();
    }

    /// <summary>Returns scanned pairs further filtered by the in-table PN/NG search inputs
    /// (the Reason input has no effect here — Reason is derived from ReasonTable lookup).</summary>
    private IEnumerable<(string ProcessName, string NgName)> ModelPairsFiltered()
    {
        IEnumerable<(string ProcessName, string NgName)> q = _modelPairs;
        if (!string.IsNullOrEmpty(_rsqProcessName))
            q = q.Where(p => p.ProcessName.Contains(_rsqProcessName, StringComparison.OrdinalIgnoreCase));
        if (!string.IsNullOrEmpty(_rsqNgName))
            q = q.Where(p => p.NgName.Contains(_rsqNgName, StringComparison.OrdinalIgnoreCase));
        return q;
    }

    private ReasonRow? FindReasonRow(string pn, string ng)
        => _reasonRows.FirstOrDefault(r =>
               string.Equals(r.ProcessName, pn, StringComparison.Ordinal)
            && string.Equals(r.NgName,      ng, StringComparison.Ordinal));

    private void AddReasonFromPair(string pn, string ng)
    {
        var newRow = new ReasonRow { ProcessName = pn, NgName = ng, Reason = string.Empty };
        var newId  = NgRateSettings.AddReasonRow(newRow);
        _reasonRows = NgRateSettings.GetReasonRows();
        _editReasonId = newId;
        _editReason   = new ReasonRow { Id = newId, ProcessName = pn, NgName = ng, Reason = string.Empty };
    }

    private void ImportReasonFromFile()
    {
        int count = NgRateSettings.ImportReasonFromFile(NgRateSettings.ReasonFilePath);
        _reasonRows = NgRateSettings.GetReasonRows();
        _editReasonId = -1;
        SetStatus(count > 0 ? $"Imported {count} reason rows from file." : "File not found or empty.", count == 0);
    }

    // ── Refresh Reason from Daily DBs ─────────────────────────────────────────
    private bool   _reasonRefreshBusy;
    private string _reasonRefreshMsg   = string.Empty;
    private bool   _reasonRefreshError;

    private async Task RefreshReasonFromDailyDbs()
    {
        if (_reasonRefreshBusy) return;
        _reasonRefreshBusy  = true;
        _reasonRefreshMsg   = string.Empty;
        _reasonRefreshError = false;
        StateHasChanged();

        try
        {
            var progress = new Progress<string>(msg =>
            {
                _reasonRefreshMsg = msg;
                InvokeAsync(StateHasChanged);
            });

            int added = await Task.Run(() => NgRateSettings.RefreshReasonFromDailyDbs(progress));
            _reasonRows    = NgRateSettings.GetReasonRows();
            _editReasonId  = -1;
            _reasonRefreshMsg = added > 0
                ? $"✓ Added {added} new pair(s)."
                : "✓ No new pairs — ReasonTable already covers all DB values.";
        }
        catch (Exception ex)
        {
            _reasonRefreshError = true;
            _reasonRefreshMsg   = $"✗ {ex.Message}";
        }
        finally
        {
            _reasonRefreshBusy = false;
            StateHasChanged();
        }
    }

    private void SetStatus(string msg, bool isError)
    {
        _statusMsg   = msg;
        _statusError = isError;
    }
