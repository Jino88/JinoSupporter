@page "/bmes/make-model"
@rendermode InteractiveServer
@using JinoSupporter.Web.Services
@using System.Text.Json
@inject NgRateSettingsService NgRateSettings
@inject IJSRuntime JS

<PageTitle>Make Model Data</PageTitle>

<style>
    .model-item {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 4px 10px;
        border-bottom: 1px solid #f1f5f9;
        cursor: pointer;
        font-size: 12px;
        font-family: monospace;
    }
    .model-item:hover { background: #f8fafc; }
    .model-item.selected { background: #eff6ff; }
    .group-card {
        border: 1px solid #e2e8f0;
        border-radius: 6px;
        margin-bottom: 8px;
        overflow: hidden;
    }
    .group-header {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 6px 10px;
        background: #f8fafc;
        border-bottom: 1px solid #e2e8f0;
    }
    .group-body {
        padding: 8px 10px;
        background: #fff;
    }
    .model-badge {
        display: inline-block;
        font-size: 11px;
        font-family: monospace;
        padding: 2px 6px;
        border-radius: 4px;
        background: #f1f5f9;
        border: 1px solid #e2e8f0;
        color: #334155;
        margin: 2px;
    }
    .reorder-btn {
        border: none; background: none;
        color: #94a3b8; cursor: pointer;
        font-size: 10px; line-height: 1.2; padding: 0;
    }
    .reorder-btn:disabled { opacity: 0.3; cursor: default; }
    .reorder-btn:not(:disabled):hover { color: #6366f1; }
    .file-item {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 7px 12px;
        border-bottom: 1px solid #f1f5f9;
        cursor: pointer;
        font-size: 12px;
    }
    .file-item:hover { background: #f8fafc; }
    .file-item:last-child { border-bottom: none; }
    /* Product group chips */
    .pg-btn {
        font-size: 11px; font-weight: 600; letter-spacing: .3px;
        padding: 3px 10px; border-radius: 14px; border: 1.5px solid #cbd5e1;
        background: #f8fafc; color: #475569; cursor: pointer;
        transition: all .15s;
    }
    .pg-btn:hover { border-color: #6366f1; color: #6366f1; background: #eef2ff; }
    .pg-btn.active { background: #6366f1; border-color: #4f46e5; color: #fff; }
    .pg-badge {
        display: inline-block; font-size: 10px; font-weight: 700;
        padding: 1px 6px; border-radius: 4px; letter-spacing: .5px;
    }
    .pg-SPK     { background:#fef9c3; color:#854d0e; border:1px solid #fde68a; }
    .pg-UNIT    { background:#dcfce7; color:#166534; border:1px solid #86efac; }
    .pg-MODULE  { background:#dbeafe; color:#1e40af; border:1px solid #93c5fd; }
    .pg-TWS     { background:#fce7f3; color:#9d174d; border:1px solid #f9a8d4; }
    .pg-ETC     { background:#f1f5f9; color:#475569; border:1px solid #cbd5e1; }
</style>

<div class="d-flex align-items-center gap-2 mb-3">
    <span style="font-size:20px;">📦</span>
    <h5 class="mb-0 fw-semibold">Make Model Data</h5>
    <span class="text-muted small ms-1">— Create JSON model group file</span>
</div>

<div class="row g-3" style="min-height:0;">

    <!-- ══ LEFT: Available Models ══════════════════════════════════════════════ -->
    <div class="col-md-4">
        <div class="card shadow-sm d-flex flex-column" style="height:calc(100vh - 130px);">
            <div class="card-header small fw-semibold d-flex align-items-center gap-2">
                <span>Available Models</span>
                <span class="text-muted ms-1" style="font-size:11px;">
                    @(_allLineShifts.Count > 0 ? $"{_allLineShifts.Count} items" : "")
                </span>
                <button class="btn btn-link btn-sm p-0 ms-auto text-secondary"
                        @onclick="LoadModelsAsync" disabled="@_loading" title="Reload">
                    @if (_loading) { <span class="spinner-border spinner-border-sm"></span> }
                    else { <span>⟳</span> }
                </button>
            </div>

            @if (_allLineShifts.Count == 0 && !_loading)
            {
                <div class="card-body d-flex align-items-center justify-content-center flex-column gap-2">
                    <div class="text-muted small text-center">
                        Loads the LineShift list from DB files.<br />
                        <span class="font-monospace" style="font-size:10px; word-break:break-all;">
                            @NgRateSettings.DbSaveDirectory
                        </span>
                    </div>
                    <button class="btn btn-primary btn-sm" @onclick="LoadModelsAsync">Load Models</button>
                    @if (!string.IsNullOrEmpty(_loadError))
                    {
                        <div class="text-danger small">@_loadError</div>
                    }
                </div>
            }
            else
            {
                <!-- Search -->
                <div class="p-2 border-bottom">
                    <input type="text" class="form-control form-control-sm"
                           placeholder="Search…" @bind="_search" @bind:event="oninput" />
                </div>

                <!-- Select all / clear -->
                <div class="d-flex align-items-center gap-3 px-2 py-1 border-bottom bg-light">
                    <button class="btn btn-link btn-sm p-0" style="font-size:12px;"
                            @onclick="SelectAllFiltered">Select All</button>
                    <button class="btn btn-link btn-sm p-0 text-secondary" style="font-size:12px;"
                            @onclick="ClearSelection">Deselect All</button>
                    <span class="ms-auto text-muted" style="font-size:11px;">
                        @_selected.Count / @FilteredLineShifts.Count() selected
                    </span>
                </div>

                <!-- List -->
                <div class="overflow-auto flex-grow-1">
                    @foreach (var ls in FilteredLineShifts)
                    {
                        bool isSel = _selected.Contains(ls);
                        <div class="model-item @(isSel ? "selected" : "")"
                             @onclick="() => ToggleSelect(ls)">
                            <input type="checkbox" class="form-check-input m-0 flex-shrink-0"
                                   checked="@isSel"
                                   @onclick:stopPropagation
                                   @onchange="@(_ => ToggleSelect(ls))" />
                            <span style="word-break:break-all;">@ls</span>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <!-- ══ RIGHT: Group Builder ═════════════════════════════════════════════════ -->
    <div class="col-md-8 d-flex flex-column" style="height:calc(100vh - 130px);">

        <!-- ── Mode selector ─────────────────────────────────────────────────── -->
        <div class="card shadow-sm mb-3">
            <div class="card-body py-2 d-flex align-items-center gap-3 flex-wrap">
                <div class="btn-group btn-group-sm">
                    <button class="btn @(_mode == PageMode.New ? "btn-primary" : "btn-outline-primary")"
                            @onclick="SwitchToNew">
                        + New
                    </button>
                    <button class="btn @(_mode != PageMode.New ? "btn-primary" : "btn-outline-primary")"
                            @onclick="OpenFilePickerAsync">
                        ✏ Edit Existing
                    </button>
                </div>
                @if (_mode == PageMode.Editing)
                {
                    <span class="text-muted small">
                        Editing: <span class="fw-semibold font-monospace">@_fileName</span>
                    </span>
                }
                @if (!string.IsNullOrEmpty(_loadFileError))
                {
                    <span class="text-danger small">@_loadFileError</span>
                }
            </div>
        </div>

        <!-- ── File picker (Edit Existing mode) ──────────────────────────────── -->
        @if (_mode == PageMode.Picking)
        {
            <div class="card shadow-sm mb-3">
                <div class="card-header small fw-semibold d-flex align-items-center gap-2">
                    <span>Select File to Edit</span>
                    <span class="text-muted ms-1" style="font-size:10px;">@JsonSaveFolder</span>
                    <button class="btn btn-link btn-sm p-0 ms-auto text-secondary"
                            @onclick="SwitchToNew" title="Cancel">✕</button>
                </div>
                <div style="max-height:260px; overflow-y:auto;">
                    @if (_existingFiles.Count == 0)
                    {
                        <div class="text-muted small text-center py-4">No JSON files found in folder.</div>
                    }
                    else
                    {
                        @foreach (var f in _existingFiles)
                        {
                            <div class="file-item" @onclick="() => LoadFileAsync(f.Path)">
                                <span class="pg-badge pg-@f.ProductGroup">@f.ProductGroup</span>
                                <span style="font-family:monospace; font-weight:600; font-size:12px;">
                                    @f.FileName
                                </span>
                                <span class="text-muted ms-auto" style="font-size:11px; white-space:nowrap;">
                                    @f.Modified.ToString("yyyy-MM-dd HH:mm")
                                </span>
                            </div>
                        }
                    }
                </div>
            </div>
        }

        <!-- ── Product Group selector + New group form ───────────────────────── -->
        @if (_mode != PageMode.Picking)
        {
            <!-- Product Group -->
            <div class="card shadow-sm mb-2">
                <div class="card-body py-2 d-flex align-items-center gap-2 flex-wrap">
                    <span class="small fw-semibold text-muted me-1">Product Group</span>
                    @foreach (var pg in ProductGroups)
                    {
                        <button class="pg-btn @(_productGroup == pg ? "active" : "")"
                                @onclick="@(() => _productGroup = pg)">
                            @pg
                        </button>
                    }
                    <span class="ms-auto">
                        <span class="pg-badge pg-@_productGroup">@_productGroup</span>
                    </span>
                </div>
            </div>

            <!-- New Group -->
            <div class="card shadow-sm mb-3">
                <div class="card-body py-2 d-flex align-items-center gap-2 flex-wrap">
                    <span class="small fw-semibold text-muted me-1">New Group</span>
                    <input type="text" class="form-control form-control-sm"
                           placeholder="Group Name" @bind="_newGroupName"
                           style="max-width:220px;"
                           @onkeydown="@(e => { if (e.Key == "Enter") AddGroup(); })" />
                    <button class="btn btn-success btn-sm" @onclick="AddGroup"
                            disabled="@(_selected.Count == 0 || string.IsNullOrWhiteSpace(_newGroupName))">
                        + Add Group
                        @if (_selected.Count > 0) { <span class="ms-1 opacity-75">(@_selected.Count)</span> }
                    </button>
                    @if (!string.IsNullOrEmpty(_groupError))
                    {
                        <span class="text-danger small">@_groupError</span>
                    }
                </div>
            </div>
        }

        <!-- ── Groups list ────────────────────────────────────────────────────── -->
        @if (_mode != PageMode.Picking)
        {
            <div class="card shadow-sm flex-grow-1 d-flex flex-column" style="min-height:0;">
                <div class="card-header small fw-semibold d-flex align-items-center gap-2">
                    <span class="pg-badge pg-@_productGroup">@_productGroup</span>
                    <span>Groups</span>
                    @if (_groups.Count > 0)
                    {
                        <span class="badge bg-primary ms-1" style="font-size:10px;">@_groups.Count</span>
                    }
                </div>

                <div class="overflow-auto flex-grow-1 p-2">
                    @if (_groups.Count == 0)
                    {
                        <div class="text-muted small text-center py-4">
                            Select models from the left → Enter Group Name → Add Group
                        </div>
                    }
                    else
                    {
                        @for (int i = 0; i < _groups.Count; i++)
                        {
                            int idx = i;
                            var grp = _groups[i];
                            bool expanded = _expandedGroup == idx;

                            <div class="group-card">
                                <div class="group-header">
                                    <!-- Up/Down -->
                                    <div class="d-flex flex-column" style="gap:1px;">
                                        <button class="reorder-btn" @onclick="() => MoveUp(idx)"
                                                disabled="@(idx == 0)">▲</button>
                                        <button class="reorder-btn" @onclick="() => MoveDown(idx)"
                                                disabled="@(idx == _groups.Count - 1)">▼</button>
                                    </div>

                                    <!-- Index badge -->
                                    <span class="badge bg-secondary" style="font-size:10px; min-width:22px; text-align:center;">
                                        @idx
                                    </span>

                                    <!-- GroupName (inline edit) -->
                                    <input type="text" class="form-control form-control-sm"
                                           style="max-width:200px; font-size:12px; font-weight:600;"
                                           value="@grp.GroupName"
                                           @onchange="@(e => grp.GroupName = e.Value?.ToString() ?? grp.GroupName)" />

                                    <span class="text-muted" style="font-size:11px;">
                                        @grp.ModelList.Count model@(grp.ModelList.Count == 1 ? "" : "s")
                                    </span>

                                    <!-- Expand toggle -->
                                    <button class="btn btn-link btn-sm p-0 ms-auto text-secondary"
                                            style="font-size:11px;"
                                            @onclick="() => _expandedGroup = expanded ? -1 : idx">
                                        @(expanded ? "▼" : "▶")
                                    </button>

                                    <!-- Delete -->
                                    <button class="btn btn-link btn-sm p-0 text-danger"
                                            @onclick="() => RemoveGroup(idx)">✕</button>
                                </div>

                                @if (expanded)
                                {
                                    <div class="group-body">
                                        @foreach (var m in grp.ModelList)
                                        {
                                            <span class="model-badge">@m</span>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    }
                </div>

                <!-- Save / Export -->
                @if (_groups.Count > 0)
                {
                    <div class="border-top p-2 d-flex align-items-center gap-2 flex-wrap bg-light">
                        <input type="text" class="form-control form-control-sm font-monospace"
                               style="max-width:200px; font-size:12px;"
                               @bind="_fileName" placeholder="filename.json" />
                        <button class="btn btn-success btn-sm" @onclick="SaveToFolderAsync">
                            💾 Save to Folder
                        </button>
                        <button class="btn btn-outline-success btn-sm" @onclick="DownloadAsync">
                            ⬇ Download
                        </button>
                        @if (!string.IsNullOrEmpty(_saveMsg))
                        {
                            <span class="small @(_saveMsg.StartsWith("✓") ? "text-success" : "text-danger") fw-semibold">
                                @_saveMsg
                            </span>
                        }
                    </div>
                }
            </div>
        }

    </div>
</div>

@code {
    private static readonly string JsonSaveFolder =
        @"D:\000. MyWorks\000. 일일업무\04. DB\01. NGRATE\ModelBmes";

    private static readonly string[] ProductGroups = ["SPK", "UNIT", "MODULE", "TWS", "ETC"];

    // ── Page mode ─────────────────────────────────────────────────────────────
    private enum PageMode { New, Picking, Editing }
    private PageMode _mode = PageMode.New;

    // ── Models ────────────────────────────────────────────────────────────────
    private bool         _loading       = false;
    private string       _loadError     = string.Empty;
    private List<string> _allLineShifts = new();
    private HashSet<string> _selected   = new();
    private string       _search        = string.Empty;

    private IEnumerable<string> FilteredLineShifts => string.IsNullOrWhiteSpace(_search)
        ? _allLineShifts
        : _allLineShifts.Where(x => x.Contains(_search, StringComparison.OrdinalIgnoreCase));

    // ── Product Group ─────────────────────────────────────────────────────────
    private string _productGroup = "ETC";

    // ── Groups ────────────────────────────────────────────────────────────────
    private sealed class GroupEntry
    {
        public string       GroupName { get; set; } = string.Empty;
        public List<string> ModelList { get; set; } = new();
    }

    private sealed class JsonGroupItem
    {
        public int          Index     { get; set; }
        public string       GroupName { get; set; } = string.Empty;
        public List<string> ModelList { get; set; } = new();
    }

    private sealed class JsonFileWrapper
    {
        public string            ProductGroup { get; set; } = "ETC";
        public List<JsonGroupItem> Groups     { get; set; } = new();
    }

    private List<GroupEntry> _groups        = new();
    private int              _expandedGroup = -1;
    private string           _newGroupName  = string.Empty;
    private string           _groupError    = string.Empty;

    // ── File picker ───────────────────────────────────────────────────────────
    private sealed record ExistingFile(string FileName, string Path, DateTime Modified, string ProductGroup);
    private List<ExistingFile> _existingFiles = new();
    private string _loadFileError = string.Empty;

    // ── Export ────────────────────────────────────────────────────────────────
    private string _fileName = "model.json";
    private string _saveMsg  = string.Empty;

    // ── Lifecycle ─────────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync() => await LoadModelsAsync();

    // ── Model list ────────────────────────────────────────────────────────────

    private async Task LoadModelsAsync()
    {
        _loading   = true;
        _loadError = string.Empty;
        try
        {
            _allLineShifts = await Task.Run(() => NgRateSettings.GetAllLineShifts());
        }
        catch (Exception ex) { _loadError = ex.Message; }
        finally { _loading = false; }
    }

    private void ToggleSelect(string ls)
    {
        if (!_selected.Remove(ls)) _selected.Add(ls);
    }

    private void SelectAllFiltered()
    {
        foreach (var ls in FilteredLineShifts) _selected.Add(ls);
    }

    private void ClearSelection() => _selected.Clear();

    // ── Mode switching ────────────────────────────────────────────────────────

    private void SwitchToNew()
    {
        _mode          = PageMode.New;
        _groups        = new();
        _expandedGroup = -1;
        _productGroup  = "ETC";
        _fileName      = "model.json";
        _saveMsg       = string.Empty;
        _loadFileError = string.Empty;
        _selected.Clear();
    }

    private async Task OpenFilePickerAsync()
    {
        _loadFileError = string.Empty;
        _mode = PageMode.Picking;
        _existingFiles = await Task.Run(() =>
        {
            if (!Directory.Exists(JsonSaveFolder))
                return new List<ExistingFile>();
            return Directory.GetFiles(JsonSaveFolder, "*.json")
                .Select(p => new ExistingFile(
                    Path.GetFileName(p), p, File.GetLastWriteTime(p),
                    ReadProductGroupFromFile(p)))
                .OrderByDescending(f => f.Modified)
                .ToList();
        });
    }

    private static string ReadProductGroupFromFile(string path)
    {
        try
        {
            string json = File.ReadAllText(path);
            using var doc = JsonDocument.Parse(json);
            var root = doc.RootElement;
            if (root.ValueKind == JsonValueKind.Object &&
                root.TryGetProperty("ProductGroup", out var pg))
                return pg.GetString() ?? "ETC";
        }
        catch { }
        return "ETC";
    }

    private async Task LoadFileAsync(string path)
    {
        _loadFileError = string.Empty;
        try
        {
            string content = await File.ReadAllTextAsync(path, System.Text.Encoding.UTF8);
            var opts = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };

            List<JsonGroupItem>? items = null;
            string loadedPg = "ETC";

            // Try new format
            try
            {
                var wrapper = JsonSerializer.Deserialize<JsonFileWrapper>(content, opts);
                if (wrapper?.Groups is { Count: > 0 })
                {
                    items   = wrapper.Groups;
                    loadedPg = wrapper.ProductGroup ?? "ETC";
                }
            }
            catch { }

            // Fall back to legacy format
            if (items is null || items.Count == 0)
            {
                try { items = JsonSerializer.Deserialize<List<JsonGroupItem>>(content, opts); }
                catch { }
            }

            _groups = (items ?? new())
                .OrderBy(i => i.Index)
                .Select(i => new GroupEntry { GroupName = i.GroupName, ModelList = i.ModelList })
                .ToList();
            _productGroup  = ProductGroups.Contains(loadedPg) ? loadedPg : "ETC";
            _fileName      = Path.GetFileName(path);
            _expandedGroup = -1;
            _saveMsg       = string.Empty;
            _mode          = PageMode.Editing;
        }
        catch (Exception ex)
        {
            _loadFileError = $"✗ {ex.Message}";
        }
    }

    // ── Group builder ─────────────────────────────────────────────────────────

    private void AddGroup()
    {
        _groupError = string.Empty;
        if (string.IsNullOrWhiteSpace(_newGroupName)) { _groupError = "Please enter a Group Name."; return; }
        if (_selected.Count == 0) { _groupError = "Please select at least one model."; return; }

        _groups.Add(new GroupEntry
        {
            GroupName = _newGroupName.Trim(),
            ModelList = _selected.OrderBy(x => x).ToList(),
        });
        _newGroupName = string.Empty;
        _selected.Clear();
    }

    private void RemoveGroup(int idx)
    {
        _groups.RemoveAt(idx);
        if (_expandedGroup == idx) _expandedGroup = -1;
        else if (_expandedGroup > idx) _expandedGroup--;
    }

    private void MoveUp(int idx)
    {
        if (idx <= 0) return;
        (_groups[idx - 1], _groups[idx]) = (_groups[idx], _groups[idx - 1]);
        if      (_expandedGroup == idx)     _expandedGroup = idx - 1;
        else if (_expandedGroup == idx - 1) _expandedGroup = idx;
    }

    private void MoveDown(int idx)
    {
        if (idx >= _groups.Count - 1) return;
        (_groups[idx + 1], _groups[idx]) = (_groups[idx], _groups[idx + 1]);
        if      (_expandedGroup == idx)     _expandedGroup = idx + 1;
        else if (_expandedGroup == idx + 1) _expandedGroup = idx;
    }

    // ── JSON ──────────────────────────────────────────────────────────────────

    private string BuildJson() => JsonSerializer.Serialize(
        new
        {
            ProductGroup = _productGroup,
            Groups       = _groups.Select((g, i) => new { Index = i, g.GroupName, g.ModelList }),
        },
        new JsonSerializerOptions { WriteIndented = true });

    private async Task DownloadAsync()
    {
        _saveMsg = string.Empty;
        var bytes = System.Text.Encoding.UTF8.GetBytes(BuildJson());
        await JS.InvokeVoidAsync("downloadBase64File", _fileName,
            Convert.ToBase64String(bytes), "application/json");
    }

    private async Task SaveToFolderAsync()
    {
        _saveMsg = string.Empty;
        try
        {
            Directory.CreateDirectory(JsonSaveFolder);
            string path = Path.Combine(JsonSaveFolder, _fileName);
            await File.WriteAllTextAsync(path, BuildJson(), System.Text.Encoding.UTF8);
            _saveMsg = $"✓ Saved: {Path.GetFileName(path)}";
            if (_mode == PageMode.New) _mode = PageMode.Editing;
        }
        catch (Exception ex) { _saveMsg = $"✗ {ex.Message}"; }
    }
}
