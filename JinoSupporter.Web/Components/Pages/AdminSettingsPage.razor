@page "/admin/settings"
@rendermode InteractiveServer
@using JinoSupporter.Web.Services
@inject WebRepository         Repo
@inject NgRateSettingsService NgRateSettings

<PageTitle>App Settings</PageTitle>

<AuthorizeView Roles="Admin">
    <NotAuthorized>
        <div class="alert alert-danger">Access denied.</div>
    </NotAuthorized>
    <Authorized>

<div class="d-flex align-items-center justify-content-between mb-3">
    <h5 class="fw-bold mb-0">App Settings</h5>
</div>

<!-- ══ Claude API ══════════════════════════════════════════════════════════════ -->
<div class="card mb-4" style="max-width:560px;">
    <div class="card-header">Claude API</div>
    <div class="card-body">
        <div class="mb-3">
            <label class="form-label fw-semibold">API Key</label>
            <div class="input-group">
                <input type="@(_showKey ? "text" : "password")"
                       class="form-control font-monospace"
                       placeholder="sk-ant-api03-..."
                       @bind="_apiKey" />
                <button class="btn btn-outline-secondary" type="button"
                        @onclick="() => _showKey = !_showKey">
                    @(_showKey ? "Hide" : "Show")
                </button>
            </div>
            <div class="form-text">Stored unencrypted in the DB. Use only on trusted local-network servers.</div>
        </div>
        <button class="btn btn-primary" @onclick="SaveClaudeAsync" disabled="@_claudeSaving">
            @(_claudeSaving ? "Saving…" : "Save")
        </button>
        @if (_claudeSaved)  { <span class="ms-3 text-success fw-semibold">Saved.</span> }
        @if (!string.IsNullOrEmpty(_claudeError)) { <div class="alert alert-danger mt-2">@_claudeError</div> }
    </div>
</div>

<!-- ══ NG Rate Settings ════════════════════════════════════════════════════════ -->
<div class="card mb-4" style="max-width:560px;">
    <div class="card-header d-flex align-items-center gap-2">
        <span>📉 NG Rate Settings</span>
        <span class="badge bg-secondary ms-auto" style="font-size:10px; font-weight:500;">
            @NgRateSettings.SettingsDbPath
        </span>
    </div>
    <div class="card-body">

        <!-- BMES Login -->
        <div class="mb-3">
            <label class="form-label fw-semibold">BMES Login</label>
            <div class="row g-2">
                <div class="col-sm-6">
                    <label class="form-label small text-muted mb-1">User ID</label>
                    <input type="text" class="form-control form-control-sm"
                           @bind="_ng.LoginId" placeholder="BMES user ID" />
                </div>
                <div class="col-sm-6">
                    <label class="form-label small text-muted mb-1">Password</label>
                    <div class="input-group input-group-sm">
                        <input type="@(_showNgPw ? "text" : "password")"
                               class="form-control form-control-sm"
                               @bind="_ng.Password" placeholder="Password" />
                        <button class="btn btn-outline-secondary btn-sm" type="button"
                                @onclick="() => _showNgPw = !_showNgPw">
                            @(_showNgPw ? "Hide" : "Show")
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <hr class="my-3" />

        <!-- Paths -->
        <div class="mb-2">
            <label class="form-label fw-semibold">Paths</label>
        </div>

        <div class="mb-3">
            <label class="form-label small text-muted mb-1">DB Save Directory</label>
            <input type="text" class="form-control form-control-sm font-monospace"
                   @bind="_ng.DbSaveDirectory"
                   placeholder="@NgRateSettings.DefaultDbSaveDirectory" />
            <div class="form-text">Collected .db files will be saved here.</div>
        </div>

        <div class="mb-3">
            <label class="form-label small text-muted mb-1">Routing.txt Path</label>
            <div class="input-group input-group-sm">
                <input type="text" class="form-control form-control-sm font-monospace"
                       @bind="_ng.RoutingFilePath"
                       placeholder="@NgRateSettings.DefaultRoutingFilePath" />
                <button class="btn btn-outline-primary btn-sm" type="button"
                        @onclick="ImportRoutingAsync" disabled="@_routingImporting">
                    @if (_routingImporting) { <span class="spinner-border spinner-border-sm me-1"></span> }
                    Update from file
                </button>
            </div>
            @if (_routingImportMsg is not null)
            {
                <div class="form-text @(_routingImportMsg.StartsWith("✓") ? "text-success" : "text-danger") fw-semibold">
                    @_routingImportMsg
                </div>
            }
        </div>

        <div class="mb-3">
            <label class="form-label small text-muted mb-1">reason.txt Path</label>
            <div class="input-group input-group-sm">
                <input type="text" class="form-control form-control-sm font-monospace"
                       @bind="_ng.ReasonFilePath"
                       placeholder="@NgRateSettings.DefaultReasonFilePath" />
                <button class="btn btn-outline-primary btn-sm" type="button"
                        @onclick="ImportReasonAsync" disabled="@_reasonImporting">
                    @if (_reasonImporting) { <span class="spinner-border spinner-border-sm me-1"></span> }
                    Update from file
                </button>
            </div>
            @if (_reasonImportMsg is not null)
            {
                <div class="form-text @(_reasonImportMsg.StartsWith("✓") ? "text-success" : "text-danger") fw-semibold">
                    @_reasonImportMsg
                </div>
            }
        </div>

        <div class="d-flex align-items-center gap-3 mt-3">
            <button class="btn btn-primary" @onclick="SaveNgRateAsync" disabled="@_ngSaving">
                @(_ngSaving ? "Saving…" : "Save")
            </button>
            <button class="btn btn-outline-secondary btn-sm"
                    @onclick="ResetNgRateDefaults">Reset to Defaults</button>
            @if (_ngSaved)  { <span class="text-success fw-semibold">Saved.</span> }
            @if (!string.IsNullOrEmpty(_ngError)) { <span class="text-danger">@_ngError</span> }
        </div>

        <!-- Status indicator -->
        <div class="mt-3 pt-2 border-top">
            <span class="small text-muted">Credentials status: </span>
            @if (NgRateSettings.IsCredentialsConfigured)
            {
                <span class="badge bg-success">Configured</span>
            }
            else
            {
                <span class="badge bg-warning text-dark">Not set</span>
                <span class="small text-muted ms-2">Users cannot run Get Data until credentials are saved.</span>
            }
        </div>

    </div>
</div>

    </Authorized>
</AuthorizeView>

@code {
    // ── Claude ────────────────────────────────────────────────────────────────
    private string _apiKey      = string.Empty;
    private bool   _showKey     = false;
    private bool   _claudeSaving = false;
    private bool   _claudeSaved  = false;
    private string _claudeError  = string.Empty;

    // ── NG Rate ───────────────────────────────────────────────────────────────
    private NgRateSettingsSnapshot _ng        = new();
    private bool   _showNgPw  = false;
    private bool   _ngSaving  = false;
    private bool   _ngSaved   = false;
    private string _ngError   = string.Empty;

    private bool    _routingImporting = false;
    private string? _routingImportMsg = null;
    private bool    _reasonImporting  = false;
    private string? _reasonImportMsg  = null;

    protected override void OnInitialized()
    {
        _apiKey = Repo.GetSetting("Claude:ApiKey") ?? string.Empty;
        _ng     = NgRateSettings.GetSnapshot();
    }

    // ── Claude save ───────────────────────────────────────────────────────────
    private async Task SaveClaudeAsync()
    {
        _claudeSaving = true;
        _claudeSaved  = false;
        _claudeError  = string.Empty;
        try
        {
            Repo.SetSetting("Claude:ApiKey", _apiKey.Trim());
            _claudeSaved = true;
        }
        catch (Exception ex) { _claudeError = ex.Message; }
        finally { _claudeSaving = false; }
        await Task.CompletedTask;
    }

    // ── NG Rate save ──────────────────────────────────────────────────────────
    private async Task SaveNgRateAsync()
    {
        _ngSaving = true;
        _ngSaved  = false;
        _ngError  = string.Empty;
        try
        {
            NgRateSettings.ApplySnapshot(_ng);
            _ngSaved = true;
        }
        catch (Exception ex) { _ngError = ex.Message; }
        finally { _ngSaving = false; }
        await Task.CompletedTask;
    }

    private void ResetNgRateDefaults()
    {
        _ng = new NgRateSettingsSnapshot();
        _ngSaved = false;
    }

    private async Task ImportRoutingAsync()
    {
        _routingImporting = true;
        _routingImportMsg = null;
        try
        {
            string path = string.IsNullOrWhiteSpace(_ng.RoutingFilePath)
                ? NgRateSettings.DefaultRoutingFilePath
                : _ng.RoutingFilePath.Trim();
            int count = await Task.Run(() => NgRateSettings.ImportRoutingFromFile(path));
            _routingImportMsg = count > 0
                ? $"✓ {count:N0} rows updated"
                : "✗ File missing or empty";
        }
        catch (Exception ex) { _routingImportMsg = $"✗ {ex.Message}"; }
        finally { _routingImporting = false; }
    }

    private async Task ImportReasonAsync()
    {
        _reasonImporting = true;
        _reasonImportMsg = null;
        try
        {
            string path = string.IsNullOrWhiteSpace(_ng.ReasonFilePath)
                ? NgRateSettings.DefaultReasonFilePath
                : _ng.ReasonFilePath.Trim();
            int count = await Task.Run(() => NgRateSettings.ImportReasonFromFile(path));
            _reasonImportMsg = count > 0
                ? $"✓ {count:N0} rows updated"
                : "✗ File missing or empty";
        }
        catch (Exception ex) { _reasonImportMsg = $"✗ {ex.Message}"; }
        finally { _reasonImporting = false; }
    }
}
