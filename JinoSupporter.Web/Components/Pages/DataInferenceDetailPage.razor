@page "/data-inference/detail"
@rendermode InteractiveServer
@inject WebRepository Repo

<PageTitle>@(string.IsNullOrEmpty(Name) ? "Data Inference — Detail" : $"📄 {Name}")</PageTitle>

<div class="didet-root">

@if (string.IsNullOrWhiteSpace(Name))
{
    <div class="didet-empty">데이터셋 이름이 지정되지 않았습니다.</div>
}
else if (_info is null)
{
    <div class="didet-empty">데이터셋 <strong>@Name</strong> 을(를) 찾을 수 없습니다.</div>
}
else
{
    <div class="didet-header">
        <div>
            <div class="didet-title">📄 @_info.DatasetName</div>
            <div class="didet-meta">
                <span class="didet-chip didet-chip-prod">@(_info.ProductType ?? "")</span>
                <span class="didet-chip">📅 @_info.ReportDate</span>
                <span class="didet-chip">🖼 @_info.ImageCount</span>
                <span class="didet-chip">📐 @_info.MeasurementCount rows</span>
                <span class="didet-chip didet-chip-dim">Saved @FormatDate(_info.CreatedAt)</span>
            </div>
        </div>
    </div>

    <div class="didet-body">
        @if (_summary is not null)
        {
            <section class="didet-card">
                <div class="didet-card-title">📊 Summary</div>
                @if (!string.IsNullOrEmpty(_summary.Summary))
                {
                    <p class="didet-card-body">@_summary.Summary</p>
                }
                @if (!string.IsNullOrEmpty(_summary.KeyFindings))
                {
                    <div class="didet-findings">@_summary.KeyFindings</div>
                }
                @if (_summary.Tags.Count > 0)
                {
                    <div class="didet-tags">
                        @foreach (var t in _summary.Tags)
                        {
                            <span class="didet-tag">🏷 @t</span>
                        }
                    </div>
                }
            </section>
        }

        @if (_measurements.Count > 0)
        {
            <section class="didet-card">
                <div class="didet-card-title">📐 Extracted Measurements — @_measurements.Count row(s)</div>
                <div class="didet-table-wrap">
                    <table class="didet-table">
                        <thead>
                            <tr>
                                <th>Variable</th>
                                <th>Group</th>
                                <th>Line</th>
                                <th>CheckType</th>
                                <th>Input</th>
                                <th>NG</th>
                                <th>NG%</th>
                                <th>Defect Type</th>
                                <th>Category</th>
                                <th>Count</th>
                                <th>Intervention</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var m in _measurements)
                            {
                                <tr>
                                    <td>@m.Variable</td>
                                    <td>@m.VariableGroup</td>
                                    <td>@m.Line</td>
                                    <td>@m.CheckType</td>
                                    <td class="n">@m.InputQty</td>
                                    <td class="n">@m.NgTotal</td>
                                    <td class="n">@m.NgRate.ToString("F1")%</td>
                                    <td>@m.DefectType</td>
                                    <td>@m.DefectCategory</td>
                                    <td class="n">@m.DefectCount</td>
                                    <td>@m.Intervention</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        }

        @if (_images.Count > 0)
        {
            <section class="didet-card">
                <div class="didet-card-title">🖼 Analysis Images (@_images.Count)</div>
                <div class="didet-imgs-grid">
                    @foreach (var (img, idx) in _images.Select((x, i) => (x, i)))
                    {
                        <div class="didet-img-thumb" @onclick="() => OpenViewer(img.DataUrl)">
                            <img src="@img.DataUrl" alt="@img.FileName" />
                            <div class="didet-img-num">@(idx + 1)</div>
                        </div>
                    }
                </div>
            </section>
        }

        @if (_files.Count > 0)
        {
            <section class="didet-card">
                <div class="didet-card-title">📎 Backup Files (@_files.Count)</div>
                <div class="didet-files">
                    @foreach (var f in _files)
                    {
                        <a class="didet-file-chip" href="/data-inference/file/@f.Id" download="@f.FileName" target="_blank">
                            <span>📄</span>
                            <span class="didet-file-name" title="@f.FileName">@f.FileName</span>
                            <span class="didet-file-size">@FormatSize(f.FileSize)</span>
                        </a>
                    }
                </div>
            </section>
        }
    </div>
}

@if (_viewerUrl is not null)
{
    <div class="didet-viewer" @onclick="() => _viewerUrl = null">
        <img src="@_viewerUrl" @onclick:stopPropagation="true" />
        <button class="didet-viewer-close" @onclick="() => _viewerUrl = null">✕</button>
    </div>
}

</div>

<style>
    .didet-root {
        min-height: 100vh; background: #f8fafc; padding: 20px 24px;
        font-family: 'Segoe UI', sans-serif;
    }
    .didet-empty { padding: 60px; text-align: center; color: #94a3b8; font-size: 14px; }
    .didet-header {
        background: #fff; border: 1px solid #e2e8f0; border-radius: 10px;
        padding: 14px 18px; margin-bottom: 14px;
    }
    .didet-title { font-size: 17px; font-weight: 700; color: #1e293b; margin-bottom: 6px; }
    .didet-meta  { display: flex; flex-wrap: wrap; gap: 6px; }
    .didet-chip  {
        display: inline-flex; align-items: center; padding: 2px 10px;
        border-radius: 12px; font-size: 11px; font-weight: 600;
        background: #f1f5f9; color: #334155;
    }
    .didet-chip-prod { background: #e0e7ff; color: #4338ca; }
    .didet-chip-dim  { background: transparent; color: #94a3b8; font-weight: 500; }

    .didet-body { display: flex; flex-direction: column; gap: 12px; }
    .didet-card {
        background: #fff; border: 1px solid #e2e8f0; border-radius: 10px;
        padding: 14px 18px;
    }
    .didet-card-title { font-size: 13px; font-weight: 700; color: #1e293b; margin-bottom: 8px; }
    .didet-card-body  { font-size: 13px; color: #0f172a; margin: 0; line-height: 1.6; }
    .didet-findings   {
        font-size: 12px; color: #475569; white-space: pre-wrap; margin-top: 6px;
        background: #f8fafc; padding: 8px 10px; border-radius: 6px;
    }
    .didet-tags       { display: flex; flex-wrap: wrap; gap: 5px; margin-top: 8px; }
    .didet-tag        {
        background: #e0e7ff; color: #4338ca;
        padding: 2px 9px; border-radius: 10px; font-size: 11px; font-weight: 600;
    }

    .didet-table-wrap { overflow-x: auto; }
    .didet-table      { border-collapse: collapse; font-size: 12px; width: max-content; min-width: 100%; }
    .didet-table th, .didet-table td {
        border: 1px solid #e2e8f0; padding: 4px 8px; white-space: nowrap; text-align: left;
    }
    .didet-table th   { background: #f1f5f9; font-weight: 600; color: #475569; }
    .didet-table td.n { text-align: right; font-variant-numeric: tabular-nums; }

    .didet-imgs-grid { display: flex; flex-wrap: wrap; gap: 10px; }
    .didet-img-thumb {
        position: relative; width: 140px; height: 140px; border-radius: 8px;
        overflow: hidden; border: 1px solid #e2e8f0; cursor: pointer; background: #fff;
    }
    .didet-img-thumb img { width: 100%; height: 100%; object-fit: cover; }
    .didet-img-thumb:hover { box-shadow: 0 4px 12px rgba(0,0,0,.12); }
    .didet-img-num {
        position: absolute; bottom: 4px; left: 6px; font-size: 10px;
        color: rgba(255,255,255,.95); text-shadow: 0 1px 3px rgba(0,0,0,.7); font-weight: 700;
    }

    .didet-files { display: flex; flex-wrap: wrap; gap: 6px; }
    .didet-file-chip {
        display: inline-flex; align-items: center; gap: 6px;
        background: #f1f5f9; border: 1px solid #e2e8f0; border-radius: 14px;
        padding: 4px 10px; font-size: 12px; color: #334155; text-decoration: none;
    }
    .didet-file-chip:hover { background: #e0e7ff; color: #1e293b; }
    .didet-file-name { max-width: 260px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-weight: 600; }
    .didet-file-size { color: #94a3b8; font-size: 10px; }

    .didet-viewer {
        position: fixed; inset: 0; background: rgba(0,0,0,.88); z-index: 9500;
        display: flex; align-items: center; justify-content: center; cursor: zoom-out;
    }
    .didet-viewer img { max-width: 94vw; max-height: 92vh; object-fit: contain; cursor: auto; }
    .didet-viewer-close {
        position: absolute; top: 16px; right: 20px; width: 36px; height: 36px;
        border-radius: 50%; border: none; background: rgba(255,255,255,.2);
        color: #fff; font-size: 18px; cursor: pointer;
    }
</style>

@code {
    private sealed record ImgThumb(string MediaType, string DataUrl, string FileName);

    [Parameter, SupplyParameterFromQuery] public string? Name { get; set; }

    private RawReportInfo?              _info         = null;
    private DatasetSummaryRecord?       _summary      = null;
    private List<NormalizedMeasurement> _measurements = [];
    private List<ImgThumb>              _images       = [];
    private List<RawFileInfo>           _files        = [];
    private string?                     _viewerUrl    = null;

    protected override void OnParametersSet() => Load();

    private void Load()
    {
        _info = null; _summary = null; _measurements = []; _images = []; _files = [];
        if (string.IsNullOrWhiteSpace(Name)) return;

        _info = Repo.GetAllRawReports().FirstOrDefault(r => r.DatasetName == Name);
        if (_info is null) return;

        _summary      = Repo.GetDatasetSummaryRecord(Name);
        _measurements = Repo.GetNormalizedMeasurements(Name);
        _images       = Repo.GetRawReportImages(Name).Select((img, i) =>
        {
            string b64     = Convert.ToBase64String(img.Data);
            string dataUrl = $"data:{img.MediaType};base64,{b64}";
            string fname   = img.FileName.Length > 0 ? img.FileName : $"img-{i + 1}";
            return new ImgThumb(img.MediaType, dataUrl, fname);
        }).ToList();
        _files = Repo.GetRawReportFileInfos(Name);
    }

    private void OpenViewer(string dataUrl) => _viewerUrl = dataUrl;

    private static string FormatSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / 1024.0 / 1024.0:F1} MB";
    }

    private static string FormatDate(string iso)
    {
        if (DateTime.TryParse(iso, null, System.Globalization.DateTimeStyles.RoundtripKind, out DateTime dt))
            return dt.ToLocalTime().ToString("yyyy-MM-dd HH:mm");
        return iso;
    }
}
