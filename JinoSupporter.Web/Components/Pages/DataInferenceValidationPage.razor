@page "/data-inference/validation"
@rendermode InteractiveServer
@implements IAsyncDisposable
@using JinoSupporter.Web.Services
@inject WebRepository Repo
@inject ClaudeService Claude
@inject IJSRuntime    JS

<PageTitle>Data Inference — Validation</PageTitle>

<div class="div-root">

<div class="div-header">
    <span class="div-title">🧪 Validation — Extraction Checksum</span>
    <span class="div-count">
        @_flagged.Count flagged / @_reports.Count dataset(s)
    </span>
    <div style="flex:1;"></div>
    <label class="div-check-label">
        <input type="checkbox" @bind="_showClean" /> Show clean datasets
    </label>
    <button class="btn btn-outline-secondary btn-sm" @onclick="RefreshAsync" disabled="@_isBusy">
        @if (_isBusy) { <span class="spinner-border spinner-border-sm me-1"></span> }
        ↻ Re-scan
    </button>
    <button class="btn btn-warning btn-sm" @onclick="ReanalyzeAllFlaggedAsync"
            disabled="@(_isBusy || _flagged.Count == 0 || !Claude.IsConfigured)"
            title="Re-analyze all flagged datasets via the Claude API">
        @if (_isBusy && _reanalyzing.Count > 0)
        { <span class="spinner-border spinner-border-sm me-1"></span> }
        🔄 Re-analyze All (@_flagged.Count)
    </button>
    <a class="btn btn-outline-primary btn-sm" href="/data-inference/export-all"
       target="_blank" title="Download all datasets with issues as a single ZIP"
       style="pointer-events:@(_flagged.Count == 0 ? "none" : "auto");
              opacity:@(_flagged.Count == 0 ? "0.5" : "1");">
        📦 Export All Flagged (@_flagged.Count)
    </a>
</div>

@if (!string.IsNullOrEmpty(_reanalyzeStatus))
{
    <div class="alert @(_reanalyzeError ? "alert-danger" : "alert-info") mb-0 py-2 small">
        @_reanalyzeStatus
    </div>
}

@if (_isBusy && _reports.Count == 0)
{
    <div class="div-empty">Scanning…</div>
}
else if (_reports.Count == 0)
{
    <div class="div-empty">No datasets saved yet.</div>
}
else
{
    <div class="div-table-wrap">
        <table class="div-table">
            <thead>
                <tr>
                    <th>Dataset</th>
                    <th>Product</th>
                    <th>Date</th>
                    <th style="width:90px;">Rows</th>
                    <th style="width:90px;">Issues</th>
                    <th>Summary</th>
                    <th style="width:120px;"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Visible)
                {
                    var issues = _issuesByDataset.GetValueOrDefault(r.DatasetName) ?? new();
                    bool hasIssues = issues.Count > 0;
                    bool expanded  = _expanded == r.DatasetName;
                    <tr class="@(hasIssues ? "div-row-bad" : "div-row-ok")"
                        @onclick="() => ToggleExpand(r.DatasetName)" style="cursor:pointer;">
                        <td><strong>@r.DatasetName</strong></td>
                        <td>@r.ProductType</td>
                        <td>@r.ReportDate</td>
                        <td class="n">@r.MeasurementCount</td>
                        <td>
                            @if (hasIssues)
                            {
                                <span class="badge bg-danger">@issues.Count ⚠</span>
                            }
                            else
                            {
                                <span class="badge bg-success">✓</span>
                            }
                        </td>
                        <td class="div-summary-cell">
                            @if (hasIssues)
                            {
                                <span>@issues[0].Message@(issues.Count > 1 ? $" … (+{issues.Count - 1})" : "")</span>
                            }
                            else if (r.MeasurementCount == 0)
                            {
                                <span class="text-muted">(no measurements — run AI Batch)</span>
                            }
                        </td>
                        <td @onclick:stopPropagation="true" style="white-space:nowrap;">
                            <button class="btn btn-outline-warning btn-sm py-0 px-2 me-1"
                                    style="font-size:11px;"
                                    title="Re-analyze this dataset's images via Claude API (uses text-only when OCR cache exists)"
                                    disabled="@(_isBusy || _reanalyzing.Contains(r.DatasetName) || !Claude.IsConfigured)"
                                    @onclick="() => ReanalyzeAsync(r.DatasetName, r.ProductType, r.ReportDate)">
                                @if (_reanalyzing.Contains(r.DatasetName))
                                { <span class="spinner-border spinner-border-sm me-1"></span><text>…</text> }
                                else { <text>🔄 Re-analyze</text> }
                            </button>
                            @{
                                bool hasOcr = _ocrCached.Contains(r.DatasetName);
                            }
                            <button class="btn btn-sm py-0 px-2 me-1 @(hasOcr ? "btn-info" : "btn-outline-secondary")"
                                    style="font-size:11px;"
                                    title="@(hasOcr ? "OCR cached — view/edit (text-only re-analysis available)" : "No OCR yet — click to extract")"
                                    @onclick="() => OpenOcrEditor(r.DatasetName, r.ProductType, r.ReportDate)">
                                @(hasOcr ? "📑 OCR✓" : "📝 OCR")
                            </button>
                            <a class="btn btn-outline-success btn-sm py-0 px-2 me-1"
                               style="font-size:11px;"
                               title="Download a ZIP with images + measurements + issues + files"
                               href="/data-inference/export/@Uri.EscapeDataString(r.DatasetName)"
                               target="_blank">📦 Export</a>
                            <a class="btn btn-outline-primary btn-sm py-0 px-2"
                               style="font-size:11px;"
                               href="/data-inference/db?open=@Uri.EscapeDataString(r.DatasetName)"
                               target="_blank">DB Data ↗</a>
                        </td>
                    </tr>
                    @if (expanded)
                    {
                        @if (hasIssues)
                        {
                            <tr class="div-detail-row">
                                <td colspan="7" style="padding:8px 16px; background:#fff7ed;">
                                    <strong class="small">All issues:</strong>
                                    <ul class="mb-0 small">
                                        @foreach (var iss in issues)
                                        {
                                            <li>
                                                <code>[@iss.Kind]</code>
                                                <strong>@iss.Variable</strong>
                                                @if (!string.IsNullOrEmpty(iss.VariableDetail))
                                                { <span class="text-muted">· @iss.VariableDetail</span> }
                                                — @iss.Message
                                            </li>
                                        }
                                    </ul>
                                </td>
                            </tr>
                        }

                        @* Summary *@
                        @if (_expandedSummary is not null)
                        {
                            <tr class="div-detail-row">
                                <td colspan="7" style="padding:8px 16px; background:#f8fafc;">
                                    <strong class="small">Summary:</strong>
                                    <span class="small">@_expandedSummary.Summary</span>
                                    @if (!string.IsNullOrEmpty(_expandedSummary.KeyFindings))
                                    {
                                        <div class="small mt-1" style="white-space:pre-wrap; color:#475569;">@_expandedSummary.KeyFindings</div>
                                    }
                                    @if (_expandedSummary.Tags.Count > 0)
                                    {
                                        <div class="mt-1">
                                            @foreach (var t in _expandedSummary.Tags)
                                            {
                                                <span class="badge bg-secondary me-1" style="font-weight:500;">🏷 @t</span>
                                            }
                                        </div>
                                    }
                                </td>
                            </tr>
                        }

                        @* Measurements *@
                        @if (_expandedMeasurements.Count > 0)
                        {
                            var issueKeys = new HashSet<(string, string)>(
                                issues.Select(i => (i.Variable ?? "", i.VariableDetail ?? "")));
                            <tr class="div-detail-row">
                                <td colspan="7" style="padding:0;">
                                    <div style="max-height:280px; overflow:auto; padding:8px 16px; background:#fff;">
                                        <table class="div-sub">
                                            <thead>
                                                <tr>
                                                    <th></th>
                                                    <th>Variable</th><th>Group</th><th>Line</th><th>CheckType</th>
                                                    <th>Input</th><th>NG</th><th>NG%</th>
                                                    <th>Defect Type</th><th>Category</th><th>Count</th><th>Intervention</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var m in _expandedMeasurements)
                                                {
                                                    bool isAlign  = m.DefectType == "__ALIGN_ERROR__";
                                                    bool isIssue  = issueKeys.Contains((m.Variable ?? "", m.VariableDetail ?? ""));
                                                    string rowCls = isAlign ? "div-row-align" : (isIssue ? "div-row-issue" : "");
                                                    <tr class="@rowCls">
                                                        <td class="div-row-mark">@(isIssue || isAlign ? "⚠" : "")</td>
                                                        <td>@m.Variable</td>
                                                        <td>@m.VariableGroup</td>
                                                        <td>@m.Line</td>
                                                        <td>@m.CheckType</td>
                                                        <td class="n">@m.InputQty</td>
                                                        <td class="n">@m.NgTotal</td>
                                                        <td class="n">@m.NgRate.ToString("F1")%</td>
                                                        <td>@m.DefectType</td>
                                                        <td>@m.DefectCategory</td>
                                                        <td class="n">@m.DefectCount</td>
                                                        <td>@m.Intervention</td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </td>
                            </tr>
                        }

                        @* Images *@
                        @if (_expandedImages.Count > 0)
                        {
                            <tr class="div-detail-row">
                                <td colspan="7" style="padding:8px 16px; background:#fff;">
                                    <div class="small text-muted mb-1">🖼 AI Analysis Images (@_expandedImages.Count)</div>
                                    <div style="display:flex; gap:8px; flex-wrap:wrap;">
                                        @foreach (var (img, idx) in _expandedImages.Select((x, i) => (x, i)))
                                        {
                                            <div class="div-img-thumb" @onclick="() => OpenViewer(img.DataUrl)"
                                                 style="width:110px; height:110px; border:1px solid #e2e8f0; border-radius:4px; overflow:hidden; position:relative; cursor:zoom-in;">
                                                <img src="@img.DataUrl" alt="@img.FileName"
                                                     style="width:100%; height:100%; object-fit:cover;" />
                                                <div style="position:absolute; top:2px; left:4px; background:rgba(0,0,0,.6); color:#fff; font-size:10px; padding:1px 5px; border-radius:3px;">
                                                    @(idx + 1)
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }

                        @* Files *@
                        @if (_expandedFiles.Count > 0)
                        {
                            <tr class="div-detail-row">
                                <td colspan="7" style="padding:8px 16px; background:#fff;">
                                    <div class="small text-muted mb-1">📎 Backup Files (@_expandedFiles.Count)</div>
                                    <div style="display:flex; gap:6px; flex-wrap:wrap;">
                                        @foreach (var f in _expandedFiles)
                                        {
                                            <a class="badge bg-light text-dark" style="font-weight:500; border:1px solid #e2e8f0;"
                                               href="/data-inference/file/@f.Id" download="@f.FileName" target="_blank">
                                                📄 @f.FileName
                                                <span class="text-muted ms-1">@FormatSize(f.FileSize)</span>
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                        else if (_expandedMeasurements.Count == 0 && _expandedSummary is null)
                        {
                            <tr class="div-detail-row">
                                <td colspan="7" style="padding:8px 16px; color:#94a3b8; font-style:italic;" class="small">
                                    No measurements / summary / files to display.
                                </td>
                            </tr>
                        }
                    }
                }
            </tbody>
        </table>
    </div>
}

@if (_viewerDataUrl is not null)
{
    <div class="div-viewer-overlay" @onclick="() => _viewerDataUrl = null">
        <img src="@_viewerDataUrl" class="div-viewer-img" @onclick:stopPropagation="true" />
        <button class="div-viewer-close" @onclick="() => _viewerDataUrl = null">✕</button>
    </div>
}

<OcrTextEditor DatasetName="@_ocrDataset"
               ProductType="@_ocrProductType"
               ReportDate="@_ocrReportDate"
               OnClose="CloseOcrEditor"
               OnReanalyzed="OnOcrReanalyzed" />

</div>

<style>
    .div-root   { flex:1; min-height:0; display:flex; flex-direction:column; overflow:hidden; background:#f8fafc; }
    .div-header {
        display:flex; align-items:center; gap:10px; padding:10px 14px;
        background:#fff; border-bottom:1px solid #e2e8f0; flex-shrink:0;
    }
    .div-title       { font-size:15px; font-weight:700; color:#1e293b; }
    .div-count       { font-size:12px; color:#94a3b8; }
    .div-check-label { font-size:12px; color:#475569; user-select:none; display:flex; align-items:center; gap:4px; }
    .div-empty       { padding:60px; text-align:center; color:#94a3b8; font-size:14px; }

    .div-table-wrap  { flex:1; overflow:auto; }
    .div-table       { border-collapse:collapse; width:100%; font-size:13px; }
    .div-table th, .div-table td {
        border-bottom:1px solid #e2e8f0; padding:7px 10px; text-align:left;
    }
    .div-table thead th {
        background:#f1f5f9; font-weight:600; color:#475569;
        position:sticky; top:0; z-index:1;
    }
    td.n             { text-align:right; font-variant-numeric:tabular-nums; }
    .div-summary-cell { max-width:500px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; color:#b45309; }
    .div-row-bad:hover { background:#fef3c7; }
    .div-row-ok        { color:#64748b; }
    .div-row-ok:hover  { background:#f1f5f9; }
    .div-detail-row td { border-bottom:1px solid #fed7aa; }

    .div-sub { border-collapse:collapse; font-size:11px; width:100%; }
    .div-sub th, .div-sub td { border:1px solid #e2e8f0; padding:3px 7px; white-space:nowrap; }
    .div-sub th { background:#f8fafc; font-weight:600; color:#64748b; }
    .div-row-align { background:#fef2f2; color:#b91c1c; font-weight:600; }
    .div-row-issue { background:#fee2e2; color:#991b1b; }
    .div-row-issue td { border-color:#fca5a5 !important; }
    .div-row-mark  { color:#dc2626; font-weight:700; text-align:center; width:22px; }

    .div-viewer-overlay {
        position:fixed; inset:0; background:rgba(0,0,0,.85); z-index:9999;
        display:flex; align-items:center; justify-content:center;
    }
    .div-viewer-img { max-width:95vw; max-height:95vh; object-fit:contain; }
    .div-viewer-close {
        position:fixed; top:16px; right:16px; background:rgba(255,255,255,.1); color:#fff;
        border:1px solid rgba(255,255,255,.3); border-radius:50%; width:40px; height:40px;
        font-size:20px; cursor:pointer;
    }
</style>

@code {
    private List<RawReportInfo> _reports = [];
    private Dictionary<string, List<MeasurementValidator.Issue>> _issuesByDataset = new(StringComparer.Ordinal);
    private List<RawReportInfo> _flagged = [];
    private string? _expanded;
    private bool    _isBusy;
    private bool    _showClean;

    // Expand detail buffers
    private List<NormalizedMeasurement>  _expandedMeasurements = [];
    private DatasetSummaryRecord?        _expandedSummary;
    private List<ImgThumb>               _expandedImages       = [];
    private List<RawFileInfo>            _expandedFiles        = [];
    private string?                      _viewerDataUrl;

    // Re-analyze state
    private HashSet<string> _reanalyzing     = new(StringComparer.Ordinal);
    private string          _reanalyzeStatus = string.Empty;
    private bool            _reanalyzeError;

    // OCR editor modal state
    private string?         _ocrDataset;
    private string          _ocrProductType = "";
    private string          _ocrReportDate  = "";
    private HashSet<string> _ocrCached      = new(StringComparer.Ordinal);

    private sealed record ImgThumb(string MediaType, string DataUrl, string FileName);

    private List<RawReportInfo> Visible =>
        _showClean ? _reports : _flagged;

    protected override async Task OnInitializedAsync()
    {
        await RefreshAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) await JS.InvokeVoidAsync("diFullPage.enter");
    }

    private async Task RefreshAsync()
    {
        _isBusy = true; StateHasChanged();
        try
        {
            _reports   = Repo.GetAllRawReports();
            _ocrCached = Repo.GetDatasetsWithExtractedText();
            _issuesByDataset = await Task.Run(() =>
            {
                var map = new Dictionary<string, List<MeasurementValidator.Issue>>(StringComparer.Ordinal);
                foreach (var r in _reports)
                {
                    if (r.MeasurementCount == 0) continue;
                    var rows       = Repo.GetNormalizedMeasurements(r.DatasetName);
                    string? excel  = Repo.GetExtractedText(r.DatasetName, WebRepository.TextKindExcelPaste);
                    var issues     = MeasurementValidator.FindIssues(rows, excel);
                    if (issues.Count > 0)
                        map[r.DatasetName] = issues;
                }
                return map;
            });
            _flagged = _reports.Where(r => _issuesByDataset.ContainsKey(r.DatasetName)).ToList();
        }
        finally { _isBusy = false; }
    }

    private void ToggleExpand(string name)
    {
        if (_expanded == name)
        {
            _expanded = null;
            _expandedMeasurements = [];
            _expandedSummary      = null;
            _expandedImages       = [];
            _expandedFiles        = [];
        }
        else
        {
            _expanded             = name;
            _expandedMeasurements = Repo.GetNormalizedMeasurements(name);
            _expandedSummary      = Repo.GetDatasetSummaryRecord(name);
            _expandedImages       = Repo.GetRawReportImages(name).Select((img, i) =>
            {
                string b64     = Convert.ToBase64String(img.Data);
                string dataUrl = $"data:{img.MediaType};base64,{b64}";
                string fname   = img.FileName.Length > 0 ? img.FileName : $"img-{i + 1}";
                return new ImgThumb(img.MediaType, dataUrl, fname);
            }).ToList();
            _expandedFiles        = Repo.GetRawReportFileInfos(name);
        }
    }

    private void OpenViewer(string dataUrl) => _viewerDataUrl = dataUrl;

    private void OpenOcrEditor(string name, string productType, string reportDate)
    {
        _ocrDataset     = name;
        _ocrProductType = productType;
        _ocrReportDate  = reportDate;
    }

    private void CloseOcrEditor()
    {
        _ocrDataset = null;
        _ocrCached  = Repo.GetDatasetsWithExtractedText();
    }

    private async Task OnOcrReanalyzed()
    {
        // After text-based re-analysis, refresh validation state + expanded buffer
        await RefreshAsync();
        if (_expanded is not null)
        {
            _expandedMeasurements = Repo.GetNormalizedMeasurements(_expanded);
            _expandedSummary      = Repo.GetDatasetSummaryRecord(_expanded);
        }
    }

    private static string FormatSize(long bytes)
    {
        if (bytes < 1024)            return $"{bytes} B";
        if (bytes < 1024 * 1024)     return $"{bytes / 1024.0:F1} KB";
        if (bytes < 1024L * 1024 * 1024) return $"{bytes / 1024.0 / 1024.0:F1} MB";
        return $"{bytes / 1024.0 / 1024.0 / 1024.0:F1} GB";
    }

    // ── Re-analyze ─────────────────────────────────────────────────────────

    private async Task<bool> ReanalyzeAsync(string datasetName, string productType, string reportDate)
    {
        if (_reanalyzing.Contains(datasetName)) return false;
        _reanalyzing.Add(datasetName);
        _reanalyzeError = false;
        _reanalyzeStatus = $"Re-analyzing: {datasetName} …";
        StateHasChanged();

        bool ok = false;
        try
        {
            var imgs = Repo.GetRawReportImages(datasetName);
            if (imgs.Count == 0)
                throw new InvalidOperationException("No images to re-analyze.");

            var imageArgs = imgs.Select(i =>
                (i.MediaType, Convert.ToBase64String(i.Data))).ToList();

            // Prefer cached OCR text if available — much cheaper + deterministic.
            string? cached     = Repo.GetExtractedText(datasetName);
            string? excelPaste = Repo.GetExtractedText(datasetName, WebRepository.TextKindExcelPaste);
            NormalizeResult result;
            if (!string.IsNullOrWhiteSpace(cached))
            {
                result = await Claude.NormalizeFromTextAsync(
                    cached!, datasetName, productType, reportDate);
            }
            else
            {
                result = await Claude.NormalizeFromImagesAsync(
                    imageArgs, datasetName, productType, reportDate,
                    rawText: excelPaste);
            }

            await Task.Run(() =>
            {
                if (result.Measurements.Count > 0)
                    Repo.SaveNormalizedMeasurements(datasetName, result.Measurements);

                string tagsJson = (result.Tags?.Count ?? 0) > 0
                    ? System.Text.Json.JsonSerializer.Serialize(result.Tags) : "";
                if (!string.IsNullOrEmpty(result.Summary) || !string.IsNullOrEmpty(tagsJson))
                    Repo.SaveDatasetSummaryRecord(datasetName, productType,
                        result.Summary, result.KeyFindings, tagsJson,
                        result.Purpose, result.TestConditions, result.RootCause,
                        result.Decision, result.RecommendedAction);
            });

            _reanalyzeStatus = $"✓ {datasetName} — Re-analysis complete ({result.Measurements.Count} rows)";
            ok = true;
        }
        catch (Exception ex)
        {
            _reanalyzeError = true;
            _reanalyzeStatus = $"✗ {datasetName} — {ex.Message}";
        }
        finally
        {
            _reanalyzing.Remove(datasetName);
        }

        StateHasChanged();
        return ok;
    }

    private async Task ReanalyzeAllFlaggedAsync()
    {
        if (_isBusy || _flagged.Count == 0) return;

        var targets = _flagged.ToList();  // snapshot
        _isBusy = true;
        int okCount = 0, errCount = 0;
        try
        {
            for (int i = 0; i < targets.Count; i++)
            {
                var t = targets[i];
                _reanalyzeStatus = $"[{i + 1}/{targets.Count}] {t.DatasetName} …";
                _reanalyzeError = false;
                StateHasChanged();

                bool ok = await ReanalyzeAsync(t.DatasetName, t.ProductType, t.ReportDate);
                if (ok) okCount++; else errCount++;
            }

            _reanalyzeStatus = $"Re-analyze All complete — {okCount} success / {errCount} failed";
            _reanalyzeError  = errCount > 0;
        }
        finally { _isBusy = false; }

        await RefreshAsync();
    }

    public async ValueTask DisposeAsync()
    {
        try { await JS.InvokeVoidAsync("diFullPage.leave"); } catch { }
    }
}
