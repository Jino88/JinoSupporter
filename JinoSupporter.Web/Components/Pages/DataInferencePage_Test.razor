@code {
    // ── Header cell for multi-level table headers ─────────────────────────────
    private sealed class HeaderCell
    {
        public string Label   { get; init; } = "";
        public int    Colspan { get; init; } = 1;
        public int    Rowspan { get; init; } = 1;
    }

    // ── Result of ParseDirect ─────────────────────────────────────────────────
    private sealed class ParsedResult
    {
        public List<ColumnDef>                     Cols       { get; init; } = [];
        public List<Dictionary<string, string>>    Rows       { get; init; } = [];
        public List<List<HeaderCell>>?             HeaderRows { get; init; }   // null = single-row header
    }

    private sealed class PendingTable
    {
        public string TableName { get; set; } = "";
        public List<ColumnDef> Columns { get; init; } = [];
        public List<Dictionary<string, string>> Rows { get; init; } = [];
        public bool IsExisting { get; init; }
        public List<List<HeaderCell>>? HeaderRows { get; init; }  // multi-level header; null = flat
    }

    private sealed record ImageEntry(string Name, string MediaType, string Base64, string DataUrl, long SizeBytes);

    private sealed class DocBlock
    {
        public string        Kind  { get; init; } = "";
        public PendingTable? Table { get; init; }
        public ImageEntry?   Image { get; init; }
        public string        Text  { get; set; }  = "";
        public int           Span  { get; set; }  = 2;
    }

    // ── State ─────────────────────────────────────────────────────────────────
    private string       _datasetName    = string.Empty;
    private string       _purpose        = string.Empty;
    private string       _memo           = string.Empty;
    private List<string> _allDatasets    = [];
    private string       _rawInput       = string.Empty;
    private bool   _useAi    = false;   // default: Direct (auto-parse on paste)
    private string _toolsTab = "table";

    private List<PendingTable> _pendingTables = [];
    private List<ImageEntry>   _images        = [];
    private List<DocBlock>     _docBlocks     = [];

    private bool CanOrganize => !string.IsNullOrWhiteSpace(_rawInput);

    private bool   _isBusy;
    private string _busyStep      = string.Empty;
    private string _statusMessage = string.Empty;
    private bool   _statusIsError;

    [CascadingParameter] private Task<AuthenticationState> AuthState { get; set; } = default!;
    private System.Security.Claims.ClaimsPrincipal _user = new();
    private bool CanEdit => AppRoles.CanEdit(_user);

    // ── Report template fields ────────────────────────────────────────────────
    private string _reportTitle  = "";
    private string _reportDept   = "";
    private string _reportDate   = "";
    private string _reportMarker = "";
    private string _secPurpose   = "";
    private string _secContent   = "";
    private string _secDecision  = "";

    private bool _showCaptureOverlay;
    private DotNetObjectReference<DataInferencePage_Test>? _dotnetRef;

    // ── Context menu ──────────────────────────────────────────────────────────
    private bool          _showCtxMenu;
    private double        _ctxX, _ctxY;
    private string        _ctxMode     = "";
    private PendingTable? _ctxTable;
    private int           _ctxRowIndex = -1;
    private int           _ctxColIndex = -1;

    // ── Inline editing ────────────────────────────────────────────────────────
    private PendingTable? _editTable;
    private int           _editRowIndex = -1;
    private string        _editColField = "";
    private string        _editValue    = "";
    private bool          _editNeedFocus;
    private ElementReference _editRef;

    [Parameter] public string? InitialTab { get; set; }

    // ── Lifecycle ─────────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        _user        = (await AuthState).User;
        _allDatasets = Repo.GetAllDatasets();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotnetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("pasteImageHandler.init", _dotnetRef);
            await JS.InvokeVoidAsync("diDragDrop.init", _dotnetRef);
        }
        if (_editNeedFocus)
        {
            _editNeedFocus = false;
            try { await JS.InvokeVoidAsync("eval", "document.querySelector('.di-cell-input')?.focus()"); } catch { }
        }
    }

    private void SetMode(bool useAi) => _useAi = useAi;
    private void SelectTableTab() => _toolsTab = "table";
    private void SelectImageTab() => _toolsTab = "image";

    // ── Table auto-parse on paste ─────────────────────────────────────────────
    private void OnTableInputChanged(ChangeEventArgs e)
    {
        _rawInput = e.Value?.ToString() ?? "";

        // Direct mode: auto-parse when tab-separated data detected (Excel paste)
        if (!_useAi && _rawInput.Contains('\t'))
        {
            var pr = ParseDirect(_rawInput);
            if (pr.Rows.Count > 0)
            {
                _pendingTables.Add(new PendingTable
                {
                    TableName  = $"Table {_pendingTables.Count + 1}",
                    Columns    = pr.Cols,
                    Rows       = pr.Rows,
                    HeaderRows = pr.HeaderRows
                });
                _rawInput = string.Empty;
                SetStatus($"표 자동 생성: {pr.Rows.Count}행 {pr.Cols.Count}열", false);
            }
        }
    }

    // ── JS Drop handler (called from JavaScript) ───────────────────────────────
    [JSInvokable]
    public void JsDrop(string kind, int itemIdx, int zoneIdx)
    {
        DocBlock? block = null;
        if (kind == "table" && itemIdx >= 0 && itemIdx < _pendingTables.Count)
            block = new DocBlock { Kind = "table", Table = _pendingTables[itemIdx], Span = 2 };
        else if (kind == "image" && itemIdx >= 0 && itemIdx < _images.Count)
            block = new DocBlock { Kind = "image", Image = _images[itemIdx], Span = 1 };

        if (block is null) return;
        _docBlocks.Insert(Math.Min(zoneIdx, _docBlocks.Count), block);
        InvokeAsync(StateHasChanged);
    }

    // ── Add text block directly ───────────────────────────────────────────────
    private void AddTextBlock(int zoneIdx)
    {
        var block = new DocBlock { Kind = "text", Text = "", Span = 2 };
        _docBlocks.Insert(Math.Min(zoneIdx, _docBlocks.Count), block);
    }

    // ── Block controls ────────────────────────────────────────────────────────
    private void MoveBlock(DocBlock blk, int delta)
    {
        int idx = _docBlocks.IndexOf(blk);
        int newIdx = idx + delta;
        if (newIdx < 0 || newIdx >= _docBlocks.Count) return;
        _docBlocks.RemoveAt(idx);
        _docBlocks.Insert(newIdx, blk);
    }

    // ── Organize ──────────────────────────────────────────────────────────────
    private async Task OrganizeAsync()
    {
        if (!CanOrganize) { SetStatus("데이터를 먼저 붙여넣으세요.", true); return; }

        _isBusy = true; _busyStep = "organize"; _statusMessage = string.Empty;
        StateHasChanged();
        try
        {
            List<PendingTable> newTables;
            if (_useAi)
            {
                List<ExtractedTable> extracted = await Claude.ExtractTablesAsync(_rawInput, null);
                if (extracted.Count == 0) { SetStatus("No tables extracted.", true); return; }
                newTables = extracted.Select(t => new PendingTable
                {
                    TableName = t.TableName, Columns = t.Columns, Rows = t.Rows
                }).ToList();
            }
            else
            {
                var pr = ParseDirect(_rawInput);
                if (pr.Rows.Count == 0) { SetStatus("No rows found.", true); return; }
                newTables = [new PendingTable
                {
                    TableName  = $"Table {_pendingTables.Count + 1}",
                    Columns    = pr.Cols,
                    Rows       = pr.Rows,
                    HeaderRows = pr.HeaderRows
                }];
            }

            _pendingTables.AddRange(newTables);
            _rawInput = string.Empty;
            SetStatus($"{newTables.Count}개 테이블 등록됨. 드래그하여 배치하세요.", false);
        }
        catch (Exception ex) { SetStatus($"Error: {ex.Message}", true); }
        finally { _isBusy = false; _busyStep = string.Empty; }
    }

    private void RemovePendingTable(PendingTable table)
    {
        _pendingTables.Remove(table);
        var blk = _docBlocks.FirstOrDefault(s => s.Table == table);
        if (blk is not null) _docBlocks.Remove(blk);
    }

    private void ClearAll()
    {
        _rawInput = string.Empty; _pendingTables = []; _images = [];
        _docBlocks = []; _statusMessage = string.Empty;
        _reportTitle = ""; _reportDept = ""; _reportDate = ""; _reportMarker = "";
        _secPurpose = ""; _secContent = ""; _secDecision = "";
    }

    // ── Dataset selection ─────────────────────────────────────────────────────
    private void OnDatasetSelected(ChangeEventArgs e)
    {
        string ds = e.Value?.ToString() ?? string.Empty;
        if (string.IsNullOrEmpty(ds)) return;
        _datasetName = ds;
        _memo        = Repo.GetMemo(ds);
        _purpose     = Repo.GetPurpose(ds);
        if (string.IsNullOrEmpty(_purpose))
        {
            var tags = Repo.GetTags(ds);
            if (tags.Count > 0) _purpose = string.Join(", ", tags);
        }
        var tables = Repo.GetTablesForDataset(ds);
        _pendingTables = tables.Select(t => new PendingTable
        {
            TableName = t.TableName, Columns = t.Columns,
            Rows = Repo.GetTableRows(t.Id), IsExisting = true,
        }).ToList();
        _docBlocks.Clear();
        SetStatus($"'{ds}' 로드됨. 오른쪽에서 드래그하여 배치하세요.", false);
    }

    // ── Save to DB ────────────────────────────────────────────────────────────
    private async Task SaveToDbAsync()
    {
        if (string.IsNullOrWhiteSpace(_datasetName)) { SetStatus("Dataset name required.", true); return; }
        _isBusy = true; _busyStep = "save"; _statusMessage = string.Empty;
        StateHasChanged();
        try
        {
            string dsName = _datasetName.Trim();
            var tables    = _pendingTables.Where(t => !t.IsExisting).ToList();
            var tags      = _purpose.Split(',').Select(s => s.Trim()).Where(s => !string.IsNullOrEmpty(s)).ToList();
            await Task.Run(() =>
            {
                foreach (var t in tables) Repo.SaveTable(dsName, t.TableName, t.Columns, t.Rows);
                if (tags.Count > 0) Repo.SaveTags(dsName, tags);
                if (!string.IsNullOrWhiteSpace(_memo))    Repo.SaveMemo(dsName, _memo);
                if (!string.IsNullOrWhiteSpace(_purpose)) Repo.SavePurpose(dsName, _purpose);
            });
            SetStatus($"Saved '{dsName}' — {tables.Sum(t => t.Rows.Count):N0} rows.", false);
            _pendingTables = []; _images = []; _datasetName = string.Empty;
            _purpose = string.Empty; _memo = string.Empty;
            _allDatasets = Repo.GetAllDatasets();
        }
        catch (Exception ex) { SetStatus($"Save error: {ex.Message}", true); }
        finally { _isBusy = false; _busyStep = string.Empty; }
    }

    // ── Images ────────────────────────────────────────────────────────────────
    private async Task OnImagesSelected(InputFileChangeEventArgs e)
    {
        foreach (IBrowserFile file in e.GetMultipleFiles(10))
        {
            if (!file.ContentType.StartsWith("image/")) continue;
            using var ms = new MemoryStream();
            await using var stream = file.OpenReadStream(10 * 1024 * 1024);
            await stream.CopyToAsync(ms);
            string base64  = Convert.ToBase64String(ms.ToArray());
            string dataUrl = $"data:{file.ContentType};base64,{base64}";
            _images.Add(new ImageEntry(file.Name, file.ContentType, base64, dataUrl, file.Size));
        }
    }

    private async Task OpenCaptureAsync()
    {
        _showCaptureOverlay = true;
        await JS.InvokeVoidAsync("pasteImageHandler.openCapture");
    }

    private async Task CancelCapture()
    {
        _showCaptureOverlay = false;
        await JS.InvokeVoidAsync("pasteImageHandler.cancelCapture");
    }

    [JSInvokable]
    public void OnImagePasted(string mediaType, string dataUrl)
    {
        string ext    = mediaType.Split('/').LastOrDefault() ?? "png";
        int commaIdx  = dataUrl.IndexOf(',');
        string base64 = commaIdx >= 0 ? dataUrl[(commaIdx + 1)..] : dataUrl;
        _images.Add(new ImageEntry($"clipboard-{DateTime.Now:HHmmss}.{ext}", mediaType,
                                   base64, dataUrl, (long)(base64.Length * 3L / 4)));
        _showCaptureOverlay = false;
        InvokeAsync(StateHasChanged);
    }

    // ── Direct parse (with colspan/rowspan and fill-down) ─────────────────────
    private static ParsedResult ParseDirect(string text)
    {
        // Trim \r and drop blank lines
        string[] lines = text.Split('\n')
            .Select(l => l.TrimEnd('\r'))
            .Where(l => !string.IsNullOrWhiteSpace(l))
            .ToArray();
        if (lines.Length < 2) return new ParsedResult();

        string[] row0     = lines[0].Split('\t');
        int      colCount = row0.Length;

        // ── Detect multi-row header ──────────────────────────────────────────
        // Condition: row0 has empty cells AND lines[1] fills some of those empties
        bool      row0HasEmpty  = row0.Any(string.IsNullOrWhiteSpace);
        bool      isMultiHeader = false;
        string[]? row1          = null;

        if (row0HasEmpty && lines.Length > 2)
        {
            row1 = lines[1].Split('\t');
            if (row1.Length > colCount) colCount = row1.Length;
            isMultiHeader = row0
                .Select((v, i) => (v, i))
                .Where(x => string.IsNullOrWhiteSpace(x.v))
                .Any(x => x.i < row1.Length && !string.IsNullOrWhiteSpace(row1[x.i]));
        }

        var cols      = new List<ColumnDef>();
        var seen      = new Dictionary<string, int>(StringComparer.OrdinalIgnoreCase);
        int dataStart;
        List<List<HeaderCell>>? headerRows = null;

        if (isMultiHeader && row1 != null)
        {
            // ── Build two-row header with colspan / rowspan ──────────────────
            dataStart = 2;
            string[] r0 = PadToLength(row0, colCount);
            string[] r1 = PadToLength(row1, colCount);

            var topRow = new List<HeaderCell>();
            var botRow = new List<HeaderCell>();

            int ci = 0;
            while (ci < colCount)
            {
                string topLbl = r0[ci].Trim();

                if (!string.IsNullOrWhiteSpace(topLbl))
                {
                    // Count horizontal span (consecutive empty r0 cells that follow)
                    int span = 1;
                    while (ci + span < colCount && string.IsNullOrWhiteSpace(r0[ci + span]))
                        span++;

                    // Does this group have sub-labels in r1?
                    bool hasSub = false;
                    for (int s = 0; s < span; s++)
                        if (ci + s < r1.Length && !string.IsNullOrWhiteSpace(r1[ci + s]))
                        { hasSub = true; break; }

                    if (hasSub)
                    {
                        // Group header: spans multiple columns
                        topRow.Add(new HeaderCell { Label = topLbl, Colspan = span, Rowspan = 1 });
                        for (int s = 0; s < span; s++)
                        {
                            string subLbl = (ci + s < r1.Length) ? r1[ci + s].Trim() : "";
                            if (string.IsNullOrWhiteSpace(subLbl)) subLbl = $"{topLbl}_{s + 1}";
                            botRow.Add(new HeaderCell { Label = subLbl, Colspan = 1, Rowspan = 1 });
                            cols.Add(MakeCol(subLbl, seen));
                        }
                    }
                    else
                    {
                        // Standalone column: spans both header rows
                        topRow.Add(new HeaderCell { Label = topLbl, Colspan = span, Rowspan = 2 });
                        for (int s = 0; s < span; s++)
                            cols.Add(MakeCol(span > 1 ? $"{topLbl}_{s + 1}" : topLbl, seen));
                        // Nothing added to botRow (rowspan=2 covers it)
                    }
                    ci += span;
                }
                else
                {
                    // Orphaned empty r0 cell → use r1 value
                    string subLbl = (ci < r1.Length) ? r1[ci].Trim() : "";
                    if (string.IsNullOrWhiteSpace(subLbl)) subLbl = $"col{ci}";
                    topRow.Add(new HeaderCell { Label = "",     Colspan = 1, Rowspan = 1 });
                    botRow.Add(new HeaderCell { Label = subLbl, Colspan = 1, Rowspan = 1 });
                    cols.Add(MakeCol(subLbl, seen));
                    ci++;
                }
            }
            headerRows = [topRow, botRow];
        }
        else
        {
            // ── Single-row header: fill-forward for empty header cells ───────
            dataStart = 1;
            string prevLbl = "";
            foreach (string raw in row0)
            {
                string lbl = raw.Trim();
                if (string.IsNullOrWhiteSpace(lbl))
                    lbl = string.IsNullOrWhiteSpace(prevLbl) ? $"col{cols.Count}" : prevLbl;
                else
                    prevLbl = lbl;
                cols.Add(MakeCol(lbl, seen));
            }
        }

        // ── Parse data rows with fill-down for vertically merged cells ───────
        var rows = new List<Dictionary<string, string>>();
        Dictionary<string, string>? prevRow = null;

        for (int li = dataStart; li < lines.Length; li++)
        {
            string[] cells = lines[li].Split('\t');
            var dict = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
            for (int ci = 0; ci < cols.Count; ci++)
            {
                string val = ci < cells.Length ? cells[ci].Trim() : "";
                // Fill-down: empty cell inherits value from previous row (vertical merge)
                if (string.IsNullOrEmpty(val) && prevRow != null &&
                    prevRow.TryGetValue(cols[ci].Field, out string? pv))
                    val = pv ?? "";
                dict[cols[ci].Field] = val;
            }
            rows.Add(dict);
            prevRow = dict;
        }

        return new ParsedResult { Cols = cols, Rows = rows, HeaderRows = headerRows };
    }

    private static string[] PadToLength(string[] arr, int length)
    {
        if (arr.Length >= length) return arr;
        var result = new string[length];
        arr.CopyTo(result, 0);
        for (int i = arr.Length; i < length; i++) result[i] = "";
        return result;
    }

    private static ColumnDef MakeCol(string label, Dictionary<string, int> seen)
    {
        string baseF = string.IsNullOrWhiteSpace(label) ? "col"
            : System.Text.RegularExpressions.Regex.Replace(label, @"[^a-zA-Z0-9가-힣]", "_");
        if (string.IsNullOrEmpty(baseF)) baseF = "col";
        string field = seen.TryGetValue(baseF, out int n)
            ? (seen[baseF] = n + 1, $"{baseF}_{n + 1}").Item2
            : (seen[baseF] = 1, baseF).Item2;
        return new ColumnDef { Field = field, Label = label };
    }

    // ── Context menu ──────────────────────────────────────────────────────────
    private void ShowCtxMenu(MouseEventArgs e, PendingTable? table, int rowIndex, int colIndex)
    {
        if (!CanEdit) return;
        _showCtxMenu = true; _ctxX = e.ClientX; _ctxY = e.ClientY;
        _ctxTable = table; _ctxRowIndex = rowIndex; _ctxColIndex = colIndex;
        _ctxMode = rowIndex >= 0 ? "row" : "col";
    }

    private void CloseCtxMenu() => _showCtxMenu = false;

    private void ExecuteCtxAction()
    {
        _showCtxMenu = false;
        if (_ctxMode == "row")
        {
            if (_ctxTable is null || _ctxRowIndex < 0 || _ctxRowIndex >= _ctxTable.Rows.Count) return;
            _ctxTable.Rows.RemoveAt(_ctxRowIndex);
        }
        else
        {
            if (_ctxTable is null || _ctxColIndex < 0 || _ctxColIndex >= _ctxTable.Columns.Count) return;
            string field = _ctxTable.Columns[_ctxColIndex].Field;
            _ctxTable.Columns.RemoveAt(_ctxColIndex);
            foreach (var row in _ctxTable.Rows) row.Remove(field);
        }
    }

    // ── Inline cell editing ───────────────────────────────────────────────────
    private bool IsEditing(PendingTable? table, int rowIndex, string colField) =>
        _editTable == table && _editRowIndex == rowIndex &&
        _editColField.Equals(colField, StringComparison.OrdinalIgnoreCase);

    private void StartEdit(PendingTable? table, int rowIndex, string colField, string currentValue)
    {
        if (!CanEdit) return;
        _editTable = table; _editRowIndex = rowIndex;
        _editColField = colField; _editValue = currentValue; _editNeedFocus = true;
    }

    private void CommitEdit()
    {
        if (_editRowIndex < 0 || _editTable is null || _editRowIndex >= _editTable.Rows.Count)
        { CancelEdit(); return; }
        _editTable.Rows[_editRowIndex][_editColField] = _editValue;
        CancelEdit();
    }

    private void CancelEdit() { _editTable = null; _editRowIndex = -1; _editColField = ""; _editValue = ""; }

    private void OnEditKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")  CommitEdit();
        if (e.Key == "Escape") CancelEdit();
    }

    private void SetStatus(string msg, bool isError) { _statusMessage = msg; _statusIsError = isError; }

    public async ValueTask DisposeAsync()
    {
        try { await JS.InvokeVoidAsync("pasteImageHandler.cancelPasteCapture"); } catch { }
        try { await JS.InvokeVoidAsync("diDragDrop.destroy", _dotnetRef); } catch { }
        _dotnetRef?.Dispose();
    }
}
