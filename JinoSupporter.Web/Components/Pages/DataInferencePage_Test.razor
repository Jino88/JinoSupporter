@page "/data-inference-test"
@page "/data-inference-test/{InitialTab}"
@rendermode InteractiveServer
@using System.Linq
@implements IAsyncDisposable
@inject WebRepository Repo
@inject ClaudeService  Claude
@inject IJSRuntime     JS

<PageTitle>Data Inference TEST</PageTitle>

@if (!Claude.IsConfigured)
{
    <div class="alert alert-warning mb-2 py-2 small">
        <strong>Claude API key not configured.</strong>
    </div>
}

<!-- ══ Top bar ══════════════════════════════════════════════════════════════ -->
<div class="di-topbar">
    <div class="input-group input-group-sm" style="max-width:340px; flex-shrink:0;">
        <input @bind="_datasetName" class="form-control" placeholder="Dataset name…" />
        <select class="form-select" style="max-width:120px;" @onchange="OnDatasetSelected">
            <option value="">Select…</option>
            @foreach (var ds in _allDatasets)
            {
                <option value="@ds">@ds</option>
            }
        </select>
    </div>

    @if (CanEdit)
    {
        <button class="btn btn-success btn-sm" @onclick="SaveToDbAsync"
                disabled="@(_isBusy || string.IsNullOrWhiteSpace(_datasetName))">
            @if (_isBusy && _busyStep == "save")
            { <span class="spinner-border spinner-border-sm me-1" /> }
            Save
        </button>
    }

    @if (!string.IsNullOrEmpty(_statusMessage))
    {
        <span class="small @(_statusIsError ? "text-danger" : "text-success")">@_statusMessage</span>
    }

    <div style="flex:1;"></div>
    <button class="btn btn-outline-secondary btn-sm" @onclick="ClearAll" disabled="@_isBusy">Clear</button>
</div>

<!-- ══ Main: document canvas + right sidebar ═══════════════════════════════ -->
<div class="di-editor-wrap">

    <!-- ── Document page background ── -->
    <div class="di-page-bg">
        <div class="di-doc-page">

            <!-- ══ Report Header ══════════════════════════════════════════════ -->
            <table class="di-rpt-hdr">
                <tbody>
                    <tr>
                        <td class="di-rpt-title-lbl" rowspan="3">TITLE</td>
                        <td class="di-rpt-title-txt" rowspan="3">
                            <input class="di-rpt-title-input"
                                   value="@_reportTitle"
                                   @oninput="e => _reportTitle = e.Value?.ToString() ?? _reportTitle"
                                   placeholder="Report Title…" />
                        </td>
                        <td class="di-rpt-meta-lbl">Dept</td>
                        <td class="di-rpt-meta-val">
                            <input class="di-rpt-meta-input" value="@_reportDept"
                                   @oninput="e => _reportDept = e.Value?.ToString() ?? _reportDept" />
                        </td>
                    </tr>
                    <tr>
                        <td class="di-rpt-meta-lbl">Date</td>
                        <td class="di-rpt-meta-val">
                            <input class="di-rpt-meta-input" value="@_reportDate"
                                   @oninput="e => _reportDate = e.Value?.ToString() ?? _reportDate" />
                        </td>
                    </tr>
                    <tr>
                        <td class="di-rpt-meta-lbl">Marker</td>
                        <td class="di-rpt-meta-val">
                            <input class="di-rpt-meta-input" value="@_reportMarker"
                                   @oninput="e => _reportMarker = e.Value?.ToString() ?? _reportMarker" />
                        </td>
                    </tr>
                </tbody>
            </table>

            <!-- ══ I. Purpose ═════════════════════════════════════════════════ -->
            <div class="di-rpt-sec">
                <div class="di-rpt-sec-hd">I. Purpose.</div>
                <textarea class="di-rpt-sec-body"
                          value="@_secPurpose"
                          @oninput="e => _secPurpose = e.Value?.ToString() ?? _secPurpose"
                          placeholder="- 목적을 입력하세요…"
                          rows="3"></textarea>
            </div>

            <!-- ══ II. Content ════════════════════════════════════════════════ -->
            <div class="di-rpt-sec">
                <div class="di-rpt-sec-hd">II. Content.</div>
                <textarea class="di-rpt-sec-body"
                          value="@_secContent"
                          @oninput="e => _secContent = e.Value?.ToString() ?? _secContent"
                          placeholder="- 내용을 입력하세요…"
                          rows="3"></textarea>
            </div>

            <!-- ══ III. Result ════════════════════════════════════════════════ -->
            <div class="di-rpt-sec">
                <div class="di-rpt-sec-hd">III. Result</div>

                <!-- Drop zone 0 -->
                <div class="di-dropzone" data-di-zone="0">
                    @if (_docBlocks.Count == 0)
                    {
                        <div class="di-dz-hint" style="padding:30px 20px;">
                            <span style="font-size:28px; opacity:.3;">⬇</span>
                            <div style="margin-top:6px; font-size:13px; color:#94a3b8;">
                                오른쪽에서 테이블·이미지를 드래그하거나 텍스트를 추가하세요
                            </div>
                            <button class="di-add-text-btn" @onclick="() => AddTextBlock(0)">＋ 텍스트 추가</button>
                        </div>
                    }
                    else
                    {
                        <button class="di-add-text-inline" @onclick="() => AddTextBlock(0)">＋</button>
                    }
                </div>

                @foreach (var block in _docBlocks)
                {
                    var blk    = block;
                    var blkIdx = _docBlocks.IndexOf(blk);
                    var dzi    = blkIdx + 1;

                    <div class="di-block">
                        <div class="di-block-bar">
                            <button class="di-slot-btn" title="위로"
                                    disabled="@(blkIdx == 0)"
                                    @onclick="() => MoveBlock(blk, -1)">▲</button>
                            <button class="di-slot-btn" title="아래로"
                                    disabled="@(blkIdx == _docBlocks.Count - 1)"
                                    @onclick="() => MoveBlock(blk, 1)">▼</button>
                            <button class="di-slot-btn" title="@(blk.Span == 2 ? "절반 너비로" : "전체 너비로")"
                                    @onclick="() => { blk.Span = blk.Span == 2 ? 1 : 2; }">
                                @(blk.Span == 2 ? "⬡" : "⬢")
                            </button>
                            <span style="flex:1; font-size:11px; color:#64748b;
                                         overflow:hidden; text-overflow:ellipsis; white-space:nowrap; padding:0 4px;">
                                @(blk.Kind == "table" ? blk.Table?.TableName : blk.Kind == "image" ? blk.Image?.Name : "Text")
                            </span>
                            <button class="di-slot-btn di-slot-remove" title="제거"
                                    @onclick="() => _docBlocks.Remove(blk)">✕</button>
                        </div>

                        @if (blk.Kind == "table" && blk.Table is not null)
                        {
                            var table = blk.Table;
                            <div class="card mb-0 border @(table.IsExisting ? "border-secondary opacity-75" : "")"
                                 style="@(blk.Span == 1 ? "max-width:50%;" : "")">
                                <div class="card-header py-2 d-flex align-items-center gap-2"
                                     style="@(table.IsExisting ? "background:#f1f5f9;" : "")">
                                    <input class="form-control form-control-sm fw-semibold"
                                           style="max-width:260px; font-size:13px;"
                                           value="@table.TableName"
                                           disabled="@table.IsExisting"
                                           @oninput="e => table.TableName = e.Value?.ToString() ?? table.TableName" />
                                    <span class="text-muted small">@table.Rows.Count rows</span>
                                    @if (table.IsExisting)
                                    {
                                        <span class="badge text-bg-secondary ms-auto">existing</span>
                                    }
                                    else
                                    {
                                        <button class="btn btn-danger btn-sm ms-auto"
                                                @onclick="() => RemovePendingTable(table)">Delete</button>
                                    }
                                </div>
                                <div style="overflow:auto; max-height:320px;">
                                    <table style="font-size:11px; min-width:max-content;
                                                  border-collapse:collapse; width:100%;">
                                        <thead style="position:sticky; top:0; z-index:1; background:#f8fafc;">
                                            @if (table.HeaderRows != null)
                                            {
                                                @foreach (var hrow in table.HeaderRows)
                                                {
                                                    <tr>
                                                        @foreach (var hcell in hrow)
                                                        {
                                                            <th colspan="@hcell.Colspan" rowspan="@hcell.Rowspan"
                                                                style="padding:6px 10px; font-size:10px; font-weight:700;
                                                                       color:#64748b; text-transform:uppercase; letter-spacing:.4px;
                                                                       white-space:normal; word-break:break-word;
                                                                       min-width:60px; max-width:160px;
                                                                       border-bottom:2px solid #e2e8f0;
                                                                       border-right:1px solid #e2e8f0;
                                                                       vertical-align:middle; line-height:1.3; text-align:center;">
                                                                @hcell.Label
                                                            </th>
                                                        }
                                                    </tr>
                                                }
                                            }
                                            else
                                            {
                                                <tr>
                                                    @{ int pci = 0; }
                                                    @foreach (ColumnDef col in table.Columns)
                                                    {
                                                        int ci = pci++;
                                                        <th style="padding:6px 10px; font-size:10px; font-weight:700;
                                                                   color:#64748b; text-transform:uppercase; letter-spacing:.4px;
                                                                   white-space:normal; word-break:break-word;
                                                                   min-width:60px; max-width:160px;
                                                                   border-bottom:2px solid #e2e8f0;
                                                                   cursor:context-menu; user-select:none;
                                                                   vertical-align:bottom; line-height:1.3;"
                                                            title="Right-click to delete column"
                                                            @oncontextmenu="e => ShowCtxMenu(e, table, -1, ci)"
                                                            @oncontextmenu:preventDefault="true">
                                                            @col.Label
                                                        </th>
                                                    }
                                                </tr>
                                            }
                                        </thead>
                                        <tbody>
                                            @{ int pri = 0; }
                                            @foreach (Dictionary<string, string> row in table.Rows.Take(200))
                                            {
                                                int ri = pri++;
                                                <tr style="border-top:1px solid #f1f5f9;"
                                                    @oncontextmenu="e => ShowCtxMenu(e, table, ri, -1)"
                                                    @oncontextmenu:preventDefault="true">
                                                    @foreach (ColumnDef col in table.Columns)
                                                    {
                                                        string cv = row.TryGetValue(col.Field, out string? v) ? v ?? "" : "";
                                                        <td style="padding:0; border-top:1px solid #f1f5f9;"
                                                            @onclick:stopPropagation="true">
                                                            @if (IsEditing(table, ri, col.Field))
                                                            {
                                                                <input class="di-cell-input"
                                                                       value="@_editValue"
                                                                       @oninput="e => _editValue = e.Value?.ToString() ?? _editValue"
                                                                       @onblur="CommitEdit"
                                                                       @onkeydown="OnEditKeyDown"
                                                                       @ref="_editRef" />
                                                            }
                                                            else
                                                            {
                                                                <span class="di-cell-span"
                                                                      @onclick="() => StartEdit(table, ri, col.Field, cv)">
                                                                    @cv
                                                                </span>
                                                            }
                                                        </td>
                                                    }
                                                </tr>
                                            }
                                            @if (table.Rows.Count > 200)
                                            {
                                                <tr>
                                                    <td colspan="@table.Columns.Count"
                                                        style="text-align:center; padding:6px; color:#94a3b8; font-size:10px;">
                                                        … @(table.Rows.Count - 200) more rows
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        }
                        else if (blk.Kind == "image" && blk.Image is not null)
                        {
                            <div class="card mb-0 border"
                                 style="overflow:hidden; @(blk.Span == 1 ? "max-width:50%;" : "")">
                                <img src="@blk.Image.DataUrl" alt="@blk.Image.Name"
                                     style="width:100%; display:block; object-fit:contain;
                                            max-height:480px; background:#f8fafc;" />
                            </div>
                        }
                        else if (blk.Kind == "text")
                        {
                            <textarea class="di-text-block"
                                      style="@(blk.Span == 1 ? "max-width:50%;" : "")"
                                      placeholder="텍스트를 입력하세요…"
                                      rows="3"
                                      value="@blk.Text"
                                      @oninput="e => blk.Text = e.Value?.ToString() ?? blk.Text"
                                      @onkeydown:stopPropagation="true"></textarea>
                        }
                    </div>

                    <div class="di-dropzone" data-di-zone="@dzi">
                        <button class="di-add-text-inline" @onclick="() => AddTextBlock(dzi)">＋</button>
                    </div>
                }

            </div>

            <!-- ══ IV. Decision ══════════════════════════════════════════════ -->
            <div class="di-rpt-sec di-rpt-sec-last">
                <div class="di-rpt-sec-hd">IV. Decision</div>
                <textarea class="di-rpt-sec-body"
                          value="@_secDecision"
                          @oninput="e => _secDecision = e.Value?.ToString() ?? _secDecision"
                          placeholder="- 내용을 입력하세요…"
                          rows="3"></textarea>
            </div>

        </div>
    </div>

    <!-- ══ Center: Tool Menu ═══════════════════════════════════════════════════ -->
    <div class="di-center-menu">
        <button class="di-menu-btn @(_toolsTab == "table" ? "di-menu-active" : "")"
                @onclick="SelectTableTab">
            <div class="di-menu-icon">📋</div>
            <div class="di-menu-label">Table</div>
        </button>
        <button class="di-menu-btn @(_toolsTab == "image" ? "di-menu-active" : "")"
                @onclick="SelectImageTab">
            <div class="di-menu-icon">🖼</div>
            <div class="di-menu-label">Image</div>
        </button>
    </div>

    <!-- ══ Right: Registration Panel ════════════════════════════════════════════ -->
    <div class="di-reg-panel">

        <!-- ── Table 등록 ── -->
        @if (_toolsTab == "table")
        {
            <div class="di-rp-hd">📋 Table 등록</div>
            <div class="di-rp-body">

                <div class="di-rp-hint">
                    Excel에서 범위 선택 후 <strong>Ctrl+C</strong> → 아래에 붙여넣기
                    <br/><span>탭 구분 데이터는 자동으로 표가 생성됩니다</span>
                </div>

                <textarea class="di-rp-paste font-monospace"
                          value="@_rawInput"
                          @oninput="OnTableInputChanged"
                          placeholder="Ctrl+V 로 붙여넣기…"
                          rows="12" spellcheck="false"></textarea>

                @if (_useAi && CanOrganize)
                {
                    <button class="btn btn-primary btn-sm w-100 mt-2" @onclick="OrganizeAsync"
                            disabled="@_isBusy">
                        @if (_isBusy && _busyStep == "organize")
                        { <span class="spinner-border spinner-border-sm me-1" /> }
                        AI 분석으로 표 생성
                    </button>
                }

                <div class="d-flex align-items-center gap-2 mt-2">
                    <span class="di-mode-lbl">모드</span>
                    <div class="btn-group btn-group-sm">
                        <input type="radio" class="btn-check" id="tp-ai" name="tp-mode"
                               checked="@_useAi" @onchange="() => SetMode(true)" />
                        <label class="btn btn-outline-primary" for="tp-ai">AI</label>
                        <input type="radio" class="btn-check" id="tp-direct" name="tp-mode"
                               checked="@(!_useAi)" @onchange="() => SetMode(false)" />
                        <label class="btn btn-outline-primary" for="tp-direct">Direct</label>
                    </div>
                    @if (!_useAi)
                    {
                        <span class="di-mode-lbl" style="color:#22c55e;">자동 파싱</span>
                    }
                </div>

                @if (_pendingTables.Count > 0)
                {
                    <div class="di-rp-list-hd">등록된 테이블 — 드래그해서 배치</div>
                    @for (int ti = 0; ti < _pendingTables.Count; ti++)
                    {
                        var tblCap = _pendingTables[ti];
                        bool inDoc = _docBlocks.Any(b => b.Table == tblCap);
                        int  tidx  = ti;
                        <div class="di-tb-item @(inDoc ? "di-tb-on" : "")"
                             draggable="true"
                             data-di-kind="table"
                             data-di-idx="@tidx"
                             title="@tblCap.TableName">
                            <span class="di-tb-icon">⠿</span>
                            <span class="di-tb-label">@tblCap.TableName</span>
                            <span class="di-tb-meta">@(tblCap.Rows.Count)행</span>
                            @if (inDoc) { <span class="di-tb-check">✓</span> }
                        </div>
                    }
                }
                else
                {
                    <div class="di-tb-empty" style="margin-top:12px; text-align:center;">
                        붙여넣기하면 표가 나타납니다
                    </div>
                }

            </div>
        }

        <!-- ── Image 등록 ── -->
        @if (_toolsTab == "image")
        {
            <div class="di-rp-hd">🖼 Image 등록</div>
            <div class="di-rp-body">

                <button class="btn btn-outline-primary btn-sm w-100 mb-2"
                        @onclick="OpenCaptureAsync">
                    📋 클립보드에서 붙여넣기 (Ctrl+V)
                </button>
                <InputFile OnChange="OnImagesSelected" multiple accept="image/*"
                           class="form-control form-control-sm" style="font-size:11px;" />

                @if (_images.Count > 0)
                {
                    <div class="di-rp-list-hd">등록된 이미지 — 드래그해서 배치</div>
                    @for (int ii = 0; ii < _images.Count; ii++)
                    {
                        var imgCap = _images[ii];
                        bool inDoc = _docBlocks.Any(b => b.Image == imgCap);
                        int  iidx  = ii;
                        <div class="di-tb-img @(inDoc ? "di-tb-on" : "")"
                             draggable="true"
                             data-di-kind="image"
                             data-di-idx="@iidx"
                             title="@imgCap.Name">
                            <img src="@imgCap.DataUrl" alt="@imgCap.Name"
                                 style="width:100%; height:72px; object-fit:cover; border-radius:4px; display:block;" />
                            @if (inDoc)
                            {
                                <div style="position:absolute;top:4px;right:4px;background:#22c55e;
                                            border-radius:50%;width:18px;height:18px;display:flex;
                                            align-items:center;justify-content:center;
                                            font-size:10px;color:#fff;font-weight:700;">✓</div>
                            }
                        </div>
                    }
                }
                else
                {
                    <div class="di-tb-empty" style="margin-top:12px; text-align:center;">
                        이미지를 추가하면 나타납니다
                    </div>
                }

            </div>
        }

    </div>

</div>

<!-- ── Context Menu ────────────────────────────────────────────────────── -->
@if (_showCtxMenu)
{
    <div style="position:fixed; inset:0; z-index:9000;"
         @onclick="CloseCtxMenu"
         @oncontextmenu="CloseCtxMenu"
         @oncontextmenu:preventDefault="true"></div>
    <div style="position:fixed; top:@(_ctxY)px; left:@(_ctxX)px; z-index:9001;
                background:#fff; border:1px solid #e2e8f0; border-radius:8px;
                box-shadow:0 4px 20px rgba(0,0,0,.13); padding:4px 0; min-width:150px;">
        @if (_ctxMode == "row")
        {
            <button class="di-ctx-btn di-ctx-danger" @onclick="ExecuteCtxAction">🗑 Delete Row</button>
        }
        else
        {
            <button class="di-ctx-btn di-ctx-danger" @onclick="ExecuteCtxAction">🗑 Delete Column</button>
        }
    </div>
}

<style>
    .di-topbar {
        display: flex; align-items: center; gap: 8px;
        padding: 8px 14px; background: #fff; flex-shrink: 0;
        border-bottom: 1px solid #e2e8f0; flex-wrap: wrap;
    }
    .di-editor-wrap {
        display: flex; flex: 1; min-height: 0; height: calc(100vh - 48px); overflow: hidden;
    }
    .di-page-bg {
        flex: 1; min-width: 0; background: #8796aa; overflow-y: auto;
        padding: 12px 8px;
    }
    .di-doc-page {
        background: #fff; width: 100%; min-height: 500px;
        box-shadow: 0 2px 12px rgba(0,0,0,.18);
        border-radius: 2px; padding: 28px 36px 40px;
        box-sizing: border-box;
    }
    /* ── Report template ──────────────────────────────────────────────── */
    .di-rpt-hdr {
        width: 100%; border-collapse: collapse; margin-bottom: 18px;
        border: 1.5px solid #334155;
    }
    .di-rpt-hdr td { border: 1px solid #64748b; padding: 0; }
    .di-rpt-title-lbl {
        width: 52px; text-align: center; font-size: 11px; font-weight: 700;
        color: #475569; background: #f1f5f9; vertical-align: middle;
        letter-spacing: .3px;
    }
    .di-rpt-title-txt { padding: 0 !important; }
    .di-rpt-title-input {
        width: 100%; border: none; outline: none; padding: 8px 12px;
        font-size: 13px; font-weight: 700; color: #0f172a; background: transparent;
        text-align: center; letter-spacing: .3px;
    }
    .di-rpt-title-input::placeholder { color: #cbd5e1; font-weight: 400; }
    .di-rpt-meta-lbl {
        width: 52px; text-align: center; font-size: 10px; font-weight: 700;
        color: #475569; background: #f1f5f9; padding: 4px 6px !important;
        white-space: nowrap;
    }
    .di-rpt-meta-val { width: 80px; padding: 0 !important; }
    .di-rpt-meta-input {
        width: 100%; border: none; outline: none; padding: 4px 8px;
        font-size: 12px; color: #1e293b; background: transparent;
    }
    .di-rpt-meta-input::placeholder { color: #cbd5e1; }
    /* ── Report sections ──────────────────────────────────────────────── */
    .di-rpt-sec { border: 1.5px solid #334155; border-top: none; }
    .di-rpt-hdr + .di-rpt-sec { border-top: 1.5px solid #334155; }
    .di-rpt-sec-hd {
        font-size: 12px; font-weight: 700; color: #0f172a; padding: 5px 12px;
        background: #f8fafc; border-bottom: 1px solid #e2e8f0; letter-spacing: .2px;
    }
    .di-rpt-sec-body {
        width: 100%; border: none; outline: none; resize: none; overflow: hidden;
        padding: 8px 16px; font-size: 13px; line-height: 1.8;
        color: #1e293b; background: transparent; font-family: inherit;
        box-sizing: border-box; min-height: 64px;
        field-sizing: content;
    }
    .di-rpt-sec-body::placeholder { color: #cbd5e1; }
    .di-rpt-sec-last { margin-bottom: 0; }
    /* ── Drop zones (JS handles di-dz-active class) ──────────────────── */
    .di-dropzone {
        min-height: 12px; margin: 6px 0; border-radius: 4px;
        border: 2px dashed transparent; transition: all .12s; box-sizing: border-box;
    }
    .di-dropzone.di-dz-active {
        min-height: 40px; background: #eff6ff; border-color: #93c5fd;
    }
    .di-dz-hint {
        display: flex; flex-direction: column; align-items: center;
        padding: 60px 20px; text-align: center;
    }
    .di-block { margin-bottom: 4px; }
    .di-block-bar {
        display: flex; align-items: center; gap: 3px;
        padding: 3px 5px; background: #f1f5f9;
        border: 1px solid #e2e8f0; border-bottom: none;
        border-radius: 6px 6px 0 0; font-size: 11px;
    }
    .di-block-bar + .card { border-radius: 0 0 6px 6px !important; }
    .di-slot-btn {
