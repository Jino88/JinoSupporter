@page "/data-inference"
@rendermode InteractiveServer
@implements IAsyncDisposable
@inject WebRepository Repo
@inject ClaudeService  Claude
@inject IJSRuntime     JS

<PageTitle>Data Inference — Input Data</PageTitle>

<div class="di-root">

@if (!Claude.IsConfigured)
{
    <div class="alert alert-warning mb-0 py-2 small" style="flex-shrink:0; margin:8px 14px 0;">
        <strong>Claude API key not configured.</strong> Go to Admin → Settings to add your key.
    </div>
}

<!-- ── Top bar ──────────────────────────────────────────────────────────────── -->
<div class="di-topbar">
    <div class="di-topbar-left">
        <label class="di-label">Dataset</label>
        <input @bind="_datasetName" class="form-control form-control-sm di-input-name"
               placeholder="Dataset name…" />
        <label class="di-label">Product Type</label>
        <input @bind="_productType" class="form-control form-control-sm" style="width:160px;"
               list="productTypeOptions" placeholder="e.g. BRS-161016" autocomplete="off" />
        <datalist id="productTypeOptions">
            @foreach (var pt in _productTypeOptions)
            {
                <option value="@pt"></option>
            }
        </datalist>
        <label class="di-label">Date</label>
        <input type="date" value="@_testDate"
               @onchange="@(e => _testDate = e.Value?.ToString() ?? _testDate)"
               class="form-control form-control-sm" style="width:145px;" />
    </div>
    <div class="di-topbar-right">
        <select class="form-select form-select-sm" style="width:220px;" @onchange="OnLoadExisting">
            <option value="">Load existing…</option>
            @foreach (var r in _allReports)
            {
                <option value="@r.DatasetName">@r.DatasetName</option>
            }
        </select>
        <button class="btn btn-primary btn-sm" @onclick="AnalyzeAsync"
                disabled="@(_images.Count == 0 || _isBusy || !Claude.IsConfigured)">
            @if (_isBusy && _busyStep == "analyze") { <span class="spinner-border spinner-border-sm me-1"></span> }
            Analyze
        </button>
        <button class="btn btn-success btn-sm" @onclick="SaveAsync"
                disabled="@(_isBusy || string.IsNullOrWhiteSpace(_datasetName))">
            @if (_isBusy && _busyStep == "save") { <span class="spinner-border spinner-border-sm me-1"></span> }
            Save
        </button>
        <button class="btn btn-outline-secondary btn-sm" @onclick="Clear" disabled="@_isBusy">Clear</button>
    </div>
</div>

@if (!string.IsNullOrEmpty(_status))
{
    <div class="di-status-bar @(_statusError ? "di-error" : "di-ok")">@_status</div>
}

<!-- ── Image zone ───────────────────────────────────────────────────────────── -->
<div class="di-image-section">
    @if (_images.Count == 0)
    {
        <div class="di-drop-zone" @onclick="EnablePaste">
            <div class="di-drop-icon">📋</div>
            <div class="di-drop-title">Click here, then press Ctrl+V to paste a screenshot</div>
            <div class="di-drop-sub">Or use the file upload below</div>
        </div>
    }
    else
    {
        <div class="di-thumb-grid" @onclick="EnablePaste">
            @foreach (var (img, idx) in _images.Select((x, i) => (x, i)))
            {
                <div class="di-thumb" @onclick:stopPropagation="true">
                    <img src="@img.DataUrl" alt="@(idx+1)" />
                    <button class="di-thumb-del" @onclick="() => RemoveImage(img)">✕</button>
                    <div class="di-thumb-num">@(idx+1)</div>
                </div>
            }
            <div class="di-thumb-add" @onclick:stopPropagation="true" @onclick="EnablePaste">
                <div style="font-size:22px; line-height:1;">＋</div>
                <div style="font-size:10px; color:#94a3b8; margin-top:3px;">Paste more</div>
            </div>
        </div>
    }
    <div class="di-upload-row">
        <InputFile OnChange="OnFilesSelected" multiple accept="image/*" style="font-size:12px; color:#64748b;" />
        <span class="di-img-count">@_images.Count image(s)</span>
    </div>
</div>

<!-- ── Attached files (backup, any type) ────────────────────────────────────── -->
<div class="di-files-section">
    <div class="di-files-header">
        <span class="di-files-title">📎 Backup Files (original files kept for archive — not used by AI)</span>
        <span class="di-img-count">@_files.Count file(s)</span>
    </div>
    <div id="bf-drop-zone" class="bf-drop-zone" @onclick="EnableFilePaste">
        <span class="bf-drop-icon">⬇</span>
        <span><strong>Drag & drop</strong> files here, or click and press <strong>Ctrl+V</strong> to paste</span>
    </div>
    @if (_files.Count > 0)
    {
        <div class="di-files-list">
            @foreach (var (f, idx) in _files.Select((x, i) => (x, i)))
            {
                <div class="di-file-chip">
                    <span class="di-file-icon">📄</span>
                    <span class="di-file-name" title="@f.FileName">@f.FileName</span>
                    <span class="di-file-size">@FormatSize(f.Data.Length)</span>
                    <button class="di-file-del" title="Remove" @onclick="() => RemoveFile(f)">✕</button>
                </div>
            }
        </div>
    }
    <InputFile OnChange="OnBackupFilesSelected" multiple style="font-size:12px; color:#64748b; margin-top:4px;" />
</div>

<!-- ── Results ──────────────────────────────────────────────────────────────── -->
@if (!string.IsNullOrEmpty(_summary) || _measurements.Count > 0)
{
    <div class="di-results">
        @if (!string.IsNullOrEmpty(_summary))
        {
            <div class="di-summary-box">
                <div class="di-summary-title">📊 Summary</div>
                <p class="mb-1" style="font-size:13px;">@_summary</p>
                @if (!string.IsNullOrEmpty(_keyFindings))
                {
                    <div class="di-key-findings">@_keyFindings</div>
                }
                @if (_tags.Count > 0)
                {
                    <div class="di-tags-row">
                        @foreach (var t in _tags)
                        {
                            <span class="di-tag di-tag-keyword">
                                🏷 @t
                                <button class="di-tag-del" title="Remove tag"
                                        @onclick="() => RemoveTag(t)">✕</button>
                            </span>
                        }
                    </div>
                }
            </div>
        }
        @if (_measurements.Count > 0)
        {
            <div class="di-results-header">
                Extracted Data — @_measurements.Count row(s)
            </div>
            <div class="di-table-wrap">
                <table class="di-table">
                    <thead>
                        <tr>
                            <th style="width:32px;"></th>
                            <th>Variable</th>
                            <th>Group</th>
                            <th>Line</th>
                            <th>CheckType</th>
                            <th>Input</th>
                            <th>NG</th>
                            <th>NG%</th>
                            <th>Defect Type</th>
                            <th>Category</th>
                            <th>Count</th>
                            <th>Intervention</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var m in _measurements)
                        {
                            <tr>
                                <td class="di-row-del-cell">
                                    <button class="di-row-del" title="Remove row"
                                            @onclick="() => RemoveMeasurement(m)">✕</button>
                                </td>
                                <td>@m.Variable</td>
                                <td>@m.VariableGroup</td>
                                <td>@m.Line</td>
                                <td>@m.CheckType</td>
                                <td class="n">@m.InputQty</td>
                                <td class="n">@m.NgTotal</td>
                                <td class="n">@m.NgRate.ToString("F1")%</td>
                                <td>@m.DefectType</td>
                                <td>@m.DefectCategory</td>
                                <td class="n">@m.DefectCount</td>
                                <td>@m.Intervention</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
}

</div>

<style>
    .di-root {
        flex: 1; min-height: 0; display: flex; flex-direction: column; overflow: hidden;
        background: #f8fafc;
    }
    .di-topbar {
        display: flex; align-items: center; justify-content: space-between; gap: 8px;
        padding: 8px 14px; background: #fff; flex-shrink: 0;
        border-bottom: 1px solid #e2e8f0; flex-wrap: wrap;
    }
    .di-topbar-left  { display: flex; align-items: center; gap: 6px; flex-wrap: wrap; }
    .di-topbar-right { display: flex; align-items: center; gap: 6px; flex-wrap: wrap; }
    .di-label        { font-size: 12px; font-weight: 600; color: #64748b; white-space: nowrap; }
    .di-input-name   { width: 200px; }
    .di-status-bar   { padding: 4px 14px; font-size: 12px; flex-shrink: 0; }
    .di-ok           { color: #16a34a; background: #f0fdf4; border-bottom: 1px solid #bbf7d0; }
    .di-error        { color: #dc2626; background: #fef2f2; border-bottom: 1px solid #fecaca; }

    /* Image zone */
    .di-image-section {
        flex-shrink: 0; padding: 10px 14px 6px;
        background: #fff; border-bottom: 1px solid #e2e8f0;
    }
    .di-drop-zone {
        display: flex; flex-direction: column; align-items: center; justify-content: center;
        border: 2px dashed #cbd5e1; border-radius: 10px; padding: 28px 20px;
        cursor: pointer; transition: all .15s; color: #94a3b8;
    }
    .di-drop-zone:hover { border-color: #94a3b8; background: #f8fafc; }
    .di-drop-icon  { font-size: 32px; margin-bottom: 8px; }
    .di-drop-title { font-size: 14px; font-weight: 600; color: #475569; margin-bottom: 4px; }
    .di-drop-sub   { font-size: 12px; }
    .di-thumb-grid {
        display: flex; flex-wrap: wrap; gap: 8px; padding: 6px;
        border: 1px solid #e2e8f0; border-radius: 8px; cursor: pointer;
        min-height: 90px; background: #f8fafc;
    }
    .di-thumb {
        position: relative; width: 80px; height: 80px; border-radius: 6px;
        overflow: hidden; border: 1px solid #e2e8f0; flex-shrink: 0;
        background: #fff;
    }
    .di-thumb img    { width: 100%; height: 100%; object-fit: cover; }
    .di-thumb-del    {
        position: absolute; top: 2px; right: 2px; width: 18px; height: 18px;
        border-radius: 50%; border: none; background: rgba(220,38,38,.85);
        color: #fff; font-size: 9px; line-height: 18px; text-align: center;
        cursor: pointer; padding: 0; display: none;
    }
    .di-thumb:hover .di-thumb-del { display: block; }
    .di-thumb-num    {
        position: absolute; bottom: 2px; left: 4px; font-size: 9px;
        color: rgba(255,255,255,.9); text-shadow: 0 1px 3px rgba(0,0,0,.6); font-weight: 700;
    }
    .di-thumb-add    {
        width: 80px; height: 80px; border-radius: 6px; border: 2px dashed #cbd5e1;
        display: flex; flex-direction: column; align-items: center; justify-content: center;
        cursor: pointer; color: #94a3b8; flex-shrink: 0; transition: all .12s;
    }
    .di-thumb-add:hover { border-color: #94a3b8; background: #fff; }
    .di-upload-row   {
        display: flex; align-items: center; gap: 10px; margin-top: 6px;
    }
    .di-img-count    { font-size: 11px; color: #94a3b8; }

    /* Backup files */
    .di-files-section {
        flex-shrink: 0; padding: 8px 14px 10px;
        background: #fff; border-bottom: 1px solid #e2e8f0;
    }
    .di-files-header { display: flex; align-items: center; gap: 8px; margin-bottom: 4px; }
    .di-files-title  { font-size: 12px; font-weight: 600; color: #475569; }
    .di-files-list   { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 4px; }
    .di-file-chip    {
        display: inline-flex; align-items: center; gap: 6px;
        background: #f1f5f9; border: 1px solid #e2e8f0; border-radius: 14px;
        padding: 3px 6px 3px 10px; font-size: 11px; color: #334155;
    }
    .di-file-icon    { font-size: 12px; }
    .di-file-name    { max-width: 260px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-weight: 600; }
    .di-file-size    { color: #94a3b8; font-size: 10px; }
    .di-file-del     {
        width: 18px; height: 18px; border-radius: 50%; border: none;
        background: transparent; color: #94a3b8; font-size: 10px; cursor: pointer; padding: 0;
    }
    .di-file-del:hover { background: #dc2626; color: #fff; }

    .bf-drop-zone {
        display: flex; align-items: center; gap: 8px; justify-content: center;
        padding: 10px 14px; margin-bottom: 6px;
        border: 2px dashed #cbd5e1; border-radius: 8px;
        font-size: 12px; color: #64748b; background: #f8fafc;
        cursor: pointer; transition: all .12s;
    }
    .bf-drop-zone:hover      { border-color: #94a3b8; color: #334155; }
    .bf-drop-zone.bf-drop-active {
        border-color: #3b82f6; background: #dbeafe; color: #1d4ed8;
    }
    .bf-drop-icon { font-size: 14px; }

    /* Results */
    .di-results {
        flex: 1; min-height: 0; overflow-y: auto; padding: 12px 14px;
    }
    .di-summary-box {
        background: #fff; border: 1px solid #e2e8f0; border-radius: 8px;
        padding: 12px 14px; margin-bottom: 12px;
    }
    .di-summary-title { font-size: 13px; font-weight: 700; color: #1e293b; margin-bottom: 6px; }
    .di-key-findings  { font-size: 12px; color: #475569; white-space: pre-wrap; margin-top: 6px; }
    .di-tags-row      { display: flex; flex-wrap: wrap; gap: 5px; margin-top: 8px; }
    .di-tag           {
        display: inline-flex; align-items: center; padding: 2px 8px; border-radius: 10px;
        font-size: 11px; font-weight: 600; line-height: 1.4;
    }
    .di-tag-keyword   { background: #e0e7ff; color: #4338ca; }
    .di-tag-del       {
        margin-left: 4px; border: none; background: transparent; padding: 0;
        color: inherit; opacity: .5; cursor: pointer; font-size: 10px; line-height: 1;
        font-weight: 700;
    }
    .di-tag-del:hover { opacity: 1; color: #dc2626; }
    .di-results-header {
        font-size: 13px; font-weight: 600; color: #1e293b; margin-bottom: 6px;
    }
    .di-table-wrap { overflow-x: auto; }
    .di-table {
        border-collapse: collapse; font-size: 12px; width: max-content; min-width: 100%;
    }
    .di-table th, .di-table td {
        border: 1px solid #e2e8f0; padding: 4px 8px; white-space: nowrap;
        text-align: left;
    }
    .di-table th { background: #f1f5f9; font-weight: 600; color: #475569; }
    .di-table td.n { text-align: right; font-variant-numeric: tabular-nums; }
    .di-table tbody tr:hover { background: #f8fafc; }
    .di-row-del-cell { text-align: center; padding: 2px !important; }
    .di-row-del {
        width: 22px; height: 22px; border-radius: 50%; border: 1px solid #fecaca;
        background: #fff; color: #dc2626; font-size: 11px; font-weight: 700;
        line-height: 1; cursor: pointer; padding: 0; transition: all .12s;
    }
    .di-row-del:hover { background: #dc2626; color: #fff; border-color: #dc2626; }
</style>

@code {
    private sealed record ImageEntry(string FileName, string MediaType, string Base64, string DataUrl);
    private sealed record FileEntry(string FileName, string MediaType, byte[] Data, long? ExistingId);

    private string            _datasetName  = "";
    private string            _productType  = "";
    private string            _testDate     = DateTime.Today.ToString("yyyy-MM-dd");
    private List<ImageEntry>  _images       = [];
    private List<FileEntry>   _files        = [];
    private List<NormalizedMeasurement> _measurements = [];
    private string            _summary      = "";
    private string            _keyFindings  = "";
    private List<string>      _tags         = [];
    private List<RawReportInfo> _allReports = [];
    private List<string>        _productTypeOptions = [];

    private bool   _isBusy;
    private string _busyStep    = "";
    private string _status      = "";
    private bool   _statusError;

    private DotNetObjectReference<DataInferencePage_Test>? _ref;

    [CascadingParameter] private Task<AuthenticationState> AuthState { get; set; } = default!;

    protected override void OnInitialized()
    {
        _allReports = Repo.GetAllRawReports();
        RefreshProductTypeOptions();
    }

    private void RefreshProductTypeOptions()
    {
        _productTypeOptions = _allReports
            .Select(r => r.ProductType)
            .Where(p => !string.IsNullOrWhiteSpace(p))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(p => p, StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("diFullPage.enter");
            _ref = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("pasteImageHandler.init", _ref);
            await JS.InvokeVoidAsync("pasteImageHandler.openCapture");
            await JS.InvokeVoidAsync("backupFileHandler.init", _ref, "bf-drop-zone");
        }
    }

    private async Task EnablePaste()
    {
        await JS.InvokeVoidAsync("pasteImageHandler.openCapture");
    }

    [JSInvokable]
    public void OnImagePasted(string mediaType, string dataUrl)
    {
        int comma  = dataUrl.IndexOf(',');
        string b64 = comma >= 0 ? dataUrl[(comma + 1)..] : dataUrl;

        (string finalB64, string finalMt) = ImageCompressor.CompressIfLarge(b64, mediaType);
        string finalDataUrl = $"data:{finalMt};base64,{finalB64}";
        string ext = finalMt.Split('/').LastOrDefault() ?? "png";

        _images.Add(new ImageEntry($"paste-{DateTime.Now:HHmmss}.{ext}", finalMt, finalB64, finalDataUrl));
        _ = JS.InvokeVoidAsync("pasteImageHandler.openCapture");
        InvokeAsync(StateHasChanged);
    }

    private async Task OnFilesSelected(InputFileChangeEventArgs e)
    {
        foreach (IBrowserFile file in e.GetMultipleFiles(20))
        {
            if (!file.ContentType.StartsWith("image/")) continue;
            using var ms = new MemoryStream();
            await using var stream = file.OpenReadStream(20 * 1024 * 1024);
            await stream.CopyToAsync(ms);
            string b64 = Convert.ToBase64String(ms.ToArray());

            (string finalB64, string finalMt) = ImageCompressor.CompressIfLarge(b64, file.ContentType);
            string dataUrl = $"data:{finalMt};base64,{finalB64}";
            _images.Add(new ImageEntry(file.Name, finalMt, finalB64, dataUrl));
        }
    }

    private void RemoveImage(ImageEntry img) => _images.Remove(img);

    private async Task OnBackupFilesSelected(InputFileChangeEventArgs e)
    {
        foreach (IBrowserFile file in e.GetMultipleFiles(20))
        {
            using var ms = new MemoryStream();
            await using var stream = file.OpenReadStream(100 * 1024 * 1024); // 100 MB
            await stream.CopyToAsync(ms);
            string mt = string.IsNullOrEmpty(file.ContentType) ? "application/octet-stream" : file.ContentType;
            _files.Add(new FileEntry(file.Name, mt, ms.ToArray(), null));
        }
    }

    private void RemoveFile(FileEntry f) => _files.Remove(f);

    private async Task EnableFilePaste()
    {
        await JS.InvokeVoidAsync("backupFileHandler.enableCapture");
    }

    [JSInvokable]
    public void OnBackupFileDropped(string fileName, string mediaType, string dataUrl)
    {
        int comma = dataUrl.IndexOf(',');
        if (comma < 0) return;
        string b64 = dataUrl[(comma + 1)..];
        byte[] bytes;
        try { bytes = Convert.FromBase64String(b64); }
        catch { return; }
        string mt = string.IsNullOrEmpty(mediaType) ? "application/octet-stream" : mediaType;
        _files.Add(new FileEntry(fileName, mt, bytes, null));
        InvokeAsync(StateHasChanged);
    }

    private static string FormatSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / 1024.0 / 1024.0:F1} MB";
    }

    private void RemoveMeasurement(NormalizedMeasurement m) => _measurements.Remove(m);

    private void RemoveTag(string t) => _tags.Remove(t);

    private async Task AnalyzeAsync()
    {
        if (_images.Count == 0) { SetStatus("Paste an image first.", true); return; }
        _isBusy = true; _busyStep = "analyze"; _status = "";
        StateHasChanged();
        try
        {
            var imageArgs = _images.Select(i => (i.MediaType, i.Base64)).ToList();
            string dsName = string.IsNullOrWhiteSpace(_datasetName) ? "dataset" : _datasetName.Trim();
            NormalizeResult result = await Claude.NormalizeFromImagesAsync(
                imageArgs, dsName, _productType.Trim(), _testDate);
            _measurements = result.Measurements;
            _summary      = result.Summary;
            _keyFindings  = result.KeyFindings;
            _tags         = result.Tags ?? [];
            SetStatus($"Analysis complete — {_measurements.Count} row(s) extracted.", false);
        }
        catch (Exception ex) { SetStatus($"Analyze error: {ex.Message}", true); }
        finally { _isBusy = false; _busyStep = ""; }
    }

    private async Task SaveAsync()
    {
        if (string.IsNullOrWhiteSpace(_datasetName)) { SetStatus("Dataset name required.", true); return; }
        _isBusy = true; _busyStep = "save"; _status = "";
        StateHasChanged();
        try
        {
            string name = _datasetName.Trim();
            var imgs = _images.Select(i => (i.MediaType, Convert.FromBase64String(i.Base64), i.FileName)).ToList();
            string tagsJson = _tags.Count > 0
                ? System.Text.Json.JsonSerializer.Serialize(_tags)
                : "";
            var newFiles = _files
                .Where(f => !f.ExistingId.HasValue)
                .Select(f => (f.MediaType, f.Data, f.FileName))
                .ToList();
            var keptIds = _files.Where(f => f.ExistingId.HasValue).Select(f => f.ExistingId!.Value).ToHashSet();
            await Task.Run(() =>
            {
                Repo.SaveRawReport(name, _productType, _testDate, imgs);

                // Sync backup files: delete removed, append new
                foreach (var fi in Repo.GetRawReportFileInfos(name))
                    if (!keptIds.Contains(fi.Id)) Repo.DeleteRawReportFile(fi.Id);
                if (newFiles.Count > 0) Repo.AppendRawReportFiles(name, newFiles);

                if (_measurements.Count > 0) Repo.SaveNormalizedMeasurements(name, _measurements);
                if (!string.IsNullOrEmpty(_summary) || !string.IsNullOrEmpty(tagsJson))
                    Repo.SaveDatasetSummaryRecord(name, _productType, _summary, _keyFindings, tagsJson);
            });
            SetStatus($"Saved — '{name}'", false);
            _allReports = Repo.GetAllRawReports();
            RefreshProductTypeOptions();
        }
        catch (Exception ex) { SetStatus($"Save error: {ex.Message}", true); }
        finally { _isBusy = false; _busyStep = ""; }
    }

    private async Task OnLoadExisting(ChangeEventArgs e)
    {
        string name = e.Value?.ToString() ?? "";
        if (string.IsNullOrEmpty(name)) return;
        var info = _allReports.FirstOrDefault(r => r.DatasetName == name);
        if (info is null) return;

        _datasetName  = info.DatasetName;
        _productType  = info.ProductType;
        _testDate     = info.ReportDate;
        _measurements = Repo.GetNormalizedMeasurements(name);
        var summ = Repo.GetDatasetSummaryRecord(name);
        _summary     = summ?.Summary     ?? "";
        _keyFindings = summ?.KeyFindings ?? "";
        _tags        = summ?.Tags        ?? [];

        var storedImgs = Repo.GetRawReportImages(name);
        _images = storedImgs.Select((img, i) =>
        {
            string b64    = Convert.ToBase64String(img.Data);
            string dataUrl = $"data:{img.MediaType};base64,{b64}";
            string fname   = img.FileName.Length > 0 ? img.FileName : $"img-{i + 1}";
            return new ImageEntry(fname, img.MediaType, b64, dataUrl);
        }).ToList();

        _files = Repo.GetRawReportFileInfos(name)
            .Select(fi => new FileEntry(fi.FileName, fi.MediaType, [], fi.Id))
            .ToList();

        SetStatus($"Loaded '{name}' — {_measurements.Count} measurement(s)", false);
    }

    private void Clear()
    {
        _datasetName = ""; _productType = ""; _testDate = DateTime.Today.ToString("yyyy-MM-dd");
        _images = []; _files = []; _measurements = []; _summary = ""; _keyFindings = "";
        _tags = []; _status = "";
    }

    private void SetStatus(string msg, bool err) { _status = msg; _statusError = err; }

    public async ValueTask DisposeAsync()
    {
        try { await JS.InvokeVoidAsync("diFullPage.leave"); } catch { }
        try { await JS.InvokeVoidAsync("pasteImageHandler.cancelPasteCapture"); } catch { }
        try { await JS.InvokeVoidAsync("backupFileHandler.dispose"); } catch { }
        _ref?.Dispose();
    }
}
