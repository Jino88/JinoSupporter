@page "/bmes/make-model-group"
@rendermode InteractiveServer
@using JinoSupporter.Web.Services
@inject WebRepository         Repo
@inject NgRateSettingsService NgRateSettings

<PageTitle>Make ModelGroup Data</PageTitle>

<div class="d-flex align-items-center gap-2 mb-3">
    <span style="font-size:20px;">🗂️</span>
    <h5 class="mb-0 fw-semibold">Make ModelGroup Data</h5>
    <span class="badge bg-secondary" style="font-size:11px;">@_rows.Count distinct</span>
    <button class="btn btn-outline-secondary btn-sm ms-auto" @onclick="Reload">↻ Refresh</button>
    <button class="btn btn-primary btn-sm"
            @onclick="SaveAsync"
            disabled="@_saving">
        @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
        💾 Save
    </button>
    <button class="btn btn-outline-danger btn-sm"
            @onclick="ClearGroups"
            disabled="@(_groups.Count <= 1 && _groups.All(g => g.MidGroups.Count == 0))">🗑 Clear groups</button>
</div>

@if (!string.IsNullOrEmpty(_saveStatus))
{
    <div class="alert @(_saveError ? "alert-danger" : "alert-success") py-1 px-2 small mb-2">@_saveStatus</div>
}

<div class="row g-3">

    <!-- ══ Left: accumulated groups ════════════════════════════════════════ -->
    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-header fw-semibold small d-flex align-items-center gap-2">
                <span>🧱 Groups</span>
                <span class="badge bg-secondary" style="font-size:10px;">@_groups.Count</span>
                <button class="btn btn-sm btn-primary py-0 px-2 ms-auto"
                        title="Add new group (subsequent selections go here)"
                        @onclick="AddNewGroup">+ New group</button>
            </div>
            <div style="max-height:70vh; overflow:auto;" class="p-2">
                @for (int gi = 0; gi < _groups.Count; gi++)
                {
                    var g       = _groups[gi];
                    var idx     = gi;
                    bool active = idx == _activeGroupIdx;
                    <div @key="g" class="grp-box mb-2 @(active ? "grp-active" : "")"
                         @onclick="() => SetActive(idx)">
                        <div class="grp-head">
                            @if (active)
                            {
                                <span class="grp-active-dot" title="Selections go into this group">●</span>
                            }
                            <input class="grp-name-input"
                                   value="@g.GroupName"
                                   @onchange="e => OnRenameGroup(idx, e.Value?.ToString() ?? string.Empty)"
                                   @onclick:stopPropagation="true"
                                   placeholder="Group name" />
                            <button class="btn btn-sm btn-outline-primary py-0 px-2 ms-auto"
                                    title="Add mid-group"
                                    @onclick="() => AddMidGroup(idx)"
                                    @onclick:stopPropagation="true">+ Mid-group</button>
                            <button class="btn btn-sm btn-outline-danger py-0 px-2"
                                    title="Remove group"
                                    @onclick="() => RemoveGroup(idx)"
                                    @onclick:stopPropagation="true">✕</button>
                        </div>
                        <div class="pg-row" @onclick:stopPropagation="true">
                            <span class="pg-row-label">Product</span>
                            @foreach (string pg in ProductGroups)
                            {
                                <button class="pg-pill pg-@pg @(g.ProductGroup == pg ? "pg-pill-on" : "")"
                                        @onclick="() => OnChangeProductGroup(idx, pg)">@pg</button>
                            }
                        </div>
                        @if (g.MidGroups.Count == 0)
                        {
                            <div class="text-muted small ps-2 py-1">(empty — click a LineShift in the right panel or click "+ Mid-group")</div>
                        }
                        else
                        {
                            <div class="ps-2 pt-1 pb-2">
                                @for (int mi = 0; mi < g.MidGroups.Count; mi++)
                                {
                                    var mid     = g.MidGroups[mi];
                                    var gidx    = idx;
                                    var midx    = mi;
                                    bool midAct = active && midx == _activeMidIdx;
                                    <div @key="mid" class="mid-grp @(midAct ? "mid-active" : "")"
                                         @onclick="() => SetActiveMid(gidx, midx)"
                                         @onclick:stopPropagation="true">
                                        <div class="mid-grp-head">
                                            @if (midAct)
                                            {
                                                <span class="grp-active-dot"
                                                      title="LineShifts go into the active sub-group">●</span>
                                            }
                                            <span class="mid-badge">Mid-group</span>
                                            <input class="mid-name-input"
                                                   value="@mid.Material"
                                                   @onchange="e => OnRenameMid(gidx, midx, e.Value?.ToString() ?? string.Empty)"
                                                   @onclick:stopPropagation="true"
                                                   placeholder="Material" />
                                            <span class="text-muted ms-1" style="font-size:10px;">@mid.TotalLineShifts</span>
                                            <button class="btn btn-sm btn-outline-primary py-0 px-2 ms-auto"
                                                    title="Add sub-group"
                                                    @onclick="() => AddSubGroupAtMidTop(gidx, midx)"
                                                    @onclick:stopPropagation="true">+ Sub</button>
                                            <button class="btn btn-sm btn-outline-danger py-0 px-2"
                                                    title="Remove mid-group"
                                                    @onclick="() => RemoveMidGroupAt(gidx, midx)"
                                                    @onclick:stopPropagation="true">✕</button>
                                        </div>
                                        <div class="sub-list">
                                            @foreach (var sub in mid.SubGroups)
                                            {
                                                bool hideHeader = mid.SubGroups.Count == 1
                                                                  && string.IsNullOrEmpty(sub.Name)
                                                                  && sub.SubGroups.Count == 0;
                                                <SubGroupNode @key="sub"
                                                              Node="@sub"
                                                              Depth="0"
                                                              HideHeader="@hideHeader"
                                                              IsActive="@IsActiveSub"
                                                              OnSelect="SetActiveSubRef"
                                                              OnAddNested="AddSubGroupUnder"
                                                              OnRemove="RemoveSub"
                                                              OnRename="@(tup => RenameSub(tup.Item1, tup.Item2))"
                                                              OnRemoveLineShift="@(tup => RemoveLineShiftFromSub(tup.Item1, tup.Item2))" />
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- ══ Middle: distinct (Maktx, Mtype) with search ════════════════════════ -->
    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-header fw-semibold small">
                📋 BMES Materials — distinct (Maktx, Mtype)
            </div>
            <div class="p-2 border-bottom">
                <input class="form-control form-control-sm"
                       placeholder="Search Maktx / Mtype…"
                       @bind="_search" @bind:event="oninput" />
            </div>
            <div style="max-height:70vh; overflow:auto;">
                @{
                    var filtered = Filtered;
                }
                @if (_rows.Count == 0)
                {
                    <div class="text-center text-muted py-5 small">
                        No data in BmesMaterials table.<br />
                        Please run "Fetch all materials" in BMES Setting first.
                    </div>
                }
                else if (filtered.Count == 0)
                {
                    <div class="text-center text-muted py-4 small">No matches.</div>
                }
                else
                {
                    <table class="mmg-table">
                        <thead>
                            <tr>
                                <th style="width:38px;">#</th>
                                <th>Maktx</th>
                                <th style="width:130px;">Category</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (int i = 0; i < filtered.Count; i++)
                            {
                                var (maktx, mtype) = filtered[i];
                                bool isSel = _selectedMaktx == maktx && _selectedMtype == mtype;
                                <tr class="@(isSel ? "row-selected" : "row-click")"
                                    @onclick="() => OnSelectRow(maktx, mtype)">
                                    <td class="n text-muted">@(i + 1)</td>
                                    <td>@maktx</td>
                                    <td title="@mtype">@ResolveCategory(mtype)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>

    <!-- ══ Right: LineShifts for selected Maktx ═════════════════════════════ -->
    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-header fw-semibold small d-flex align-items-center gap-2">
                <span>🧭 LineShifts</span>
                @if (!string.IsNullOrEmpty(_selectedMaktx))
                {
                    <span class="text-muted" style="font-size:11px;">— @_selectedMaktx</span>
                    <span class="badge bg-secondary ms-auto" style="font-size:10px;">@_lineShifts.Count</span>
                }
            </div>
            <div style="max-height:70vh; overflow:auto;">
                @if (string.IsNullOrEmpty(_selectedMaktx))
                {
                    <div class="text-center text-muted py-4 small">
                        Select a Maktx row in the middle panel.
                    </div>
                }
                else if (_loadingMid)
                {
                    <div class="text-center text-muted py-4 small">
                        <span class="spinner-border spinner-border-sm me-1"></span>Loading…
                    </div>
                }
                else if (_lineShifts.Count == 0)
                {
                    <div class="text-center text-muted py-4 small">
                        No LineShift in DB for this MATERIALNAME.
                    </div>
                }
                else
                {
                    <div class="text-muted small px-2 py-1">Click a row to add it to the active mid-group</div>
                    <table class="mmg-table">
                        <thead>
                            <tr>
                                <th style="width:38px;">#</th>
                                <th>LineShift</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (int i = 0; i < _lineShifts.Count; i++)
                            {
                                var ls = _lineShifts[i];
                                <tr class="row-click" @onclick="() => AddLineShiftToActiveMid(ls)">
                                    <td class="n text-muted">@(i + 1)</td>
                                    <td>@ls</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>

</div>

<style>
