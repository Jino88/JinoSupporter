        text-transform: uppercase; letter-spacing: .4px;
        padding: 6px 10px; border-bottom: 1px solid #e2e8f0;
        text-align: left;
    }
    .mmg-table td {
        padding: 4px 10px; border-bottom: 1px solid #f1f5f9;
        vertical-align: middle; white-space: nowrap;
    }
    .mmg-table td.n { text-align: right; font-variant-numeric: tabular-nums; }
    .row-click { cursor: pointer; }
    .row-click:hover td { background: #f8fafc; }
