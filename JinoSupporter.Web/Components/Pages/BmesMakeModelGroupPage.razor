@code {
    private static readonly string[] ProductGroups = ["SPK", "UNIT", "MODULE", "TWS", "ETC"];

    private sealed class GroupVm
    {
        public string           GroupName    { get; set; } = string.Empty;
        public string           ProductGroup { get; set; } = "ETC";
        public List<MidGroupVm> MidGroups    { get; set; } = new();
    }

    private sealed class MidGroupVm
    {
        public string             Material  { get; set; } = string.Empty;
        public List<SubGroupVm>   SubGroups { get; set; } = new();

        public int TotalLineShifts => SubGroups.Sum(s => s.TotalLineShifts);
    }

    /// <summary>Recursive sub-group VM — a sub-group can contain LineShifts AND further nested sub-groups.</summary>
    public sealed class SubGroupVm
    {
        public string            Name       { get; set; } = string.Empty;
        public List<string>      LineShifts { get; set; } = new();
        public List<SubGroupVm>  SubGroups  { get; set; } = new();

        public int TotalLineShifts => LineShifts.Count + SubGroups.Sum(s => s.TotalLineShifts);
    }

    private List<(string Maktx, string Mtype)> _rows = new();
    private Dictionary<string, string> _mtypeMap = new(StringComparer.OrdinalIgnoreCase);
    private string       _search = string.Empty;
    private string       _selectedMaktx = string.Empty;
    private string       _selectedMtype = string.Empty;
    private List<string> _lineShifts = new();
    private bool         _loadingMid;
    private List<GroupVm> _groups = new() { new GroupVm { GroupName = "Group 1" } };
    private int          _activeGroupIdx;
    private int          _activeMidIdx = -1;
    private SubGroupVm?  _activeSub    = null;   // direct reference to the active sub-group (any depth)

    private string ResolveCategory(string mtype)
    {
        if (string.IsNullOrEmpty(mtype)) return "";
        return _mtypeMap.TryGetValue(mtype, out string? n) && !string.IsNullOrEmpty(n)
            ? n : mtype;
    }
    private bool         _saving;
    private string       _saveStatus = string.Empty;
    private bool         _saveError;

    private List<(string Maktx, string Mtype)> Filtered
    {
        get
        {
            if (string.IsNullOrWhiteSpace(_search)) return _rows;
            // AND of whitespace-separated tokens — each token must appear (case-insensitive)
            // in Maktx, Mtype, or the resolved category name. Order-independent.
            var tokens = _search.Split(
                (char[]?)null, StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
            if (tokens.Length == 0) return _rows;
            return _rows.Where(r =>
            {
                string hay = $"{r.Maktx}{r.Mtype}{ResolveCategory(r.Mtype)}";
                foreach (string t in tokens)
                    if (hay.IndexOf(t, StringComparison.OrdinalIgnoreCase) < 0) return false;
                return true;
            }).ToList();
        }
    }

    protected override void OnInitialized()
    {
        Reload();
        LoadGroupsFromDb();
    }

    private void Reload()
    {
        _rows     = Repo.GetBmesMaktxMtypeDistinct();
        _mtypeMap = Repo.GetMtypeCategoryMap();
    }

    private void LoadGroupsFromDb()
    {
        var saved = Repo.GetModelGroups();
        if (saved.Count > 0)
        {
            _groups = saved.Select(s => new GroupVm
            {
                GroupName    = s.Name,
                ProductGroup = ProductGroups.Contains(s.ProductGroup) ? s.ProductGroup : "ETC",
                MidGroups    = s.MidGroups.Select(m => new MidGroupVm
                {
                    Material  = m.Material,
                    SubGroups = m.SubGroups.Count > 0
                        ? m.SubGroups.Select(SubRecordToVm).ToList()
                        : new List<SubGroupVm> { new SubGroupVm() },
                }).ToList(),
            }).ToList();
            _activeGroupIdx = 0;
        }
    }

    private static SubGroupVm SubRecordToVm(SubGroupRecord s) => new SubGroupVm
    {
        Name       = s.Name ?? string.Empty,
        LineShifts = s.LineShifts.ToList(),
        SubGroups  = s.SubGroups.Select(SubRecordToVm).ToList(),
    };

    private static SubGroupRecord SubVmToRecord(SubGroupVm s) => new SubGroupRecord
    {
        Name       = s.Name ?? string.Empty,
        LineShifts = s.LineShifts.ToList(),
        SubGroups  = s.SubGroups.Select(SubVmToRecord).ToList(),
    };

    private void OnRenameGroup(int idx, string newName)
    {
        if (idx < 0 || idx >= _groups.Count) return;
        _groups[idx].GroupName = newName;
    }

    private void OnChangeProductGroup(int idx, string pg)
    {
        if (idx < 0 || idx >= _groups.Count) return;
        _groups[idx].ProductGroup = ProductGroups.Contains(pg) ? pg : "ETC";
    }

    private async Task SaveAsync()
    {
        if (_saving) return;
        _saving     = true;
        _saveStatus = string.Empty;
        _saveError  = false;
        StateHasChanged();

        try
        {
            var records = _groups.Select((g, i) => new ModelGroupRecord
            {
                Name         = g.GroupName,
                ProductGroup = ProductGroups.Contains(g.ProductGroup) ? g.ProductGroup : "ETC",
                SortOrder    = i,
                MidGroups    = g.MidGroups.Select(m => new MidGroupRecord
                {
                    Material  = m.Material,
                    SubGroups = m.SubGroups.Select(SubVmToRecord).ToList(),
                }).ToList(),
            }).ToList();

            await Task.Run(() => Repo.SaveModelGroups(records));
            int totalLs = records.Sum(r => r.MidGroups.Sum(m => m.LineShifts.Count));
            int midCount = records.Sum(r => r.MidGroups.Count);
            int subCount = records.Sum(r => r.MidGroups.Sum(m => CountSubs(m.SubGroups)));
            _saveStatus = $"✓ Saved {records.Count} group(s), {midCount} mid-group(s), {subCount} sub-group(s), {totalLs} line-shift(s).";
        }
        catch (Exception ex)
        {
            _saveError  = true;
            _saveStatus = $"Save failed: {ex.Message}";
        }
        finally
        {
            _saving = false;
            StateHasChanged();
        }
    }

    private async Task OnSelectRow(string maktx, string mtype)
    {
        _selectedMaktx = maktx;
        _selectedMtype = mtype;
        _loadingMid    = true;
        _lineShifts    = new();
        StateHasChanged();

        try
        {
            _lineShifts = await Task.Run(() =>
                NgRateSettings.GetLineShiftsByMaterialName(maktx));
        }
        finally
        {
            _loadingMid = false;
        }
    }

    private void RemoveMidGroup(int groupIdx, string material)
    {
        if (groupIdx < 0 || groupIdx >= _groups.Count) return;
        _groups[groupIdx].MidGroups.RemoveAll(m => m.Material == material);
        if (_activeMidIdx >= _groups[groupIdx].MidGroups.Count) _activeMidIdx = -1;
    }

    private void RemoveMidGroupAt(int groupIdx, int midIdx)
    {
        if (groupIdx < 0 || groupIdx >= _groups.Count) return;
        var grp = _groups[groupIdx];
        if (midIdx < 0 || midIdx >= grp.MidGroups.Count) return;
        grp.MidGroups.RemoveAt(midIdx);
        if (_activeGroupIdx == groupIdx && _activeMidIdx >= grp.MidGroups.Count)
            _activeMidIdx = grp.MidGroups.Count - 1;
    }

    private void AddMidGroup(int groupIdx)
    {
        if (groupIdx < 0 || groupIdx >= _groups.Count) return;
        var newMid = new MidGroupVm { Material = "" };
        var defaultSub = new SubGroupVm();
        newMid.SubGroups.Add(defaultSub);
        _groups[groupIdx].MidGroups.Add(newMid);
        _activeGroupIdx = groupIdx;
        _activeMidIdx   = _groups[groupIdx].MidGroups.Count - 1;
        _activeSub      = defaultSub;
    }

    private void OnRenameMid(int groupIdx, int midIdx, string newName)
    {
        if (groupIdx < 0 || groupIdx >= _groups.Count) return;
        var grp = _groups[groupIdx];
        if (midIdx < 0 || midIdx >= grp.MidGroups.Count) return;
        grp.MidGroups[midIdx].Material = newName;
    }

    private void SetActiveMid(int groupIdx, int midIdx)
    {
        SetActive(groupIdx);
        if (_activeMidIdx != midIdx) _activeSub = null;
        _activeMidIdx = midIdx;
    }

    /// <summary>Add a new sub-group as a child of <paramref name="parent"/>.
    /// If parent is null, adds to the currently-active mid-group's top level.</summary>
    private void AddSubGroupUnder(SubGroupVm? parent)
    {
        var list = parent is null
            ? ResolveActiveMid()?.SubGroups
            : parent.SubGroups;
        if (list is null) return;
        var newSub = new SubGroupVm { Name = $"Sub {list.Count + 1}" };
        list.Add(newSub);
        _activeSub = newSub;
    }

    private void AddSubGroupAtMidTop(int groupIdx, int midIdx)
    {
        if (groupIdx < 0 || groupIdx >= _groups.Count) return;
        var grp = _groups[groupIdx];
        if (midIdx < 0 || midIdx >= grp.MidGroups.Count) return;
        var mid = grp.MidGroups[midIdx];
        var newSub = new SubGroupVm { Name = $"Sub {mid.SubGroups.Count + 1}" };
        mid.SubGroups.Add(newSub);
        _activeGroupIdx = groupIdx;
        _activeMidIdx   = midIdx;
        _activeSub      = newSub;
    }

    private void RenameSub(SubGroupVm sub, string newName)
    {
        sub.Name = newName;
    }

    /// <summary>Remove <paramref name="target"/> from whatever parent list contains it.</summary>
    private void RemoveSub(SubGroupVm target)
    {
        foreach (var grp in _groups)
            foreach (var mid in grp.MidGroups)
            {
                if (mid.SubGroups.Remove(target))
                {
                    if (mid.SubGroups.Count == 0) mid.SubGroups.Add(new SubGroupVm());
                    if (ReferenceEquals(_activeSub, target)) _activeSub = null;
                    return;
                }
                if (RemoveSubFromTree(mid.SubGroups, target))
                {
                    if (ReferenceEquals(_activeSub, target)) _activeSub = null;
                    return;
                }
            }
    }

    private static bool RemoveSubFromTree(List<SubGroupVm> list, SubGroupVm target)
    {
        for (int i = 0; i < list.Count; i++)
        {
            if (list[i].SubGroups.Remove(target)) return true;
            if (RemoveSubFromTree(list[i].SubGroups, target)) return true;
        }
        return false;
    }

    private void SetActiveSubRef(SubGroupVm sub)
    {
        _activeSub = sub;
    }

    public bool IsActiveSub(SubGroupVm s) => ReferenceEquals(_activeSub, s);

    private MidGroupVm? ResolveActiveMid()
    {
        if (_activeGroupIdx < 0 || _activeGroupIdx >= _groups.Count) return null;
        var grp = _groups[_activeGroupIdx];
        if (_activeMidIdx < 0 || _activeMidIdx >= grp.MidGroups.Count) return null;
        return grp.MidGroups[_activeMidIdx];
    }

    private void AddLineShiftToActiveMid(string lineShift)
    {
        if (string.IsNullOrEmpty(lineShift)) return;
        if (_groups.Count == 0)
        {
            _groups.Add(new GroupVm { GroupName = "Group 1" });
            _activeGroupIdx = 0;
        }
        if (_activeGroupIdx < 0 || _activeGroupIdx >= _groups.Count)
            _activeGroupIdx = _groups.Count - 1;

        var grp = _groups[_activeGroupIdx];
        if (_activeMidIdx < 0 || _activeMidIdx >= grp.MidGroups.Count)
        {
            var newMid = new MidGroupVm
            {
                Material = !string.IsNullOrEmpty(_selectedMaktx) ? _selectedMaktx : "",
            };
            var defaultSub = new SubGroupVm();
            newMid.SubGroups.Add(defaultSub);
            grp.MidGroups.Add(newMid);
            _activeMidIdx = grp.MidGroups.Count - 1;
            _activeSub    = defaultSub;
        }

        var mid = grp.MidGroups[_activeMidIdx];
        if (mid.SubGroups.Count == 0) mid.SubGroups.Add(new SubGroupVm());

        // If active sub is set and still in this mid's tree, use it; otherwise fall back to first top-level sub.
        if (_activeSub is null || !SubBelongsToMid(_activeSub, mid))
            _activeSub = mid.SubGroups[0];

        if (!_activeSub.LineShifts.Contains(lineShift, StringComparer.Ordinal))
            _activeSub.LineShifts.Add(lineShift);
    }

    private static bool SubBelongsToMid(SubGroupVm target, MidGroupVm mid)
    {
        foreach (var s in mid.SubGroups)
            if (SubContains(s, target)) return true;
        return false;
    }

    private static bool SubContains(SubGroupVm parent, SubGroupVm target)
    {
        if (ReferenceEquals(parent, target)) return true;
        foreach (var c in parent.SubGroups)
            if (SubContains(c, target)) return true;
        return false;
    }

    private void RemoveLineShiftFromSub(SubGroupVm sub, string lineShift)
    {
        sub.LineShifts.Remove(lineShift);
    }

    private static int CountSubs(IEnumerable<SubGroupRecord> list)
    {
        int n = 0;
        foreach (var s in list) n += 1 + CountSubs(s.SubGroups);
        return n;
    }

    private void AddNewGroup()
    {
        _groups.Add(new GroupVm { GroupName = $"Group {_groups.Count + 1}" });
        _activeGroupIdx = _groups.Count - 1;
    }

    private void SetActive(int idx)
    {
        if (idx < 0 || idx >= _groups.Count) return;
        if (_activeGroupIdx != idx) { _activeMidIdx = -1; _activeSub = null; }
        _activeGroupIdx = idx;
    }

    private void RemoveGroup(int idx)
    {
        if (idx < 0 || idx >= _groups.Count) return;
        _groups.RemoveAt(idx);
        if (_groups.Count == 0)
        {
            _groups.Add(new GroupVm { GroupName = "Group 1" });
            _activeGroupIdx = 0;
        }
        else if (_activeGroupIdx >= _groups.Count)
        {
            _activeGroupIdx = _groups.Count - 1;
        }
    }

    private void ClearGroups()
    {
        _groups = new() { new GroupVm { GroupName = "Group 1" } };
        _activeGroupIdx = 0;
    }
}
