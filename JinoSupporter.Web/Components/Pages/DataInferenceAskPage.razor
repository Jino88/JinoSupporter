@code {
    private List<RawReportInfo>        _reports           = [];
    private string                     _productTypeFilter = "";
    private string                     _question          = "";
    private string                     _answerLanguage    = "English";
    private ClaudeService.AskAiResult? _answer            = null;
    private bool                       _isBusy;
    private string                     _status            = "";
    private bool                       _statusError;

    private bool                       _showHistory       = false;
    private List<AskAiHistoryRecord>   _history           = [];
    private long?                      _activeHistoryId   = null;
    private bool                       _showClearConfirm  = false;

    // CLI flow
    private bool                       _isWaitingCli;
    private System.Threading.CancellationTokenSource? _cliCts;

    private List<string> _productTypeOptions => _reports
        .Select(r => r.ProductType)
        .Where(p => !string.IsNullOrWhiteSpace(p))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(p => p, StringComparer.OrdinalIgnoreCase)
        .ToList();

    private List<RawReportInfo> FilteredReports => string.IsNullOrEmpty(_productTypeFilter)
        ? _reports
        : _reports.Where(r => string.Equals(r.ProductType, _productTypeFilter, StringComparison.OrdinalIgnoreCase)).ToList();

    protected override void OnInitialized()
    {
        _reports = Repo.GetAllRawReports();
        _history = Repo.GetAskAiHistory();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) await JS.InvokeVoidAsync("diFullPage.enter");
    }

    private static string DetailUrl(string datasetName)
        => $"/data-inference/detail?name={Uri.EscapeDataString(datasetName)}";

    private void ToggleHistory() => _showHistory = !_showHistory;

    private async Task AskAsync()
    {
        if (string.IsNullOrWhiteSpace(_question))
        {
            SetStatus("Please enter a question.", true);
            return;
        }

        _isBusy = true;
        _status = "";
        _answer = null;
        _activeHistoryId = null;
        StateHasChanged();

        try
        {
            string context = await Task.Run(BuildDatasetsContext);
            if (string.IsNullOrWhiteSpace(context))
            {
                SetStatus("No AI analysis reports match the selected filter.", true);
                return;
            }

            _answer = await Claude.AskAiAsync(_question.Trim(), context, _answerLanguage);

            // Persist to DB
            string perDsJson = System.Text.Json.JsonSerializer.Serialize(_answer.PerDataset);
            long id = Repo.SaveAskAiHistory(
                _question.Trim(), _productTypeFilter, _answer.Overall, perDsJson);
            _activeHistoryId = id;
            _history = Repo.GetAskAiHistory();

            SetStatus($"Answer generated — {_answer.PerDataset.Count} per-dataset answer(s)", false);
        }
        catch (Exception ex)
        {
            SetStatus($"Error: {ex.Message}", true);
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task LaunchCliAskAsync()
    {
        if (string.IsNullOrWhiteSpace(_question))
        {
            SetStatus("Please enter a question.", true);
            return;
        }

        string workDir = FindRepoRoot();
        string tmpDir  = Path.Combine(workDir, "tmp");
        Directory.CreateDirectory(tmpDir);

        string pendingQuestion  = _question.Trim();
        DateTime pendingStarted = DateTime.UtcNow;

        var req = new
        {
            question          = pendingQuestion,
            language          = _answerLanguage,
            productTypeFilter = _productTypeFilter ?? "",
            createdAt         = pendingStarted.ToString("O"),
        };
        try
        {
            File.WriteAllText(Path.Combine(tmpDir, "ask_request.json"),
                System.Text.Json.JsonSerializer.Serialize(req,
                    new System.Text.Json.JsonSerializerOptions { WriteIndented = true }));
        }
        catch (Exception ex)
        {
            SetStatus($"Failed to write ask_request.json: {ex.Message}", true);
            return;
        }

        // Launch Windows Terminal (falls back to cmd).
        bool launched = false;
        string prompt = "CLI_ASK_AI.md 읽고 실행해";
        try
        {
            var wt = new System.Diagnostics.ProcessStartInfo
            {
                FileName         = "wt.exe",
                Arguments        = $"-d \"{workDir}\" cmd /k chcp 65001>nul && title Ask AI (Claude CLI) && claude \"{prompt}\"",
                UseShellExecute  = true,
                CreateNoWindow   = false,
            };
            System.Diagnostics.Process.Start(wt);
            launched = true;
        }
        catch { }
        if (!launched)
        {
            try
            {
                var psi = new System.Diagnostics.ProcessStartInfo
                {
                    FileName         = "cmd.exe",
                    Arguments        = $"/k chcp 65001>nul && title Ask AI (Claude CLI) && claude \"{prompt}\"",
                    WorkingDirectory = workDir,
                    UseShellExecute  = true,
                    CreateNoWindow   = false,
                };
                System.Diagnostics.Process.Start(psi);
                launched = true;
            }
            catch (Exception ex)
            {
                SetStatus($"Failed to launch Claude CLI: {ex.Message}", true);
                return;
            }
        }

        _isBusy        = true;
        _isWaitingCli  = true;
        _answer        = null;
        SetStatus("Claude CLI launched — waiting for answer to land in AskAiHistory…", false);
        StateHasChanged();

        _cliCts?.Cancel(); _cliCts?.Dispose();
        _cliCts = new System.Threading.CancellationTokenSource(TimeSpan.FromMinutes(10));
        var token = _cliCts.Token;

        try
        {
            while (!token.IsCancellationRequested)
            {
                await Task.Delay(TimeSpan.FromSeconds(2), token);

                // Look for a newly-committed AskAiHistory row with the same question
                // created after we launched the CLI.
                var recent = await Task.Run(() => Repo.GetAskAiHistory(limit: 30));
                AskAiHistoryRecord? hit = null;
                foreach (var h in recent)
                {
                    if (!string.Equals(h.Question?.Trim(), pendingQuestion, StringComparison.Ordinal)) continue;
                    if (!DateTime.TryParse(h.CreatedAt, null, System.Globalization.DateTimeStyles.RoundtripKind, out DateTime dt)) continue;
                    if (dt >= pendingStarted) { hit = h; break; }
                }
                if (hit is not null)
                {
                    _history = recent;
                    LoadHistory(hit.Id);
                    SetStatus($"CLI answer received — {_answer?.PerDataset.Count ?? 0} per-dataset answer(s)", false);
                    break;
                }
            }
            if (token.IsCancellationRequested && _answer is null)
            {
                SetStatus("Wait cancelled or timed out (10min). Open History to load the answer manually when CLI finishes.", true);
            }
        }
        catch (OperationCanceledException)
        {
            if (_answer is null)
                SetStatus("Wait cancelled. Open History to load the answer manually when CLI finishes.", true);
        }
        catch (Exception ex)
        {
            SetStatus($"Polling error: {ex.Message}", true);
        }
        finally
        {
            _cliCts?.Dispose();
            _cliCts       = null;
            _isWaitingCli = false;
            _isBusy       = false;
            StateHasChanged();
        }
    }

    private void CancelCliWait()
    {
        try { _cliCts?.Cancel(); } catch { }
    }

    private static string FindRepoRoot()
    {
        string dir = AppContext.BaseDirectory;
        for (int i = 0; i < 8; i++)
        {
            if (File.Exists(Path.Combine(dir, "CLI_ASK_AI.md"))) return dir;
            string? parent = Path.GetDirectoryName(dir.TrimEnd('\\', '/'));
            if (string.IsNullOrEmpty(parent) || parent == dir) break;
            dir = parent;
        }
        return AppContext.BaseDirectory;
    }

    private void LoadHistory(long id)
    {
        AskAiHistoryRecord? h = Repo.GetAskAiHistoryById(id);
        if (h is null) return;
        _question          = h.Question;
        _productTypeFilter = h.ProductTypeFilter;
        _activeHistoryId   = h.Id;

        List<ClaudeService.AskAiPerDataset> per = [];
        try
        {
            per = System.Text.Json.JsonSerializer.Deserialize<List<ClaudeService.AskAiPerDataset>>(
                h.PerDatasetJson,
                new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true }) ?? [];
        }
        catch { }

        _answer = new ClaudeService.AskAiResult
        {
            Overall    = h.Overall,
            PerDataset = per
        };
        SetStatus($"History loaded — {FormatDate(h.CreatedAt)}", false);
    }

    private void DeleteHistory(long id)
    {
        Repo.DeleteAskAiHistory(id);
        _history = Repo.GetAskAiHistory();
        if (_activeHistoryId == id)
        {
            _activeHistoryId = null;
            _answer = null;
        }
    }

    private void ConfirmClearHistory() => _showClearConfirm = true;

    private void ClearAllHistory()
    {
        Repo.DeleteAllAskAiHistory();
        _history = [];
        _activeHistoryId = null;
        _answer = null;
        _showClearConfirm = false;
    }

    private string BuildDatasetsContext()
    {
        var sb = new System.Text.StringBuilder();
        int idx = 1;
        foreach (RawReportInfo r in FilteredReports)
        {
            DatasetSummaryRecord? summ = Repo.GetDatasetSummaryRecord(r.DatasetName);
            string summary     = summ?.Summary     ?? "";
            string keyFindings = summ?.KeyFindings ?? "";
            List<string> tags  = summ?.Tags        ?? [];

            if (string.IsNullOrWhiteSpace(summary)
                && string.IsNullOrWhiteSpace(keyFindings)
                && tags.Count == 0
                && r.MeasurementCount == 0)
            {
                continue;
            }

            List<NormalizedMeasurement> meas = Repo.GetNormalizedMeasurements(r.DatasetName);
            string defectsStat = BuildDefectStats(meas);

            string purpose           = summ?.Purpose           ?? "";
            string testConditions    = summ?.TestConditions    ?? "";
            string rootCause         = summ?.RootCause         ?? "";
            string decision          = summ?.Decision          ?? "";
            string recommendedAction = summ?.RecommendedAction ?? "";
            string normalVsTest      = BuildNormalVsTestStats(meas);

            sb.Append("───── [").Append(idx++).Append("] Dataset: ").AppendLine(r.DatasetName);
            if (!string.IsNullOrWhiteSpace(r.ProductType)) sb.Append("    ProductType: ").AppendLine(r.ProductType);
            if (!string.IsNullOrWhiteSpace(r.ReportDate))  sb.Append("    Date: ").AppendLine(r.ReportDate);
            if (tags.Count > 0) sb.Append("    Tags: ").AppendLine(string.Join(", ", tags));
            if (!string.IsNullOrWhiteSpace(purpose))           sb.Append("    Purpose: ").AppendLine(purpose);
            if (!string.IsNullOrWhiteSpace(testConditions))    sb.Append("    TestConditions: ").AppendLine(testConditions);
            if (!string.IsNullOrWhiteSpace(rootCause))         sb.Append("    RootCause: ").AppendLine(rootCause);
            if (!string.IsNullOrWhiteSpace(decision))          sb.Append("    Decision: ").AppendLine(decision);
            if (!string.IsNullOrWhiteSpace(recommendedAction)) sb.Append("    RecommendedAction: ").AppendLine(recommendedAction);
            if (!string.IsNullOrWhiteSpace(summary))     sb.Append("    Summary: ").AppendLine(summary);
            if (!string.IsNullOrWhiteSpace(keyFindings)) sb.Append("    KeyFindings: ").AppendLine(keyFindings);
            if (!string.IsNullOrWhiteSpace(defectsStat)) sb.Append("    TopDefects: ").AppendLine(defectsStat);
            if (!string.IsNullOrWhiteSpace(normalVsTest)) sb.Append("    NormalVsTest: ").AppendLine(normalVsTest);
            sb.AppendLine();
        }
        return sb.ToString();
    }

    private static string BuildDefectStats(List<NormalizedMeasurement> meas)
    {
        if (meas.Count == 0) return "";
        var topDefects = meas
            .Where(m => !string.IsNullOrWhiteSpace(m.DefectType) && m.DefectCount > 0)
            .GroupBy(m => m.DefectType)
            .Select(g => new { Type = g.Key, Count = g.Sum(x => x.DefectCount) })
            .OrderByDescending(x => x.Count)
            .Take(5)
            .ToList();
        double maxNg = meas.Max(m => m.NgRate);
        string defects = topDefects.Count > 0
            ? string.Join(", ", topDefects.Select(d => $"{d.Type}({d.Count})"))
            : "none";
        return $"maxNgRate={maxNg:F1}%, topDefects=[{defects}]";
    }

    /// <summary>
    /// Computes Normal-vs-Test comparison stats + best/worst condition.
    /// Ignored when the dataset doesn't use normal/test variableGroup semantics.
    /// </summary>
    private static string BuildNormalVsTestStats(List<NormalizedMeasurement> meas)
    {
        if (meas.Count == 0) return "";

        // Weighted average NG rate per variableGroup (input-weighted)
        double AvgNg(string grp)
        {
            var rows = meas
                .Where(m => string.Equals(m.VariableGroup, grp, StringComparison.OrdinalIgnoreCase)
                            && string.IsNullOrWhiteSpace(m.DefectType))  // aggregate rows only
                .ToList();
            if (rows.Count == 0) return double.NaN;
            long totInput = rows.Sum(m => (long)m.InputQty);
            long totNg    = rows.Sum(m => (long)m.NgTotal);
            return totInput > 0 ? (totNg * 100.0 / totInput) : double.NaN;
        }

        double normal = AvgNg("normal");
        double test   = AvgNg("test");
        var parts = new List<string>();

        if (!double.IsNaN(normal)) parts.Add($"normal={normal:F1}%");
        if (!double.IsNaN(test))   parts.Add($"test={test:F1}%");
        if (!double.IsNaN(normal) && !double.IsNaN(test) && normal > 0)
        {
            double improvement = (normal - test) / normal * 100.0;
            parts.Add($"improvement={improvement:F0}%");
        }

        // Best / Worst test conditions by NG rate
        var testAggs = meas
            .Where(m => string.Equals(m.VariableGroup, "test", StringComparison.OrdinalIgnoreCase)
                        && string.IsNullOrWhiteSpace(m.DefectType))
            .GroupBy(m => (m.Variable, m.VariableDetail))
            .Select(g => new
            {
                g.Key.Variable,
                NgRate = g.Average(x => x.NgRate),
            })
            .OrderBy(x => x.NgRate)
            .ToList();

        if (testAggs.Count >= 2)
        {
            var best  = testAggs.First();
            var worst = testAggs.Last();
            parts.Add($"best={best.Variable}({best.NgRate:F1}%)");
            parts.Add($"worst={worst.Variable}({worst.NgRate:F1}%)");
        }

        return parts.Count == 0 ? "" : string.Join(", ", parts);
    }

    private void Clear()
    {
        _question = "";
        _answer   = null;
        _status   = "";
        _activeHistoryId = null;
    }

    private void SetStatus(string msg, bool err) { _status = msg; _statusError = err; }

    private static string Truncate(string s, int len)
        => (s?.Length ?? 0) <= len ? (s ?? "") : s![..len] + "…";

    private static string FormatDate(string iso)
    {
        if (DateTime.TryParse(iso, null, System.Globalization.DateTimeStyles.RoundtripKind, out DateTime dt))
            return dt.ToLocalTime().ToString("yyyy-MM-dd HH:mm");
        return iso;
    }

    public async ValueTask DisposeAsync()
    {
        try { _cliCts?.Cancel(); _cliCts?.Dispose(); } catch { }
        try { await JS.InvokeVoidAsync("diFullPage.leave"); } catch { }
    }
}
