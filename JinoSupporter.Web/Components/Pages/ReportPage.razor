@page "/report"
@rendermode InteractiveServer
@using System.Linq
@inject WebRepository Repo
@inject ClaudeService  Claude

<PageTitle>Report</PageTitle>

<h4 class="mb-3 fw-semibold">Report</h4>

<div class="row g-3">

    <!-- ── Left: filters + dataset list ───────────────────────────────────── -->
    <div class="col-xl-3 col-lg-4 col-md-4">

        <!-- Tag Filter -->
        <div class="card shadow-sm mb-3">
            <div class="card-header small fw-semibold d-flex justify-content-between align-items-center">
                Tag Filter
                @if (_filterTags.Count > 0)
                {
                    <button class="btn btn-link btn-sm p-0 text-secondary text-decoration-none"
                            @onclick="ClearTagFilter">Clear</button>
                }
            </div>
            <div class="card-body py-2" style="max-height:220px; overflow-y:auto;">
                @if (_allTags.Count == 0)
                {
                    <span class="text-muted small">No tags found.</span>
                }
                @foreach (string tag in _allTags)
                {
                    bool active = _filterTags.Contains(tag);
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="tag_@tag"
                               checked="@active"
                               @onchange="e => ToggleFilterTag(tag, (bool)(e.Value ?? false))" />
                        <label class="form-check-label small" for="tag_@tag">@tag</label>
                    </div>
                }
            </div>
        </div>

        <!-- Dataset list (multi-select checkboxes) -->
        <div class="card shadow-sm">
            <div class="card-header small fw-semibold d-flex justify-content-between align-items-center">
                <span>Datasets (@_datasets.Count)</span>
                @if (_selected.Count > 0)
                {
                    <button class="btn btn-link btn-sm p-0 text-secondary text-decoration-none"
                            @onclick="ClearSelection">Clear (@_selected.Count)</button>
                }
            </div>
            <div class="list-group list-group-flush" style="max-height:500px; overflow-y:auto;">
                @if (_datasets.Count == 0)
                {
                    <div class="list-group-item text-muted small">No datasets found.</div>
                }
                @foreach (RawReportInfo r in _datasets)
                {
                    string ds          = r.DatasetName;
                    bool   isSelected  = _selected.Contains(ds);
                    bool   isActive    = _activeDataset == ds;
                    <div class="list-group-item small py-2 d-flex align-items-start gap-2"
                         style="cursor:pointer; @(isSelected ? "background:#eff6ff;" : "") border-left:3px solid @(isActive ? "#2563eb" : "transparent");"
                         @onclick="() => ToggleDataset(ds)">
                        <input class="form-check-input mt-0 flex-shrink-0" type="checkbox"
                               checked="@isSelected"
                               @onclick:stopPropagation="true"
                               @onchange="e => ToggleDataset(ds)" />
                        <div style="flex:1; min-width:0;">
                            <div style="color:@(isActive ? "#1d4ed8" : isSelected ? "#2563eb" : "#334155"); font-weight:@(isSelected ? "600" : "500"); overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                                @ds
                            </div>
                            <div class="text-muted" style="font-size:10.5px;">
                                @r.ProductType · @r.ReportDate
                                <span class="ms-1">· 🖼 @r.ImageCount</span>
                                <span class="ms-1">· ∑ @r.MeasurementCount</span>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- ── Right: viewer ───────────────────────────────────────────────────── -->
    <div class="col-xl-9 col-lg-8 col-md-8">

        @if (_selected.Count == 0)
        {
            <div class="text-muted small mt-2">Select one or more datasets from the left.</div>
        }
        else
        {
            <!-- Top action bar -->
            <div class="d-flex align-items-center gap-2 mb-2 flex-wrap">
                <span class="small text-muted">@_selected.Count dataset(s) selected</span>
                <div class="ms-auto d-flex gap-2">
                    @if (CanAiReport)
                    {
                        <button class="btn btn-sm btn-outline-primary"
                                @onclick="GenerateAiReportAsync"
                                disabled="@(_isGenerating || !Claude.IsConfigured)">
                            @if (_isGenerating)
                            { <span class="spinner-border spinner-border-sm me-1" /> }
                            Generate AI Report (@_selected.Count)
                        </button>
                    }
                    @if (!string.IsNullOrEmpty(_reportHtml))
                    {
                        <button class="btn btn-sm btn-success" @onclick="SaveAiReportAsync">Save Report</button>
                        <button class="btn btn-sm btn-outline-secondary"
                                @onclick="() => _showReport = !_showReport">
                            @(_showReport ? "Hide Report" : "Show Report")
                        </button>
                    }
                </div>
            </div>

            @if (!string.IsNullOrEmpty(_reportStatusMessage))
            {
                <div class="alert @(_reportStatusError ? "alert-danger" : "alert-success") py-2 small mb-2">
                    @_reportStatusMessage
                </div>
            }

            <!-- AI Report panel -->
            @if (_showReport && !string.IsNullOrEmpty(_reportHtml))
            {
                <div class="card shadow-sm mb-3">
                    <div class="card-header small fw-semibold d-flex justify-content-between">
                        AI Generated Report
                        <button class="btn btn-link btn-sm p-0" @onclick="() => _showReport = false">Close</button>
                    </div>
                    <div class="card-body p-0" style="max-height:60vh; overflow:auto;">
                        <iframe srcdoc="@_reportHtml" style="width:100%; height:55vh; border:none;" />
                    </div>
                </div>
            }

            <!-- Dataset tabs -->
            @if (_selected.Count > 1)
            {
                <ul class="nav nav-tabs mb-0 small" style="border-bottom:none;">
                    @foreach (string ds in _selected)
                    {
                        <li class="nav-item">
                            <button class="nav-link @(_activeDataset == ds ? "active" : "")"
                                    style="max-width:200px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;"
                                    title="@ds"
                                    @onclick="() => _activeDataset = ds">
                                @(ds.Length > 28 ? ds[..25] + "…" : ds)
                            </button>
                        </li>
                    }
                </ul>
            }

            <!-- Active dataset content -->
            @if (_activeDataset is not null && _views.TryGetValue(_activeDataset, out DatasetView? view))
            {
                <div class="card shadow-sm" style="border-radius: @(_selected.Count > 1 ? "0 8px 8px 8px" : "12px");">
                    <!-- Dataset header -->
                    <div class="card-header d-flex align-items-center gap-2 flex-wrap py-2">
                        <span class="fw-semibold small">@_activeDataset</span>
                        <span class="text-muted small">· @view.ProductType · @view.TestDate</span>
                        @foreach (string t in view.Tags)
                        {
                            <span class="badge text-bg-secondary">@t</span>
                        }
                    </div>

                    <div class="card-body p-0">
                        <!-- Summary + KeyFindings -->
                        @if (!string.IsNullOrEmpty(view.Summary) || !string.IsNullOrEmpty(view.KeyFindings))
                        {
                            <div style="padding:10px 14px; background:#f0f9ff; border-bottom:1px solid #bae6fd;">
                                @if (!string.IsNullOrEmpty(view.Summary))
                                {
                                    <div style="font-size:12.5px; color:#0c4a6e;">
                                        <strong>Summary:</strong> @view.Summary
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(view.KeyFindings))
                                {
                                    <div style="font-size:11.5px; color:#475569; white-space:pre-wrap; margin-top:4px;">
                                        @view.KeyFindings
                                    </div>
                                }
                            </div>
                        }

                        <!-- Measurements -->
                        @if (view.Measurements.Count == 0)
                        {
                            <div class="text-muted small p-3">No normalized measurements for this dataset.</div>
                        }
                        else
                        {
                            <div style="padding:6px 14px; background:#f8fafc; font-size:11px; font-weight:700;
                                        color:#475569; text-transform:uppercase; letter-spacing:.5px;
                                        border-bottom:1px solid #e2e8f0;">
                                Normalized Measurements
                                <span style="font-size:10px; font-weight:500; background:#e2e8f0; color:#64748b;
                                             padding:1px 7px; border-radius:10px; margin-left:6px;">@view.Measurements.Count rows</span>
                            </div>
                            <div style="overflow-x:auto;">
                                <table style="width:100%; min-width:max-content; border-collapse:collapse;">
                                    <thead>
                                        <tr style="background:#f8fafc; position:sticky; top:0; z-index:1; box-shadow:0 1px 0 #e2e8f0;">
                                            @foreach (string col in MeasurementColumns)
                                            {
                                                <th style="padding:8px 12px; text-align:left; font-size:10.5px;
                                                           font-weight:700; color:#64748b; text-transform:uppercase;
                                                           letter-spacing:.4px; white-space:nowrap;">@col</th>
                                            }
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @{ int rowIdx = 0; }
                                        @foreach (NormalizedMeasurement m in view.Measurements)
                                        {
                                            string bg = rowIdx++ % 2 == 0 ? "#ffffff" : "#f8fafc";
                                            <tr style="background:@bg;">
                                                <td style="padding:6px 12px; font-size:12px;">@m.Variable</td>
                                                <td style="padding:6px 12px; font-size:12px;">@m.VariableDetail</td>
                                                <td style="padding:6px 12px; font-size:12px;">@m.VariableGroup</td>
                                                <td style="padding:6px 12px; font-size:12px;">@m.Line</td>
                                                <td style="padding:6px 12px; font-size:12px;">@m.CheckType</td>
                                                <td style="padding:6px 12px; font-size:12px; text-align:right;">@m.InputQty</td>
                                                <td style="padding:6px 12px; font-size:12px; text-align:right;">@m.NgTotal</td>
                                                <td style="padding:6px 12px; font-size:12px; text-align:right;">@m.NgRate.ToString("F1")%</td>
                                                <td style="padding:6px 12px; font-size:12px;">@m.DefectType</td>
                                                <td style="padding:6px 12px; font-size:12px;">@m.DefectCategory</td>
                                                <td style="padding:6px 12px; font-size:12px; text-align:right;">@m.DefectCount</td>
                                                <td style="padding:6px 12px; font-size:12px;">@m.Intervention</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }

                        <!-- Images -->
                        @if (view.Images.Count > 0)
                        {
                            <div style="padding:12px 14px; border-top:2px solid #e2e8f0;">
                                <div style="font-size:11px; font-weight:700; color:#475569; text-transform:uppercase;
                                            letter-spacing:.5px; margin-bottom:10px;">
                                    Images (@view.Images.Count)
                                </div>
                                <div style="display:flex; flex-wrap:wrap; gap:16px;">
                                    @foreach ((string fileName, string mediaType, string base64) in view.Images)
                                    {
                                        string dataUrl = $"data:{mediaType};base64,{base64}";
                                        <figure style="margin:0; text-align:center;">
                                            <img src="@dataUrl"
                                                 alt="@fileName"
                                                 title="Click to enlarge"
                                                 @onclick="() => OpenViewer(dataUrl)"
                                                 style="max-width:480px; max-height:360px; object-fit:contain;
                                                        border:1px solid #e2e8f0; border-radius:8px; display:block;
                                                        cursor:zoom-in; transition:transform .12s, box-shadow .12s;"
                                                 onmouseover="this.style.boxShadow='0 4px 12px rgba(0,0,0,.15)';"
                                                 onmouseout="this.style.boxShadow='none';" />
                                            <figcaption style="font-size:11px; color:#64748b; margin-top:4px;">@fileName</figcaption>
                                        </figure>
                                    }
                                </div>
                            </div>
                        }

                        <!-- Backup files -->
                        @if (view.Files.Count > 0)
                        {
                            <div style="padding:12px 14px; border-top:2px solid #e2e8f0;">
                                <div style="font-size:11px; font-weight:700; color:#475569; text-transform:uppercase;
                                            letter-spacing:.5px; margin-bottom:10px;">
                                    📎 Backup Files (@view.Files.Count)
                                </div>
                                <div style="display:flex; flex-wrap:wrap; gap:6px;">
                                    @foreach (RawFileInfo f in view.Files)
                                    {
                                        <a href="/data-inference/file/@f.Id" download="@f.FileName" target="_blank"
                                           style="display:inline-flex; align-items:center; gap:6px;
                                                  background:#f1f5f9; border:1px solid #e2e8f0; border-radius:14px;
                                                  padding:4px 10px; font-size:12px; color:#334155; text-decoration:none;">
                                            <span>📄</span>
                                            <span style="font-weight:600; max-width:260px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;" title="@f.FileName">@f.FileName</span>
                                            <span style="color:#94a3b8; font-size:10px;">@FormatSize(f.FileSize)</span>
                                        </a>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        }
    </div>

</div>

@if (_viewerDataUrl is not null)
{
    <div class="rpt-viewer-overlay" @onclick="CloseViewer">
        <img src="@_viewerDataUrl" class="rpt-viewer-img" @onclick:stopPropagation="true" />
        <button class="rpt-viewer-close" @onclick="CloseViewer">✕</button>
    </div>
}

<style>
    .rpt-viewer-overlay {
        position: fixed; inset: 0; background: rgba(0,0,0,.85); z-index: 9500;
        display: flex; align-items: center; justify-content: center; cursor: zoom-out;
    }
    .rpt-viewer-img  { max-width: 94vw; max-height: 92vh; object-fit: contain; cursor: auto; }
    .rpt-viewer-close {
        position: absolute; top: 16px; right: 20px; width: 36px; height: 36px;
        border-radius: 50%; border: none; background: rgba(255,255,255,.2);
        color: #fff; font-size: 18px; cursor: pointer;
    }
    .rpt-viewer-close:hover { background: rgba(255,255,255,.35); }
</style>

@code {
    private static readonly string[] MeasurementColumns =
    [
        "Variable", "Detail", "Group", "Line", "CheckType",
        "Input", "NG", "NG%", "DefectType", "Category", "Count", "Intervention",
    ];

    // ── Inner type ────────────────────────────────────────────────────────────
    private sealed class DatasetView
    {
        public string                      DatasetName  { get; init; } = "";
        public string                      ProductType  { get; init; } = "";
        public string                      TestDate     { get; init; } = "";
        public string                      Summary      { get; init; } = "";
        public string                      KeyFindings  { get; init; } = "";
        public List<string>                Tags         { get; init; } = [];
        public List<NormalizedMeasurement> Measurements { get; init; } = [];
        public List<(string FileName, string MediaType, string Base64)> Images { get; init; } = [];
        public List<RawFileInfo>           Files        { get; init; } = [];
    }

    // ── State ─────────────────────────────────────────────────────────────────
    private List<string>         _allTags    = [];
    private HashSet<string>      _filterTags = new(StringComparer.OrdinalIgnoreCase);
    private List<RawReportInfo>  _datasets   = [];

    private List<string>                    _selected      = [];
    private Dictionary<string, DatasetView> _views         = new(StringComparer.OrdinalIgnoreCase);
    private string?                         _activeDataset;

    // Image viewer
    private string? _viewerDataUrl;

    // AI report
    private bool   _isGenerating        = false;
    private string _reportHtml          = string.Empty;
    private bool   _showReport          = false;
    private string _reportStatusMessage = string.Empty;
    private bool   _reportStatusError   = false;

    // Auth
    [CascadingParameter] private Task<AuthenticationState> AuthState { get; set; } = default!;
    private System.Security.Claims.ClaimsPrincipal _user = new();
    private bool CanAiReport => AppRoles.CanAiReport(_user);

    protected override async Task OnInitializedAsync()
    {
        _user     = (await AuthState).User;
        _allTags  = Repo.GetAllDataInferenceTags();
        _datasets = Repo.GetAllRawReports();
    }

    // ── Dataset selection ─────────────────────────────────────────────────────

    private void ToggleDataset(string ds)
    {
        if (_selected.Contains(ds, StringComparer.OrdinalIgnoreCase))
        {
            _selected.RemoveAll(s => s.Equals(ds, StringComparison.OrdinalIgnoreCase));
            _views.Remove(ds);
            _activeDataset = _selected.Count > 0 ? _selected[^1] : null;
        }
        else
        {
            _selected.Add(ds);
            _views[ds] = LoadView(ds);
            _activeDataset = ds;
            _reportHtml    = string.Empty;
            _showReport    = false;
        }
    }

    private DatasetView LoadView(string ds)
    {
        RawReportInfo? info = _datasets.FirstOrDefault(r => r.DatasetName == ds);
        DatasetSummaryRecord? summ = Repo.GetDatasetSummaryRecord(ds);

        var imgs = Repo.GetRawReportImages(ds)
            .Select(i => (i.FileName, i.MediaType, Convert.ToBase64String(i.Data)))
            .ToList();

        return new DatasetView
        {
            DatasetName  = ds,
            ProductType  = info?.ProductType ?? "",
            TestDate     = info?.ReportDate  ?? "",
            Summary      = summ?.Summary     ?? "",
            KeyFindings  = summ?.KeyFindings ?? "",
            Tags         = summ?.Tags        ?? [],
            Measurements = Repo.GetNormalizedMeasurements(ds),
            Images       = imgs,
            Files        = Repo.GetRawReportFileInfos(ds),
        };
    }

    private void ClearSelection()
    {
        _selected.Clear();
        _views.Clear();
        _activeDataset       = null;
        _reportHtml          = string.Empty;
        _showReport          = false;
        _reportStatusMessage = string.Empty;
    }

    // ── Tag filter ────────────────────────────────────────────────────────────

    private void ToggleFilterTag(string tag, bool isChecked)
    {
        if (isChecked) _filterTags.Add(tag);
        else           _filterTags.Remove(tag);
        RefreshDatasets();
    }

    private void ClearTagFilter()
    {
        _filterTags.Clear();
        RefreshDatasets();
    }

    private void RefreshDatasets()
    {
        List<RawReportInfo> all = Repo.GetAllRawReports();
        if (_filterTags.Count == 0)
        {
            _datasets = all;
        }
        else
        {
            var allowed = new HashSet<string>(
                Repo.GetDataInferenceDatasetsByTags([.. _filterTags]),
                StringComparer.OrdinalIgnoreCase);
            _datasets = all.Where(r => allowed.Contains(r.DatasetName)).ToList();
        }

        var visible = new HashSet<string>(
            _datasets.Select(r => r.DatasetName),
            StringComparer.OrdinalIgnoreCase);
        var gone = _selected.Where(s => !visible.Contains(s)).ToList();
        foreach (string s in gone) { _selected.Remove(s); _views.Remove(s); }
        if (_activeDataset is not null && !_selected.Contains(_activeDataset, StringComparer.OrdinalIgnoreCase))
            _activeDataset = _selected.Count > 0 ? _selected[^1] : null;
    }

    // ── AI Report ─────────────────────────────────────────────────────────────

    private async Task GenerateAiReportAsync()
    {
        if (_selected.Count == 0) return;

        _isGenerating        = true;
        _reportStatusMessage = string.Empty;
        StateHasChanged();

        try
        {
            var sb = new System.Text.StringBuilder();
            var allImages = new List<(string FileName, string MediaType, string Base64)>();

            foreach (string ds in _selected)
            {
                if (!_views.TryGetValue(ds, out DatasetView? view)) continue;

                sb.AppendLine($"══ Dataset: {ds} ══");
                sb.AppendLine($"ProductType: {view.ProductType} | TestDate: {view.TestDate}");
                if (view.Tags.Count > 0)
                    sb.AppendLine($"Tags: {string.Join(", ", view.Tags)}");
                if (!string.IsNullOrEmpty(view.Summary))
                    sb.AppendLine($"Summary: {view.Summary}");
                if (!string.IsNullOrEmpty(view.KeyFindings))
                    sb.AppendLine($"KeyFindings: {view.KeyFindings}");

                if (view.Measurements.Count > 0)
                {
                    sb.AppendLine();
                    sb.AppendLine("Measurements:");
                    sb.AppendLine("  " + string.Join("\t", MeasurementColumns));
                    foreach (var m in view.Measurements.Take(300))
                    {
                        sb.Append("  ")
                          .Append(m.Variable).Append('\t')
                          .Append(m.VariableDetail).Append('\t')
                          .Append(m.VariableGroup).Append('\t')
                          .Append(m.Line).Append('\t')
                          .Append(m.CheckType).Append('\t')
                          .Append(m.InputQty).Append('\t')
                          .Append(m.NgTotal).Append('\t')
                          .Append(m.NgRate.ToString("F1")).Append("%\t")
                          .Append(m.DefectType).Append('\t')
                          .Append(m.DefectCategory).Append('\t')
                          .Append(m.DefectCount).Append('\t')
                          .AppendLine(m.Intervention);
                    }
                }
                sb.AppendLine();
                allImages.AddRange(view.Images);
            }

            string title = _selected.Count == 1
                ? _selected[0]
                : $"{_selected.Count} datasets: {string.Join(", ", _selected.Select(s => s.Length > 20 ? s[..20] + "…" : s))}";

            var images = allImages.Select(i => (i.MediaType, i.Base64)).ToList();
            _reportHtml = await Claude.GenerateReportAsync(title, sb.ToString(), images);

            if (allImages.Count > 0)
            {
                string imgSection = BuildImageSection(allImages);
                int bodyClose = _reportHtml.LastIndexOf("</body>", StringComparison.OrdinalIgnoreCase);
                _reportHtml = bodyClose >= 0
                    ? _reportHtml.Insert(bodyClose, imgSection)
                    : _reportHtml + imgSection;
            }

            _showReport          = true;
            _reportStatusMessage = "Report generated. Click Save Report to store it.";
        }
        catch (Exception ex)
        {
            _reportStatusMessage = $"Error: {ex.Message}";
            _reportStatusError   = true;
        }
        finally
        {
            _isGenerating = false;
        }
    }

    private async Task SaveAiReportAsync()
    {
        if (string.IsNullOrEmpty(_reportHtml)) return;
        try
        {
            string dsNames = string.Join("; ", _selected);
            string title   = $"[{_selected.Count} datasets] {DateTime.Now:yyyy-MM-dd HH:mm}";
            await Task.Run(() => Repo.SaveReport(title, dsNames, _reportHtml));
            _reportStatusMessage = $"Report saved: {title}";
            _reportStatusError   = false;
        }
        catch (Exception ex)
        {
            _reportStatusMessage = $"Save error: {ex.Message}";
            _reportStatusError   = true;
        }
    }

    private static string BuildImageSection(List<(string FileName, string MediaType, string Base64)> images)
    {
        var sb = new System.Text.StringBuilder();
        sb.Append("<section style=\"margin:40px auto;max-width:1000px;padding:0 24px;\">");
        sb.Append("<h2 style=\"font-size:18px;font-weight:700;color:#1e293b;border-bottom:2px solid #e2e8f0;padding-bottom:8px;margin-bottom:20px;\">Reference Images</h2>");
        sb.Append("<div style=\"display:flex;flex-wrap:wrap;gap:16px;\">");
        foreach ((string fileName, string mediaType, string base64) in images)
        {
            string enc = System.Net.WebUtility.HtmlEncode(fileName);
            sb.Append("<figure style=\"margin:0;text-align:center;\">");
            sb.Append($"<img src=\"data:{mediaType};base64,{base64}\" alt=\"{enc}\" style=\"max-width:480px;max-height:360px;object-fit:contain;border:1px solid #e2e8f0;border-radius:8px;\" />");
            sb.Append($"<figcaption style=\"font-size:11px;color:#64748b;margin-top:4px;\">{enc}</figcaption>");
            sb.Append("</figure>");
        }
        sb.Append("</div></section>");
        return sb.ToString();
    }

    private void OpenViewer(string dataUrl) => _viewerDataUrl = dataUrl;
    private void CloseViewer()               => _viewerDataUrl = null;

    private static string FormatSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / 1024.0 / 1024.0:F1} MB";
    }
}
