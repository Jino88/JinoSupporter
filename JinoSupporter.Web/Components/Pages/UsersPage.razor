@page "/admin/users"
@rendermode InteractiveServer
@using JinoSupporter.Web.Services
@inject WebRepository         Repo
@inject ConnectedUsersService ConnectedUsers
@inject MenuPermissionService Perms

<PageTitle>User Management</PageTitle>

<AuthorizeView Roles="Admin">
    <NotAuthorized>
        <div class="alert alert-danger">Access denied.</div>
    </NotAuthorized>
    <Authorized>

<div class="d-flex align-items-center justify-content-between mb-3">
    <h5 class="fw-bold mb-0">User Management</h5>
</div>

<!-- User list -->
<div class="card mb-4">
    <div class="card-header">Users</div>
    <div class="card-body p-0">
        <table class="table table-bordered mb-0">
            <thead>
                <tr>
                    <th>Username</th>
                    <th>Name</th>
                    <th>Role</th>
                    <th>Created</th>
                    <th style="width:180px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (UserRecord u in _users)
                {
                    bool editingName = _editNameId == u.Id;
                    <tr>
                        <td>@u.Username</td>
                        <td>
                            @if (editingName)
                            {
                                <div class="d-flex gap-1 align-items-center">
                                    <input class="form-control form-control-sm" style="width:140px;"
                                           @bind="_editNameValue"
                                           @onkeydown="@(e => { if (e.Key == "Enter") SaveDisplayName(u.Id); else if (e.Key == "Escape") CancelEditName(); })" />
                                    <button class="btn btn-success btn-sm py-0 px-2"  @onclick="() => SaveDisplayName(u.Id)">✓</button>
                                    <button class="btn btn-secondary btn-sm py-0 px-2" @onclick="CancelEditName">✕</button>
                                </div>
                            }
                            else
                            {
                                <span class="me-1" style="font-size:13px;">
                                    @(string.IsNullOrEmpty(u.DisplayName) ? "—" : u.DisplayName)
                                </span>
                                <button class="btn btn-link btn-sm p-0 text-secondary" style="font-size:11px;"
                                        @onclick="() => StartEditName(u)">✎</button>
                            }
                        </td>
                        <td>
                            <select class="form-select form-select-sm" style="width:auto;"
                                    value="@u.Role"
                                    @onchange="e => ChangeRole(u, e.Value?.ToString() ?? u.Role)"
                                    disabled="@(u.Username.Equals(_currentUser, StringComparison.OrdinalIgnoreCase))">
                                @foreach (string r in AppRoles.All)
                                {
                                    <option value="@r" selected="@(u.Role == r)">@r</option>
                                }
                            </select>
                        </td>
                        <td class="text-muted small">@u.CreatedAt</td>
                        <td>
                            <button class="btn btn-outline-secondary btn-sm me-1"
                                    @onclick="() => StartResetPassword(u)">
                                Reset PW
                            </button>
                            <button class="btn btn-outline-danger btn-sm"
                                    @onclick="() => DeleteUser(u)"
                                    disabled="@(u.Username.Equals(_currentUser, StringComparison.OrdinalIgnoreCase))">
                                Remove
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Add user -->
<div class="card mb-3">
    <div class="card-header">Add User</div>
    <div class="card-body">
        <div class="row g-2 align-items-end">
            <div class="col-auto">
                <label class="form-label">Username</label>
                <input @bind="_newUsername" class="form-control form-control-sm" placeholder="username" />
            </div>
            <div class="col-auto">
                <label class="form-label">Name</label>
                <input @bind="_newDisplayName" class="form-control form-control-sm" placeholder="display name" />
            </div>
            <div class="col-auto">
                <label class="form-label">Password</label>
                <input @bind="_newPassword" type="password" class="form-control form-control-sm" placeholder="password" />
            </div>
            <div class="col-auto">
                <label class="form-label">Role</label>
                <select @bind="_newRole" class="form-select form-select-sm">
                    @foreach (string r in AppRoles.All)
                    {
                        <option value="@r">@r</option>
                    }
                </select>
            </div>
            <div class="col-auto">
                <button class="btn btn-primary btn-sm" @onclick="AddUser">Add</button>
            </div>
        </div>
        @if (!string.IsNullOrEmpty(_addError))
        {
            <div class="alert alert-danger py-1 mt-2 small mb-0">@_addError</div>
        }
    </div>
</div>

<!-- Menu permissions matrix -->
<div class="card mb-4">
    <div class="card-header d-flex align-items-center justify-content-between">
        <span>Menu Permissions (by Role)</span>
        <span class="text-muted small">
            체크박스 클릭 즉시 자동 저장됩니다. Admin 역할은 항상 전체 메뉴 접근 가능합니다.
            @if (_permsSavedFlash)
            {
                <span class="badge bg-success ms-2">✓ 저장됨</span>
            }
        </span>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-bordered table-sm mb-0 perms-table">
                <thead>
                    <tr>
                        <th style="min-width:180px;">Menu</th>
                        @foreach (string role in AppRoles.All)
                        {
                            <th class="text-center">@role</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var grp in AppMenus.All.GroupBy(m => m.Group))
                    {
                        <tr class="perms-group-row">
                            <td colspan="@(AppRoles.All.Length + 1)">@grp.Key</td>
                        </tr>
                        @foreach (var m in grp)
                        {
                            <tr>
                                <td>@m.Label <span class="text-muted small">(@m.Id)</span></td>
                                @foreach (string role in AppRoles.All)
                                {
                                    bool isAdmin = role == AppRoles.Admin;
                                    bool allowed = isAdmin || (_perms.TryGetValue(role, out var set) && set.Contains(m.Id));
                                    <td class="text-center">
                                        <input type="checkbox"
                                               checked="@allowed"
                                               disabled="@isAdmin"
                                               @onchange="async e => await TogglePermission(role, m.Id, (bool)e.Value!)" />
                                    </td>
                                }
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .perms-table th, .perms-table td { font-size: 12px; vertical-align: middle; }
    .perms-group-row td {
        background: #f1f5f9; font-weight: 700; color: #475569;
        font-size: 11px; letter-spacing: .3px; text-transform: uppercase;
    }
</style>

<!-- Reset password modal -->
@if (_resetTarget is not null)
{
    <div class="paste-modal-backdrop" @onclick="() => _resetTarget = null">
        <div class="paste-modal" @onclick:stopPropagation="true" style="min-width:320px;">
            <div class="paste-modal-title">Reset Password — @_resetTarget.Username</div>
            <div class="paste-modal-body">
                <input @bind="_resetPassword" type="password" class="form-control mb-3"
                       placeholder="New password" />
                <div class="d-flex gap-2 justify-content-center">
                    <button class="btn btn-primary btn-sm" @onclick="ConfirmResetPassword">Save</button>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="() => _resetTarget = null">Cancel</button>
                </div>
                @if (!string.IsNullOrEmpty(_resetError))
                {
                    <div class="alert alert-danger py-1 mt-2 small mb-0">@_resetError</div>
                }
            </div>
        </div>
    </div>
}

    </Authorized>
</AuthorizeView>

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthState { get; set; } = default!;

    private List<UserRecord> _users = [];
    private string _currentUser = string.Empty;
    private Dictionary<string, HashSet<string>> _perms = new(StringComparer.Ordinal);
    private bool   _permsSavedFlash;
    private CancellationTokenSource? _flashCts;

    private string _newUsername    = string.Empty;
    private string _newDisplayName = string.Empty;
    private string _newPassword    = string.Empty;
    private string _newRole        = AppRoles.Viewer;
    private string _addError       = string.Empty;

    private long   _editNameId    = -1;
    private string _editNameValue = string.Empty;

    private UserRecord? _resetTarget;
    private string _resetPassword = string.Empty;
    private string _resetError    = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        _currentUser = (await AuthState).User.Identity?.Name ?? string.Empty;
        Load();
    }

    private void Load()
    {
        _users = Repo.GetAllUsers();
        _perms = Repo.GetAllMenuPermissions();
    }

    private async Task TogglePermission(string role, string menuId, bool allowed)
    {
        Repo.SetMenuPermission(role, menuId, allowed);
        if (!_perms.TryGetValue(role, out var set))
        {
            set = new HashSet<string>(StringComparer.Ordinal);
            _perms[role] = set;
        }
        if (allowed) set.Add(menuId); else set.Remove(menuId);

        _flashCts?.Cancel();
        _flashCts = new CancellationTokenSource();
        CancellationToken token = _flashCts.Token;
        _permsSavedFlash = true;
        StateHasChanged();
        try
        {
            await Task.Delay(1500, token);
            _permsSavedFlash = false;
            StateHasChanged();
        }
        catch (TaskCanceledException) { }
    }

    private void ChangeRole(UserRecord u, string newRole)
    {
        Repo.UpdateUserRole(u.Id, newRole);
        Load();
    }

    private void DeleteUser(UserRecord u)
    {
        Repo.DeleteUser(u.Id);
        Load();
    }

    private void AddUser()
    {
        _addError = string.Empty;
        if (string.IsNullOrWhiteSpace(_newUsername)) { _addError = "Username required."; return; }
        if (string.IsNullOrWhiteSpace(_newPassword)) { _addError = "Password required."; return; }
        try
        {
            Repo.AddUser(_newUsername.Trim(), AuthService.HashPassword(_newPassword), _newRole, _newDisplayName.Trim());
            _newUsername = _newDisplayName = _newPassword = string.Empty;
            _newRole = AppRoles.Viewer;
            Load();
        }
        catch (Exception ex)
        {
            _addError = ex.Message.Contains("UNIQUE") ? "Username already exists." : ex.Message;
        }
    }

    private void StartEditName(UserRecord u)
    {
        _editNameId    = u.Id;
        _editNameValue = u.DisplayName;
    }

    private void SaveDisplayName(long id)
    {
        string newName = _editNameValue.Trim();
        Repo.UpdateUserDisplayName(id, newName);
        // real-time update for currently connected sessions
        var target = _users.FirstOrDefault(u => u.Id == id);
        if (target is not null)
            ConnectedUsers.UpdateNameByUsername(target.Username,
                string.IsNullOrEmpty(newName) ? target.Username : newName);
        _editNameId = -1;
        Load();
    }

    private void CancelEditName() => _editNameId = -1;

    private void StartResetPassword(UserRecord u) { _resetTarget = u; _resetPassword = _resetError = string.Empty; }

    private void ConfirmResetPassword()
    {
        _resetError = string.Empty;
        if (string.IsNullOrWhiteSpace(_resetPassword)) { _resetError = "Password required."; return; }
        Repo.UpdateUserPassword(_resetTarget!.Id, AuthService.HashPassword(_resetPassword));
        _resetTarget = null;
    }
}
