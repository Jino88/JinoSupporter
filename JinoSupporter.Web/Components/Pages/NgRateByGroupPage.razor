@page "/ng-rate-by-group"
@rendermode InteractiveServer
@* NG Rate By Group — groups are defined by ModelGroups DB table (BmesMakeModelGroupPage).
   View shows per-group × per-date defect rate Summary only. *@
@using JinoSupporter.Web.Services
@inject NgRateService         NgRate
@inject NgRateSettingsService NgRateSettings
@inject NgRateReportService   NgRateReportSvc
@inject WebRepository         Repo
@inject IJSRuntime            JS
@implements IAsyncDisposable

<PageTitle>NG Rate — By Group</PageTitle>

<div class="d-flex align-items-center gap-2 mb-3">
    <span style="font-size:20px;">📉</span>
    <h5 class="mb-0 fw-semibold">NG Rate</h5>
    <div class="ms-3 btn-group btn-group-sm" role="group" aria-label="View mode">
        <a href="/ng-rate" class="btn btn-outline-secondary"
           title="Switch to By Model view">
            🎯 By Model
        </a>
        <a href="/ng-rate-all" class="btn btn-outline-secondary"
           title="Switch to By Section view">
            📑 By Section
        </a>
        <button type="button" class="btn btn-primary" disabled
                title="Current view: By Group">
            🧩 By Group
        </button>
    </div>
</div>

<div class="row g-3">

    <!-- ══ Get Data ══════════════════════════════════════════════════════════ -->
    <div class="col-md-6">
        <div class="card shadow-sm h-100">
            <div class="card-header small fw-semibold">Get Data</div>
            <div class="card-body d-flex flex-column gap-3">
                <div>
                    <div class="form-label small fw-semibold mb-1">Period</div>
                    <div class="d-flex gap-2 align-items-center flex-wrap">
                        <input type="date" class="form-control form-control-sm"
                               style="width:auto; flex:1; min-width:110px;"
                               @bind="_startDate" @bind:format="yyyy-MM-dd" />
                        <span class="small text-muted">–</span>
                        <input type="date" class="form-control form-control-sm"
                               style="width:auto; flex:1; min-width:110px;"
                               @bind="_endDate" @bind:format="yyyy-MM-dd" />
                        <button class="btn btn-outline-secondary btn-sm" @onclick="SetToday">Today</button>
                    </div>
                </div>

                <div class="d-flex align-items-center gap-2">
                    <span class="small text-muted">BMES:</span>
                    @if (NgRateSettings.IsCredentialsConfigured)
                    {
                        <span class="badge bg-success">Credentials OK</span>
                        <span class="small text-muted font-monospace">@NgRateSettings.LoginId</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark">Not configured</span>
                        <a href="/admin/settings" class="small text-primary">→ Admin Settings</a>
                    }
                </div>

                <button class="btn btn-primary"
                        @onclick="GetDataAsync"
                        disabled="@(_isBusy || !NgRateSettings.IsCredentialsConfigured)">
                    @if (_isBusy)
                    { <span class="spinner-border spinner-border-sm me-1"></span><span>Processing…</span> }
                    else { <span>Get Data</span> }
                </button>

                @if (!string.IsNullOrEmpty(_savedDbPath))
                {
                    <div class="alert alert-success py-2 small mb-0">
                        <div class="fw-semibold mb-1">
                            <span class="badge bg-success me-1">Done</span> Saved DB
                        </div>
                        <div class="font-monospace text-break" style="font-size:11px;">@_savedDbPath</div>
                    </div>
                }
                @if (!string.IsNullOrEmpty(_errorMessage))
                {
                    <div class="alert alert-danger py-2 small mb-0">
                        <span class="badge bg-danger me-1">Error</span> @_errorMessage
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- ══ Groups (from ModelGroups DB) ══════════════════════════════════════ -->
    <div class="col-md-6">
        <div class="card shadow-sm h-100">
            <div class="card-header small fw-semibold d-flex align-items-center gap-2">
                <span>🧱 Model Groups</span>
                <span class="badge bg-secondary" style="font-size:10px;">@_groups.Count</span>
                <button class="btn btn-outline-secondary btn-sm ms-auto" @onclick="ReloadGroups">↻</button>
                <a class="btn btn-outline-secondary btn-sm" href="/bmes/make-model-group" target="_blank"
                   title="Edit groups">Edit</a>
            </div>
            <div class="card-body d-flex flex-column gap-2">
                @if (_groups.Count == 0)
                {
                    <div class="text-muted small">
                        No saved groups. Please create a group first at <a href="/bmes/make-model-group" target="_blank">Make ModelGroup Data</a>.
                    </div>
                }
                else
                {
                    <div class="d-flex gap-2 small">
                        <button class="btn btn-link btn-sm p-0" @onclick="SelectAllGroups">All</button>
                        <span class="text-muted">|</span>
                        <button class="btn btn-link btn-sm p-0" @onclick="ClearSelectedGroups">None</button>
                        <span class="text-muted ms-auto">@_selectedGroupNames.Count selected</span>
                    </div>
                    <div style="max-height:220px; overflow:auto;">
                        @foreach (var g in _groups)
                        {
                            <label class="grp-chk">
                                <input type="checkbox"
                                       checked="@_selectedGroupNames.Contains(g.Name)"
                                       @onchange="e => ToggleGroup(g.Name, (bool)e.Value!)" />
                                <span class="grp-name">@g.Name</span>
                                <span class="grp-count text-muted">@(g.MidGroups.Count) / @g.MidGroups.Sum(m => m.LineShifts.Count)</span>
                            </label>
                        }
                    </div>
                }

                <button class="btn btn-success mt-1"
                        @onclick="GetReportAsync"
                        disabled="@(_isReportBusy || _selectedGroupNames.Count == 0 || !HasUsableDb)">
                    @if (_isReportBusy)
                    { <span class="spinner-border spinner-border-sm me-1"></span><span>Generating…</span> }
                    else { <span>▶ Generate Report</span> }
                </button>
                @if (!HasUsableDb)
                {
                    <div class="small text-muted">Please run Get Data first to fetch the NG Rate DB.</div>
                }
            </div>
        </div>
    </div>

</div>

<!-- ══ Summary (per group × per date) ════════════════════════════════════════ -->
<div class="card shadow-sm mt-3">
    <div class="card-header small fw-semibold d-flex align-items-center gap-2">
        <span>📊 Summary — group × Date / Week / Month (PPM)</span>
        @if (_report is not null)
        {
            <span class="text-muted" style="font-size:11px;">
                D @VisibleDateCols.Count/@_report.DateCols.Count · W @VisibleWeekCols.Count/@_report.WeekCols.Count · M @VisibleMonthCols.Count/@_report.MonthCols.Count · @_report.TotalRows rows
            </span>
            <div class="btn-group btn-group-sm ms-auto">
                @if (HiddenDateCount > 0 || _dateExpanded)
                {
                    <button class="btn btn-outline-primary"
                            @onclick="() => _dateExpanded = !_dateExpanded">
                        @(_dateExpanded ? $"◂ Date ({_report.DateCols.Count - DefaultDateCap} hide)" : $"▸ Date (+{HiddenDateCount})")
                    </button>
                }
                @if (HiddenWeekCount > 0 || _weekExpanded)
                {
                    <button class="btn btn-outline-success"
                            @onclick="() => _weekExpanded = !_weekExpanded">
                        @(_weekExpanded ? $"◂ Week ({_report.WeekCols.Count - DefaultWeekCap} hide)" : $"▸ Week (+{HiddenWeekCount})")
                    </button>
                }
                @if (HiddenMonthCount > 0 || _monthExpanded)
                {
                    <button class="btn btn-outline-warning"
                            @onclick="() => _monthExpanded = !_monthExpanded">
                        @(_monthExpanded ? $"◂ Month ({_report.MonthCols.Count - DefaultMonthCap} hide)" : $"▸ Month (+{HiddenMonthCount})")
                    </button>
                }
            </div>
        }
    </div>
    <div class="card-body p-0">
        @if (!string.IsNullOrEmpty(_reportError))
        {
            <div class="alert alert-danger m-3 py-2 small">@_reportError</div>
        }
        else if (_report is null)
        {
            <div class="text-muted small p-4 text-center">
                Select groups, then click <strong>Generate Report</strong>.
            </div>
        }
        else if (TotalColCount == 0)
        {
            <div class="text-muted small p-4 text-center">No data.</div>
        }
        else
        {
            <div style="overflow-x:auto;">
                <table class="pivot-table">
                    <thead>
                        <tr>
                            <th class="label-th" style="width:220px;" rowspan="2">Group</th>
                            @if (VisibleDateCols.Count > 0)
                            {
                                <th class="blk-date"  colspan="@VisibleDateCols.Count">Date</th>
                                <th class="sep-th" rowspan="2"></th>
                            }
                            @if (VisibleWeekCols.Count > 0)
                            {
                                <th class="blk-week"  colspan="@VisibleWeekCols.Count">Week</th>
                                <th class="sep-th" rowspan="2"></th>
                            }
                            @if (VisibleMonthCols.Count > 0)
                            {
                                <th class="blk-month" colspan="@VisibleMonthCols.Count">Month</th>
                            }
                        </tr>
                        <tr>
                            @foreach (var col in VisibleDateCols)  { <th>@col.Header</th> }
                            @foreach (var col in VisibleWeekCols)  { <th>@col.Header</th> }
                            @foreach (var col in VisibleMonthCols) { <th>@col.Header</th> }
                        </tr>
                    </thead>
                    <tbody>
                        <tr class="grp-overall-row">
                            <td class="label-td"><strong>TOTAL</strong>
                                <span class="text-muted ms-1" style="font-size:10px;">@_selectedGroupNames.Count groups avg</span>
                            </td>
                            @foreach (var col in VisibleDateCols)
                            {
                                double v = MeanOfGroups(col.Key);
                                <td class="@(v == 0 ? "ppm-zero" : "ppm-val")">@FormatPpm(v)</td>
                            }
                            @if (VisibleDateCols.Count > 0) { <td class="sep-td"></td> }
                            @foreach (var col in VisibleWeekCols)
                            {
                                double v = MeanOfGroups(col.Key);
                                <td class="@(v == 0 ? "ppm-zero" : "ppm-val")">@FormatPpm(v)</td>
                            }
                            @if (VisibleWeekCols.Count > 0) { <td class="sep-td"></td> }
                            @foreach (var col in VisibleMonthCols)
                            {
                                double v = MeanOfGroups(col.Key);
                                <td class="@(v == 0 ? "ppm-zero" : "ppm-val")">@FormatPpm(v)</td>
                            }
                        </tr>
                        @foreach (var gName in _selectedGroupNames)
                        {
                            var rows  = _report.GroupSummary.GetValueOrDefault(gName);
                            var total = rows?.FirstOrDefault(r => r.IsTotal);
                            bool expanded = _expandedGroups.Contains(gName);

                            <tr class="grp-total-row" @onclick="() => ToggleExpand(gName)">
                                <td class="label-td">
                                    <span class="tog-icon">@(expanded ? "▼" : "▶")</span>
                                    <strong>@gName</strong>
                                </td>
                                @foreach (var col in VisibleDateCols)
                                {
                                    double v = MeanOfMembers(gName, col.Key, null);
                                    <td class="@(v == 0 ? "ppm-zero" : "ppm-val")">@FormatPpm(v)</td>
                                }
                                @if (VisibleDateCols.Count > 0) { <td class="sep-td"></td> }
                                @foreach (var col in VisibleWeekCols)
                                {
                                    double v = MeanOfMembers(gName, col.Key, null);
                                    <td class="@(v == 0 ? "ppm-zero" : "ppm-val")">@FormatPpm(v)</td>
                                }
                                @if (VisibleWeekCols.Count > 0) { <td class="sep-td"></td> }
                                @foreach (var col in VisibleMonthCols)
                                {
                                    double v = MeanOfMembers(gName, col.Key, null);
                                    <td class="@(v == 0 ? "ppm-zero" : "ppm-val")">@FormatPpm(v)</td>
                                }
                            </tr>

                            @if (expanded && rows is not null)
                            {
                                @foreach (var r in rows.Where(r => !r.IsTotal).OrderBy(r => ProcessTypeRank(r.ProcessType)))
                                {
                                    <tr class="grp-sub-row">
                                        <td class="label-td ps-4">
                                            <span class="pt-badge">@r.ProcessType</span>
                                        </td>
                                        @foreach (var col in VisibleDateCols)
                                        {
                                            double v = MeanOfMembers(gName, col.Key, r.ProcessType);
                                            <td class="@(v == 0 ? "ppm-zero" : "ppm-val")">@FormatPpm(v)</td>
                                        }
                                        @if (VisibleDateCols.Count > 0) { <td class="sep-td"></td> }
                                        @foreach (var col in VisibleWeekCols)
                                        {
                                            double v = MeanOfMembers(gName, col.Key, r.ProcessType);
                                            <td class="@(v == 0 ? "ppm-zero" : "ppm-val")">@FormatPpm(v)</td>
                                        }
                                        @if (VisibleWeekCols.Count > 0) { <td class="sep-td"></td> }
                                        @foreach (var col in VisibleMonthCols)
                                        {
                                            double v = MeanOfMembers(gName, col.Key, r.ProcessType);
                                            <td class="@(v == 0 ? "ppm-zero" : "ppm-val")">@FormatPpm(v)</td>
                                        }
                                    </tr>
                                }
                            }
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<!-- ══ Chart (per-group PPM trend over dates) ════════════════════════════════ -->
@if (_report is not null && TotalColCount > 0 && _selectedGroupNames.Count > 0)
{
    <div class="card shadow-sm mt-3">
        <div class="card-header small fw-semibold d-flex align-items-center gap-2">
            <span>📈 Group trend — PPM (Date / Week / Month)</span>
        </div>
        <div class="card-body" style="height:320px;">
            <canvas id="ngrateByGroupCanvas"></canvas>
        </div>
    </div>
}

<!-- ══ Summary 2 (per group × per model) ═════════════════════════════════════ -->
<div class="card shadow-sm mt-3">
    <div class="card-header small fw-semibold d-flex align-items-center gap-2">
        <span>📊 Summary — Main Group → Mid Group × Date / Week / Month (PPM)</span>
        @if (_reportByMid is not null)
        {
            <span class="text-muted" style="font-size:11px;">Mid Group PPM = same combo-merged as per-model</span>
        }
    </div>
    <div class="card-body p-0">
        @if (_report is null || _reportByMid is null)
        {
            <div class="text-muted small p-4 text-center">
                Displayed after Generate Report.
            </div>
        }
        else if (TotalColCount == 0)
        {
            <div class="text-muted small p-4 text-center">No data.</div>
        }
        else
        {
            <div style="overflow-x:auto;">
                <table class="pivot-table">
                    <thead>
                        <tr>
                            <th class="label-th" style="width:260px;" rowspan="2">Group / Model</th>
                            @if (VisibleDateCols.Count > 0)
                            {
                                <th class="blk-date"  colspan="@VisibleDateCols.Count">Date</th>
                                <th class="sep-th" rowspan="2"></th>
                            }
                            @if (VisibleWeekCols.Count > 0)
                            {
                                <th class="blk-week"  colspan="@VisibleWeekCols.Count">Week</th>
                                <th class="sep-th" rowspan="2"></th>
                            }
                            @if (VisibleMonthCols.Count > 0)
                            {
                                <th class="blk-month" colspan="@VisibleMonthCols.Count">Month</th>
                            }
                        </tr>
                        <tr>
                            @foreach (var col in VisibleDateCols)  { <th>@col.Header</th> }
                            @foreach (var col in VisibleWeekCols)  { <th>@col.Header</th> }
                            @foreach (var col in VisibleMonthCols) { <th>@col.Header</th> }
                        </tr>
                    </thead>
                    <tbody>
                        <tr class="grp-overall-row">
                            <td class="label-td"><strong>TOTAL</strong>
                                <span class="text-muted ms-1" style="font-size:10px;">@_selectedGroupNames.Count groups avg</span>
                            </td>
                            @foreach (var col in VisibleDateCols)
                            {
                                double v = MeanOfGroups(col.Key);
                                <td class="@(v == 0 ? "ppm-zero" : "ppm-val")">@FormatPpm(v)</td>
                            }
                            @if (VisibleDateCols.Count > 0) { <td class="sep-td"></td> }
                            @foreach (var col in VisibleWeekCols)
                            {
                                double v = MeanOfGroups(col.Key);
                                <td class="@(v == 0 ? "ppm-zero" : "ppm-val")">@FormatPpm(v)</td>
                            }
                            @if (VisibleWeekCols.Count > 0) { <td class="sep-td"></td> }
                            @foreach (var col in VisibleMonthCols)
                            {
                                double v = MeanOfGroups(col.Key);
                                <td class="@(v == 0 ? "ppm-zero" : "ppm-val")">@FormatPpm(v)</td>
                            }
                        </tr>
                        @foreach (var gName in _selectedGroupNames)
                        {
                            bool exp     = _expandedGroupsModel.Contains(gName);
                            var  grpVm   = _groups.FirstOrDefault(g => g.Name == gName);
                            var  midList = grpVm?.MidGroups ?? new List<MidGroupRecord>();

                            <tr class="grp-total-row" @onclick="() => ToggleExpandModel(gName)">
                                <td class="label-td">
                                    <span class="tog-icon">@(exp ? "▼" : "▶")</span>
                                    <strong>@gName</strong>
                                    <span class="text-muted ms-1" style="font-size:10px;">@midList.Count mid groups</span>
                                </td>
                                @foreach (var col in VisibleDateCols)
                                {
                                    double v = MeanOfMembers(gName, col.Key, null);
                                    <td class="@(v == 0 ? "ppm-zero" : "ppm-val")">@FormatPpm(v)</td>
                                }
                                @if (VisibleDateCols.Count > 0) { <td class="sep-td"></td> }
                                @foreach (var col in VisibleWeekCols)
                                {
                                    double v = MeanOfMembers(gName, col.Key, null);
                                    <td class="@(v == 0 ? "ppm-zero" : "ppm-val")">@FormatPpm(v)</td>
                                }
                                @if (VisibleWeekCols.Count > 0) { <td class="sep-td"></td> }
                                @foreach (var col in VisibleMonthCols)
                                {
                                    double v = MeanOfMembers(gName, col.Key, null);
                                    <td class="@(v == 0 ? "ppm-zero" : "ppm-val")">@FormatPpm(v)</td>
                                }
                            </tr>

                            @if (exp)
                            {
                                @foreach (var mid in midList)
                                {
                                    string midKey = $"{gName}::{mid.Material}";
                                    bool midExp   = _expandedMids.Contains(midKey);
                                    <tr class="grp-sub-row grp-mid-row" @onclick="() => ToggleExpandMid(midKey)">
                                        <td class="label-td ps-4" style="font-size:11px;">
                                            <span class="tog-icon">@(midExp ? "▼" : "▶")</span>
                                            <span class="mid-badge">Mid</span>
                                            <span class="ms-1">@mid.Material</span>
                                            <span class="text-muted ms-1" style="font-size:10px;">@mid.LineShifts.Count</span>
                                        </td>
                                        @foreach (var col in VisibleDateCols)
                                        {
                                            double v = MidGroupPpm(gName, mid.Material, col.Key);
                                            <td class="@(v == 0 ? "ppm-zero" : "ppm-val")">@FormatPpm(v)</td>
                                        }
                                        @if (VisibleDateCols.Count > 0) { <td class="sep-td"></td> }
                                        @foreach (var col in VisibleWeekCols)
                                        {
                                            double v = MidGroupPpm(gName, mid.Material, col.Key);
                                            <td class="@(v == 0 ? "ppm-zero" : "ppm-val")">@FormatPpm(v)</td>
                                        }
                                        @if (VisibleWeekCols.Count > 0) { <td class="sep-td"></td> }
                                        @foreach (var col in VisibleMonthCols)
                                        {
                                            double v = MidGroupPpm(gName, mid.Material, col.Key);
                                            <td class="@(v == 0 ? "ppm-zero" : "ppm-val")">@FormatPpm(v)</td>
                                        }
                                    </tr>

                                    @if (midExp)
                                    {
                                        @foreach (var ls in mid.LineShifts)
                                        {
                                            var mRows = _reportByModel?.GroupSummary.GetValueOrDefault(ls);
                                            var mTot  = mRows?.FirstOrDefault(r => r.IsTotal);
                                            <tr class="grp-ls-row">
                                                <td class="label-td ps-5 font-monospace" style="font-size:11px;">
                                                    <span class="ls-badge">Sub</span>
                                                    <span class="ms-1">@ls</span>
                                                </td>
                                                @foreach (var col in VisibleDateCols)
                                                {
                                                    double v = mTot?.Ppm.GetValueOrDefault(col.Key) ?? 0;
                                                    <td class="@(v == 0 ? "ppm-zero" : "ppm-val")">@FormatPpm(v)</td>
                                                }
                                                @if (VisibleDateCols.Count > 0) { <td class="sep-td"></td> }
                                                @foreach (var col in VisibleWeekCols)
                                                {
                                                    double v = mTot?.Ppm.GetValueOrDefault(col.Key) ?? 0;
                                                    <td class="@(v == 0 ? "ppm-zero" : "ppm-val")">@FormatPpm(v)</td>
                                                }
                                                @if (VisibleWeekCols.Count > 0) { <td class="sep-td"></td> }
                                                @foreach (var col in VisibleMonthCols)
                                                {
                                                    double v = mTot?.Ppm.GetValueOrDefault(col.Key) ?? 0;
                                                    <td class="@(v == 0 ? "ppm-zero" : "ppm-val")">@FormatPpm(v)</td>
                                                }
                                            </tr>
                                        }
                                    }
                                }
                            }
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<!-- ══ Chart 2 (per-model PPM trend) ═════════════════════════════════════════ -->
@if (_reportByModel is not null && TotalColCount > 0 && _selectedGroupNames.Count > 0)
{
    <div class="card shadow-sm mt-3">
        <div class="card-header small fw-semibold d-flex align-items-center gap-2">
            <span>📈 Group trend — PPM (Date / Week / Month)</span>
        </div>
        <div class="card-body" style="height:320px;">
            <canvas id="ngrateByGroupModelCanvas"></canvas>
        </div>
    </div>
}

<!-- ══ Top-10 per group (Mid Group × Process × NG) ══════════════════════════════ -->
@if (_midNgReport is not null && _selectedGroupNames.Count > 0)
{
    var (_refKey, _refBucket) = SortRefKey();
    <div class="card shadow-sm mt-3">
        <div class="card-header small fw-semibold d-flex align-items-center gap-2">
            <span>🥇 Top 10 per group — Mid Group × Process × NG</span>
            <span class="text-muted" style="font-size:11px;">
                @if (!string.IsNullOrEmpty(_refKey))
                { <text>Sorted: previous-week PPM, descending (ref = @_refBucket @ShiftedRefLabel(_refKey, _refBucket))</text> }
                else { <text>No sort reference available.</text> }
            </span>
        </div>
        <div class="card-body p-0">
            @foreach (var gName in _selectedGroupNames)
            {
                // 중그룹 키는 "대그룹::Material" 형태. 현재 대그룹에 해당하는 키만 필터.
                string prefix = gName + "::";
                var top = _midNgReport.Details
                    .Where(d => d.LineShift.StartsWith(prefix, StringComparison.Ordinal))
                    .Select(d => new
                    {
                        Detail   = d,
                        Material = d.LineShift.Substring(prefix.Length),
                        Ref      = DetailSortValue(d),
                    })
                    .Where(x => x.Ref > 0)
                    .OrderByDescending(x => x.Ref)
                    .Take(10)
                    .ToList();

                <div class="px-3 py-2 top10-group-head">
                    <strong class="me-2">@gName</strong>
                    <span class="text-muted small">@top.Count rows</span>
                </div>
                @if (top.Count == 0)
                {
                    <div class="text-muted small px-3 pb-3">(no data)</div>
                }
                else
                {
                    <div style="overflow-x:auto;">
                        <table class="pivot-table top10-table">
                            <colgroup>
                                <col style="width:32px;" />
                                <col style="width:210px;" />
                                <col style="width:220px;" />
                                <col style="width:160px;" />
                                @foreach (var _ in Top10DateCols)  { <col style="width:70px;" /> }
                                @if (Top10DateCols.Count > 0)   { <col style="width:8px;" /> }
                                @foreach (var _ in Top10WeekCols)  { <col style="width:70px;" /> }
                                @if (Top10WeekCols.Count > 0)   { <col style="width:8px;" /> }
                                @foreach (var _ in Top10MonthCols) { <col style="width:70px;" /> }
                            </colgroup>
                            <thead>
                                <tr>
                                    <th class="label-th" rowspan="2">#</th>
                                    <th class="label-th" rowspan="2">Mid Group</th>
                                    <th class="label-th" rowspan="2">Process</th>
                                    <th class="label-th" rowspan="2">NG Name</th>
                                    @if (Top10DateCols.Count > 0)
                                    {
                                        <th class="blk-date"  colspan="@Top10DateCols.Count">Date</th>
                                        <th class="sep-th" rowspan="2"></th>
                                    }
                                    @if (Top10WeekCols.Count > 0)
                                    {
                                        <th class="blk-week"  colspan="@Top10WeekCols.Count">Week</th>
                                        <th class="sep-th" rowspan="2"></th>
                                    }
                                    @if (Top10MonthCols.Count > 0)
                                    {
                                        <th class="blk-month" colspan="@Top10MonthCols.Count">Month</th>
                                    }
                                </tr>
                                <tr>
                                    @foreach (var col in Top10DateCols)  { <th>@ShiftedDateHeader(col)</th> }
                                    @foreach (var col in Top10WeekCols)  { <th>@ShiftedWeekHeader(col)</th> }
                                    @foreach (var col in Top10MonthCols) { <th>@col.Header</th> }
                                </tr>
                            </thead>
                            <tbody>
                                @{ int rank = 0; }
                                @foreach (var x in top)
                                {
                                    rank++;
                                    var d = x.Detail;
                                    <tr>
                                        <td class="label-td n text-muted">@rank</td>
                                        <td class="label-td font-monospace" style="font-size:11px;">@x.Material</td>
                                        <td class="label-td" style="font-size:11px;">
                                            <span class="pt-badge">@d.ProcessType</span>
                                            <span class="ms-1">@d.ProcessName</span>
                                        </td>
                                        <td class="label-td" style="font-size:11px;">@d.NgName</td>
                                        @foreach (var col in Top10DateCols)
                                        {
                                            double v = d.DatePpm.GetValueOrDefault(col.Key);
                                            <td class="@(v == 0 ? "ppm-zero" : "ppm-val")">@FormatPpm(v)</td>
                                        }
                                        @if (Top10DateCols.Count > 0) { <td class="sep-td"></td> }
                                        @foreach (var col in Top10WeekCols)
                                        {
                                            double v = d.WeekPpm.GetValueOrDefault(col.Key);
                                            <td class="@(v == 0 ? "ppm-zero" : "ppm-val")">@FormatPpm(v)</td>
                                        }
                                        @if (Top10WeekCols.Count > 0) { <td class="sep-td"></td> }
                                        @foreach (var col in Top10MonthCols)
                                        {
                                            double v = d.MonthPpm.GetValueOrDefault(col.Key);
                                            <td class="@(v == 0 ? "ppm-zero" : "ppm-val")">@FormatPpm(v)</td>
                                        }
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            }
        </div>
    </div>
}

