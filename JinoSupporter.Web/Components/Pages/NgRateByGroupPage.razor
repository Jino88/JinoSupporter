@code {
    private DateTime _startDate = DateTime.Today;
    private DateTime _endDate   = DateTime.Today;
    private bool     _isBusy;
    private string?  _savedDbPath;
    private string   _errorMessage = string.Empty;

    private List<ModelGroupRecord> _groups             = new();
    private HashSet<string>        _selectedGroupNames = new(StringComparer.Ordinal);

    private NgRateReportService.NgRateReport?       _report;
    private NgRateReportService.NgRateReport?       _reportByMid;
    private NgRateReportService.NgRateReport?       _reportByModel;
    private NgRateReportService.LineShiftNgReport?  _lsNgReport;
    private NgRateReportService.LineShiftNgReport?  _midNgReport;
    private HashSet<string>                         _expandedMids = new(StringComparer.Ordinal);
    private bool           _isReportBusy;
    private string         _reportError = string.Empty;
    private HashSet<string> _expandedGroups      = new(StringComparer.Ordinal);
    private HashSet<string> _expandedGroupsModel = new(StringComparer.Ordinal);
    private bool           _pendingChartRender;
    private const string   CanvasId      = "ngrateByGroupCanvas";
    private const string   CanvasIdModel = "ngrateByGroupModelCanvas";

    // Period collapse defaults / state
    private const int DefaultDateCap  = 10;
    private const int DefaultWeekCap  = 4;
    private const int DefaultMonthCap = 3;
    private bool _dateExpanded;
    private bool _weekExpanded;
    private bool _monthExpanded;

    private IReadOnlyList<NgRateReportService.PeriodColumn> VisibleDateCols =>
        _report is null ? Array.Empty<NgRateReportService.PeriodColumn>()
        : _dateExpanded ? _report.DateCols
        : _report.DateCols.Take(DefaultDateCap).ToList();
    private IReadOnlyList<NgRateReportService.PeriodColumn> VisibleWeekCols =>
        _report is null ? Array.Empty<NgRateReportService.PeriodColumn>()
        : _weekExpanded ? _report.WeekCols
        : _report.WeekCols.Take(DefaultWeekCap).ToList();
    private IReadOnlyList<NgRateReportService.PeriodColumn> VisibleMonthCols =>
        _report is null ? Array.Empty<NgRateReportService.PeriodColumn>()
        : _monthExpanded ? _report.MonthCols
        : _report.MonthCols.Take(DefaultMonthCap).ToList();

    private int HiddenDateCount  => _report is null ? 0 : Math.Max(0, _report.DateCols.Count  - VisibleDateCols.Count);
    private int HiddenWeekCount  => _report is null ? 0 : Math.Max(0, _report.WeekCols.Count  - VisibleWeekCols.Count);
    private int HiddenMonthCount => _report is null ? 0 : Math.Max(0, _report.MonthCols.Count - VisibleMonthCols.Count);

    // Top-10 카드 전용 고정 cap (상단 접기와 무관)
    private const int Top10DateCap  = 10;
    private const int Top10WeekCap  = 4;
    private const int Top10MonthCap = 3;
    private IReadOnlyList<NgRateReportService.PeriodColumn> Top10DateCols =>
        _report is null ? Array.Empty<NgRateReportService.PeriodColumn>()
        : _report.DateCols.Take(Top10DateCap).ToList();
    private IReadOnlyList<NgRateReportService.PeriodColumn> Top10WeekCols =>
        _report is null ? Array.Empty<NgRateReportService.PeriodColumn>()
        : _report.WeekCols.Take(Top10WeekCap).ToList();
    private IReadOnlyList<NgRateReportService.PeriodColumn> Top10MonthCols =>
        _report is null ? Array.Empty<NgRateReportService.PeriodColumn>()
        : _report.MonthCols.Take(Top10MonthCap).ToList();

    private int TotalColCount =>
        _report is null ? 0
        : VisibleDateCols.Count + VisibleWeekCols.Count + VisibleMonthCols.Count;

    /// <summary>선택된 그룹들의 MeanOfMembers 값을 다시 평균 — 전체 TOTAL 행에 사용.</summary>
    private double MeanOfGroups(string colKey)
    {
        double sum = 0;
        int    cnt = 0;
        foreach (var g in _selectedGroupNames)
        {
            double v = MeanOfMembers(g, colKey, null);
            if (v <= 0) continue;
            sum += v;
            cnt++;
        }
        return cnt == 0 ? 0 : sum / cnt;
    }

    /// <summary>정렬 기준 키: 이전 주차(Week[1]) → Week[0] → Date[0] 순 fallback.</summary>
    private (string Key, string Bucket) SortRefKey()
    {
        if (VisibleWeekCols.Count >= 2) return (VisibleWeekCols[1].Key, "week");
        if (VisibleWeekCols.Count == 1) return (VisibleWeekCols[0].Key, "week");
        if (VisibleDateCols.Count > 0)  return (VisibleDateCols[0].Key, "date");
        return ("", "");
    }

    // Display-only label for the sort-reference period: shifts week -1 and date -2 days.
    // Does NOT affect sort logic — `SortRefKey` still returns the real column key.
    private static string ShiftedRefLabel(string key, string bucket)
    {
        if (string.IsNullOrEmpty(key)) return "";
        if (bucket == "week" && key.Length >= 6
            && int.TryParse(key[..4], out int yy) && int.TryParse(key[4..], out int ww))
        {
            ww -= 1;
            if (ww < 1) { yy -= 1; ww = System.Globalization.ISOWeek.GetWeeksInYear(yy); }
            return $"{yy}{ww:D2}";
        }
        if (bucket == "date" && DateTime.TryParse(key, out DateTime dt))
        {
            return dt.AddDays(-2).ToString("yyyy-MM-dd");
        }
        return key;
    }

    // Display-only header shifts for the Top-10 table columns:
    //   date column header → -2 days (format MM/dd to match FormatDateHeader)
    //   week column header → -1 week ("W" + shifted week number)
    // Underlying `col.Key` (data binding) is unchanged.
    private static string ShiftedDateHeader(NgRateReportService.PeriodColumn col)
    {
        if (DateTime.TryParse(col.Key, out DateTime dt))
            return dt.AddDays(-2).ToString("MM/dd");
        return col.Header;
    }

    private static string ShiftedWeekHeader(NgRateReportService.PeriodColumn col)
    {
        if (col.Key.Length >= 6
            && int.TryParse(col.Key[..4], out int yy)
            && int.TryParse(col.Key[4..], out int ww))
        {
            ww -= 1;
            if (ww < 1) { yy -= 1; ww = System.Globalization.ISOWeek.GetWeeksInYear(yy); }
            return "W" + ww;
        }
        return col.Header;
    }

    private double DetailSortValue(NgRateReportService.LineShiftNgDetail d)
    {
        var (k, b) = SortRefKey();
        if (string.IsNullOrEmpty(k)) return 0;
        return b switch
        {
            "week" => d.WeekPpm.GetValueOrDefault(k),
            "date" => d.DatePpm.GetValueOrDefault(k),
            _      => 0,
        };
    }

    /// <summary>true when the given line-shift has at least one non-zero PPM across all visible period columns.</summary>
    private bool MemberHasAnyData(string lineShift)
    {
        if (_reportByModel is null || _report is null) return false;
        var rows = _reportByModel.GroupSummary.GetValueOrDefault(lineShift);
        var tot  = rows?.FirstOrDefault(r => r.IsTotal);
        if (tot is null) return false;
        foreach (var col in VisibleDateCols)  if (tot.Ppm.GetValueOrDefault(col.Key) > 0) return true;
        foreach (var col in VisibleWeekCols)  if (tot.Ppm.GetValueOrDefault(col.Key) > 0) return true;
        foreach (var col in VisibleMonthCols) if (tot.Ppm.GetValueOrDefault(col.Key) > 0) return true;
        return false;
    }

    /// <summary>
    /// 중그룹 PPM — per-model과 동일하게 서비스의 combo-merged 결과 사용.
    /// processType=null 이면 Total, 아니면 해당 ProcessType row의 PPM.
    /// </summary>
    private double MidGroupPpm(string groupName, string material, string colKey, string? processType = null)
    {
        if (_reportByMid is null) return 0;
        string key  = $"{groupName}::{material}";
        var rows = _reportByMid.GroupSummary.GetValueOrDefault(key);
        if (rows is null) return 0;
        var row = processType is null
            ? rows.FirstOrDefault(r => r.IsTotal)
            : rows.FirstOrDefault(r => !r.IsTotal && r.ProcessType == processType);
        if (row is null) return 0;
        return row.Ppm.GetValueOrDefault(colKey);
    }

    /// <summary>대그룹 PPM — 멤버 중그룹들의 processType별 PPM 평균 (값>0만).</summary>
    private double MeanOfMembers(string groupName, string colKey, string? processType)
    {
        var grp = _groups.FirstOrDefault(g => g.Name == groupName);
        if (grp is null || grp.MidGroups.Count == 0 || _reportByMid is null) return 0;

        double sum = 0;
        int    cnt = 0;
        foreach (var mid in grp.MidGroups)
        {
            double v = MidGroupPpm(groupName, mid.Material, colKey, processType);
            if (v <= 0) continue;
            sum += v;
            cnt++;
        }
        return cnt == 0 ? 0 : sum / cnt;
    }

    private bool HasUsableDb =>
        (!string.IsNullOrEmpty(_savedDbPath) && File.Exists(_savedDbPath)) ||
        NgRateReportSvc.FindMostRecentDb() is { Length: > 0 };

    protected override void OnInitialized()
    {
        ReloadGroups();
    }

    private void ReloadGroups()
    {
        _groups = Repo.GetModelGroups();
        _selectedGroupNames.RemoveWhere(n => !_groups.Any(g => g.Name == n));
    }

    private void SelectAllGroups()
    {
        _selectedGroupNames = new HashSet<string>(_groups.Select(g => g.Name), StringComparer.Ordinal);
    }

    private void ClearSelectedGroups() => _selectedGroupNames.Clear();

    private void ToggleGroup(string name, bool sel)
    {
        if (sel) _selectedGroupNames.Add(name);
        else     _selectedGroupNames.Remove(name);
    }

    private void SetToday()
    {
        _startDate = DateTime.Today;
        _endDate   = DateTime.Today;
    }

    private async Task GetDataAsync()
    {
        if (_endDate < _startDate)
        {
            _errorMessage = "End date must be on or after start date.";
            return;
        }
        _errorMessage = string.Empty;
        _savedDbPath  = null;
        _isBusy       = true;
        StateHasChanged();

        var progress = new Progress<string>(_ => { });

        try
        {
            string? dbPath = await NgRate.FetchAndSaveAsync(_startDate, _endDate, progress);
            if (string.IsNullOrEmpty(dbPath))
                _errorMessage = "Fetch failed — check credentials / logs.";
            else
                _savedDbPath = dbPath;
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isBusy = false;
            StateHasChanged();
        }
    }

    private async Task GetReportAsync()
    {
        if (_isReportBusy || _selectedGroupNames.Count == 0) return;
        _isReportBusy  = true;
        _reportError   = string.Empty;
        _report        = null;
        _reportByMid   = null;
        _reportByModel = null;
        _lsNgReport    = null;
        _midNgReport   = null;
        StateHasChanged();

        try
        {
            string? dbPath = _savedDbPath ?? NgRateReportSvc.FindMostRecentDb();
            if (string.IsNullOrEmpty(dbPath) || !File.Exists(dbPath))
            {
                _reportError = "No .db file found. Run Get Data first.";
                return;
            }

            var mapping      = new Dictionary<string, string>(StringComparer.Ordinal); // LS → 대그룹
            var midMapping   = new Dictionary<string, string>(StringComparer.Ordinal); // LS → 중그룹 (Material)
            var modelMapping = new Dictionary<string, string>(StringComparer.Ordinal); // LS → LS (per-LS pseudo-group)
            var groupList    = new List<string>();
            var midList      = new List<string>();
            var modelList    = new List<string>();
            foreach (var g in _groups.Where(g => _selectedGroupNames.Contains(g.Name)))
            {
                groupList.Add(g.Name);
                foreach (var mid in g.MidGroups)
                {
                    string matKey = $"{g.Name}::{mid.Material}"; // namespace by 대그룹 to avoid clashes
                    if (!midList.Contains(matKey)) midList.Add(matKey);
                    foreach (var ls in mid.LineShifts)
                    {
                        if (string.IsNullOrEmpty(ls)) continue;
                        mapping[ls]      = g.Name;
                        midMapping[ls]   = matKey;
                        modelMapping[ls] = ls;
                        if (!modelList.Contains(ls)) modelList.Add(ls);
                    }
                }
            }

            if (mapping.Count == 0)
            {
                _reportError = "No LineShift found in the selected groups.";
                return;
            }

            var progress = new Progress<string>(_ => { });
            _report        = await NgRateReportSvc.GenerateReportAsync(dbPath, mapping,      groupList, progress);
            _reportByMid   = await NgRateReportSvc.GenerateReportAsync(dbPath, midMapping,   midList,   progress);
            _reportByModel = await NgRateReportSvc.GenerateReportAsync(dbPath, modelMapping, modelList, progress);
            _lsNgReport    = await NgRateReportSvc.ComputeLineShiftNgDetailsAsync(dbPath, modelList, progress);
            _midNgReport   = await NgRateReportSvc.ComputeGroupedNgDetailsAsync(dbPath, midMapping, progress);
            _pendingChartRender = true;
        }
        catch (Exception ex)
        {
            _reportError = $"Error: {ex.Message}";
        }
        finally
        {
            _isReportBusy = false;
            StateHasChanged();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_pendingChartRender && _report is not null && _reportByModel is not null
            && _selectedGroupNames.Count > 0)
        {
            _pendingChartRender = false;

            // Build combined period list — keep service's DESC order (newest → oldest) per block.
            // Each entry: (label, keyOrNull). Null key = separator position.
            var periodCells = new List<(string Label, string? Key)>();
            if (VisibleDateCols.Count > 0)
                periodCells.AddRange(VisibleDateCols.Select(c => (c.Header, (string?)c.Key)));
            if (VisibleWeekCols.Count > 0)
            {
                if (periodCells.Count > 0) periodCells.Add(("", null));
                periodCells.AddRange(VisibleWeekCols.Select(c => (c.Header, (string?)c.Key)));
            }
            if (VisibleMonthCols.Count > 0)
            {
                if (periodCells.Count > 0) periodCells.Add(("", null));
                periodCells.AddRange(VisibleMonthCols.Select(c => (c.Header, (string?)c.Key)));
            }

            if (periodCells.Count == 0) return;

            var labels = periodCells.Select(p => p.Label).ToArray();

            var grpSeries = _selectedGroupNames.Select(g => new
            {
                name   = g,
                values = periodCells.Select(p =>
                {
                    if (p.Key is null) return (double?)null; // separator
                    double v = MeanOfMembers(g, p.Key, null);
                    return v > 0 ? (double?)v : null;
                }).ToArray(),
            }).ToArray();

            try
            {
                await JS.InvokeVoidAsync("ngRateGroupChart.render", CanvasId,      labels, grpSeries);
                await JS.InvokeVoidAsync("ngRateGroupChart.render", CanvasIdModel, labels, grpSeries);
            }
            catch { }
        }
    }

    public async ValueTask DisposeAsync()
    {
        try { await JS.InvokeVoidAsync("ngRateGroupChart.destroy", CanvasId); }      catch { }
        try { await JS.InvokeVoidAsync("ngRateGroupChart.destroy", CanvasIdModel); } catch { }
    }

    private void ToggleExpand(string name)
    {
        if (!_expandedGroups.Remove(name)) _expandedGroups.Add(name);
    }

    private void ToggleExpandModel(string name)
    {
        if (!_expandedGroupsModel.Remove(name)) _expandedGroupsModel.Add(name);
    }

    private void ToggleExpandMid(string midKey)
    {
        if (!_expandedMids.Remove(midKey)) _expandedMids.Add(midKey);
    }

    private static string FormatPpm(double v)
        => v == 0 ? "-" : ((long)Math.Round(v)).ToString("N0");

    private static int ProcessTypeRank(string pt) => pt switch
    {
        "SUB"      => 1,
        "MAIN"     => 2,
        "FUNCTION" => 3,
        "VISUAL"   => 4,
        _          => pt.StartsWith("SUB") ? 1 : 5,
    };
}
