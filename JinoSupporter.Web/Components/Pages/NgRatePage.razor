    /// <summary>Builds the (LineShift → GroupName) mapping + group list for the DB-overload
    /// of NgRateReportService.GenerateReportAsync. Produces the same shape the JSON path
    /// used to produce, so the report output is identical.</summary>
    private static (Dictionary<string, string> mapping, List<string> groups) BuildGroupMapping(
        IEnumerable<ModelGroupRecord> selected)
    {
        var mapping = new Dictionary<string, string>(StringComparer.Ordinal);
        var groups  = new List<string>();
        foreach (var g in selected)
        {
            if (!groups.Contains(g.Name)) groups.Add(g.Name);
            foreach (var mid in g.MidGroups)
                foreach (var ls in mid.LineShifts)
                    if (!string.IsNullOrEmpty(ls))
                        mapping[ls] = g.Name;
        }
        return (mapping, groups);
    }

    /// <summary>
    /// Builds a multi-valued mapping so each LineShift contributes to every level of
    /// the hierarchy it belongs to. The returned <c>groups</c> list defines the drill-down
    /// row order shown under each ProcessType in the Summary:
    ///   1) root group name (the whole ModelGroup),
    ///   2) each mid-group (Material) that holds LineShifts,
    ///   3) every named sub-group (DFS pre-order, all depths),
    ///   4) individual LineShift leaves (DFS leaf order).
    /// A sub-group's row is de-duplicated against the mid-group row above it when both
    /// labels match exactly, to avoid a double row when a named sub-group shares the
    /// same label as its material.
    /// </summary>
    private static (Dictionary<string, IReadOnlyList<string>> mapping, List<string> groups)
        BuildTreeMultiMapping(ModelGroupRecord g)
    {
        var raw    = new Dictionary<string, List<string>>(StringComparer.Ordinal);
        var groups = new List<string>();

        void Attach(string ls, string group)
        {
            if (string.IsNullOrEmpty(group)) return;
            if (!raw.TryGetValue(ls, out var list))
            {
                list = new List<string>();
                raw[ls] = list;
            }
            if (!list.Contains(group, StringComparer.Ordinal)) list.Add(group);
            if (!groups.Contains(group, StringComparer.Ordinal)) groups.Add(group);
        }

        // 1) Root
        var allLs = g.MidGroups
            .SelectMany(m => m.SubGroups.SelectMany(s => s.AllLineShifts))
            .Where(ls => !string.IsNullOrEmpty(ls))
            .Distinct(StringComparer.Ordinal)
            .ToList();
        if (allLs.Count == 0)
        {
            return (new Dictionary<string, IReadOnlyList<string>>(StringComparer.Ordinal), groups);
        }
        foreach (var ls in allLs) Attach(ls, g.Name);

        // 2) Mid-groups (Material) — only when more than one mid-group OR the single
        // mid-group's label differs from the root group name (avoid a redundant duplicate row).
        bool includeMids = g.MidGroups.Count > 1
            || (g.MidGroups.Count == 1 &&
                !string.Equals(g.MidGroups[0].Material, g.Name, StringComparison.Ordinal));
        if (includeMids)
        {
            foreach (var mid in g.MidGroups)
            {
                if (string.IsNullOrEmpty(mid.Material)) continue;
                foreach (var ls in mid.SubGroups.SelectMany(s => s.AllLineShifts))
                    if (!string.IsNullOrEmpty(ls)) Attach(ls, mid.Material);
            }
        }

        // 3) Named sub-groups (DFS pre-order, "parent / child" labels)
        foreach (var mid in g.MidGroups)
            foreach (var sub in mid.SubGroups)
                CollectSubGroupMulti(sub, prefix: string.Empty, Attach);

        // 4) Individual LineShifts (DFS leaf order)
        foreach (var mid in g.MidGroups)
            foreach (var sub in mid.SubGroups)
                CollectLineShiftLeaves(sub, Attach);

        var ro = raw.ToDictionary(
            kv => kv.Key,
            kv => (IReadOnlyList<string>)kv.Value,
            StringComparer.Ordinal);
        return (ro, groups);
    }

    private static void CollectSubGroupMulti(SubGroupRecord node, string prefix, Action<string, string> attach)
    {
        string label = string.IsNullOrEmpty(prefix)
            ? (node.Name ?? string.Empty)
            : prefix + " / " + (node.Name ?? string.Empty);

        if (!string.IsNullOrEmpty(node.Name))
        {
            foreach (var ls in node.AllLineShifts)
                if (!string.IsNullOrEmpty(ls)) attach(ls, label);
        }

        foreach (var child in node.SubGroups)
        {
            string childPrefix = string.IsNullOrEmpty(node.Name) ? prefix : label;
            CollectSubGroupMulti(child, childPrefix, attach);
        }
    }

    private static void CollectLineShiftLeaves(SubGroupRecord node, Action<string, string> attach)
    {
        foreach (var ls in node.LineShifts)
            if (!string.IsNullOrEmpty(ls)) attach(ls, ls);
        foreach (var child in node.SubGroups)
            CollectLineShiftLeaves(child, attach);
    }

    /// <summary>Resolves a <see cref="ChildEntry.Key"/> into a scoped multi-mapping:
    /// the mid-group becomes the synthetic "root" of its own drill-down tree.</summary>
    private (string label,
             Dictionary<string, IReadOnlyList<string>> multi,
             List<string> groupList)? BuildChildEntryReport(string key)
    {
        var parts = key.Split('|');
        if (parts.Length != 3 || parts[1] != "mid") return null;
        if (!long.TryParse(parts[0], out long gid)) return null;
        var g = _dbGroups.FirstOrDefault(x => x.Id == gid);
        if (g is null) return null;

        string material = parts[2];
        var mid = g.MidGroups.FirstOrDefault(m => m.Material == material);
        if (mid is null) return null;
        var virt = new ModelGroupRecord
        {
            Id           = g.Id,
            Name         = material,
            ProductGroup = g.ProductGroup,
            MidGroups    = new List<MidGroupRecord> { mid },
        };
        var (multi, groupList) = BuildTreeMultiMapping(virt);
        return (material, multi, groupList);
    }

    // ── Get Data ──────────────────────────────────────────────────────────────────

    private void SetToday()
    {
        _startDate = DateTime.Today;
        _endDate   = DateTime.Today;
    }

    private async Task GetDataAsync()
    {
        if (_endDate < _startDate)
        {
            _errorMessage = "End date must be on or after start date.";
            return;
        }

        _isBusy       = true;
        _errorMessage = null;
        _savedDbPath  = null;
        _logs.Clear();

        var progress = new Progress<string>(msg =>
        {
            _logs.Add($"[{DateTime.Now:HH:mm:ss}] {msg}");
            InvokeAsync(StateHasChanged);
        });

        try
        {
            string? dbPath = await NgRate.FetchAndSaveAsync(
                _startDate, _endDate, progress);

            if (string.IsNullOrEmpty(dbPath))
                _errorMessage = "Data fetch or save failed — check the log.";
            else
            {
                _savedDbPath = dbPath;
                RefreshGroups();
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Exception: {ex.Message}";
            _logs.Add($"[{DateTime.Now:HH:mm:ss}] [ERROR] {ex}");
        }
        finally
        {
            _isBusy = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void ClearResult()
    {
        _savedDbPath  = null;
        _errorMessage = null;
    }

    // ── Get Report ────────────────────────────────────────────────────────────────

    private async Task GetReportAsync()
    {
        _reportError     = string.Empty;
        _reports.Clear();
        _activeReportTab = 0;
        _isReportBusy    = true;
        _logs.Clear();
        _expandedSummary.Clear();
        _expandedProcess.Clear();
        _expandedNg.Clear();
        _expandedReason.Clear();
        _collapsedReasonCategory.Clear();
        _dateExpanded  = false;
        _weekExpanded  = false;
        _monthExpanded = false;
        await InvokeAsync(StateHasChanged);

        IProgress<string> progress = new Progress<string>(msg =>
        {
            _logs.Add($"[{DateTime.Now:HH:mm:ss}] {msg}");
            InvokeAsync(StateHasChanged);
        });

        try
        {
            string? dbPath = _savedDbPath ?? NgRateReport.FindMostRecentDb();
            if (string.IsNullOrEmpty(dbPath) || !File.Exists(dbPath))
            {
                _reportError = "No .db file found. Run Get Data first.";
                return;
            }

            progress.Report($"Using DB: {Path.GetFileName(dbPath)}");

            if (_selectedGroupIds.Count == 0 && _selectedSubEntries.Count == 0)
            {
                // No selection → single "All" report across every group (no tree expansion).
                var (mapping, groupList) = BuildGroupMapping(_dbGroups);
                if (mapping.Count == 0)
                {
                    _reportError = "No LineShift found in the selected groups.";
                    return;
                }
                var r = await NgRateReport.GenerateReportAsync(dbPath, mapping, groupList, progress);
                _reports.Add(("All", r));
            }
            else
            {
                // Whole-group selections: full-tree drill-down.
                foreach (var g in _dbGroups
                    .Where(g => _selectedGroupIds.Contains(g.Id))
                    .OrderBy(g => g.Name, StringComparer.Ordinal))
                {
                    progress.Report($"─── {g.Name}");
                    var (multi, groupList) = BuildTreeMultiMapping(g);
                    if (multi.Count == 0)
                    {
                        progress.Report($"  (skipped: no LineShift)");
                        continue;
                    }
                    var r = await NgRateReport.GenerateReportAsync(dbPath, multi, groupList, progress);
                    _reports.Add((g.Name, r));
                }

                // First-level child selections (mid-group Material or top-level named sub-group):
                // scoped drill-down over just that sub-tree.
                foreach (string key in _selectedSubEntries.OrderBy(k => k, StringComparer.Ordinal))
                {
                    var spec = BuildChildEntryReport(key);
                    if (spec is null)
                    {
                        progress.Report($"─── {key}  (skipped: not found)");
                        continue;
                    }
                    progress.Report($"─── {spec.Value.label}");
                    var r = await NgRateReport.GenerateReportAsync(
                        dbPath, spec.Value.multi, spec.Value.groupList, progress);
                    _reports.Add((spec.Value.label, r));
                }

                if (_reports.Count == 0)
                {
                    _reportError = "No LineShift found in the selected groups.";
                    return;
                }
            }

            _pendingChartRender = true;
            // Fresh reports → caches may reference stale rows from the prior report.
            _selectedChips.Clear();
            RebuildCombinedRaw();
            RebuildRowPpmCache();
        }
        catch (Exception ex)
        {
            _reportError = $"Error: {ex.Message}";
            _logs.Add($"[{DateTime.Now:HH:mm:ss}] [ERROR] {ex}");
        }
        finally
        {
            _isReportBusy = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task ExportExcelAsync()
    {
        if (_reports.Count == 0 || _isExporting) return;
        _isExporting = true;
        try
        {
            var bytes   = await Task.Run(() => NgRateExcelExporter.Export(_reports));
            string b64  = Convert.ToBase64String(bytes);
            string name = $"NgRate_{DateTime.Now:yyyyMMdd_HHmmss}.xlsx";
            await JS.InvokeVoidAsync("downloadBase64File", name, b64,
                "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
        }
        finally
        {
            _isExporting = false;
        }
    }

    private async Task SwitchReportTab(int idx)
    {
        try { await JS.InvokeVoidAsync("ngRateChart.destroy", $"summaryChart_{_activeReportTab}"); } catch { }
        _activeReportTab = idx;
        _expandedProcess.Clear();
        _expandedNg.Clear();
        _expandedReason.Clear();
        _collapsedReasonCategory.Clear();
        _pendingChartRender = true;
        // Chip selection is per-session, not per-tab — rebuild caches from the newly
        // active report so multi-chip totals reflect the tab's own raw data.
        RebuildCombinedRaw();
        RebuildRowPpmCache();
    }

    // ── Utilities ─────────────────────────────────────────────────────────────────

    private static string GetLogClass(string line)
    {
        if (line.Contains("[ERROR]")) return "text-danger";
        if (line.Contains("[WARN]"))  return "text-warning";
        if (line.Contains("───")) return "text-info fw-semibold";
        if (line.Contains("Done") || line.Contains("done") ||
            line.Contains("complete", StringComparison.OrdinalIgnoreCase) ||
            line.Contains("Report"))
            return "text-success";
        return string.Empty;
    }
}
