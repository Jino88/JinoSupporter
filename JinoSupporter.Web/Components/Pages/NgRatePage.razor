    private HashSet<string> _expandedSummary = new();
    private HashSet<int>    _expandedProcess = new();
    private HashSet<int>    _expandedNg      = new();

    // Group names the user hid from the Summary expansion rows. Hiding is global
    // across all ProcessType sections (hiding C1120-D3-L removes its ↳ row from
    // TOTAL, SUB, MAIN, FUNCTION, and VISUAL). Cleared via the Clear-hidden
    // button in the card header; does not affect chart or totals.
    private HashSet<string> _hiddenGroups = new(StringComparer.Ordinal);

    private void HideGroup(string grp)
    {
        if (_hiddenGroups.Add(grp)) StateHasChanged();
    }

    private void ClearHiddenGroups()
    {
        if (_hiddenGroups.Count == 0) return;
        _hiddenGroups.Clear();
        StateHasChanged();
    }

    // Retained-but-unused chip state (the chip UI was replaced by per-row hide
    // buttons; filter helpers below all take the no-chip fast path and behave as
    // a pass-through over the original report data).
    private HashSet<string> _selectedChips = new(StringComparer.Ordinal);

    private bool NoChipSelected => _selectedChips.Count == 0;

    private void OnChipSelectionChanged()
    {
        // Expansion rows are meaningless when scoped to a selection — clear them.
        _expandedSummary.Clear();
        _expandedProcess.Clear();
        _expandedNg.Clear();
        _pendingChartRender = true;
        RebuildCombinedRaw();
        RebuildRowPpmCache();
    }

    // Per-row combined PPM, pre-computed once whenever chip selection changes.
    // Keyed by the row object reference so Reason Total rows — which can't be
    // derived from a single (PT, PN, NG) triple — get their PPM as the sum of
    // their Reason's combo-row combined PPMs.
    private readonly Dictionary<object, Dictionary<string, double>> _combinedRowPpm = new();

    private void RebuildRowPpmCache()
    {
        _combinedRowPpm.Clear();
        if (_report is null || _selectedChips.Count < 2) return;

        foreach (var row in _report.Top10Process)
            _combinedRowPpm[row] = ComputeCombinedPpmByFilter(
                (pt, pn, _) => pt == row.ProcessType && pn == row.ProcessName);

        foreach (var row in _report.Top10Ng)
            _combinedRowPpm[row] = ComputeCombinedPpmByFilter(
                (pt, pn, ng) => pt == row.ProcessType && pn == row.ProcessName && ng == row.NgName);

        // Reason combos first; each Reason's Total row is the period-wise sum of its
        // combo-row combined PPMs (matches within-Reason additive semantics).
        foreach (var grp in _report.ReasonRows.GroupBy(r => r.Reason))
        {
            var comboPpms = new List<Dictionary<string, double>>();
            foreach (var c in grp.Where(r => !r.IsTotal))
            {
                var ppm = ComputeCombinedPpmByFilter(
                    (pt, pn, ng) => pt == c.ProcessType && pn == c.ProcessName && ng == c.NgName);
                _combinedRowPpm[c] = ppm;
                comboPpms.Add(ppm);
            }
            var total = grp.FirstOrDefault(r => r.IsTotal);
            if (total is not null)
            {
                var totalPpm = new Dictionary<string, double>(StringComparer.Ordinal);
                foreach (var p in comboPpms)
                    foreach (var (k, v) in p)
                        totalPpm[k] = totalPpm.GetValueOrDefault(k) + v;
                _combinedRowPpm[total] = totalPpm;
            }
        }
    }

    // Cache of per-(PT, PN, NG) → per-period summed (Input, NG) across the current
    // chip selection. Rebuilt whenever the selection changes so that subsequent
    // row-level PPM queries are O(1) filter hits over this small indexed dict.
    private Dictionary<(string PT, string PN, string NG), Dictionary<string, (double I, double N)>> _combinedRaw
        = new();

    private void RebuildCombinedRaw()
    {
        _combinedRaw.Clear();
        if (_report is null || _selectedChips.Count < 2) return;
        foreach (var kv in _report.GroupRawIn)
        {
            if (!_selectedChips.Contains(kv.Key.Group)) continue;
            var rowKey = (kv.Key.PT, kv.Key.PN, kv.Key.NG);
            if (!_combinedRaw.TryGetValue(rowKey, out var perPeriod))
            {
                perPeriod = new Dictionary<string, (double I, double N)>(StringComparer.Ordinal);
                _combinedRaw[rowKey] = perPeriod;
            }
            var prev = perPeriod.GetValueOrDefault(kv.Key.PeriodKey);
            perPeriod[kv.Key.PeriodKey] = (prev.I + kv.Value.I, prev.N + kv.Value.N);
        }
    }

    // Re-aggregates PPM correctly from raw Σinput / Σng across selected chips.
    // filter: decide whether each row-key (PT, PN, NG) contributes to the
    // requested aggregation. Per-key combined PPM = Σng / Σinput · 1M, then summed
    // across qualifying keys — mirrors the within-group NgName-sum semantic of the
    // original ComputeGroupSummary so single-chip and multi-chip values stay
    // comparable.
    private Dictionary<string, double> ComputeCombinedPpmByFilter(
        Func<string /*PT*/, string /*PN*/, string /*NG*/, bool> filter)
    {
        var result = new Dictionary<string, double>(StringComparer.Ordinal);
        foreach (var (rowKey, perPeriod) in _combinedRaw)
        {
            if (!filter(rowKey.PT, rowKey.PN, rowKey.NG)) continue;
            foreach (var (periodKey, raw) in perPeriod)
            {
                if (raw.I <= 0) continue;
                double ppm = raw.N / raw.I * 1_000_000;
                result[periodKey] = result.GetValueOrDefault(periodKey) + ppm;
            }
        }
        return result;
    }

    // Merge PPM dicts from multiple sources by per-key sum.
    private static Dictionary<string, double> CombinePpm(IEnumerable<Dictionary<string, double>> dicts)
    {
        var result = new Dictionary<string, double>(StringComparer.Ordinal);
        foreach (var d in dicts)
            if (d is not null)
                foreach (var (k, v) in d)
                    result[k] = result.GetValueOrDefault(k) + v;
        return result;
    }

    // Scale every PPM value by 1/divisor. Used to turn a chip-wise SUM into an
    // arithmetic mean so that selecting two similar groups doesn't double the
    // displayed defect rate. Divisor of 0/1 returns the input unchanged.
    private static Dictionary<string, double> ScalePpm(
        Dictionary<string, double> src, int divisor)
    {
        if (divisor <= 1) return src;
        var result = new Dictionary<string, double>(src.Count, StringComparer.Ordinal);
        double inv = 1.0 / divisor;
        foreach (var (k, v) in src) result[k] = v * inv;
        return result;
    }

    // Effective Summary row list. Combined multi-chip view is rebuilt from raw
    // Input/NG per (PT, PN, NG, G, period) so the displayed PPM is the TRUE
    // merged defect rate (Σng / Σinput · 1M), not an average of pre-computed
    // per-group PPMs.
    private IReadOnlyList<NgRateReportService.SummaryPivotRow> EffectiveSummary
    {
        get
        {
            if (_report is null)
                return Array.Empty<NgRateReportService.SummaryPivotRow>();
            if (NoChipSelected)
                return _report.Summary;
            if (_selectedChips.Count == 1
                && _report.GroupSummary.TryGetValue(_selectedChips.First(), out var singleRows))
                return singleRows;

            // Multi-chip: recompute per-ProcessType PPM from combined raw data.
            var ptOrder = _report.Summary
                .Where(r => !r.IsTotal)
                .Select(r => r.ProcessType)
                .ToList();

            var rebuilt = new List<NgRateReportService.SummaryPivotRow>();
            var totalPpm = new Dictionary<string, double>(StringComparer.Ordinal);
            foreach (string pt in ptOrder)
            {
                var ppm = ComputeCombinedPpmByFilter((p, _, _) => p == pt);
                rebuilt.Add(new NgRateReportService.SummaryPivotRow
                {
                    ProcessType = pt,
                    IsTotal     = false,
                    Ppm         = ppm,
                });
                foreach (var (k, v) in ppm)
                    totalPpm[k] = totalPpm.GetValueOrDefault(k) + v;
            }
            rebuilt.Insert(0, new NgRateReportService.SummaryPivotRow
            {
                ProcessType = "TOTAL",
                IsTotal     = true,
                Ppm         = totalPpm,
            });
            return rebuilt;
        }
    }

    // Picks the right Ppm dict for a Top-10 / Reason row given the current chip set.
    //   No chips     → row's overall Ppm (everything combined, server-computed).
    //   Single chip  → that group's own Ppm from row.Groups.
    //   Multi chips  → input-weighted Σng/Σinput re-aggregation cached by rowRef.
    private Dictionary<string, double> PpmForRow(
        object rowRef,
        Dictionary<string, double> overallPpm,
        IReadOnlyList<NgRateReportService.GroupPivotRow> groups)
    {
        if (NoChipSelected) return overallPpm;
        if (_selectedChips.Count == 1)
        {
            string only = _selectedChips.First();
            var g = groups.FirstOrDefault(x => x.GroupName == only);
            return g?.Ppm ?? new Dictionary<string, double>();
        }
        return _combinedRowPpm.GetValueOrDefault(rowRef) ?? new Dictionary<string, double>();
    }

    // A group "has data" when its Summary TOTAL row contains at least one non-zero
    // PPM across all visible periods. Empty groups are disabled as chips.
    private bool GroupHasData(string grp)
    {
        if (_report is null) return false;
        if (!_report.GroupSummary.TryGetValue(grp, out var rows)) return false;
        foreach (var r in rows)
            foreach (var v in r.Ppm.Values)
                if (v > 0) return true;
        return false;
    }

    // Sort-reference key for re-ranking when a chip is active. Mirrors the
    // NgRateByGroupPage convention: previous week (Week[1]) if ≥2 weeks are
    // visible, else current week, else most-recent date. Empty key disables re-sort.
    private string SortRefKey()
    {
        var weeks = VisibleWeekCols.ToList();
        var dates = VisibleDateCols.ToList();
        if (weeks.Count >= 2) return weeks[1].Key;
        if (weeks.Count == 1) return weeks[0].Key;
        if (dates.Count > 0)  return dates[0].Key;
        return "";
    }

    // Chip-scoped prior-week PPM used as the re-sort key for Top-10 / Reason rows.
    private double RefPpmForRow(
        object rowRef,
        Dictionary<string, double> overallPpm,
        IReadOnlyList<NgRateReportService.GroupPivotRow> groups)
    {
        string k = SortRefKey();
        if (string.IsNullOrEmpty(k)) return 0;
        return PpmForRow(rowRef, overallPpm, groups).GetValueOrDefault(k);
    }

    // Re-ranked top-10 rows: unchanged when no chip is selected, otherwise
    // sorted by the chip's previous-week PPM descending.
    private IReadOnlyList<NgRateReportService.ProcessPivotRow> SortedTop10Process
    {
        get
        {
            if (_report is null) return Array.Empty<NgRateReportService.ProcessPivotRow>();
            if (NoChipSelected) return _report.Top10Process;
            return _report.Top10Process
                .OrderByDescending(r => RefPpmForRow(r, r.Ppm, r.Groups))
                .ToList();
        }
    }

    private IReadOnlyList<NgRateReportService.NgPivotRow> SortedTop10Ng
    {
        get
        {
            if (_report is null) return Array.Empty<NgRateReportService.NgPivotRow>();
            if (NoChipSelected) return _report.Top10Ng;
            return _report.Top10Ng
                .OrderByDescending(r => RefPpmForRow(r, r.Ppm, r.Groups))
                .ToList();
        }
    }

    // Re-ranked Reason rows: keeps each Reason's Total row at the top of its
    // section, sorts combo rows within a section by chip-scoped prior-week PPM
    // descending, and orders whole Reason sections by their Total's ref PPM.
    // Non-Total rows whose chip-scoped PPM is entirely zero across the period
    // are hidden.
    private IReadOnlyList<NgRateReportService.ReasonRow> SortedReasonRows
    {
        get
        {
            if (_report is null) return Array.Empty<NgRateReportService.ReasonRow>();

            bool HasAnyPpm(NgRateReportService.ReasonRow r)
                => PpmForRow(r, r.Ppm, r.Groups).Values.Any(v => v > 0);

            if (NoChipSelected)
                return _report.ReasonRows
                    .Where(r => r.IsTotal || HasAnyPpm(r))
                    .ToList();

            var byReason = _report.ReasonRows
                .GroupBy(r => r.Reason)
                .Select(g =>
                {
                    var list = g.ToList();
                    var total = list.FirstOrDefault(r => r.IsTotal);
                    var combos = list.Where(r => !r.IsTotal && HasAnyPpm(r))
                        .OrderByDescending(r => RefPpmForRow(r, r.Ppm, r.Groups))
                        .ToList();
                    double totalPpm = total is null ? combos.Sum(r => RefPpmForRow(r, r.Ppm, r.Groups))
                                                   : RefPpmForRow(total, total.Ppm, total.Groups);
                    return (TotalPpm: totalPpm, Total: total, Combos: combos);
                })
                .OrderByDescending(x => x.TotalPpm)
                .ToList();

            var result = new List<NgRateReportService.ReasonRow>();
            foreach (var section in byReason)
            {
                if (section.Total is not null) result.Add(section.Total);
                result.AddRange(section.Combos);
            }
            return result;
        }
    }
