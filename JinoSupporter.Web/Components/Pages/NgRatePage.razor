@page "/ng-rate"
@rendermode InteractiveServer
@using JinoSupporter.Web.Services
@inject NgRateService         NgRate
@inject NgRateSettingsService NgRateSettings
@inject NgRateReportService   NgRateReport
@inject WebRepository         Repo
@inject IJSRuntime            JS
@implements IAsyncDisposable

<PageTitle>NG Rate</PageTitle>

<style>
    .ngrate-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        grid-template-rows: auto auto;
        gap: 16px;
    }
    .ngrate-cell-tl { grid-column: 1; grid-row: 1; }
    .ngrate-cell-tr { grid-column: 2; grid-row: 1; }
    .ngrate-cell-bl { grid-column: 1; grid-row: 2; }
    .ngrate-cell-br { grid-column: 2; grid-row: 2; }
    @@media (max-width: 700px) {
        .ngrate-grid { grid-template-columns: 1fr; }
        .ngrate-cell-tl, .ngrate-cell-tr,
        .ngrate-cell-bl, .ngrate-cell-br { grid-column: 1; grid-row: auto; }
    }
    .json-file-item {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 3px 6px;
        border-radius: 4px;
        font-size: 12px;
        font-family: monospace;
        color: #334155;
        cursor: pointer;
    }
    .json-file-item:hover { background: #f1f5f9; }
    .json-file-item .file-date { font-size: 10px; color: #94a3b8; margin-left: auto; }
    .json-file-item input[type=checkbox] { cursor: pointer; flex-shrink: 0; }
    .json-file-item.sub-row { padding-left: 22px; color: #64748b; font-size: 11px; }
    .json-file-item.sub-row .file-date { color: #cbd5e1; }
    /* Product group tabs in Model Files */
    .pg-tab {
        font-size: 10px; font-weight: 700; letter-spacing: .4px;
        padding: 2px 9px; border-radius: 10px; border: 1.5px solid #cbd5e1;
        background: #f8fafc; color: #64748b; cursor: pointer; white-space: nowrap;
        transition: all .15s;
    }
    .pg-tab:hover { border-color: #6366f1; color: #6366f1; }
    .pg-tab.active { background: #6366f1; border-color: #4f46e5; color: #fff; }
    .pg-section-label {
        font-size: 10px; font-weight: 700; letter-spacing: .4px;
        padding: 1px 6px; border-radius: 4px; flex-shrink: 0;
    }
    .pg-SPK    { background:#fef9c3; color:#854d0e; }
    .pg-UNIT   { background:#dcfce7; color:#166534; }
    .pg-MODULE { background:#dbeafe; color:#1e40af; }
    .pg-TWS    { background:#fce7f3; color:#9d174d; }
    .pg-ETC    { background:#f1f5f9; color:#475569; }

    /* Delete-files confirm modal */
    .ngrate-del-overlay {
        position: fixed; inset: 0; background: rgba(0,0,0,.45); z-index: 9500;
        display: flex; align-items: center; justify-content: center;
    }
    .ngrate-del-dialog {
        background: #fff; border-radius: 10px; padding: 0;
        box-shadow: 0 10px 40px rgba(0,0,0,.25);
        min-width: 420px; max-width: 80vw; max-height: 80vh;
        display: flex; flex-direction: column;
    }
    .ngrate-del-head {
        padding: 12px 16px; border-bottom: 1px solid #e2e8f0;
        font-size: 14px; font-weight: 700; color: #b91c1c;
    }
    .ngrate-del-body { flex: 1; overflow: auto; padding: 12px 16px; }
    .ngrate-del-foot {
        display: flex; gap: 8px; justify-content: flex-end;
        padding: 10px 16px; border-top: 1px solid #e2e8f0;
    }

    /* Pivot report tables */
    .pivot-wrap { overflow-x: auto; }
    .pivot-table { font-size: 11px; white-space: nowrap; border-collapse: collapse; }
    .pivot-table th {
        background: #f1f5f9; font-weight: 600; font-size: 10px;
        padding: 3px 6px; text-align: right; border: 1px solid #e2e8f0;
        position: sticky; top: 0; z-index: 1;
    }
    .pivot-table th.label-th { text-align: left; min-width: 100px; }
    .pivot-table th.sep-th { background: #e2e8f0; width: 8px; padding: 0; border: none; }
    .pivot-table td { padding: 2px 6px; border: 1px solid #e2e8f0; text-align: right; font-family: monospace; }
    .pivot-table td.label-td { text-align: left; min-width: 100px; font-family: inherit; font-size: 11px; }
    .pivot-table td.sep-td { background: #e2e8f0; width: 8px; padding: 0; border: none; }
    .pivot-table td.ppm-zero { color: #cbd5e1; }
    .pivot-table td.ppm-val { font-weight: 600; color: #1e293b; }
    .pivot-table tr.total-row td { background: #eff6ff; font-weight: 700; }
    .pivot-table tr.rank-row:nth-child(odd) td { background: #fafafa; }
    .pivot-table tr.rank-row:hover td { background: #f0f9ff; }
    .pivot-table tr.group-row td { background: #f8fafc; font-size: 10px; color: #64748b; }
    .pivot-table tr.group-row:hover td { background: #f0f4ff; }
    .group-name-td { padding-left: 18px !important; color: #6366f1 !important; font-size: 10px !important; }
    .pt-badge {
        display: inline-block; font-size: 9px; padding: 1px 4px;
        border: 1px solid #cbd5e1; border-radius: 3px; background: #f8fafc;
        color: #475569;
    }
    .toggle-cell {
        cursor: pointer; text-align: center; color: #94a3b8; user-select: none;
    }
    .toggle-cell:hover { color: #6366f1; }
    .toggle-icon { font-size: 9px; margin-right: 2px; }
    .expand-btn {
        font-size: 10px; padding: 0; border: none; background: none;
        color: #94a3b8; cursor: pointer; text-decoration: none;
    }
    .expand-btn:hover { color: #6366f1; }
    .group-chip {
        display: inline-block; font-size: 10px; padding: 2px 7px;
        border-radius: 12px; cursor: pointer; user-select: none;
        border: 1px solid #6366f1; background: #eef2ff; color: #4f46e5;
        transition: background .15s, color .15s;
    }
    .group-chip:hover { background: #e0e7ff; }
    .group-chip.active { background: #6366f1; color: #fff; border-color: #4f46e5; }
    .group-chip.empty  {
        background: #f8fafc; color: #cbd5e1; border-color: #e2e8f0;
        cursor: not-allowed; opacity: .55; text-decoration: line-through;
    }
    .group-chip.empty:hover { background: #f8fafc; }
    .group-chip-clear {
        display: inline-flex; align-items: center; gap: 4px;
        font-size: 10px; font-weight: 600; padding: 2px 9px;
        border-radius: 12px; cursor: pointer; user-select: none;
        border: 1px solid #ef4444; background: #fef2f2; color: #b91c1c;
        transition: background .15s, color .15s;
    }
    .group-chip-clear:hover { background: #fee2e2; }

    /* Row-hide ✕ button shown on each expanded group sub-row */
    .row-hide-cell { width: 22px; text-align: center; padding: 0 !important; }
    .row-hide-btn  {
        width: 16px; height: 16px; padding: 0; line-height: 1;
        font-size: 10px; color: #94a3b8; cursor: pointer;
        background: transparent; border: 1px solid transparent; border-radius: 3px;
    }
    .row-hide-btn:hover { color: #b91c1c; background: #fee2e2; border-color: #fecaca; }
    /* Group detail modal overlay */
    .grp-modal-overlay {
        position: fixed; inset: 0; background: rgba(0,0,0,0.35);
        z-index: 1050; display: flex; align-items: center; justify-content: center;
    }
    .grp-modal-box {
        background: #fff; border-radius: 8px; box-shadow: 0 8px 32px rgba(0,0,0,0.18);
        max-width: 92vw; width: 960px; max-height: 80vh;
        display: flex; flex-direction: column; overflow: hidden;
    }
    .grp-modal-header {
        display: flex; align-items: center; gap: 8px;
        padding: 10px 14px; border-bottom: 1px solid #e2e8f0;
        font-weight: 600; font-size: 13px; flex-shrink: 0;
    }
    .grp-modal-body { overflow: auto; padding: 10px; flex: 1; }
</style>

<div class="d-flex align-items-center gap-2 mb-3">
    <span style="font-size:20px;">📉</span>
    <h5 class="mb-0 fw-semibold">NG Rate</h5>
    <div class="ms-3 btn-group btn-group-sm" role="group" aria-label="View mode">
        <button type="button" class="btn btn-primary" disabled
                title="Current view: By Model — show full Summary/Detail/Chart per model, one at a time">
            🎯 By Model
        </button>
        <a href="/ng-rate-all" class="btn btn-outline-secondary"
           title="Switch to By Section view — multiple models stacked vertically by Summary/Process/NG/Reason sections">
            📑 By Section
        </a>
        <a href="/ng-rate-by-group" class="btn btn-outline-secondary"
           title="Switch to By Group view">
            🧩 By Group
        </a>
    </div>
</div>

<div class="ngrate-grid">

    <!-- ══ ROW 1, COL 1 — Get Data ══════════════════════════════════════════════ -->
    <div class="ngrate-cell-tl">
        <div class="card shadow-sm h-100">
            <div class="card-header small fw-semibold">Get Data</div>
            <div class="card-body d-flex flex-column gap-3">

                <!-- Period -->
                <div>
                    <div class="form-label small fw-semibold mb-1">Period</div>
                    <div class="d-flex gap-2 align-items-center flex-wrap">
                        <input type="date" class="form-control form-control-sm"
                               style="width:auto; flex:1; min-width:110px;"
                               @bind="_startDate" @bind:format="yyyy-MM-dd" />
                        <span class="small text-muted">–</span>
                        <input type="date" class="form-control form-control-sm"
                               style="width:auto; flex:1; min-width:110px;"
                               @bind="_endDate" @bind:format="yyyy-MM-dd" />
                        <button class="btn btn-outline-secondary btn-sm"
                                @onclick="SetToday">Today</button>
                    </div>
                </div>

                <!-- Credential status -->
                <div class="d-flex align-items-center gap-2">
                    <span class="small text-muted">BMES:</span>
                    @if (NgRateSettings.IsCredentialsConfigured)
                    {
                        <span class="badge bg-success">Credentials OK</span>
                        <span class="small text-muted font-monospace">@NgRateSettings.LoginId</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark">Not configured</span>
                        <a href="/admin/settings" class="small text-primary">→ Admin Settings</a>
                    }
                </div>

                <!-- Get Data button -->
                <div>
                    <button class="btn btn-primary w-100"
                            @onclick="GetDataAsync"
                            disabled="@(_isBusy || !NgRateSettings.IsCredentialsConfigured)">
                        @if (_isBusy)
                        {
                            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                            <span>Processing…</span>
                        }
                        else
                        {
                            <span>Get Data</span>
                        }
                    </button>
                </div>

                <!-- Inline result / error -->
                @if (!string.IsNullOrEmpty(_savedDbPath))
                {
                    <div class="alert alert-success py-2 small mb-0">
                        <div class="fw-semibold mb-1">
                            <span class="badge bg-success me-1">Done</span> Saved DB
                        </div>
                        <div class="font-monospace text-break" style="font-size:11px;">
                            @_savedDbPath
                        </div>
                        <button class="btn btn-link btn-sm p-0 mt-1 text-secondary"
                                @onclick="ClearResult">Clear</button>
                    </div>
                }
                @if (!string.IsNullOrEmpty(_errorMessage))
                {
                    <div class="alert alert-danger py-2 small mb-0">
                        <span class="badge bg-danger me-1">Error</span> @_errorMessage
                        <button class="btn btn-link btn-sm p-0 ms-1 text-secondary"
                                @onclick="ClearResult">Clear</button>
                    </div>
                }

            </div>
        </div>
    </div>

    <!-- ══ ROW 1, COL 2 — Model Groups (from DB) ════════════════════════════════ -->
    <div class="ngrate-cell-tr">
        <div class="card shadow-sm h-100">
            <div class="card-header small fw-semibold d-flex justify-content-between align-items-center">
                <span>Model Groups</span>
                <div class="d-flex align-items-center gap-2">
                    @{ int totalSel = _selectedGroupIds.Count + _selectedSubEntries.Count; }
                    @if (totalSel > 0)
                    {
                        <span class="badge bg-primary" style="font-size:10px;">
                            @totalSel selected
                        </span>
                    }
                    <span class="text-muted" style="font-size:11px;">
                        @(_dbGroups.Count) group@(_dbGroups.Count == 1 ? "" : "s")
                    </span>
                    <button class="btn btn-link btn-sm p-0 text-secondary"
                            @onclick="RefreshGroups" title="Refresh">⟳</button>
                </div>
            </div>
            <div class="card-body p-0 d-flex flex-column">

                @if (_dbGroups.Count == 0)
                {
                    <div class="text-muted small p-3 flex-grow-1">
                        <span>No groups found. Define groups on the <a href="/bmes/make-model-group">Make ModelGroup Data</a> page.</span>
                    </div>
                }
                else
                {
                    <!-- ── Step 1: Product Group tabs ───────────────────────── -->
                    <div class="d-flex flex-wrap gap-1 px-2 py-2 border-bottom bg-light">
                        @foreach (var pg in GroupProductGroups)
                        {
                            int pgCount = _dbGroups.Count(g => g.ProductGroup == pg);
                            int pgSel   = _selectedGroupIds.Count(id => _dbGroups.Any(g => g.Id == id && g.ProductGroup == pg));
                            <button class="pg-tab @(_activePg == pg ? "active" : "")"
                                    @onclick="@(() => _activePg = pg)">
                                @pg
                                @if (pgSel > 0)
                                {
                                    <span class="ms-1" style="opacity:.85;">(@pgSel)</span>
                                }
                                else
                                {
                                    <span class="ms-1 opacity-50">@pgCount</span>
                                }
                            </button>
                        }
                    </div>

                    <!-- ── Step 2: Groups for active ProductGroup ──────────── -->
                    <div class="overflow-auto" style="max-height:240px; flex:1;">
                        <div class="px-2 py-1">
                            @foreach (var g in _dbGroups.Where(g => g.ProductGroup == _activePg))
                            {
                                bool isChecked = _selectedGroupIds.Contains(g.Id);
                                int lsCount = g.MidGroups.Sum(m => m.LineShifts.Count);
                                <label class="json-file-item" title="@g.Name">
                                    <input type="checkbox"
                                           class="form-check-input"
                                           checked="@isChecked"
                                           @onchange="@(_ => ToggleGroup(g.Id))" />
                                    <span style="color:#6366f1; font-size:13px;">▣</span>
                                    <span>@g.Name</span>
                                    <span class="file-date">@lsCount LS</span>
                                </label>

                                @* First-level children — mid-groups (Material) that differ from the root name.
                                   Named top-level sub-groups surface here too so the user can report on a
                                   named slice without opening the whole tree. *@
                                @foreach (var entry in FirstLevelChildren(g))
                                {
                                    var cap = entry;
                                    bool subChecked = _selectedSubEntries.Contains(cap.Key);
                                    <label class="json-file-item sub-row" title="@cap.Label">
                                        <input type="checkbox"
                                               class="form-check-input"
                                               checked="@subChecked"
                                               @onchange="@(_ => ToggleSubEntry(cap.Key))" />
                                        <span style="color:#94a3b8; font-size:11px;">↳</span>
                                        <span>@cap.Label</span>
                                        <span class="file-date">@cap.LsCount LS</span>
                                    </label>
                                }
                            }
                            @if (!_dbGroups.Any(g => g.ProductGroup == _activePg))
                            {
                                <div class="text-muted small py-2 text-center">
                                    No groups in @_activePg
                                </div>
                            }
                        </div>
                    </div>
                }

                <!-- Get Report button -->
                <div class="border-top p-2">
                    <button class="btn btn-success w-100 btn-sm"
                            @onclick="GetReportAsync"
                            disabled="@(_isReportBusy || _isBusy)">
                        @if (_isReportBusy)
                        {
                            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                            <span>Generating…</span>
                        }
                        else
                        {
                            int btnSel = _selectedGroupIds.Count + _selectedSubEntries.Count;
                            <span>Get Report</span>
                            @if (btnSel > 0)
                            {
                                <span class="ms-1 opacity-75"
                                      style="font-size:10px;">(@btnSel group@(btnSel == 1 ? "" : "s"))</span>
                            }
                        }
                    </button>
                    @if (!string.IsNullOrEmpty(_reportError))
                    {
                        <div class="text-danger small mt-1">@_reportError</div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- ══ ROW 2, COL 1 — Progress ══════════════════════════════════════════════ -->
    <div class="ngrate-cell-bl">
        <div class="card shadow-sm h-100">
            <div class="card-header small fw-semibold">Progress</div>
            <div class="card-body">
                @if (_isBusy || _isReportBusy)
                {
                    <div class="progress mb-2" style="height:5px;">
                        <div class="progress-bar progress-bar-striped progress-bar-animated"
                             style="width:100%;"></div>
                    </div>
                    <div class="small text-muted font-monospace">
                        @(_logs.Count > 0 ? _logs[^1] : "Starting…")
                    </div>
                }
                else if (_logs.Count > 0)
                {
                    <div class="progress mb-2" style="height:5px;">
                        <div class="progress-bar @(_savedDbPath != null || _report != null ? "bg-success" : "bg-danger")"
                             style="width:100%;"></div>
                    </div>
                    <div class="small text-muted font-monospace">@_logs[^1]</div>
                }
                else
                {
                    <div class="text-muted small">Waiting…</div>
                }
            </div>
        </div>
    </div>

    <!-- ══ ROW 2, COL 2 — Log ════════════════════════════════════════════════════ -->
    <div class="ngrate-cell-br">
        <div class="card shadow-sm h-100">
            <div class="card-header small fw-semibold d-flex justify-content-between align-items-center">
                <span>Log</span>
                @if (_logs.Count > 0)
                {
                    <button class="btn btn-link btn-sm p-0 text-secondary"
                            @onclick="() => _logs.Clear()">Clear</button>
                }
            </div>
            <div class="card-body p-0">
                <div class="font-monospace p-2 overflow-auto"
                     style="height:150px; background:#0f172a; color:#94a3b8;
                            border-radius:0 0 .375rem .375rem; font-size:11px;">
                    @if (_logs.Count == 0)
                    {
                        <span style="opacity:.4;">No log entries yet.</span>
                    }
                    else
                    {
                        @foreach (string line in _logs)
                        {
                            <div class="@GetLogClass(line)">@line</div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>

</div>

<!-- ══ REPORT SECTION ══════════════════════════════════════════════════════════ -->
@if (_reports.Count > 0)
{
    <div class="mt-4">

        <!-- Tabs + Export -->
        <div class="d-flex align-items-end justify-content-between mb-0">
            @if (_reports.Count > 1)
            {
                <ul class="nav nav-tabs mb-0" style="border-bottom:none;">
                    @for (int i = 0; i < _reports.Count; i++)
                    {
                        int tabIdx = i;
                        bool active = i == _activeReportTab;
                        <li class="nav-item">
                            <button class="nav-link @(active ? "active fw-semibold" : "")"
                                    style="font-size:13px; padding:6px 14px;"
                                    @onclick="() => SwitchReportTab(tabIdx)">
                                @_reports[tabIdx].Label
                            </button>
                        </li>
                    }
                </ul>
            }
            else
            {
                <div></div>
            }
            <button class="btn btn-outline-success btn-sm mb-1"
                    style="font-size:12px;"
                    @onclick="ExportExcelAsync"
                    disabled="@_isExporting">
                @if (_isExporting)
                {
                    <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                }
                else
                {
                    <span>⬇ Export Excel</span>
                }
            </button>
        </div>
        <div style="border-top:2px solid #e2e8f0; margin-bottom:12px;"></div>

        <!-- Report header -->
        <div class="d-flex align-items-center gap-2 mb-3 border-bottom pb-2">
            <span style="font-size:18px;">📊</span>
            <h6 class="mb-0 fw-semibold">Report</h6>
            <span class="small text-muted ms-1">
                @Path.GetFileName(_report.DbPath) ·
                @_report.TotalRows.ToString("N0") rows ·
                @_report.GeneratedAt.ToString("HH:mm:ss")
            </span>
            @if (_report.ModelFilter.Count > 0)
            {
                <span class="badge bg-secondary ms-1" style="font-size:10px;">
                    @_report.ModelFilter.Count model@(_report.ModelFilter.Count == 1 ? "" : "s") filtered
                </span>
            }
            <button class="btn btn-link btn-sm p-0 ms-auto text-secondary"
                    @onclick="ClearReportAsync">✕ Clear</button>
        </div>

        <!-- ── Summary ───────────────────────────────────────────────────────── -->
        <div class="card mb-3 shadow-sm">
            <div class="card-header small fw-semibold d-flex justify-content-between align-items-center">
                <div class="d-flex align-items-center gap-2 flex-wrap">
                    <span>Summary — NG PPM by Process Type</span>
                    @if (_hiddenGroups.Count > 0)
                    {
                        <button class="group-chip-clear ms-2" type="button"
                                title="Restore all hidden group rows"
                                @onclick="ClearHiddenGroups">✕ Clear hidden (@_hiddenGroups.Count)</button>
                    }
                </div>
                <div class="d-flex gap-2 align-items-center">
                    @if (_report.GroupSummary.Count > 0)
                    {
                        <button class="expand-btn" @onclick="ExpandAllSummary">Expand All</button>
                        <span class="text-muted" style="font-size:10px;">|</span>
                        <button class="expand-btn" @onclick="CollapseAllSummary">Collapse All</button>
                        <span class="text-muted" style="font-size:10px;">|</span>
                    }
                    @if (_report.DateCols.Count > DateVisibleLimit)
                    {
                        <button class="expand-btn" @onclick="ToggleDateCols">
                            Date @(_dateExpanded ? "▼" : $"▶ +{_report.DateCols.Count - DateVisibleLimit}")
                        </button>
                    }
                    @if (_report.WeekCols.Count > WeekVisibleLimit)
                    {
                        <button class="expand-btn" @onclick="ToggleWeekCols">
                            Week @(_weekExpanded ? "▼" : $"▶ +{_report.WeekCols.Count - WeekVisibleLimit}")
                        </button>
                    }
                    @if (_report.MonthCols.Count > MonthVisibleLimit)
                    {
                        <button class="expand-btn" @onclick="ToggleMonthCols">
                            Month @(_monthExpanded ? "▼" : $"▶ +{_report.MonthCols.Count - MonthVisibleLimit}")
                        </button>
                    }
                </div>
            </div>
            <div class="card-body p-2">
                <div class="pivot-wrap">
                    <table class="pivot-table">
                        <thead>
                            <tr>
                                <th class="label-th" style="min-width:20px; text-align:center;"></th>
                                <th class="label-th">Process Type</th>
                                @foreach (var col in VisibleDateCols)
                                {
                                    <th>@col.Header</th>
                                }
                                <th class="sep-th"></th>
                                @foreach (var col in VisibleWeekCols)
                                {
