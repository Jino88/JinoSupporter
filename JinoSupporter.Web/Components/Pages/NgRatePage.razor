@code {
    private static readonly string[] AllProductGroups = ["SPK", "UNIT", "MODULE", "TWS", "ETC"];

    // ── Get Data state ────────────────────────────────────────────────────────────
    private DateTime     _startDate    = DateTime.Today;
    private DateTime     _endDate      = DateTime.Today;
    private bool         _isBusy       = false;
    private string?      _savedDbPath  = null;
    private string?      _errorMessage = null;
    private List<string> _logs         = new();

    // ── Model Groups state (from ModelGroups DB) ─────────────────────────────────
    private List<ModelGroupRecord> _dbGroups         = new();
    private HashSet<long>          _selectedGroupIds = new();
    private HashSet<string>        _selectedSubEntries = new(StringComparer.Ordinal);
    private string                 _activePg         = "ETC";

    /// <summary>Key for a first-level child row: "groupId|mid|material".</summary>
    private sealed record ChildEntry(string Key, string Label, int LsCount);

    /// <summary>First-level children of <paramref name="g"/> shown as indented rows in the picker —
    /// each mid-group (Material) with LineShifts. A single mid-group whose Material equals the
    /// root group name is suppressed to avoid a redundant duplicate row.</summary>
    private static IEnumerable<ChildEntry> FirstLevelChildren(ModelGroupRecord g)
    {
        bool skipMidWhenSingle = g.MidGroups.Count == 1
            && string.Equals(g.MidGroups[0].Material, g.Name, StringComparison.Ordinal);

        foreach (var mid in g.MidGroups)
        {
            int midLs = mid.LineShifts.Count;
            if (midLs == 0) continue;
            if (skipMidWhenSingle) continue;
            if (string.IsNullOrEmpty(mid.Material)) continue;

            yield return new ChildEntry(
                Key:     $"{g.Id}|mid|{mid.Material}",
                Label:   mid.Material,
                LsCount: midLs);
        }
    }

    /// <summary>Only ProductGroups that actually have groups (preserves AllProductGroups order)</summary>
    private IEnumerable<string> GroupProductGroups =>
        AllProductGroups.Where(pg => _dbGroups.Any(g => g.ProductGroup == pg));

    // ── Report state ──────────────────────────────────────────────────────────────
    private bool   _isReportBusy = false;
    private string _reportError  = string.Empty;
    private List<(string Label, NgRateReportService.NgRateReport Report)> _reports = new();
    private int    _activeReportTab = 0;
    private NgRateReportService.NgRateReport? _report =>
        _activeReportTab < _reports.Count ? _reports[_activeReportTab].Report : null;

    // ── Chart state ───────────────────────────────────────────────────────────────
    private bool _pendingChartRender = false;

    // ── Export state ──────────────────────────────────────────────────────────────
    private bool _isExporting = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_pendingChartRender && _report is not null)
        {
            _pendingChartRender = false;
            await RenderSummaryChartAsync();
        }
    }

    private async Task RenderSummaryChartAsync()
    {
        if (_report is null) return;

        var dateCols  = VisibleDateCols.ToList();
        var weekCols  = VisibleWeekCols.ToList();
        var monthCols = VisibleMonthCols.ToList();
        bool hasWeek  = weekCols.Count > 0;
        bool hasMonth = monthCols.Count > 0;

        // Insert empty label ("") as separator between sections
        var labels = new List<string>();
        labels.AddRange(dateCols.Select(c => c.Header));
        if (hasWeek)  { labels.Add(""); labels.AddRange(weekCols.Select(c  => c.Header)); }
        if (hasMonth) { labels.Add(""); labels.AddRange(monthCols.Select(c => c.Header)); }

        // Data array builder — insert null at separator positions
        double?[] BuildData(Dictionary<string, double> ppm)
        {
            var d = new List<double?>();
            foreach (var c in dateCols)  d.Add(GetChartVal(ppm, c.Key));
            if (hasWeek)  { d.Add(null); foreach (var c in weekCols)  d.Add(GetChartVal(ppm, c.Key)); }
            if (hasMonth) { d.Add(null); foreach (var c in monthCols) d.Add(GetChartVal(ppm, c.Key)); }
            return d.ToArray();
        }

        // When a chip is selected, chart scopes to that group's Summary rows.
        var chartSummary = EffectiveSummary;

        // TOTAL line chart
        var totalRow = chartSummary.FirstOrDefault(r => r.IsTotal);
        string totalLabel = NoChipSelected
            ? "TOTAL"
            : (_selectedChips.Count == 1
                ? $"TOTAL — {_selectedChips.First()}"
                : $"TOTAL — Combined ({_selectedChips.Count})");
        object? totalDs = totalRow is null ? null : new
        {
            label           = totalLabel,
            data            = BuildData(totalRow.Ppm),
            borderColor     = "#3b82f6",
            backgroundColor = "rgba(59,130,246,0.08)",
            borderWidth     = 2,
            pointRadius     = 3,
            tension         = 0.1,
            fill            = false,
            yAxisID         = "y1",
            order           = 0,
            spanGaps        = false,
        };

        // ProcessType bars
        int fi = 0;
        var barDatasets = chartSummary
            .Where(r => !r.IsTotal)
            .Select(r =>
            {
                var ds = (object)new
                {
                    type            = "bar",
                    label           = r.ProcessType,
                    data            = BuildData(r.Ppm),
                    backgroundColor = GetPtColor(r.ProcessType, fi),
                    stack           = "pt",
                    order           = 1,
                };
                fi++;
                return ds;
            })
            .ToArray();

        await JS.InvokeVoidAsync("ngRateChart.render", $"summaryChart_{_activeReportTab}", labels.ToArray(), barDatasets, totalDs);
    }

    private static double? GetChartVal(Dictionary<string, double> ppm, string key)
        => ppm.TryGetValue(key, out double v) && v > 0 ? v : null;

    private static string GetPtColor(string pt, int fi)
    {
        if (pt.StartsWith("SUB",    StringComparison.OrdinalIgnoreCase)) return "rgba(239,68,68,0.85)";
        if (pt == "MAIN")                                                 return "rgba(34,197,94,0.85)";
        if (pt == "FUNCTION")                                             return "rgba(168,85,247,0.85)";
        if (pt.StartsWith("VISUAL", StringComparison.OrdinalIgnoreCase)) return "rgba(6,182,212,0.85)";
        string[] fb = ["rgba(249,115,22,0.85)", "rgba(234,179,8,0.85)", "rgba(99,102,241,0.85)", "rgba(236,72,153,0.85)"];
        return fb[fi % fb.Length];
    }

    private async Task ClearReportAsync()
    {
        for (int i = 0; i < _reports.Count; i++)
            try { await JS.InvokeVoidAsync("ngRateChart.destroy", $"summaryChart_{i}"); } catch { }
        _reports.Clear();
        _activeReportTab = 0;
    }

    public async ValueTask DisposeAsync()
    {
        for (int i = 0; i < _reports.Count; i++)
            try { await JS.InvokeVoidAsync("ngRateChart.destroy", $"summaryChart_{i}"); } catch { }
    }

