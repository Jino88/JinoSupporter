        _selectedGroupIds.RemoveWhere(id => !_dbGroups.Any(g => g.Id == id));
        var live = _dbGroups.SelectMany(FirstLevelChildren).Select(c => c.Key).ToHashSet(StringComparer.Ordinal);
        _selectedSubEntries.RemoveWhere(k => !live.Contains(k));
