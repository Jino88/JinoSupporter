<UserControl x:Class="JinoSupporter.App.Modules.DataInference.DataInferenceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:app="clr-namespace:JinoSupporter.Controls;assembly=JinoSupporter.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <UserControl.Resources>
        <Style x:Key="DbTabItemStyle" TargetType="TabItem">
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#617084" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Foreground" Value="#22304A" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DgHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#EEF3F9" />
            <Setter Property="Foreground" Value="#22304A" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="BorderBrush" Value="#D3DCEA" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
        </Style>

        <Style x:Key="DgCellStyle" TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="7,0" Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#C8DCEE" />
                    <Setter Property="Foreground" Value="#22304A" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource ShellCanvasBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Margin="10,10,10,6" Padding="14"
                Style="{StaticResource ShellCardBorderStyle}" Background="White">
            <DockPanel>
                <!-- Token / cost badge (upper right) -->
                <Border DockPanel.Dock="Right" Padding="12,6" CornerRadius="6"
                        Background="#EBF3FC" BorderBrush="#B8D4F0" BorderThickness="1"
                        VerticalAlignment="Center" Margin="12,0,0,0"
                        Cursor="Hand"
                        ToolTip="Click: Refresh Balance  |  Right-click: Enter Session Key  |  Shift+Click: Open Console"
                        MouseLeftButtonUp="TokenCostBadge_Click"
                        MouseRightButtonUp="TokenCostBadge_RightClick">
                    <StackPanel>
                        <TextBlock x:Name="TokenCostTextBlock"
                                   FontSize="16" FontWeight="Bold" Foreground="#1A5FA8"
                                   HorizontalAlignment="Right" Text="$0.0000" />
                        <TextBlock x:Name="TokenUsageTextBlock"
                                   FontSize="10" Foreground="#617084"
                                   HorizontalAlignment="Right" Text="0 tokens" />
                        <TextBlock x:Name="CreditBalanceTextBlock"
                                   FontSize="11" FontWeight="SemiBold" Foreground="#059669"
                                   HorizontalAlignment="Right" Text="" />
                        <TextBlock FontSize="9" Foreground="#9BAABF"
                                   HorizontalAlignment="Right" Text="Right-click: Set Session Key" />
                    </StackPanel>
                </Border>
                <StackPanel>
                    <TextBlock FontSize="20" FontWeight="SemiBold" Foreground="#22304A" Text="Data Inference" />
                    <TextBlock Margin="0,6,0,0" Foreground="#617084" FontSize="12"
                               Text="Enter filename → Organize each table → Ctrl+V image → Save to DB" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main content -->
        <Grid Grid.Row="1" Margin="10,0,10,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left panel -->
            <Border Grid.Column="0" Padding="14"
                    Style="{StaticResource ShellCardBorderStyle}" Background="White">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Excel filename + memo -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,10">
                        <DockPanel Margin="0,0,0,4">
                            <Button DockPanel.Dock="Right" Content="Glossary"
                                    Padding="8,3" FontSize="10" FontWeight="SemiBold"
                                    Background="#EBF3FC" Foreground="#1A5FA8"
                                    BorderBrush="#B8D4F0" BorderThickness="1"
                                    Cursor="Hand"
                                    Click="GlossaryButton_Click" />
                            <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#22304A"
                                       Text="Dataset Name (Excel filename)"
                                       VerticalAlignment="Center" />
                        </DockPanel>
                        <Border BorderBrush="#3B6EA5" BorderThickness="1" CornerRadius="5" Background="#F4F8FD">
                            <TextBox x:Name="DatasetNameTextBox"
                                     Padding="8,7" BorderThickness="0" FontSize="12"
                                     Background="Transparent" Foreground="#22304A"
                                     ToolTip="Same name = appended to existing dataset" />
                        </Border>
                        <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="#617084"
                                   Text="Memo (Purpose / Review Notes)" Margin="0,8,0,3"/>
                        <Border BorderBrush="#D3DCEA" BorderThickness="1" CornerRadius="5" Background="#F8FAFD">
                            <TextBox x:Name="DatasetMemoTextBox"
                                     Padding="8,6" BorderThickness="0" FontSize="11"
                                     Background="Transparent" Foreground="#22304A"
                                     AcceptsReturn="True" TextWrapping="Wrap"
                                     MaxHeight="64" VerticalScrollBarVisibility="Auto"
                                     ToolTip="Briefly note the purpose or content of this dataset" />
                        </Border>
                    </StackPanel>

                    <!-- Data input header -->
                    <StackPanel Grid.Row="1" Margin="0,0,0,6">
                        <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#22304A"
                                   Text="Table Data Input" Margin="0,0,0,6"/>
                        <!-- Input mode selector -->
                        <Border Background="#F0F4F8" CornerRadius="6" Padding="8,6"
                                BorderBrush="#D3DCEA" BorderThickness="1" Margin="0,0,0,6">
                            <StackPanel Orientation="Horizontal">
                                <RadioButton x:Name="RadioAiExtract"
                                             Content="AI Extract"
                                             IsChecked="True"
                                             GroupName="InputMode"
                                             FontSize="11" FontWeight="SemiBold"
                                             Foreground="#22304A"
                                             Margin="0,0,16,0"
                                             ToolTip="Claude AI analyzes and extracts table structure" />
                                <RadioButton x:Name="RadioJustInput"
                                             Content="Just Input Table"
                                             GroupName="InputMode"
                                             FontSize="11" FontWeight="SemiBold"
                                             Foreground="#22304A"
                                             ToolTip="First row = headers, rest = data (no AI call)" />
                            </StackPanel>
                        </Border>
                        <CheckBox x:Name="IncludeImagesCheckBox"
                                  Content="Include Images in AI Analysis"
                                  FontSize="11" FontWeight="SemiBold"
                                  Foreground="#22304A"
                                  Margin="0,6,0,0"
                                  ToolTip="When checked, pasted images are sent to Claude for visual analysis (Ctrl+V to paste image)"
                                  Checked="IncludeImagesCheckBox_CheckedChanged"
                                  Unchecked="IncludeImagesCheckBox_CheckedChanged" />
                        <TextBlock x:Name="InputModeHintText"
                                   FontSize="10" Foreground="#617084" TextWrapping="Wrap"
                                   Margin="0,4,0,0"
                                   Text="Select range → Ctrl+C → Ctrl+V here → Organize" />
                    </StackPanel>

                    <!-- TextArea: Border click passes focus to TextBox -->
                    <Border Grid.Row="2" BorderBrush="#D3DCEA" BorderThickness="1"
                            CornerRadius="6" Background="#F8FAFD"
                            MouseLeftButtonDown="TextAreaBorder_MouseLeftButtonDown">
                        <TextBox x:Name="DataInputTextBox"
                                 AcceptsReturn="True" AcceptsTab="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 FontFamily="Consolas" FontSize="11"
                                 Padding="8" BorderThickness="0"
                                 Background="Transparent" Foreground="#22304A"
                                 TextWrapping="NoWrap"
                                 VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                                 VerticalContentAlignment="Top" />
                    </Border>

                    <!-- Buttons + image + save + info -->
                    <StackPanel Grid.Row="3" Margin="0,10,0,0">

                        <app:AppButton x:Name="OrganizeButton"
                                Content="Organize"
                                HorizontalAlignment="Stretch"
                                Margin="0,0,0,6"
                                Click="AnalyzeButton_Click" />

                        <app:AppButton Content="Clear"
                                HorizontalAlignment="Stretch"
                                Margin="0,0,0,10"
                                Click="ClearButton_Click" />

                        <!-- Attached images -->
                        <Border Padding="8" CornerRadius="6"
                                Background="#F0F4F8" BorderBrush="#D3DCEA" BorderThickness="1"
                                Margin="0,0,0,6">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,5">
                                    <TextBlock DockPanel.Dock="Right"
                                               Text="Ctrl+V" FontSize="10" FontWeight="SemiBold"
                                               Foreground="#4A6FA5" VerticalAlignment="Center" />
                                    <TextBlock Text="Attached Images"
                                               FontSize="11" FontWeight="SemiBold" Foreground="#22304A" />
                                </DockPanel>
                                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Disabled" Height="72">
                                    <WrapPanel x:Name="PendingImagePanel" Orientation="Horizontal" />
                                </ScrollViewer>
                            </StackPanel>
                        </Border>

                        <app:AppButton x:Name="ExtractTagsButton"
                                Content="Extract Tags"
                                HorizontalAlignment="Stretch"
                                Margin="0,0,0,6"
                                IsEnabled="False"
                                Click="ExtractTagsButton_Click" />

                        <Border x:Name="TagsAreaBorder" Visibility="Collapsed"
                                Margin="0,0,0,8" Padding="8,6" CornerRadius="6"
                                Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1">
                            <StackPanel>
                                <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="#1D4ED8"
                                           Text="Extracted Tags" Margin="0,0,0,4"/>
                                <WrapPanel x:Name="TagsWrapPanel" />
                            </StackPanel>
                        </Border>

                        <app:AppButton x:Name="SaveDbButton"
                                Content="Save to DB"
                                HorizontalAlignment="Stretch"
                                Margin="0,0,0,8"
                                IsEnabled="False"
                                Click="SaveDbButton_Click" />

                        <Border Margin="0,0,0,8" Padding="8" CornerRadius="5" Background="#EBF3FC">
                            <TextBlock FontSize="10" Foreground="#4A6FA5" TextWrapping="Wrap"
                                       Text="Tip: Organize each table → stacks on the right. Images via Ctrl+V. Done? Save to DB." />
                        </Border>

                        <Border Padding="10" CornerRadius="6"
                                Background="#F0F4F8" BorderBrush="#D3DCEA" BorderThickness="1"
                                Cursor="Hand" ToolTip="Click to change DB save location"
                                MouseLeftButtonUp="DbInfoBorder_Click">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,6">
                                    <TextBlock DockPanel.Dock="Right" FontSize="9" Foreground="#4A6FA5"
                                               Text="📁 Change" VerticalAlignment="Center"/>
                                    <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#22304A"
                                               Text="DB Info" />
                                </DockPanel>
                                <TextBlock FontSize="10" Foreground="#617084" Text="Path" />
                                <TextBlock x:Name="DbPathTextBlock" FontSize="10"
                                           Foreground="#33435C" TextWrapping="Wrap" Margin="0,2,0,8" />
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontSize="10" Foreground="#617084" Text="Records: " />
                                    <TextBlock x:Name="DbCountTextBlock" FontSize="10"
                                               FontWeight="SemiBold" Foreground="#22304A" Text="0" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Right: TabControl -->
            <TabControl Grid.Column="2" x:Name="MainTabControl"
                        SelectionChanged="MainTabControl_SelectionChanged"
                        Background="Transparent" BorderThickness="0" Padding="0">
                <TabControl.Resources>
                    <Style TargetType="TabItem" BasedOn="{StaticResource DbTabItemStyle}" />
                </TabControl.Resources>

                <!-- Tab 1: Results -->
                <TabItem Header="Results">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Padding="10,7" Margin="0,4,0,4"
                                Background="White" CornerRadius="8"
                                BorderBrush="#D3DCEA" BorderThickness="1">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Right" FontSize="10" Foreground="#617084"
                                           VerticalAlignment="Center"
                                           Text="Click cell to edit / use 'Delete' on the top-right of each card to remove" />
                                <TextBlock x:Name="ResultGridHeaderText"
                                           FontSize="12" FontWeight="SemiBold" Foreground="#22304A"
                                           VerticalAlignment="Center" Text="Results" />
                            </DockPanel>
                        </Border>

                        <!-- Area where table cards stack up -->
                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel x:Name="TablesPanel" Margin="0,4,4,4" />
                        </ScrollViewer>
                    </Grid>
                </TabItem>

                <!-- Tab 2: DB Data -->
                <TabItem Header="DB Data" x:Name="DbDataTab">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="175" />    <!-- Dataset list -->
                            <RowDefinition Height="*" />      <!-- Tables (left) + Row detail (right) -->
                            <RowDefinition Height="Auto" />   <!-- Image strip -->
                            <RowDefinition Height="Auto" />   <!-- Tags + Memo (side by side) -->
                            <RowDefinition Height="Auto" />   <!-- Action bar -->
                        </Grid.RowDefinitions>

                        <!-- Dataset list -->
                        <Border Grid.Row="0" BorderBrush="#D3DCEA" BorderThickness="1"
                                CornerRadius="8" Margin="0,4,0,6">
                            <DataGrid x:Name="DatasetDataGrid"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      CanUserAddRows="False" CanUserDeleteRows="False"
                                      SelectionMode="Single"
                                      GridLinesVisibility="Horizontal"
                                      HorizontalGridLinesBrush="#EEF2F7"
                                      AlternatingRowBackground="#F8FAFD" RowBackground="White"
                                      BorderThickness="0" FontSize="12" RowHeight="28"
                                      ColumnHeaderStyle="{StaticResource DgHeaderStyle}"
                                      CellStyle="{StaticResource DgCellStyle}"
                                      SelectionChanged="DatasetDataGrid_SelectionChanged">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Dataset"  Binding="{Binding Name}"       Width="*" />
                                    <DataGridTextColumn Header="Tables"   Binding="{Binding TableCount}"  Width="60" />
                                    <DataGridTextColumn Header="Images"   Binding="{Binding ImageCount}"  Width="60" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                        <!-- Tables (left) + Row detail (right) -->
                        <Grid Grid.Row="1" Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="330" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Tables list -->
                            <Border Grid.Column="0" BorderBrush="#D3DCEA" BorderThickness="1" CornerRadius="8">
                                <DataGrid x:Name="TablesDataGrid"
                                          AutoGenerateColumns="False" IsReadOnly="False"
                                          CanUserAddRows="False" CanUserDeleteRows="False"
                                          SelectionMode="Single"
                                          GridLinesVisibility="Horizontal"
                                          HorizontalGridLinesBrush="#EEF2F7"
                                          AlternatingRowBackground="#F8FAFD" RowBackground="White"
                                          BorderThickness="0" FontSize="12" RowHeight="28"
                                          ColumnHeaderStyle="{StaticResource DgHeaderStyle}"
                                          CellStyle="{StaticResource DgCellStyle}"
                                          SelectionChanged="TablesDataGrid_SelectionChanged"
                                          CellEditEnding="TablesDataGrid_CellEditEnding"
                                          PreviewMouseRightButtonUp="TablesDataGrid_PreviewMouseRightButtonUp">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Table" Binding="{Binding TableName, UpdateSourceTrigger=LostFocus}" Width="*" />
                                        <DataGridTextColumn Header="Rows" Binding="{Binding RowCount}" Width="50" IsReadOnly="True" />
                                        <DataGridTextColumn Header="Saved At" Binding="{Binding CreatedAtLocal}" Width="120" IsReadOnly="True" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>

                            <!-- Row detail -->
                            <Border Grid.Column="2" BorderBrush="#D3DCEA" BorderThickness="1" CornerRadius="8">
                                <DataGrid x:Name="RowDetailDataGrid"
                                          AutoGenerateColumns="False" IsReadOnly="True"
                                          CanUserAddRows="False" CanUserDeleteRows="False"
                                          SelectionMode="Single"
                                          GridLinesVisibility="Horizontal"
                                          HorizontalGridLinesBrush="#EEF2F7"
                                          AlternatingRowBackground="#F8FAFD" RowBackground="White"
                                          BorderThickness="0" FontSize="12" RowHeight="28"
                                          ColumnHeaderStyle="{StaticResource DgHeaderStyle}"
                                          CellStyle="{StaticResource DgCellStyle}"
                                          PreviewMouseRightButtonUp="RowDetailDataGrid_PreviewMouseRightButtonUp" />
                            </Border>
                        </Grid>

                        <!-- DB image strip -->
                        <Border Grid.Row="2" x:Name="DbImageBorder" Visibility="Collapsed"
                                Padding="10,8" Margin="0,6,0,0"
                                Background="#F8FAFD" CornerRadius="8"
                                BorderBrush="#D3DCEA" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Attached Images" FontSize="11" FontWeight="SemiBold"
                                           Foreground="#22304A" Margin="0,0,0,5" />
                                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Disabled" Height="90">
                                    <WrapPanel x:Name="DbImagePanel" Orientation="Horizontal" />
                                </ScrollViewer>
                            </StackPanel>
                        </Border>

                        <!-- Tags (left) + Memo (right) side by side -->
                        <Grid Grid.Row="3" x:Name="DbTagsMemoGrid" Visibility="Collapsed" Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Tags -->
                            <Border x:Name="DbTagsAreaBorder" Grid.Column="0"
                                    Padding="8,6"
                                    Background="#EFF6FF" CornerRadius="6"
                                    BorderBrush="#BFDBFE" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="#1D4ED8"
                                               Text="Tags" Margin="0,0,0,4"/>
                                    <WrapPanel x:Name="DbTagsWrapPanel" />
                                </StackPanel>
                            </Border>

                            <!-- Memo -->
                            <Border x:Name="DbMemoAreaBorder" Grid.Column="2"
                                    Padding="8,6"
                                    Background="#FFFDF0" CornerRadius="6"
                                    BorderBrush="#FDE68A" BorderThickness="1">
                                <DockPanel>
                                    <app:AppButton DockPanel.Dock="Right" x:Name="SaveMemoDbButton"
                                            Content="Save Memo"
                                            Margin="8,0,0,0"
                                            Click="SaveMemoDbButton_Click" />
                                    <StackPanel>
                                        <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="#92400E"
                                                   Text="Memo (Purpose / Review Notes)" Margin="0,0,0,3"/>
                                        <Border BorderBrush="#FCD34D" BorderThickness="1" CornerRadius="4" Background="White">
                                            <TextBox x:Name="DbMemoTextBox"
                                                     Padding="7,5" BorderThickness="0" FontSize="11"
                                                     Background="Transparent" Foreground="#22304A"
                                                     AcceptsReturn="True" TextWrapping="Wrap"
                                                     MaxHeight="60" VerticalScrollBarVisibility="Auto" />
                                        </Border>
                                    </StackPanel>
                                </DockPanel>
                            </Border>
                        </Grid>

                        <!-- Action bar -->
                        <Border Grid.Row="4" Padding="8,6" Margin="0,6,0,0"
                                Background="#F8FAFD" CornerRadius="6"
                                BorderBrush="#D3DCEA" BorderThickness="1">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                    <app:AppButton x:Name="SaveDbRowsButton" Content="Save Changes"
                                            Margin="0,0,6,0"
                                            IsEnabled="False"
                                            Click="SaveDbRowsButton_Click" />
                                    <app:AppButton x:Name="ReExtractGlossaryDbButton" Content="Extract Terms"
                                            Margin="0,0,6,0"
                                            IsEnabled="False"
                                            Click="ReExtractGlossaryDbButton_Click" />
                                    <app:AppButton x:Name="ReTagDbButton" Content="Re-tag"
                                            Margin="0,0,6,0"
                                            IsEnabled="False"
                                            Click="ReTagDbButton_Click" />
                                    <app:AppButton Content="Delete Table"
                                            Click="DeleteDbRowButton_Click" />
                                </StackPanel>
                                <TextBlock x:Name="DbStatusTextBlock" VerticalAlignment="Center"
                                           FontSize="11" Foreground="#617084"
                                           Text="Open DB tab to load data." />
                            </DockPanel>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="2" Margin="10,0,10,10" Padding="10,8"
                Style="{StaticResource ShellCardBorderStyle}" Background="#F8FAFD">
            <TextBlock x:Name="StatusTextBlock" Foreground="#4E5A6C" FontSize="11" Text="Ready." />
        </Border>
    </Grid>
</UserControl>
