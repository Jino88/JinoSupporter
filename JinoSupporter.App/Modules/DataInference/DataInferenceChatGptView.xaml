<UserControl x:Class="JinoSupporter.App.Modules.DataInference.DataInferenceChatGptView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:app="clr-namespace:JinoSupporter.Controls;assembly=JinoSupporter.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <UserControl.Resources>
        <Style x:Key="DbTabItemStyle" TargetType="TabItem">
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#617084" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Foreground" Value="#22304A" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DgHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#EEF3F9" />
            <Setter Property="Foreground" Value="#22304A" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="BorderBrush" Value="#D3DCEA" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
        </Style>

        <Style x:Key="DgCellStyle" TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="7,0" Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#C8DCEE" />
                    <Setter Property="Foreground" Value="#22304A" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource ShellCanvasBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Margin="10,10,10,6" Padding="14"
                Style="{StaticResource ShellCardBorderStyle}" Background="White">
            <DockPanel>
                <!-- Token / cost badge (upper right) -->
                <Border DockPanel.Dock="Right" Padding="12,6" CornerRadius="6"
                        Background="#EBF3FC" BorderBrush="#B8D4F0" BorderThickness="1"
                        VerticalAlignment="Center" Margin="12,0,0,0">
                    <StackPanel>
                        <TextBlock x:Name="TokenCostTextBlock"
                                   FontSize="16" FontWeight="Bold" Foreground="#1A5FA8"
                                   HorizontalAlignment="Right" Text="$0.0000" />
                        <TextBlock x:Name="TokenUsageTextBlock"
                                   FontSize="10" Foreground="#617084"
                                   HorizontalAlignment="Right" Text="0 tokens" />
                    </StackPanel>
                </Border>
                <StackPanel>
                    <TextBlock FontSize="20" FontWeight="SemiBold" Foreground="#22304A" Text="Data Inference (ChatGPT)" />
                    <TextBlock Margin="0,6,0,0" Foreground="#617084" FontSize="12"
                               Text="Enter filename → Organize each table with ChatGPT → Ctrl+V image → Save to DB" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main content -->
        <Grid Grid.Row="1" Margin="10,0,10,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left panel -->
            <Border Grid.Column="0" Padding="14"
                    Style="{StaticResource ShellCardBorderStyle}" Background="White">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Excel filename -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#22304A"
                                   Text="Dataset Name (Excel filename)" Margin="0,0,0,4" />
                        <Border BorderBrush="#3B6EA5" BorderThickness="1" CornerRadius="5" Background="#F4F8FD">
                            <TextBox x:Name="DatasetNameTextBox"
                                     Padding="8,7" BorderThickness="0" FontSize="12"
                                     Background="Transparent" Foreground="#22304A"
                                     ToolTip="Same name = appended to existing dataset" />
                        </Border>
                    </StackPanel>

                    <!-- Data input header -->
                    <StackPanel Grid.Row="1" Margin="0,0,0,6">
                        <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#22304A"
                                   Text="Table Data Input" Margin="0,0,0,6"/>
                        <!-- Input mode selector -->
                        <Border Background="#F0F4F8" CornerRadius="6" Padding="8,6"
                                BorderBrush="#D3DCEA" BorderThickness="1" Margin="0,0,0,6">
                            <StackPanel Orientation="Horizontal">
                                <RadioButton x:Name="RadioAiExtract"
                                             Content="AI Extract"
                                             IsChecked="True"
                                             GroupName="InputMode"
                                             FontSize="11" FontWeight="SemiBold"
                                             Foreground="#22304A"
                                             Margin="0,0,16,0"
                                             ToolTip="ChatGPT analyzes and extracts table structure" />
                                <RadioButton x:Name="RadioJustInput"
                                             Content="Just Input Table"
                                             GroupName="InputMode"
                                             FontSize="11" FontWeight="SemiBold"
                                             Foreground="#22304A"
                                             ToolTip="First row = headers, rest = data (no AI call)" />
                            </StackPanel>
                        </Border>
                        <TextBlock x:Name="InputModeHintText"
                                   FontSize="10" Foreground="#617084" TextWrapping="Wrap"
                                   Text="Select range → Ctrl+C → Ctrl+V here → Organize" />
                    </StackPanel>

                    <!-- TextArea: Border click passes focus to TextBox -->
                    <Border Grid.Row="2" BorderBrush="#D3DCEA" BorderThickness="1"
                            CornerRadius="6" Background="#F8FAFD"
                            MouseLeftButtonDown="TextAreaBorder_MouseLeftButtonDown">
                        <TextBox x:Name="DataInputTextBox"
                                 AcceptsReturn="True" AcceptsTab="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 FontFamily="Consolas" FontSize="11"
                                 Padding="8" BorderThickness="0"
                                 Background="Transparent" Foreground="#22304A"
                                 TextWrapping="NoWrap"
                                 VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                                 VerticalContentAlignment="Top" />
                    </Border>

                    <!-- Buttons + image + save + info -->
                    <StackPanel Grid.Row="3" Margin="0,10,0,0">

                        <app:AppButton Content="Organize"
                                HorizontalAlignment="Stretch"
                                Margin="0,0,0,6"
                                Click="AnalyzeButton_Click" />

                        <app:AppButton Content="Clear"
                                HorizontalAlignment="Stretch"
                                Margin="0,0,0,10"
                                Click="ClearButton_Click" />

                        <!-- Attached images -->
                        <Border Padding="8" CornerRadius="6"
                                Background="#F0F4F8" BorderBrush="#D3DCEA" BorderThickness="1"
                                Margin="0,0,0,6">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,5">
                                    <TextBlock DockPanel.Dock="Right"
                                               Text="Ctrl+V" FontSize="10" FontWeight="SemiBold"
                                               Foreground="#4A6FA5" VerticalAlignment="Center" />
                                    <TextBlock Text="Attached Images"
                                               FontSize="11" FontWeight="SemiBold" Foreground="#22304A" />
                                </DockPanel>
                                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Disabled" Height="72">
                                    <WrapPanel x:Name="PendingImagePanel" Orientation="Horizontal" />
                                </ScrollViewer>
                            </StackPanel>
                        </Border>

                        <app:AppButton x:Name="SaveDbButton"
                                Content="Save to DB"
                                HorizontalAlignment="Stretch"
                                Margin="0,0,0,8"
                                IsEnabled="False"
                                Click="SaveDbButton_Click" />

                        <Border Margin="0,0,0,8" Padding="8" CornerRadius="5" Background="#EBF3FC">
                            <TextBlock FontSize="10" Foreground="#4A6FA5" TextWrapping="Wrap"
                                       Text="Tip: Organize each table → stacks on the right. Images via Ctrl+V. Done? Save to DB." />
                        </Border>

                        <Border Padding="10" CornerRadius="6"
                                Background="#F0F4F8" BorderBrush="#D3DCEA" BorderThickness="1">
                            <StackPanel>
                                <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#22304A"
                                           Text="DB Info" Margin="0,0,0,6" />
                                <TextBlock FontSize="10" Foreground="#617084" Text="Path" />
                                <TextBlock x:Name="DbPathTextBlock" FontSize="10"
                                           Foreground="#33435C" TextWrapping="Wrap" Margin="0,2,0,8" />
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontSize="10" Foreground="#617084" Text="Records: " />
                                    <TextBlock x:Name="DbCountTextBlock" FontSize="10"
                                               FontWeight="SemiBold" Foreground="#22304A" Text="0" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Right: TabControl -->
            <TabControl Grid.Column="2" x:Name="MainTabControl"
                        SelectionChanged="MainTabControl_SelectionChanged"
                        Background="Transparent" BorderThickness="0" Padding="0">
                <TabControl.Resources>
                    <Style TargetType="TabItem" BasedOn="{StaticResource DbTabItemStyle}" />
                </TabControl.Resources>

                <!-- Tab 1: Results -->
                <TabItem Header="Results">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Padding="10,7" Margin="0,4,0,4"
                                Background="White" CornerRadius="8"
                                BorderBrush="#D3DCEA" BorderThickness="1">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Right" FontSize="10" Foreground="#617084"
                                           VerticalAlignment="Center"
                                           Text="Click cell to edit / use 'Delete' on the top-right of each card to remove" />
                                <TextBlock x:Name="ResultGridHeaderText"
                                           FontSize="12" FontWeight="SemiBold" Foreground="#22304A"
                                           VerticalAlignment="Center" Text="Results" />
                            </DockPanel>
                        </Border>

                        <!-- Area where table cards stack up -->
                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel x:Name="TablesPanel" Margin="0,4,4,4" />
                        </ScrollViewer>
                    </Grid>
                </TabItem>

                <!-- Tab 2: DB Data -->
                <TabItem Header="DB Data" x:Name="DbDataTab">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />   <!-- Refresh bar -->
                            <RowDefinition Height="110" />    <!-- Dataset list -->
                            <RowDefinition Height="160" />    <!-- Tables list -->
                            <RowDefinition Height="*" />      <!-- Row detail -->
                            <RowDefinition Height="Auto" />   <!-- Image strip -->
                            <RowDefinition Height="Auto" />   <!-- Action bar -->
                        </Grid.RowDefinitions>

                        <!-- Refresh bar -->
                        <Border Grid.Row="0" Padding="10,8" Margin="0,4,0,6"
                                Background="White" CornerRadius="8"
                                BorderBrush="#D3DCEA" BorderThickness="1">
                            <DockPanel>
                                <app:AppButton DockPanel.Dock="Right" Content="Refresh"
                                        Click="RefreshDbButton_Click" />
                                <TextBlock Text="Click dataset → click table → view row data"
                                           FontSize="11" Foreground="#617084" VerticalAlignment="Center" />
                            </DockPanel>
                        </Border>

                        <!-- Dataset list -->
                        <Border Grid.Row="1" BorderBrush="#D3DCEA" BorderThickness="1"
                                CornerRadius="8" Margin="0,0,0,6">
                            <DataGrid x:Name="DatasetDataGrid"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      CanUserAddRows="False" CanUserDeleteRows="False"
                                      SelectionMode="Single"
                                      GridLinesVisibility="Horizontal"
                                      HorizontalGridLinesBrush="#EEF2F7"
                                      AlternatingRowBackground="#F8FAFD" RowBackground="White"
                                      BorderThickness="0" FontSize="12" RowHeight="28"
                                      ColumnHeaderStyle="{StaticResource DgHeaderStyle}"
                                      CellStyle="{StaticResource DgCellStyle}"
                                      SelectionChanged="DatasetDataGrid_SelectionChanged">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Dataset"  Binding="{Binding Name}"       Width="*" />
                                    <DataGridTextColumn Header="Tables"   Binding="{Binding TableCount}"  Width="60" />
                                    <DataGridTextColumn Header="Images"   Binding="{Binding ImageCount}"  Width="60" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                        <!-- Tables list -->
                        <Border Grid.Row="2" BorderBrush="#D3DCEA" BorderThickness="1"
                                CornerRadius="8" Margin="0,0,0,6">
                            <DataGrid x:Name="TablesDataGrid"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      CanUserAddRows="False" CanUserDeleteRows="False"
                                      SelectionMode="Single"
                                      GridLinesVisibility="Horizontal"
                                      HorizontalGridLinesBrush="#EEF2F7"
                                      AlternatingRowBackground="#F8FAFD" RowBackground="White"
                                      BorderThickness="0" FontSize="12" RowHeight="28"
                                      ColumnHeaderStyle="{StaticResource DgHeaderStyle}"
                                      CellStyle="{StaticResource DgCellStyle}"
                                      SelectionChanged="TablesDataGrid_SelectionChanged">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Table (rows)" Binding="{Binding DisplayLabel}" Width="*" />
                                    <DataGridTextColumn Header="Saved At"     Binding="{Binding CreatedAtLocal}" Width="130" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                        <!-- Row detail (dynamic columns, populated in code) -->
                        <Border Grid.Row="3" BorderBrush="#D3DCEA" BorderThickness="1" CornerRadius="8">
                            <DataGrid x:Name="RowDetailDataGrid"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      CanUserAddRows="False" CanUserDeleteRows="False"
                                      SelectionMode="Single"
                                      GridLinesVisibility="Horizontal"
                                      HorizontalGridLinesBrush="#EEF2F7"
                                      AlternatingRowBackground="#F8FAFD" RowBackground="White"
                                      BorderThickness="0" FontSize="12" RowHeight="28"
                                      ColumnHeaderStyle="{StaticResource DgHeaderStyle}"
                                      CellStyle="{StaticResource DgCellStyle}" />
                        </Border>

                        <!-- DB image strip -->
                        <Border Grid.Row="4" x:Name="DbImageBorder" Visibility="Collapsed"
                                Padding="10,8" Margin="0,6,0,0"
                                Background="#F8FAFD" CornerRadius="8"
                                BorderBrush="#D3DCEA" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Attached Images" FontSize="11" FontWeight="SemiBold"
                                           Foreground="#22304A" Margin="0,0,0,5" />
                                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Disabled" Height="90">
                                    <WrapPanel x:Name="DbImagePanel" Orientation="Horizontal" />
                                </ScrollViewer>
                            </StackPanel>
                        </Border>

                        <!-- Action bar -->
                        <Border Grid.Row="5" Padding="8,6" Margin="0,6,0,0"
                                Background="#F8FAFD" CornerRadius="6"
                                BorderBrush="#D3DCEA" BorderThickness="1">
                            <DockPanel>
                                <app:AppButton DockPanel.Dock="Right" Content="Delete Table"
                                        Click="DeleteDbRowButton_Click" />
                                <TextBlock x:Name="DbStatusTextBlock" VerticalAlignment="Center"
                                           FontSize="11" Foreground="#617084"
                                           Text="Open DB tab to load data." />
                            </DockPanel>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="2" Margin="10,0,10,10" Padding="10,8"
                Style="{StaticResource ShellCardBorderStyle}" Background="#F8FAFD">
            <TextBlock x:Name="StatusTextBlock" Foreground="#4E5A6C" FontSize="11" Text="Ready." />
        </Border>
    </Grid>
</UserControl>

