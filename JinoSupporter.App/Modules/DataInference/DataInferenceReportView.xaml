<UserControl x:Class="JinoSupporter.App.Modules.DataInference.DataInferenceReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:app="clr-namespace:JinoSupporter.Controls;assembly=JinoSupporter.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <Grid Background="{StaticResource ShellCanvasBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Margin="10,10,10,6" Padding="14"
                Style="{StaticResource ShellCardBorderStyle}" Background="White">
            <DockPanel>
                <!-- Token / cost badge (upper right) -->
                <Border DockPanel.Dock="Right" Padding="12,6" CornerRadius="6"
                        Background="#EBF3FC" BorderBrush="#B8D4F0" BorderThickness="1"
                        VerticalAlignment="Center" Margin="12,0,0,0"
                        Cursor="Hand"
                        MouseLeftButtonUp="TokenCostBadge_Click"
                        MouseRightButtonUp="TokenCostBadge_RightClick">
                    <Border.ToolTip>Click: Refresh Balance | Right-click: Set Session Key</Border.ToolTip>
                    <StackPanel>
                        <TextBlock x:Name="TokenCostTextBlock"
                                   FontSize="16" FontWeight="Bold" Foreground="#1A5FA8"
                                   HorizontalAlignment="Right" Text="$0.0000" />
                        <TextBlock x:Name="TokenUsageTextBlock"
                                   FontSize="10" Foreground="#617084"
                                   HorizontalAlignment="Right" Text="0 tokens" />
                        <TextBlock x:Name="CreditBalanceTextBlock"
                                   FontSize="10" Foreground="#059669"
                                   HorizontalAlignment="Right" Text="Balance: Set Session Key" />
                    </StackPanel>
                </Border>
                <StackPanel>
                    <TextBlock FontSize="20" FontWeight="SemiBold" Foreground="#22304A" Text="Report Generator" />
                    <TextBlock Margin="0,6,0,0" Foreground="#617084" FontSize="12"
                               Text="Select datasets → Generate Report → Claude AI creates an HTML report" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="1" Margin="10,0,10,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left panel -->
            <Border Grid.Column="0" Padding="14"
                    Style="{StaticResource ShellCardBorderStyle}" Background="White">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />  <!-- Tag filter header -->
                        <RowDefinition Height="120" />   <!-- Tag checklist -->
                        <RowDefinition Height="Auto" />  <!-- Dataset header -->
                        <RowDefinition Height="*" />     <!-- Dataset checklist -->
                        <RowDefinition Height="Auto" />  <!-- Generate button -->
                        <RowDefinition Height="160" />   <!-- Saved reports -->
                    </Grid.RowDefinitions>

                    <!-- Tag filter header -->
                    <DockPanel Grid.Row="0" Margin="0,0,0,4">
                        <app:AppButton DockPanel.Dock="Right" Content="Clear"
                                       Click="ClearTagFilterButton_Click" />
                        <app:AppButton DockPanel.Dock="Right" Content="Refresh"
                                       Margin="0,0,4,0"
                                       Click="RefreshButton_Click" />
                        <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#22304A"
                                   Text="Tag Filter" VerticalAlignment="Center" />
                    </DockPanel>

                    <!-- Tag checklist -->
                    <Border Grid.Row="1" BorderBrush="#D3DCEA" BorderThickness="1"
                            CornerRadius="6" Background="#F0F7FF" Margin="0,0,0,8">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="TagFilterPanel" Margin="6" />
                        </ScrollViewer>
                    </Border>

                    <!-- Dataset header -->
                    <DockPanel Grid.Row="2" Margin="0,0,0,4">
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <app:AppButton Content="All" Margin="0,0,4,0"
                                           Click="SelectAllButton_Click" />
                            <app:AppButton Content="None"
                                           Click="ClearSelectionButton_Click" />
                        </StackPanel>
                        <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#22304A"
                                   Text="Datasets" VerticalAlignment="Center" />
                    </DockPanel>

                    <!-- Dataset checklist -->
                    <Border Grid.Row="3" BorderBrush="#D3DCEA" BorderThickness="1"
                            CornerRadius="6" Background="#F8FAFD" Margin="0,0,0,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="DatasetCheckPanel" Margin="6" />
                        </ScrollViewer>
                    </Border>

                    <!-- Generate button -->
                    <StackPanel Grid.Row="4" Margin="0,8,0,8">
                        <app:AppButton x:Name="GenerateReportButton"
                                       Content="Generate Report"
                                       HorizontalAlignment="Stretch"
                                       Click="GenerateReportButton_Click" />
                    </StackPanel>

                    <!-- Saved reports list -->
                    <Grid Grid.Row="5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" FontSize="11" FontWeight="SemiBold"
                                   Foreground="#22304A" Text="Saved Reports" Margin="0,0,0,4" />
                        <Border Grid.Row="1" BorderBrush="#D3DCEA" BorderThickness="1"
                                CornerRadius="6" Background="#F8FAFD">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="SavedReportsPanel" Margin="4" />
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <!-- Right: report viewer -->
            <Border Grid.Column="2" Style="{StaticResource ShellCardBorderStyle}" Background="White">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Toolbar -->
                    <Border Grid.Row="0" Padding="10,8"
                            Background="#F8FAFD" BorderBrush="#D3DCEA" BorderThickness="0,0,0,1">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                <app:AppButton Content="Save HTML" Margin="0,0,6,0"
                                               Click="SaveHtmlButton_Click" />
                                <app:AppButton Content="Copy HTML"
                                               Click="CopyHtmlButton_Click" />
                            </StackPanel>
                            <TextBlock x:Name="ReportTitleText"
                                       FontSize="12" FontWeight="SemiBold" Foreground="#22304A"
                                       VerticalAlignment="Center" Text="Report" />
                        </DockPanel>
                    </Border>

                    <!-- Browser + placeholder -->
                    <Grid Grid.Row="1">
                        <WebBrowser x:Name="ReportBrowser" />
                        <Border x:Name="ReportPlaceholder" Background="White">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="No report yet"
                                           FontSize="14" FontWeight="SemiBold"
                                           Foreground="#22304A"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="Select datasets on the left and click Generate Report."
                                           FontSize="11" Foreground="#617084"
                                           HorizontalAlignment="Center" Margin="0,6,0,0" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="2" Margin="10,0,10,10" Padding="10,8"
                Style="{StaticResource ShellCardBorderStyle}" Background="#F8FAFD">
            <TextBlock x:Name="StatusTextBlock" Foreground="#4E5A6C" FontSize="11" Text="Ready." />
        </Border>
    </Grid>
</UserControl>
