<Window x:Class="JinoSupporter.App.Modules.DataInference.AnthropicLoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Anthropic Login — Window closes automatically after login"
        Width="960" Height="720"
        WindowStartupLocation="CenterOwner"
        Background="#F4F7FB">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Info bar -->
        <Border Grid.Row="0" Padding="14,10" Background="#EBF3FC" BorderBrush="#B8D4F0" BorderThickness="0,0,0,1">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="Cancel"
                        Padding="16,6" FontSize="12"
                        Background="#E5EAF2" Foreground="#22304A"
                        BorderThickness="0" Cursor="Hand"
                        Click="CancelButton_Click" />
                <Button x:Name="SaveSessionButton" DockPanel.Dock="Right" Content="Save Session"
                        Padding="16,6" FontSize="12" Margin="0,0,8,0"
                        Background="#1A5FA8" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        Click="SaveSessionButton_Click" />
                <TextBlock VerticalAlignment="Center" FontSize="12" Foreground="#1A5FA8" TextWrapping="Wrap"
                           Text="Window closes automatically after login. If it doesn't close, click the 'Save Session' button." />
            </DockPanel>
        </Border>

        <!-- WebView2 browser -->
        <wv2:WebView2 x:Name="BrowserView" Grid.Row="1"
                      Source="https://platform.claude.com/login" />
    </Grid>
</Window>
