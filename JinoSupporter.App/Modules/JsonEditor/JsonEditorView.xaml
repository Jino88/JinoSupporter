<UserControl x:Class="WorkbenchHost.Modules.JsonEditor.JsonEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:WorkbenchHost.Modules.JsonEditor"
             mc:Ignorable="d"
             AllowDrop="True"
             DragOver="UserControl_DragOver"
             Drop="UserControl_Drop">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <Style x:Key="JsonEditorActionButtonStyle" TargetType="Button" BasedOn="{StaticResource AppButtonBaseStyle}">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style x:Key="JsonEditorMiniButtonStyle" TargetType="Button" BasedOn="{StaticResource AppButtonBaseStyle}">
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="MinWidth" Value="68" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Margin" Value="4,0,0,0" />
            <Setter Property="FontSize" Value="11" />
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource ShellCanvasBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Margin="10,10,10,6"
                Padding="10"
                Style="{StaticResource ShellCardBorderStyle}"
                Background="White">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <Button Content="Open JSON" Style="{StaticResource JsonEditorActionButtonStyle}" Click="OpenJsonButton_Click" />
                    <Button Content="Save" Style="{StaticResource JsonEditorActionButtonStyle}" Click="SaveButton_Click" />
                    <Button Content="Save As" Style="{StaticResource JsonEditorActionButtonStyle}" Click="SaveAsButton_Click" />
                    <Button Content="Reload" Style="{StaticResource JsonEditorActionButtonStyle}" Click="ReloadButton_Click" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock VerticalAlignment="Center"
                               Margin="0,0,8,0"
                               Foreground="#42526A"
                               Text="Drag a JSON file into the editor area" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="10,0,10,6">
            <Border Padding="10" Style="{StaticResource ShellCardBorderStyle}" Background="White">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top">
                        <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="#22304A" Text="JSON Tree Editor" />
                        <TextBlock Margin="0,4,0,8" Foreground="#6A7486" FontSize="11" Text="{Binding CurrentFilePath, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                    </StackPanel>

                    <Grid DockPanel.Dock="Top" Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="90" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="170" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" FontWeight="SemiBold" FontSize="11" Text="Key" Foreground="#526178" />
                        <TextBlock Grid.Column="1" FontWeight="SemiBold" FontSize="11" Text="Type" Foreground="#526178" />
                        <TextBlock Grid.Column="2" FontWeight="SemiBold" FontSize="11" Text="Value" Foreground="#526178" />
                        <TextBlock Grid.Column="3" FontWeight="SemiBold" FontSize="11" Text="Actions" Foreground="#526178" />
                    </Grid>

                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <TreeView x:Name="JsonTreeView"
                                  BorderThickness="0"
                                  Background="Transparent"
                                  SelectedItemChanged="JsonTreeView_SelectedItemChanged">
                            <TreeView.Resources>
                                <HierarchicalDataTemplate DataType="{x:Type local:JsonTreeNode}" ItemsSource="{Binding Children}">
                                    <Grid Margin="0,1,0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="200" />
                                            <ColumnDefinition Width="90" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="170" />
                                        </Grid.ColumnDefinitions>

                                        <TextBox Grid.Column="0"
                                                 Text="{Binding EditableKey, UpdateSourceTrigger=PropertyChanged}"
                                                 IsReadOnly="{Binding IsKeyReadOnly}"
                                                 BorderBrush="#CCD5E2"
                                                 Background="{Binding KeyBackground}"
                                                 Padding="8,4"
                                                 FontSize="12"
                                                 MinHeight="32"
                                                 VerticalContentAlignment="Center" />

                                        <TextBlock Grid.Column="1"
                                                   VerticalAlignment="Center"
                                                   Foreground="#4F5C70"
                                                   FontSize="11"
                                                   Text="{Binding KindLabel}" />

                                        <TextBox Grid.Column="2"
                                                 Text="{Binding EditableValue, UpdateSourceTrigger=PropertyChanged}"
                                                 IsReadOnly="{Binding IsValueReadOnly}"
                                                 BorderBrush="#CCD5E2"
                                                 Background="{Binding ValueBackground}"
                                                 Padding="8,4"
                                                 FontSize="12"
                                                 MinHeight="32"
                                                 VerticalContentAlignment="Center" />

                                        <StackPanel Grid.Column="3" Orientation="Horizontal">
                                            <Button Content="+ Property"
                                                    Style="{StaticResource JsonEditorMiniButtonStyle}"
                                                    Visibility="{Binding CanAddProperty, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                    Tag="{Binding}"
                                                    Click="AddPropertyButton_Click" />
                                            <Button Content="+ Item"
                                                    Style="{StaticResource JsonEditorMiniButtonStyle}"
                                                    Visibility="{Binding CanAddItem, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                    Tag="{Binding}"
                                                    Click="AddItemButton_Click" />
                                            <Button Content="Delete"
                                                    Style="{StaticResource JsonEditorMiniButtonStyle}"
                                                    Visibility="{Binding CanDelete, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                    Tag="{Binding}"
                                                    Click="DeleteNodeButton_Click" />
                                        </StackPanel>
                                    </Grid>
                                </HierarchicalDataTemplate>
                            </TreeView.Resources>
                        </TreeView>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Margin="10,0,10,10" Padding="8,6" Style="{StaticResource ShellCardBorderStyle}" Background="#F8FAFD">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           Foreground="#4E5A6C"
                           FontSize="11"
                           Text="{Binding StatusMessage, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                <TextBlock DockPanel.Dock="Right"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           Foreground="#7A8699"
                           FontSize="11"
                           Text="{Binding DirtyStateText, RelativeSource={RelativeSource AncestorType=UserControl}}" />
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
