<Window x:Class="JinoSupporter.App.Modules.Home.UsageLoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Usage Login"
        Width="1200"
        Height="860"
        WindowStartupLocation="CenterOwner"
        Background="#F8FBFF">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Background="#FFFFFF"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="12"
                Padding="12">
            <StackPanel>
                <TextBlock x:Name="HeaderTitleTextBlock"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="#0F172A" />
                <TextBlock x:Name="HeaderDescriptionTextBlock"
                           Margin="0,6,0,0"
                           TextWrapping="Wrap"
                           Foreground="#475569" />
                <TextBlock x:Name="StatusTextBlock"
                           Margin="0,8,0,0"
                           TextWrapping="Wrap"
                           Foreground="#64748B" />
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Margin="0,10,0,10"
                Background="#FFFFFF"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="12"
                ClipToBounds="True">
            <wv2:WebView2 x:Name="Browser" />
        </Border>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Open Usage Page"
                    Width="140"
                    Margin="0,0,8,0"
                    Click="OpenUsagePageButton_Click" />
            <Button Content="Use This Session"
                    Width="140"
                    Margin="0,0,8,0"
                    Click="UseThisSessionButton_Click" />
            <Button Content="Close"
                    Width="100"
                    Click="CloseButton_Click" />
        </StackPanel>
    </Grid>
</Window>
