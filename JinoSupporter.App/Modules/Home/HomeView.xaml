<UserControl x:Class="JinoSupporter.App.Modules.Home.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:app="clr-namespace:JinoSupporter.Controls;assembly=JinoSupporter.Controls"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf">
    <Grid Background="#F8FBFF">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="0" />
        </Grid.RowDefinitions>

        <Border Background="#EFF6FF"
                BorderBrush="#D9E7F7"
                BorderThickness="1"
                CornerRadius="16"
                Padding="18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="AI Usage Status"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#102A43" />
                    <TextBlock Text="ChatGPT / Claude usage dashboard"
                               Margin="0,6,0,0"
                               Foreground="#486581" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Top">
                    <app:AppButton Content="ChatGPT Login"
                                   Width="120"
                                   Margin="0,0,8,0"
                                   Click="ChatGptLoginButton_Click" />
                    <app:AppButton Content="Claude Login"
                                   Width="120"
                                   Margin="0,0,8,0"
                                   Click="ClaudeLoginButton_Click" />
                    <app:AppButton Content="Refresh"
                                   Width="110"
                                   Click="RefreshButton_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Margin="0,12,0,0"
                Background="#FFFFFF"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="16"
                Padding="16">
            <CheckBox x:Name="RememberSessionCheckBox"
                      Content="로그인 세션 자동 저장 및 자동 로그인"
                      IsChecked="True"
                      Checked="RememberSessionCheckBox_Checked"
                      Unchecked="RememberSessionCheckBox_Unchecked" />
        </Border>

        <Grid Grid.Row="2"
              Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Margin="0,0,10,0"
                    Background="#FFFFFF"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    CornerRadius="18"
                    Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="ChatGPT"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="#0F172A" />
                        <TextBlock x:Name="ChatGptStatusTextBlock"
                                   Margin="0,8,0,0"
                                   TextWrapping="Wrap"
                                   Foreground="#475569" />
                    </StackPanel>

                    <UniformGrid Grid.Row="1"
                                 Margin="0,16,0,0"
                                 Columns="2">
                        <Border Margin="0,0,8,8"
                                Background="#F8FBFF"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="16">
                            <StackPanel>
                                <TextBlock Text="5시간 사용 한도" Foreground="#64748B" />
                                <TextBlock x:Name="ChatGptFiveHourValueTextBlock" Margin="0,8,0,0" FontSize="26" FontWeight="Bold" Foreground="#0F172A" />
                                <TextBlock x:Name="ChatGptFiveHourDetailTextBlock" Margin="0,10,0,0" TextWrapping="Wrap" Foreground="#64748B" />
                            </StackPanel>
                        </Border>
                        <Border Margin="8,0,0,8"
                                Background="#F8FBFF"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="16">
                            <StackPanel>
                                <TextBlock Text="주간 사용 한도" Foreground="#64748B" />
                                <TextBlock x:Name="ChatGptWeeklyValueTextBlock" Margin="0,8,0,0" FontSize="26" FontWeight="Bold" Foreground="#0F172A" />
                                <TextBlock x:Name="ChatGptWeeklyDetailTextBlock" Margin="0,10,0,0" TextWrapping="Wrap" Foreground="#64748B" />
                            </StackPanel>
                        </Border>
                        <Border Margin="0,8,8,0"
                                Background="#F8FBFF"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="16">
                            <StackPanel>
                                <TextBlock Text="코드 검토" Foreground="#64748B" />
                                <TextBlock x:Name="ChatGptReviewValueTextBlock" Margin="0,8,0,0" FontSize="26" FontWeight="Bold" Foreground="#0F172A" />
                                <TextBlock x:Name="ChatGptReviewDetailTextBlock" Margin="0,10,0,0" TextWrapping="Wrap" Foreground="#64748B" />
                            </StackPanel>
                        </Border>
                        <Border Margin="8,8,0,0"
                                Background="#F8FBFF"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="16">
                            <StackPanel>
                                <TextBlock Text="남은 크레딧" Foreground="#64748B" />
                                <TextBlock x:Name="ChatGptCreditsValueTextBlock" Margin="0,8,0,0" FontSize="26" FontWeight="Bold" Foreground="#0F172A" />
                                <TextBlock x:Name="ChatGptCreditsDetailTextBlock" Margin="0,10,0,0" TextWrapping="Wrap" Foreground="#64748B" />
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Margin="10,0,0,0"
                    Background="#FFFFFF"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    CornerRadius="18"
                    Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="Claude"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="#0F172A" />
                        <TextBlock x:Name="ClaudeStatusTextBlock"
                                   Margin="0,8,0,0"
                                   TextWrapping="Wrap"
                                   Foreground="#475569" />
                    </StackPanel>

                    <UniformGrid Grid.Row="1"
                                 Margin="0,16,0,0"
                                 Columns="2">
                        <Border Margin="0,0,8,8"
                                Background="#FFF9F4"
                                BorderBrush="#F0D8C2"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="16">
                            <StackPanel>
                                <TextBlock Text="현재 세션" Foreground="#8C5A2B" />
                                <TextBlock x:Name="ClaudeValue1TextBlock" Margin="0,8,0,0" FontSize="26" FontWeight="Bold" Foreground="#4A2C14" />
                                <TextBlock x:Name="ClaudeDetail1TextBlock" Margin="0,10,0,0" TextWrapping="Wrap" Foreground="#8C5A2B" />
                            </StackPanel>
                        </Border>
                        <Border Margin="8,0,0,8"
                                Background="#FFF9F4"
                                BorderBrush="#F0D8C2"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="16">
                            <StackPanel>
                                <TextBlock Text="주간 한도" Foreground="#8C5A2B" />
                                <TextBlock x:Name="ClaudeValue2TextBlock" Margin="0,8,0,0" FontSize="26" FontWeight="Bold" Foreground="#4A2C14" />
                                <TextBlock x:Name="ClaudeDetail2TextBlock" Margin="0,10,0,0" TextWrapping="Wrap" Foreground="#8C5A2B" />
                            </StackPanel>
                        </Border>
                        <Border Margin="0,8,8,0"
                                Background="#FFF9F4"
                                BorderBrush="#F0D8C2"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="16">
                            <StackPanel>
                                <TextBlock Text="추가 사용량" Foreground="#8C5A2B" />
                                <TextBlock x:Name="ClaudeValue3TextBlock" Margin="0,8,0,0" FontSize="26" FontWeight="Bold" Foreground="#4A2C14" />
                                <TextBlock x:Name="ClaudeDetail3TextBlock" Margin="0,10,0,0" TextWrapping="Wrap" Foreground="#8C5A2B" />
                            </StackPanel>
                        </Border>
                        <Border Margin="8,8,0,0"
                                Background="#FFF9F4"
                                BorderBrush="#F0D8C2"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="16">
                            <StackPanel>
                                <TextBlock Text="월간 지출 한도" Foreground="#8C5A2B" />
                                <TextBlock x:Name="ClaudeValue4TextBlock" Margin="0,8,0,0" FontSize="26" FontWeight="Bold" Foreground="#4A2C14" />
                                <TextBlock x:Name="ClaudeDetail4TextBlock" Margin="0,10,0,0" TextWrapping="Wrap" Foreground="#8C5A2B" />
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                </Grid>
            </Border>
        </Grid>

        <wv2:WebView2 x:Name="ChatGptHiddenBrowser"
                      Grid.Row="3"
                      Width="0"
                      Height="0"
                      Visibility="Collapsed" />
        <wv2:WebView2 x:Name="ClaudeHiddenBrowser"
                      Grid.Row="3"
                      Width="0"
                      Height="0"
                      Visibility="Collapsed" />
    </Grid>
</UserControl>
