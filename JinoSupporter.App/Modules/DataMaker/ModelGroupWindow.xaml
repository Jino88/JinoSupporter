<Window x:Class="DataMaker.ModelGroupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:app="clr-namespace:JinoSupporter.Controls;assembly=JinoSupporter.Controls"
        Title="Model Groups" Width="800" Height="500"
        ResizeMode="CanResize" WindowStartupLocation="CenterOwner"
        Background="#F5F6FA" Foreground="#1A1D26">

    <Window.Resources>
        <SolidColorBrush x:Key="Surface1Brush" Color="#F0F1F5"/>
        <SolidColorBrush x:Key="Surface2Brush" Color="#E4E5EB"/>
        <SolidColorBrush x:Key="TextBrush" Color="#1A1D26"/>
        <SolidColorBrush x:Key="BlueBrush" Color="#4F6BED"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF"/>

        <Style x:Key="ModernButton" TargetType="Button" BasedOn="{StaticResource AppButtonBaseStyle}">
            <Setter Property="Background" Value="{StaticResource Surface1Brush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="{StaticResource BlueBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderBrush" Value="{StaticResource BlueBrush}"/>
        </Style>
    </Window.Resources>

    <DockPanel Margin="16">
        <!-- Top toolbar -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
            <app:AppButton x:Name="CT_BT_PLUS" Content="+ Add" Style="{StaticResource AccentButton}" Margin="0,0,6,0" Click="CT_BT_PLUS_Click"/>
            <app:AppButton x:Name="CT_BT_MINUS" Content="- Remove" Style="{StaticResource ModernButton}" Margin="0,0,6,0" Click="CT_BT_MINUS_Click"/>
            <app:AppButton x:Name="CT_BT_LOAD" Content="Load JSON" Style="{StaticResource ModernButton}" Margin="0,0,6,0" Click="CT_BT_LOAD_Click"/>
            <app:AppButton x:Name="CT_BT_SAVE" Content="Save JSON" Style="{StaticResource ModernButton}" Margin="0,0,6,0" Click="CT_BT_SAVE_Click"/>
        </StackPanel>

        <!-- Scrollable group panels -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
            <WrapPanel x:Name="CT_PANEL_MODEL"/>
        </ScrollViewer>
    </DockPanel>
</Window>
