<Window x:Class="DataMaker.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Width="500" Height="520"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        Background="#F5F6FA" Foreground="#1A1D26">

    <Window.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
        </Style>
        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#1A1D26"/>
            <Setter Property="BorderBrush" Value="#E2E4EA"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="SectionStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#4F6BED"/>
            <Setter Property="Margin" Value="0,12,0,6"/>
        </Style>
    </Window.Resources>

    <DockPanel Margin="20">
        <!-- Bottom buttons -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="CT_BT_CANCEL" Content="Cancel" Width="80" Margin="0,0,8,0" Click="CT_BT_CANCEL_Click"
                    Background="#F0F1F5" Foreground="#1A1D26" BorderBrush="#E2E4EA" BorderThickness="1" Padding="0,8" Cursor="Hand"/>
            <Button x:Name="CT_BT_SAVE" Content="Save" Width="80" Click="CT_BT_SAVE_Click"
                    Background="#4F6BED" Foreground="White" BorderThickness="0" Padding="0,8"
                    FontWeight="SemiBold" Cursor="Hand"/>
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- File Paths -->
                <TextBlock Text="FILE PATHS" Style="{StaticResource SectionStyle}"/>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Routing File Path" Style="{StaticResource LabelStyle}" Grid.Row="0"/>
                    <TextBox x:Name="TB_RoutingPath" Style="{StaticResource InputStyle}" Grid.Row="0" Grid.Column="1"/>
                    <TextBlock Text="Reason File Path" Style="{StaticResource LabelStyle}" Grid.Row="2"/>
                    <TextBox x:Name="TB_ReasonPath" Style="{StaticResource InputStyle}" Grid.Row="2" Grid.Column="1"/>
                </Grid>

                <!-- Report Options -->
                <TextBlock Text="REPORT OPTIONS" Style="{StaticResource SectionStyle}"/>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Top NG Count" Style="{StaticResource LabelStyle}" Grid.Row="0"/>
                    <TextBox x:Name="TB_TopNGCount" Style="{StaticResource InputStyle}" Grid.Row="0" Grid.Column="1"/>

                    <TextBlock Text="Top Process Count" Style="{StaticResource LabelStyle}" Grid.Row="2"/>
                    <TextBox x:Name="TB_TopProcessCount" Style="{StaticResource InputStyle}" Grid.Row="2" Grid.Column="1"/>

                    <TextBlock Text="Top Defects Per Reason" Style="{StaticResource LabelStyle}" Grid.Row="4"/>
                    <TextBox x:Name="TB_TopDefectsPerReason" Style="{StaticResource InputStyle}" Grid.Row="4" Grid.Column="1"/>

                    <TextBlock Text="Ranking Period Type" Style="{StaticResource LabelStyle}" Grid.Row="6"/>
                    <ComboBox x:Name="CB_RankingPeriodType" Grid.Row="6" Grid.Column="1"
                              Background="White" FontSize="12" Padding="8,5">
                        <ComboBoxItem Content="Week"/>
                        <ComboBoxItem Content="Month"/>
                    </ComboBox>

                    <TextBlock Text="Worst Ranking Week Offset" Style="{StaticResource LabelStyle}" Grid.Row="8"/>
                    <TextBox x:Name="TB_WeekOffset" Style="{StaticResource InputStyle}" Grid.Row="8" Grid.Column="1"/>

                    <TextBlock Text="Worst Ranking Month Offset" Style="{StaticResource LabelStyle}" Grid.Row="10"/>
                    <TextBox x:Name="TB_MonthOffset" Style="{StaticResource InputStyle}" Grid.Row="10" Grid.Column="1"/>

                    <TextBlock Text="Query Count (nQUERY)" Style="{StaticResource LabelStyle}" Grid.Row="12"/>
                    <TextBox x:Name="TB_nQUERY" Style="{StaticResource InputStyle}" Grid.Row="12" Grid.Column="1"/>

                    <TextBlock Text="Qty Worst (nQtyWorst)" Style="{StaticResource LabelStyle}" Grid.Row="14"/>
                    <TextBox x:Name="TB_nQtyWorst" Style="{StaticResource InputStyle}" Grid.Row="14" Grid.Column="1"/>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
