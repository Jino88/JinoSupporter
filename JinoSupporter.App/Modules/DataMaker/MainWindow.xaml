<Window x:Class="DataMaker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Data Maker" Width="1680" Height="960"
        MinWidth="1460" MinHeight="840"
        ResizeMode="CanResize"
        Background="#F5F6FA" Foreground="#1A1D26">

    <Window.Resources>
        <!-- Light Color Palette -->
        <Color x:Key="Surface0">#FFFFFF</Color>
        <Color x:Key="Surface1">#F0F1F5</Color>
        <Color x:Key="Surface2">#E4E5EB</Color>
        <Color x:Key="Base">#F5F6FA</Color>
        <Color x:Key="Text">#1A1D26</Color>
        <Color x:Key="Subtext">#6B7280</Color>
        <Color x:Key="Blue">#4F6BED</Color>
        <Color x:Key="Green">#16A34A</Color>
        <Color x:Key="Mauve">#7C3AED</Color>
        <Color x:Key="Red">#EF4444</Color>
        <Color x:Key="Peach">#EA580C</Color>
        <Color x:Key="Yellow">#CA8A04</Color>

        <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource Surface0}"/>
        <SolidColorBrush x:Key="Surface1Brush" Color="{StaticResource Surface1}"/>
        <SolidColorBrush x:Key="Surface2Brush" Color="{StaticResource Surface2}"/>
        <SolidColorBrush x:Key="TextBrush" Color="{StaticResource Text}"/>
        <SolidColorBrush x:Key="SubtextBrush" Color="{StaticResource Subtext}"/>
        <SolidColorBrush x:Key="BlueBrush" Color="{StaticResource Blue}"/>
        <SolidColorBrush x:Key="GreenBrush" Color="{StaticResource Green}"/>
        <SolidColorBrush x:Key="MauveBrush" Color="{StaticResource Mauve}"/>
        <SolidColorBrush x:Key="RedBrush" Color="{StaticResource Red}"/>
        <SolidColorBrush x:Key="PeachBrush" Color="{StaticResource Peach}"/>

        <!-- Modern Button Style -->
        <Style x:Key="ModernButton" TargetType="Button" BasedOn="{StaticResource AppButtonBaseStyle}">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D5DFEC"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="10.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- Accent Button (Primary actions) -->
        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderBrush" Value="#D5DFEC"/>
        </Style>

        <!-- Card Panel Style -->
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.06" Color="Black"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Section Header -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource SubtextBrush}"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <!-- Modern ProgressBar -->
        <Style x:Key="ModernProgress" TargetType="ProgressBar" BasedOn="{StaticResource AppProgressBarBaseStyle}">
            <Setter Property="Background" Value="{StaticResource Surface1Brush}"/>
            <Setter Property="Foreground" Value="{StaticResource BlueBrush}"/>
        </Style>

        <!-- Small icon button -->
        <Style x:Key="IconButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </Window.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TOP ACTIONS -->
        <Border Style="{StaticResource CardBorder}" Grid.Row="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="360"/>
                </Grid.ColumnDefinitions>

                <DockPanel Grid.Column="0" LastChildFill="True" Margin="0,0,12,0">
                        <WrapPanel>
                        <Button x:Name="CT_BT_SHOW_GETDATA" Content="Get Data" Style="{StaticResource AccentButton}" Margin="0,3,8,3" Click="CT_BT_SHOW_GETDATA_Click"/>
                        <Button x:Name="CT_BT_LOAD" Content="Load DB..." Style="{StaticResource AccentButton}" Margin="0,3,8,3" Click="CT_BT_LOAD_Click"/>
                        <Button x:Name="CT_BT_MAPPING" Content="Mapping" Style="{StaticResource ModernButton}" Margin="0,3,8,3" Click="CT_BT_MAPPING_Click"/>
                        <Button x:Name="CT_BT_MODELGROUPS" Content="Model Groups" Style="{StaticResource AccentButton}" Margin="0,3,8,3" Click="CT_BT_MODELGROUPS_Click">
                            <Button.Background>
                                <SolidColorBrush Color="White"/>
                            </Button.Background>
                        </Button>
                        <Separator Width="1" Height="20" Margin="4,3,4,3" Background="#D5DFEC"/>
                        <Button x:Name="CT_BT_GETREPORT" Content="Get Report" Style="{StaticResource AccentButton}" Margin="0,3,8,3" Click="CT_BT_GETREPORT_Click">
                            <Button.Background>
                                <SolidColorBrush Color="White"/>
                            </Button.Background>
                        </Button>
                        <Button x:Name="CT_BT_SETTINGS" Content="Settings" Style="{StaticResource AccentButton}" Margin="0,3,0,3" Click="CT_BT_SETTINGS_Click">
                            <Button.Background>
                                <SolidColorBrush Color="White"/>
                            </Button.Background>
                        </Button>
                    </WrapPanel>
                </DockPanel>

                <Border Grid.Column="1"
                        Background="#F8FAFC"
                        BorderBrush="#E2E4EA"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="10,8">
                    <StackPanel>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Current Task" Foreground="{StaticResource SubtextBrush}" FontSize="11"/>
                            <TextBlock Grid.Column="1" x:Name="CT_LB_TASK_PERCENT" Text="0%" Foreground="{StaticResource BlueBrush}"
                                       FontSize="11" HorizontalAlignment="Right"/>
                        </Grid>
                        <ProgressBar x:Name="CT_PROG_TASK" Style="{StaticResource ModernProgress}" Minimum="0" Maximum="100"/>

                        <Grid Margin="0,10,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Total Task" Foreground="{StaticResource SubtextBrush}" FontSize="11"/>
                            <TextBlock Grid.Column="1" x:Name="CT_LB_TOTAL_PERCENT" Text="0%" Foreground="{StaticResource GreenBrush}"
                                       FontSize="11" HorizontalAlignment="Right"/>
                        </Grid>
                        <ProgressBar x:Name="CT_PROG_TOTAL" Style="{StaticResource ModernProgress}" Minimum="0" Maximum="100">
                            <ProgressBar.Foreground>
                                <SolidColorBrush Color="{StaticResource Green}"/>
                            </ProgressBar.Foreground>
                        </ProgressBar>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Border x:Name="CT_EMPTY_HOME" Style="{StaticResource CardBorder}">
                    <Grid>
                        <TextBlock Text="Action 메뉴를 선택하면 여기에서 작업 화면이 열립니다."
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource SubtextBrush}"
                                   FontSize="11"/>
                    </Grid>
                </Border>

                <Grid x:Name="CT_LOAD_CONTENT" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.45*"/>
                        <ColumnDefinition Width="0.75*"/>
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource CardBorder}" Grid.Column="0">
                        <DockPanel>
                            <TextBlock Text="DB LOAD" Style="{StaticResource SectionHeader}" DockPanel.Dock="Top"/>
                            <StackPanel>
                                <TextBlock Text="Selected DB"
                                           Foreground="{StaticResource SubtextBrush}"
                                           Margin="0,0,0,6"/>
                                <TextBox x:Name="CT_TB_DB_PATH"
                                         IsReadOnly="True"
                                         TextWrapping="Wrap"
                                         MinHeight="38"
                                         Background="#F8FAFC"
                                         Foreground="#334155"
                                         BorderThickness="1"
                                         BorderBrush="#E2E4EA"
                                         Padding="6"/>
                                <Grid Margin="0,12,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Button x:Name="CT_BT_LOAD_GROUP_JSON"
                                            Grid.Row="0"
                                            Grid.Column="0"
                                            Content="Json Load"
                                            Style="{StaticResource AccentButton}"
                                            Click="CT_BT_LOAD_GROUP_JSON_Click"/>

                                    <TextBlock x:Name="CT_LB_GROUP_JSON_PATH"
                                               Grid.Row="0"
                                               Grid.Column="1"
                                               Margin="12,0,0,0"
                                               Foreground="{StaticResource SubtextBrush}"
                                               Text="Load a group JSON file after DB load."
                                               TextTrimming="CharacterEllipsis"/>

                                    <TextBlock Grid.Row="1"
                                               Grid.ColumnSpan="2"
                                               Margin="0,12,0,8"
                                               Text="Groups / Sub Groups"
                                               Style="{StaticResource SectionHeader}"/>

                                    <Grid Grid.Row="2" Grid.ColumnSpan="2" Height="300">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="210"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0"
                                                Background="#F8FAFC"
                                                BorderBrush="#E2E4EA"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="10">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="*"/>
                                                </Grid.RowDefinitions>
                                                <TextBlock Grid.Row="0"
                                                           Margin="0,0,0,8"
                                                           Text="Group Name"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource SubtextBrush}"/>
                                                <ListBox x:Name="CT_LB_GROUPS"
                                                         Grid.Row="1"
                                                         DisplayMemberPath="GroupName"
                                                         AllowDrop="True"
                                                         Background="#FDFEFF"
                                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                         DragOver="GroupJsonList_DragOver"
                                                         Drop="GroupJsonList_Drop"
                                                         ToolTip="Drag a JSON file here"
                                                         SelectionChanged="CT_LB_GROUPS_SelectionChanged"/>
                                            </Grid>
                                        </Border>

                                        <Border Grid.Column="2"
                                                Background="#F8FAFC"
                                                BorderBrush="#E2E4EA"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="10">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="*"/>
                                                </Grid.RowDefinitions>
                                                <TextBlock x:Name="CT_LB_SUBGROUP_HEADER"
                                                           Grid.Row="0"
                                                           Margin="0,0,0,8"
                                                           Text="Sub Groups"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource SubtextBrush}"/>
                                                <ListBox x:Name="CT_LB_SUBGROUPS"
                                                         Grid.Row="1"
                                                         AllowDrop="True"
                                                         Background="#FDFEFF"
                                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                         DragOver="GroupJsonList_DragOver"
                                                         Drop="GroupJsonList_Drop"
                                                         ToolTip="Drag a JSON file here"/>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </Grid>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource CardBorder}">
                        <DockPanel>
                            <TextBlock Text="MAPPING STATUS" Style="{StaticResource SectionHeader}" DockPanel.Dock="Top"/>
                            <StackPanel>
                                <TextBlock x:Name="CT_LB_LOAD_MAPPING_STATUS_HINT"
                                           Text="Load DB 완료 후 자동으로 Mapping 상태를 계산합니다."
                                           Foreground="{StaticResource SubtextBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,10"/>

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="RoutingTable Rows"
                                               Foreground="{StaticResource SubtextBrush}"/>
                                    <TextBlock x:Name="CT_LB_LOAD_ROUTING_TABLE_COUNT"
                                               Grid.Column="1"
                                               Text="0"
                                               FontWeight="SemiBold"/>
                                </Grid>

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="ReasonTable Rows"
                                               Foreground="{StaticResource SubtextBrush}"/>
                                    <TextBlock x:Name="CT_LB_LOAD_REASON_TABLE_COUNT"
                                               Grid.Column="1"
                                               Text="0"
                                               FontWeight="SemiBold"/>
                                </Grid>

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="DB Routing 미매핑"
                                               Foreground="{StaticResource SubtextBrush}"/>
                                    <TextBlock x:Name="CT_LB_LOAD_MISSING_ROUTING_COUNT"
                                               Grid.Column="1"
                                               Text="0"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource RedBrush}"/>
                                </Grid>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="DB Reason 미매핑"
                                               Foreground="{StaticResource SubtextBrush}"/>
                                    <TextBlock x:Name="CT_LB_LOAD_MISSING_REASON_COUNT"
                                               Grid.Column="1"
                                               Text="0"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource RedBrush}"/>
                                </Grid>

                                <Border Background="#F8FAFC"
                                        BorderBrush="#E2E4EA"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="10">
                                    <TextBlock x:Name="CT_LB_LOAD_MAPPING_STATUS_SUMMARY"
                                               Text="Mapping status is not available yet."
                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource SubtextBrush}"/>
                                </Border>
                            </StackPanel>
                        </DockPanel>
                    </Border>
                </Grid>

                <DockPanel x:Name="CT_REPORT_SETUP_CONTENT" Visibility="Collapsed">
                    <Border Style="{StaticResource CardBorder}" DockPanel.Dock="Top">
                        <DockPanel>
                            <TextBlock Text="REPORT ORDER" Style="{StaticResource SectionHeader}" DockPanel.Dock="Top"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,12">
                                    <TextBlock Text="Output Folder"
                                               Foreground="{StaticResource SubtextBrush}"
                                               Margin="0,0,0,6"/>
                                    <TextBox x:Name="CT_TB_REPORT_OUTPUT_PATH"
                                             IsReadOnly="True"
                                             TextWrapping="Wrap"
                                             MinHeight="40"
                                             Background="#F8FAFC"
                                             Foreground="#334155"
                                             BorderThickness="1"
                                             BorderBrush="#E2E4EA"
                                             Padding="8"/>
                                </StackPanel>

                                <ListBox x:Name="CT_LB_REPORT_JSON_ORDER"
                                         Grid.Row="1"
                                         Grid.Column="0"
                                         MinHeight="240"
                                         Margin="0,0,12,0"
                                         Background="#F8FAFC"
                                         BorderBrush="#E2E4EA"
                                         BorderThickness="1"/>

                                <StackPanel Grid.Row="1" Grid.Column="1" VerticalAlignment="Top">
                                    <Button x:Name="CT_BT_REPORT_MOVE_UP"
                                            Content="Up"
                                            Style="{StaticResource ModernButton}"
                                            Margin="0,0,0,8"
                                            Click="CT_BT_REPORT_MOVE_UP_Click"/>
                                    <Button x:Name="CT_BT_REPORT_MOVE_DOWN"
                                            Content="Down"
                                            Style="{StaticResource ModernButton}"
                                            Margin="0,0,0,8"
                                            Click="CT_BT_REPORT_MOVE_DOWN_Click"/>
                                </StackPanel>

                                <StackPanel Grid.Row="2"
                                            Grid.ColumnSpan="2"
                                            Orientation="Horizontal"
                                            HorizontalAlignment="Right"
                                            Margin="0,12,0,0">
                                    <Button x:Name="CT_BT_REPORT_LOAD_SAVED"
                                            Content="Load Saved"
                                            Style="{StaticResource ModernButton}"
                                            Margin="0,0,8,0"
                                            Click="CT_BT_REPORT_LOAD_SAVED_Click"/>
                                    <Button x:Name="CT_BT_REPORT_SAVE"
                                            Content="Save"
                                            Style="{StaticResource ModernButton}"
                                            Margin="0,0,8,0"
                                            Click="CT_BT_REPORT_SAVE_Click"/>
                                    <Button x:Name="CT_BT_REPORT_CANCEL"
                                            Content="Cancel"
                                            Style="{StaticResource ModernButton}"
                                            Margin="0,0,8,0"
                                            Click="CT_BT_REPORT_CANCEL_Click"/>
                                    <Button x:Name="CT_BT_REPORT_START"
                                            Content="Start"
                                            Style="{StaticResource AccentButton}"
                                            Click="CT_BT_REPORT_START_Click"/>
                                </StackPanel>
                            </Grid>
                        </DockPanel>
                    </Border>
                </DockPanel>

                <ScrollViewer x:Name="CT_MAIN_CONTENT_SCROLL"
                              Visibility="Collapsed"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <DockPanel x:Name="CT_MAIN_CONTENT">

                <Border x:Name="CT_MAPPING_CONTENT" Style="{StaticResource CardBorder}" DockPanel.Dock="Top" Visibility="Collapsed">
                    <DockPanel>
                        <TextBlock x:Name="CT_LB_MAPPING_TITLE" Text="MAPPING STATUS" Style="{StaticResource SectionHeader}" DockPanel.Dock="Top"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="180"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Button x:Name="CT_BT_MAPPING_SHOW_ROUTING"
                                            Content="Routing"
                                            Style="{StaticResource ModernButton}"
                                            Margin="0,0,8,0"
                                            Click="CT_BT_MAPPING_SHOW_ROUTING_Click"/>
                                    <Button x:Name="CT_BT_MAPPING_SHOW_REASON"
                                            Content="Reason"
                                            Style="{StaticResource ModernButton}"
                                            Click="CT_BT_MAPPING_SHOW_REASON_Click"/>
                                </StackPanel>

                                <TextBlock x:Name="CT_LB_MAPPING_PATH"
                                           Foreground="{StaticResource SubtextBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,8"/>

                                <Border Background="#F8FAFC"
                                        BorderBrush="#E2E4EA"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="12"
                                        Margin="0,0,0,12">
                                    <TextBlock x:Name="CT_LB_MAPPING_SUMMARY"
                                               Foreground="{StaticResource SubtextBrush}"
                                               TextWrapping="Wrap"
                                               FontFamily="Consolas"/>
                                </Border>

                                <Border Background="#F8FAFC"
                                        BorderBrush="#E2E4EA"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="8">
                                    <Grid>
                                        <TextBlock x:Name="CT_LB_MAPPING_EMPTY"
                                                   Text="No rows to display."
                                                   Foreground="{StaticResource SubtextBrush}"
                                                   TextWrapping="Wrap"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"
                                                   Visibility="Collapsed"/>
                                        <DataGrid x:Name="CT_DG_MAPPING"
                                                  AutoGenerateColumns="True"
                                                  IsReadOnly="True"
                                                  CanUserAddRows="False"
                                                  CanUserDeleteRows="False"
                                                  HeadersVisibility="Column"
                                                  EnableRowVirtualization="True"
                                                  EnableColumnVirtualization="True"
                                                  VirtualizingPanel.IsVirtualizing="True"
                                                  VirtualizingPanel.VirtualizationMode="Recycling"
                                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                  MinHeight="320"/>
                                    </Grid>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <Button x:Name="CT_BT_MAPPING_EXPORT"
                                        Content="Export Txt"
                                        Style="{StaticResource AccentButton}"
                                        Margin="0,0,0,8"
                                        Click="CT_BT_MAPPING_EXPORT_Click"/>
                                <Button x:Name="CT_BT_MAPPING_IMPORT"
                                        Content="Import From Txt"
                                        Style="{StaticResource ModernButton}"
                                        Click="CT_BT_MAPPING_IMPORT_Click"/>
                            </StackPanel>
                        </Grid>
                    </DockPanel>
                </Border>

                <!-- Top: BMES Data Card -->
                <Border Style="{StaticResource CardBorder}" DockPanel.Dock="Top">
                    <DockPanel>
                        <TextBlock Text="BMES DATA" Style="{StaticResource SectionHeader}" DockPanel.Dock="Top"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Start" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"
                                       Foreground="{StaticResource SubtextBrush}" Margin="0,0,10,4"/>
                            <DatePicker x:Name="CT_DATE_START" Grid.Row="0" Grid.Column="1" Margin="0,0,8,4"/>

                            <TextBlock Text="End" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"
                                       Foreground="{StaticResource SubtextBrush}" Margin="0,0,10,0"/>
                            <DatePicker x:Name="CT_DATE_END" Grid.Row="1" Grid.Column="1" Margin="0,0,8,0"/>

                            <Button x:Name="CT_BT_GETROUTING" Content="Get Routing"
                                    Style="{StaticResource ModernButton}" Grid.Row="0" Grid.Column="2"
                                    Grid.RowSpan="2" VerticalAlignment="Center" Click="CT_BT_GETROUTING_Click"/>

                            <StackPanel Grid.Row="3" Grid.ColumnSpan="3" Orientation="Horizontal">
                                <Button x:Name="CT_BT_BMESSETTING" Content="Setting" Style="{StaticResource ModernButton}" Margin="0,0,6,0" Click="CT_BT_BMESSETTING_Click"/>
                                <Button x:Name="CT_BT_GETBMESDATA" Content="Get Data" Style="{StaticResource AccentButton}" Margin="0,0,6,0" Click="CT_BT_GETBMESDATA_Click"/>
                                <Button x:Name="CT_BT_MERGEDB" Content="Merge DB" Style="{StaticResource ModernButton}"/>
                            </StackPanel>
                        </Grid>
                    </DockPanel>
                </Border>

                <!-- Debug NG Rate -->
                <Border Style="{StaticResource CardBorder}" DockPanel.Dock="Top">
                    <DockPanel>
                        <TextBlock Text="DEBUG NG RATE" Style="{StaticResource SectionHeader}" DockPanel.Dock="Top"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                        <TextBlock Text="ProcessName" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"
                                   Foreground="{StaticResource SubtextBrush}" Margin="0,0,10,6"/>
                        <ComboBox x:Name="CT_CB_DEBUG_PROCESS" Grid.Row="0" Grid.Column="1" Margin="0,0,10,6" MinWidth="220"
                                  IsEditable="True" IsTextSearchEnabled="True"
                                  SelectionChanged="CT_CB_DEBUG_PROCESS_SelectionChanged"/>

                        <TextBlock Text="NgName" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"
                                   Foreground="{StaticResource SubtextBrush}" Margin="0,0,10,6"/>
                        <ComboBox x:Name="CT_CB_DEBUG_NG" Grid.Row="1" Grid.Column="1" Margin="0,0,10,6"
                                  IsEditable="True" IsTextSearchEnabled="True"
                                  SelectionChanged="CT_CB_DEBUG_NG_SelectionChanged"/>

                        <TextBlock Text="Date" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"
                                   Foreground="{StaticResource SubtextBrush}" Margin="0,0,10,6"/>
                        <ComboBox x:Name="CT_CB_DEBUG_DATE" Grid.Row="2" Grid.Column="1" Margin="0,0,10,6"
                                  IsEditable="True" IsTextSearchEnabled="True"/>

                        <TextBlock Text="GroupName" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center"
                                   Foreground="{StaticResource SubtextBrush}" Margin="0,0,10,6"/>
                        <ComboBox x:Name="CT_CB_DEBUG_GROUP" Grid.Row="3" Grid.Column="1" Margin="0,0,10,6"
                                  IsEditable="True" IsTextSearchEnabled="True"
                                  DropDownOpened="CT_CB_DEBUG_GROUP_DropDownOpened"
                                  SelectionChanged="CT_CB_DEBUG_GROUP_SelectionChanged"/>

                        <Button x:Name="CT_BT_DEBUG_RATE" Content="Check"
                                Style="{StaticResource ModernButton}" Grid.Row="0" Grid.Column="2"
                                Grid.RowSpan="4" VerticalAlignment="Stretch" MinWidth="88"
                                Click="CT_BT_DEBUG_RATE_Click"/>

                        <TextBox x:Name="CT_TB_DEBUG_RESULT"
                                 Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3"
                                 IsReadOnly="True" TextWrapping="Wrap"
                                 AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                                 Background="#F8FAFC" Foreground="#334155" BorderThickness="1" BorderBrush="#E2E4EA"
                                 FontFamily="Cascadia Code,Consolas,Courier New" FontSize="12"
                                 Padding="8" MinHeight="44"/>
                        </Grid>
                    </DockPanel>
                </Border>

                    </DockPanel>
                </ScrollViewer>
            </Grid>

            <Border Grid.Column="1" Style="{StaticResource CardBorder}">
                <DockPanel>
                    <DockPanel DockPanel.Dock="Top" LastChildFill="False" Margin="0,0,0,10">
                        <Button x:Name="CT_BT_CLEAR_LOG"
                                Content="Clear"
                                Style="{StaticResource ModernButton}"
                                Padding="10,4"
                                DockPanel.Dock="Right"
                                Click="CT_BT_CLEAR_LOG_Click"/>
                        <TextBlock Text="LOG" Style="{StaticResource SectionHeader}" Margin="0"/>
                    </DockPanel>
                    <RichTextBox x:Name="CT_TB_LOG"
                                 IsReadOnly="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 Background="#F1F5F9"
                                 Foreground="#334155"
                                 BorderThickness="1"
                                 BorderBrush="#E2E4EA"
                                 FontFamily="Cascadia Code,Consolas,Courier New"
                                 FontSize="12"
                                 Padding="10" />
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
