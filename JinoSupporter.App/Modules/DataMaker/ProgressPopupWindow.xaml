<Window x:Class="DataMaker.ProgressPopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:app="clr-namespace:JinoSupporter.Controls;assembly=JinoSupporter.Controls"
        Title="Progress"
        Width="460"
        Height="330"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        WindowStyle="None"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        Background="Transparent"
        Foreground="#132033">
    <Window.Resources>
        <LinearGradientBrush x:Key="ShellBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F7F9FC" Offset="0"/>
            <GradientStop Color="#E8EEF8" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="AccentBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#1F6FEB" Offset="0"/>
            <GradientStop Color="#14B8A6" Offset="1"/>
        </LinearGradientBrush>
        <Style x:Key="SlimProgressBar" TargetType="ProgressBar" BasedOn="{StaticResource AppProgressBarBaseStyle}">
            <Setter Property="Height" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Background" Value="#DCE5F2"/>
        </Style>
    </Window.Resources>

    <Border Margin="14"
            Padding="22"
            Background="{StaticResource ShellBrush}"
            CornerRadius="18"
            BorderBrush="#D4DEEC"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Width="54"
                    Height="54"
                    HorizontalAlignment="Center"
                    Background="#FFFFFF"
                    CornerRadius="27"
                    BorderBrush="#D7E3F3"
                    BorderThickness="1">
                <TextBlock HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="#1F6FEB"
                           Text="..."/>
            </Border>

            <TextBlock x:Name="CT_TB_TITLE"
                       Grid.Row="1"
                       Margin="0,18,0,0"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Text="Processing"/>

            <TextBlock x:Name="CT_TB_MESSAGE"
                       Grid.Row="2"
                       Margin="0,12,0,20"
                       FontSize="14"
                       Foreground="#4A5B73"
                       TextWrapping="Wrap"
                       Text="Please wait..."/>

            <Grid Grid.Row="3"
                  Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="#5B6B82"
                           Text="Current Task"/>
                <TextBlock Grid.Column="1"
                           x:Name="CT_TB_TASK_PERCENT"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="#1F6FEB"
                           Text="0%"/>
            </Grid>
            <app:AppProgressBar x:Name="CT_PROG_TASK"
                         Style="{StaticResource SlimProgressBar}"
                         Grid.Row="4"
                         Minimum="0"
                         Maximum="100"/>

            <Grid Grid.Row="5"
                  Margin="0,18,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="#5B6B82"
                           Text="Total Task"/>
                <TextBlock Grid.Column="1"
                           x:Name="CT_TB_TOTAL_PERCENT"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="#14B8A6"
                           Text="0%"/>
            </Grid>
            <app:AppProgressBar x:Name="CT_PROG_TOTAL"
                         Style="{StaticResource SlimProgressBar}"
                         Grid.Row="6"
                         Minimum="0"
                         Maximum="100"/>

            <TextBlock x:Name="CT_TB_PERCENT"
                       Grid.Row="7"
                       Margin="0,18,0,0"
                       HorizontalAlignment="Left"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="#35507A"
                       Text="Current Task 0% | Total Task 0%"/>
        </Grid>
    </Border>
</Window>
