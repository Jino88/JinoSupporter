<UserControl x:Class="WorkbenchHost.Modules.ScreenCapture.ScreenCaptureView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="CaptureActionButtonStyle" TargetType="Button" BasedOn="{StaticResource AppButtonBaseStyle}">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style x:Key="CaptureToggleStyle" TargetType="ToggleButton">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="MinWidth" Value="86" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#24364F" />
            <Setter Property="Background" Value="#EEF4FB" />
            <Setter Property="BorderBrush" Value="#AABBD2" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#DCE9F8" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#C9DCF3" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.5" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2A4E84" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#2A4E84" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#2A4E84" />
                    <Setter Property="Foreground" Value="White" />
                    <Setter Property="BorderBrush" Value="#2A4E84" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource ShellCanvasBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Margin="10,10,10,6"
                Padding="10"
                Style="{StaticResource ShellCardBorderStyle}"
                Background="White">
            <DockPanel LastChildFill="True">
                <WrapPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                    <Button x:Name="CaptureFullScreenButton"
                            Content="Capture Full Screen"
                            Style="{StaticResource CaptureActionButtonStyle}"
                            Tag="FullScreen"
                            ToolTip="{Binding FullScreenHotkeyText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            Click="CaptureFullScreenButton_Click" />
                    <Button x:Name="CaptureActiveWindowButton"
                            Content="Capture Active Window"
                            Style="{StaticResource CaptureActionButtonStyle}"
                            Tag="ActiveWindow"
                            ToolTip="{Binding ActiveWindowHotkeyText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            Click="CaptureActiveWindowButton_Click" />
                    <Button x:Name="CaptureRegionButton"
                            Content="Capture Region"
                            Style="{StaticResource CaptureActionButtonStyle}"
                            Tag="Region"
                            ToolTip="{Binding RegionHotkeyText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            Click="CaptureRegionButton_Click" />
                    <Button Content="Copy"
                            Style="{StaticResource CaptureActionButtonStyle}"
                            Click="CopyButton_Click" />
                    <Button Content="Save PNG"
                            Style="{StaticResource CaptureActionButtonStyle}"
                            Click="SaveButton_Click" />
                </WrapPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <ToggleButton x:Name="PenToolToggle"
                                  Content="Pen"
                                  Style="{StaticResource CaptureToggleStyle}"
                                  Click="PenToolToggle_Click" />
                    <ToggleButton x:Name="HighlighterToolToggle"
                                  Content="Highlighter"
                                  Style="{StaticResource CaptureToggleStyle}"
                                  Click="HighlighterToolToggle_Click" />
                    <ToggleButton x:Name="EraserToolToggle"
                                  Content="Eraser"
                                  Style="{StaticResource CaptureToggleStyle}"
                                  Click="EraserToolToggle_Click" />
                    <Button Content="Clear Ink"
                            Style="{StaticResource CaptureActionButtonStyle}"
                            Margin="0,0,0,0"
                            Click="ClearInkButton_Click" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="10,0,10,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Margin="0,0,6,0"
                    Padding="12"
                    Style="{StaticResource ShellCardBorderStyle}"
                    Background="White">
                <StackPanel>
                    <TextBlock FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#22304A"
                               Text="Capture Studio" />
                    <TextBlock Margin="0,6,0,12"
                               Foreground="#617084"
                               FontSize="11"
                               Text="PicPick-style quick capture and markup inside WorkHost." />

                    <TextBlock FontWeight="SemiBold" Foreground="#445269" Text="Stroke Color" />
                    <ComboBox x:Name="ColorComboBox"
                              Margin="0,6,0,12"
                              SelectionChanged="ColorComboBox_SelectionChanged" />

                    <TextBlock FontWeight="SemiBold" Foreground="#445269" Text="Stroke Width" />
                    <Slider x:Name="StrokeWidthSlider"
                            Margin="0,6,0,4"
                            Minimum="1"
                            Maximum="18"
                            Value="3"
                            TickFrequency="1"
                            IsSnapToTickEnabled="False"
                            ValueChanged="StrokeWidthSlider_ValueChanged" />
                    <TextBlock Foreground="#708094"
                               FontSize="11"
                               Text="{Binding StrokeWidthText, RelativeSource={RelativeSource AncestorType=UserControl}}" />

                    <Separator Margin="0,12,0,12" />

                    <TextBlock FontWeight="SemiBold" Foreground="#445269" Text="Last Capture" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="#617084"
                               FontSize="11"
                               Text="{Binding CaptureInfoText, RelativeSource={RelativeSource AncestorType=UserControl}}" />

                    <Border Margin="0,12,0,0"
                            Padding="10"
                            Background="#F5F8FC"
                            BorderBrush="#D3DCEA"
                            BorderThickness="1"
                            CornerRadius="6">
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="#55657B"
                                   FontSize="11"
                                   Text="Region capture opens a transparent overlay. Drag to select the area, then annotate directly on the screenshot." />
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Padding="10"
                    Style="{StaticResource ShellCardBorderStyle}"
                    Background="White">
                <Grid Background="#EDF3FA">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto">
                        <Grid x:Name="CaptureSurface"
                              HorizontalAlignment="Left"
                              VerticalAlignment="Top"
                              Background="#DDE6F2">
                            <Image x:Name="CaptureImage"
                                   Stretch="None"
                                   SnapsToDevicePixels="True"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor" />
                            <InkCanvas x:Name="AnnotationCanvas"
                                       Background="Transparent" />
                        </Grid>
                    </ScrollViewer>

                    <TextBlock x:Name="EmptyStateText"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="#6B7C92"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Text="Take a capture to start editing"
                               IsHitTestVisible="False" />
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Margin="10,0,10,10"
                Padding="8,6"
                Style="{StaticResource ShellCardBorderStyle}"
                Background="#F8FAFD">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           Foreground="#4E5A6C"
                           FontSize="11"
                           Text="{Binding StatusMessage, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                <TextBlock DockPanel.Dock="Right"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           Foreground="#6A7891"
                           FontSize="11"
                           Text="{Binding HotkeySummaryText, RelativeSource={RelativeSource AncestorType=UserControl}}" />
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
