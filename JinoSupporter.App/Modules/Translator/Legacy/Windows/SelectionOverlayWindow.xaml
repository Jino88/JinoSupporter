<Window x:Class="CustomKeyboardCSharp.Windows.SelectionOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="#20000000"
        ShowInTaskbar="False"
        Topmost="True">
    <Grid>
        <Image x:Name="ScreenshotImage"
               Stretch="Fill"
               Opacity="0.95" />
        <Canvas x:Name="OverlayCanvas"
                Background="Transparent"
                MouseLeftButtonDown="OverlayCanvas_OnMouseLeftButtonDown"
                MouseMove="OverlayCanvas_OnMouseMove"
                MouseLeftButtonUp="OverlayCanvas_OnMouseLeftButtonUp">
            <Rectangle x:Name="SelectionRectangle"
                       Visibility="Collapsed"
                       Fill="#30FFFFFF"
                       Stroke="#FF38BDF8"
                       StrokeThickness="2" />
        </Canvas>
        <Border HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,20,0,0"
                Padding="16,10"
                CornerRadius="16"
                Background="#DD0F172A">
            <TextBlock Foreground="White"
                       FontSize="14"
                       Text="Drag to select the capture area. Press Esc to cancel." />
        </Border>
    </Grid>
</Window>
