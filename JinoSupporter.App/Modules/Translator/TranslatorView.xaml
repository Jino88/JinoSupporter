<UserControl x:Class="JinoSupporter.App.Modules.Translator.TranslatorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:app="clr-namespace:JinoSupporter.Controls;assembly=JinoSupporter.Controls">
    <Grid Background="#F4F7FB">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Margin="10"
                Padding="16"
                Background="White"
                BorderBrush="#D9E2EC"
                BorderThickness="1"
                CornerRadius="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Translator"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="#102A43" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="#486581"
                               Text="Text translation, image capture translation, local history DB, and Google Drive sync are now hosted directly in WPF." />
                </StackPanel>
                <TextBlock x:Name="StatusTextBlock"
                           Grid.Column="1"
                           VerticalAlignment="Center"
                           Foreground="#486581"
                           FontWeight="SemiBold"
                           Text="Ready" />
            </Grid>
        </Border>

        <Grid Grid.Row="1"
              Margin="10,0,10,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.2*" />
                <ColumnDefinition Width="1.1*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0"
                  Margin="0,0,10,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Padding="14"
                        Background="White"
                        BorderBrush="#D9E2EC"
                        BorderThickness="1"
                        CornerRadius="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="Provider" Foreground="#486581" />
                            <app:AppComboBox x:Name="ProviderComboBox"
                                      Margin="0,6,0,0"
                                      SelectionChanged="ProviderComboBox_OnSelectionChanged" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,10,0">
                            <TextBlock Text="Text Direction" Foreground="#486581" />
                            <app:AppComboBox x:Name="DirectionComboBox"
                                      Margin="0,6,0,0"
                                      SelectionChanged="DirectionComboBox_OnSelectionChanged" />
                        </StackPanel>

                        <StackPanel Grid.Column="2" Margin="0,0,10,0">
                            <TextBlock Text="Image Direction" Foreground="#486581" />
                            <app:AppComboBox x:Name="ScreenDirectionComboBox"
                                      Margin="0,6,0,0"
                                      SelectionChanged="ScreenDirectionComboBox_OnSelectionChanged" />
                        </StackPanel>

                        <StackPanel Grid.Column="3">
                            <TextBlock Text="Timeout" Foreground="#486581" />
                            <app:AppTextBox x:Name="TimeoutTextBox"
                                     Margin="0,6,0,0"
                                     TextChanged="SettingsField_OnChanged" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="1"
                      Margin="0,10,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Margin="0,0,10,0"
                            Padding="14"
                            Background="White"
                            BorderBrush="#D9E2EC"
                            BorderThickness="1"
                            CornerRadius="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="Source"
                                       FontSize="16"
                                       FontWeight="SemiBold" />
                            <app:AppTextBox x:Name="SourceTextBox"
                                     Grid.Row="1"
                                     Margin="0,10,0,10"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     TextWrapping="Wrap"
                                     TextChanged="SourceTextBox_OnTextChanged" />
                            <WrapPanel Grid.Row="2">
                                <app:AppButton Content="Translate Text"
                                        Padding="12,7"
                                        Margin="0,0,8,0"
                                        Click="TranslateButton_Click" />
                                <app:AppButton Content="Capture Translate"
                                        Padding="12,7"
                                        Margin="0,0,8,0"
                                        Click="CaptureTranslateButton_Click" />
                                <app:AppButton Content="Swap"
                                        Padding="12,7"
                                        Margin="0,0,8,0"
                                        Click="SwapButton_Click" />
                                <app:AppButton Content="Clear"
                                        Padding="12,7"
                                        Click="ClearButton_Click" />
                            </WrapPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1"
                            Padding="14"
                            Background="White"
                            BorderBrush="#D9E2EC"
                            BorderThickness="1"
                            CornerRadius="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="Options"
                                       FontSize="16"
                                       FontWeight="SemiBold" />
                            <TextBlock x:Name="DetectedTextBlock"
                                       Grid.Row="1"
                                       Margin="0,8,0,10"
                                       Foreground="#486581"
                                       TextWrapping="Wrap" />
                            <app:AppListBox x:Name="OptionListBox"
                                     Grid.Row="2" />
                        </Grid>
                    </Border>
                </Grid>

                <Border Grid.Row="2"
                        Padding="14"
                        Background="White"
                        BorderBrush="#D9E2EC"
                        BorderThickness="1"
                        CornerRadius="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.1*" />
                            <ColumnDefinition Width="1.4*" />
                            <ColumnDefinition Width="1.4*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="Last Capture"
                                       FontSize="16"
                                       FontWeight="SemiBold" />
                            <Border Margin="0,10,0,0"
                                    BorderBrush="#D9E2EC"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                <Image x:Name="CapturedImage"
                                       Height="220"
                                       Stretch="Uniform" />
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,10,0">
                            <TextBlock Text="API Settings"
                                       FontSize="16"
                                       FontWeight="SemiBold" />
                            <TextBlock Margin="0,10,0,0" Text="OpenAI API Key" Foreground="#486581" />
                            <PasswordBox x:Name="OpenAiApiKeyBox"
                                         Margin="0,6,0,10"
                                         PasswordChanged="SettingsField_OnChanged" />
                            <TextBlock Text="Gemini API Key" Foreground="#486581" />
                            <PasswordBox x:Name="GeminiApiKeyBox"
                                         Margin="0,6,0,0"
                                         PasswordChanged="SettingsField_OnChanged" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Google Drive Sync"
                                       FontSize="16"
                                       FontWeight="SemiBold" />
                            <TextBlock Margin="0,10,0,0" Text="Google Client ID" Foreground="#486581" />
                            <app:AppTextBox x:Name="GoogleClientIdTextBox"
                                     Margin="0,6,0,10"
                                     TextChanged="SettingsField_OnChanged" />
                            <TextBlock Text="Google Client Secret" Foreground="#486581" />
                            <app:AppTextBox x:Name="GoogleClientSecretTextBox"
                                     Margin="0,6,0,10"
                                     TextChanged="SettingsField_OnChanged" />
                            <WrapPanel>
                                <app:AppButton Content="Sign In"
                                        Padding="12,7"
                                        Margin="0,0,8,0"
                                        Click="SignInButton_Click" />
                                <app:AppButton Content="Sign Out"
                                        Padding="12,7"
                                        Margin="0,0,8,0"
                                        Click="SignOutButton_Click" />
                                <app:AppButton Content="Upload DB"
                                        Padding="12,7"
                                        Margin="0,0,8,0"
                                        Click="UploadDbButton_Click" />
                                <app:AppButton Content="Download DB"
                                        Padding="12,7"
                                        Margin="0,0,8,0"
                                        Click="DownloadDbButton_Click" />
                                <app:AppButton Content="Merge DB"
                                        Padding="12,7"
                                        Click="MergeDbButton_Click" />
                            </WrapPanel>
                            <TextBlock x:Name="DriveStatusTextBlock"
                                       Margin="0,10,0,0"
                                       Foreground="#486581"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Padding="14"
                        Background="White"
                        BorderBrush="#D9E2EC"
                        BorderThickness="1"
                        CornerRadius="12">
                    <WrapPanel>
                        <app:AppButton Content="Refresh Lists"
                                Padding="12,7"
                                Margin="0,0,8,0"
                                Click="RefreshButton_Click" />
                        <app:AppButton Content="Export DB"
                                Padding="12,7"
                                Margin="0,0,8,0"
                                Click="ExportDbButton_Click" />
                        <app:AppButton Content="Delete History"
                                Padding="12,7"
                                Margin="0,0,8,0"
                                Click="DeleteHistoryButton_Click" />
                        <app:AppButton Content="Delete Vocabulary"
                                Padding="12,7"
                                Click="DeleteVocabularyButton_Click" />
                    </WrapPanel>
                </Border>

                <Border Grid.Row="1"
                        Margin="0,10,0,10"
                        Padding="14"
                        Background="White"
                        BorderBrush="#D9E2EC"
                        BorderThickness="1"
                        CornerRadius="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="History"
                                   FontSize="16"
                                   FontWeight="SemiBold" />
                        <app:AppListBox x:Name="HistoryListBox"
                                 Grid.Row="1"
                                 Margin="0,10,0,0" />
                    </Grid>
                </Border>

                <Border Grid.Row="2"
                        Padding="14"
                        Background="White"
                        BorderBrush="#D9E2EC"
                        BorderThickness="1"
                        CornerRadius="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="Vocabulary"
                                   FontSize="16"
                                   FontWeight="SemiBold" />
                        <TextBlock x:Name="DbPathTextBlock"
                                   Grid.Row="1"
                                   Margin="0,8,0,10"
                                   Foreground="#486581"
                                   TextWrapping="Wrap" />
                        <app:AppListBox x:Name="VocabularyListBox"
                                 Grid.Row="2" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
