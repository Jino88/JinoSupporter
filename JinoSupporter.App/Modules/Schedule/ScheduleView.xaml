<UserControl x:Class="JinoSupporter.App.Modules.Schedule.ScheduleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F3F7FB">
    <Grid>
        <Grid.ColumnDefinitions>
            <!-- 달력 영역 -->
            <ColumnDefinition Width="*" />
            <!-- 우측 패널 -->
            <ColumnDefinition Width="310" />
        </Grid.ColumnDefinitions>

        <!-- ── 좌측: 달력 ────────────────────────────────────────── -->
        <Border Grid.Column="0"
                Margin="0,0,10,0"
                Background="White"
                CornerRadius="16"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                Padding="16">
            <DockPanel LastChildFill="True">

                <!-- 월 네비게이션 -->
                <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button x:Name="PrevMonthButton"
                            Grid.Column="0"
                            Content="&#x25C4;"
                            Width="32" Height="32"
                            Padding="0"
                            FontSize="12"
                            Background="#EFF6FF"
                            BorderBrush="#BFDBFE"
                            BorderThickness="1"
                            Foreground="#1D4ED8"
                            Cursor="Hand"
                            Click="PrevMonthButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#DBEAFE" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <TextBlock x:Name="MonthYearLabel"
                               Grid.Column="1"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#0F172A"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />

                    <Button x:Name="TodayButton"
                            Grid.Column="2"
                            Content="Today"
                            Height="32"
                            Padding="10,0"
                            FontSize="12"
                            Background="#EFF6FF"
                            BorderBrush="#BFDBFE"
                            BorderThickness="1"
                            Foreground="#1D4ED8"
                            Margin="0,0,8,0"
                            Cursor="Hand"
                            Click="TodayButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      Margin="{TemplateBinding Padding}" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#DBEAFE" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button x:Name="NextMonthButton"
                            Grid.Column="3"
                            Content="&#x25BA;"
                            Width="32" Height="32"
                            Padding="0"
                            FontSize="12"
                            Background="#EFF6FF"
                            BorderBrush="#BFDBFE"
                            BorderThickness="1"
                            Foreground="#1D4ED8"
                            Cursor="Hand"
                            Click="NextMonthButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#DBEAFE" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <!-- 달력 본체 -->
                <Grid x:Name="CalendarGrid" DockPanel.Dock="Top">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <!-- 요일 헤더 + 날짜 행들은 코드비하인드에서 동적으로 생성 -->
                </Grid>
            </DockPanel>
        </Border>

        <!-- ── 우측 패널 ──────────────────────────────────────────── -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- 상단: 이번 주 스케쥴 -->
            <Border Grid.Row="0"
                    Margin="0,0,0,10"
                    Background="White"
                    CornerRadius="16"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    Padding="14">
                <DockPanel LastChildFill="True">
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                        <DockPanel Margin="0,0,0,4">
                            <Button x:Name="TagFilterClearButton"
                                    DockPanel.Dock="Right"
                                    Content="Clear"
                                    Height="22"
                                    Padding="6,0"
                                    FontSize="10"
                                    Background="#EFF6FF"
                                    BorderBrush="#BFDBFE"
                                    BorderThickness="1"
                                    Foreground="#1D4ED8"
                                    Cursor="Hand"
                                    Click="TagFilterClearButton_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="5">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              Margin="{TemplateBinding Padding}" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#DBEAFE" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <TextBlock Text="이번 주 스케쥴"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="#0F172A"
                                       VerticalAlignment="Center" />
                        </DockPanel>
                        <TextBlock x:Name="UpcomingRangeLabel"
                                   FontSize="11"
                                   Foreground="#64748B"
                                   Margin="0,0,0,4" />
                        <!-- 태그 필터 칩 영역 -->
                        <WrapPanel x:Name="TagFilterChipPanel" Margin="0,0,0,2" />
                    </StackPanel>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="UpcomingPanel" />
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- 하단: 신규 스케쥴 등록 -->
            <Border Grid.Row="1"
                    Background="White"
                    CornerRadius="16"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    Padding="14">
                <StackPanel>
                    <TextBlock Text="신규 스케쥴 등록"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="#0F172A"
                               Margin="0,0,0,10" />

                    <TextBlock Text="제목" FontSize="11" Foreground="#64748B" Margin="0,0,0,3" />
                    <TextBox x:Name="NewTitleBox"
                             Padding="6,5"
                             BorderBrush="#CBD5E1"
                             BorderThickness="1"
                             FontSize="12">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6" />
                            </Style>
                        </TextBox.Resources>
                    </TextBox>

                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="시작일" FontSize="11" Foreground="#64748B" Margin="0,0,0,3" />
                            <DatePicker x:Name="StartDatePicker"
                                        FontSize="12"
                                        BorderBrush="#CBD5E1"
                                        BorderThickness="1"
                                        SelectedDateFormat="Short" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="종료일" FontSize="11" Foreground="#64748B" Margin="0,0,0,3" />
                            <DatePicker x:Name="EndDatePicker"
                                        FontSize="12"
                                        BorderBrush="#CBD5E1"
                                        BorderThickness="1"
                                        SelectedDateFormat="Short" />
                        </StackPanel>
                    </Grid>

                    <!-- 시간 입력 (선택) -->
                    <Grid Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="시작 시간 (선택)" FontSize="11" Foreground="#64748B" Margin="0,0,0,3" />
                            <TextBox x:Name="StartTimeBox"
                                     Padding="6,5"
                                     BorderBrush="#CBD5E1"
                                     BorderThickness="1"
                                     FontSize="12"
                                     ToolTip="HH:mm 형식 (예: 09:30) — 비워두면 종일">
                                <TextBox.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="6" />
                                    </Style>
                                </TextBox.Resources>
                            </TextBox>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="종료 시간 (선택)" FontSize="11" Foreground="#64748B" Margin="0,0,0,3" />
                            <TextBox x:Name="EndTimeBox"
                                     Padding="6,5"
                                     BorderBrush="#CBD5E1"
                                     BorderThickness="1"
                                     FontSize="12"
                                     ToolTip="HH:mm 형식 (예: 17:00)">
                                <TextBox.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="6" />
                                    </Style>
                                </TextBox.Resources>
                            </TextBox>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="색상" FontSize="11" Foreground="#64748B" Margin="0,8,0,4" />
                    <StackPanel x:Name="ColorPickerPanel" Orientation="Horizontal" />

                    <TextBlock Text="태그 (쉼표 구분, 선택)" FontSize="11" Foreground="#64748B" Margin="0,8,0,3" />
                    <TextBox x:Name="NewTagsBox"
                             Padding="6,5"
                             BorderBrush="#CBD5E1"
                             BorderThickness="1"
                             FontSize="12"
                             ToolTip="쉼표로 구분하여 여러 태그 입력 (예: 오디오버스, TIU, 2월)">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6" />
                            </Style>
                        </TextBox.Resources>
                    </TextBox>

                    <TextBlock Text="설명 (선택)" FontSize="11" Foreground="#64748B" Margin="0,8,0,3" />
                    <TextBox x:Name="NewDescBox"
                             Padding="6,5"
                             Height="52"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             BorderBrush="#CBD5E1"
                             BorderThickness="1"
                             FontSize="12">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6" />
                            </Style>
                        </TextBox.Resources>
                    </TextBox>

                    <Button x:Name="AddScheduleButton"
                            Content="스케쥴 추가"
                            Height="34"
                            Margin="0,10,0,0"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Background="#3B82F6"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="AddScheduleButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd"
                                        Background="{TemplateBinding Background}"
                                        CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#2563EB" />
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#1D4ED8" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
