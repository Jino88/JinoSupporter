<UserControl x:Class="WorkbenchHost.Modules.AppSettings.AppSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:app="clr-namespace:JinoSupporter.Controls;assembly=JinoSupporter.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="SettingsActionButtonStyle" TargetType="Button" BasedOn="{StaticResource AppButtonBaseStyle}">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource ShellCanvasBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Margin="10,10,10,6"
                Padding="14"
                Style="{StaticResource ShellCardBorderStyle}"
                Background="White">
            <StackPanel>
                <TextBlock FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="#22304A"
                           Text="Settings Hub" />
                <TextBlock Margin="0,6,0,0"
                           Foreground="#617084"
                           FontSize="12"
                           Text="WorkHost 기본 설정 저장 위치를 한곳에서 확인하고 바꿀 수 있습니다." />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1"
                      Margin="10,0,10,6"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Padding="14"
                        Margin="0,0,0,8"
                        Style="{StaticResource ShellCardBorderStyle}"
                        Background="White">
                    <StackPanel>
                        <TextBlock FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="#22304A"
                                   Text="Batch Directory" />
                        <TextBlock Margin="0,6,0,10"
                                   Foreground="#617084"
                                   FontSize="11"
                                   Text="폴더 하나를 고르면 unified settings 파일과 공통 저장 루트를 한 번에 맞춥니다." />
                        <app:AppTextBox x:Name="BatchDirectoryTextBox"
                                 Margin="0,0,0,10"
                                 TextWrapping="Wrap" />
                        <WrapPanel Margin="0,0,0,10">
                            <app:AppButton Content="Browse Folder"
                                    Style="{StaticResource SettingsActionButtonStyle}"
                                    Click="BrowseBatchDirectoryButton_Click" />
                            <app:AppButton Content="Apply To All"
                                    Style="{StaticResource SettingsActionButtonStyle}"
                                    Click="ApplyBatchDirectoryButton_Click" />
                            <app:AppButton Content="Open Folder"
                                    Style="{StaticResource SettingsActionButtonStyle}"
                                    Click="OpenBatchDirectoryButton_Click" />
                        </WrapPanel>

                        <TextBlock FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="#22304A"
                                   Text="Unified Settings File" />
                        <TextBlock Margin="0,6,0,10"
                                   Foreground="#617084"
                                   FontSize="11"
                                   Text="WorkHost 설정값은 이 JSON 파일 하나에 저장됩니다." />
                        <app:AppTextBox x:Name="SettingsFilePathTextBox"
                                 Margin="0,0,0,10"
                                 TextWrapping="Wrap" />
                        <WrapPanel Margin="0,0,0,10">
                            <app:AppButton Content="Browse File"
                                    Style="{StaticResource SettingsActionButtonStyle}"
                                    Click="BrowseSettingsFileButton_Click" />
                            <app:AppButton Content="Save File Path"
                                    Style="{StaticResource SettingsActionButtonStyle}"
                                    Click="SaveSettingsFileButton_Click" />
                            <app:AppButton Content="Reset Default"
                                    Style="{StaticResource SettingsActionButtonStyle}"
                                    Click="ResetSettingsFileButton_Click" />
                            <app:AppButton Content="Open Folder"
                                    Style="{StaticResource SettingsActionButtonStyle}"
                                    Click="OpenSettingsFileFolderButton_Click" />
                        </WrapPanel>

                        <TextBlock FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="#22304A"
                                   Text="Shared Storage Root" />
                        <TextBlock Margin="0,6,0,10"
                                   Foreground="#617084"
                                   FontSize="11"
                                   Text="ScreenCapture, VideoConverter, DiskTree, DataMaker 기본 파일들이 이 루트를 기준으로 저장됩니다." />
                        <app:AppTextBox x:Name="StorageRootTextBox"
                                 Margin="0,0,0,10"
                                 TextWrapping="Wrap" />
                        <WrapPanel>
                            <app:AppButton Content="Browse Folder"
                                    Style="{StaticResource SettingsActionButtonStyle}"
                                    Click="BrowseStorageRootButton_Click" />
                            <app:AppButton Content="Save Root"
                                    Style="{StaticResource SettingsActionButtonStyle}"
                                    Click="SaveStorageRootButton_Click" />
                            <app:AppButton Content="Reset Default"
                                    Style="{StaticResource SettingsActionButtonStyle}"
                                    Click="ResetStorageRootButton_Click" />
                            <app:AppButton Content="Open Folder"
                                    Style="{StaticResource SettingsActionButtonStyle}"
                                    Click="OpenStorageRootButton_Click" />
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Border Padding="14"
                        Margin="0,0,0,8"
                        Style="{StaticResource ShellCardBorderStyle}"
                        Background="White">
                    <StackPanel>
                        <TextBlock FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="#22304A"
                                   Text="Claude API Key" />
                        <TextBlock Margin="0,6,0,10"
                                   Foreground="#617084"
                                   FontSize="11"
                                   Text="데이터 추론 기능에서 Claude AI를 사용하기 위한 Anthropic API 키입니다. 암호화하여 저장됩니다." />
                        <PasswordBox x:Name="ClaudeApiKeyBox"
                                     Margin="0,0,0,10"
                                     Padding="8,6"
                                     FontSize="12"
                                     BorderBrush="#D3DCEA"
                                     BorderThickness="1" />
                        <WrapPanel>
                            <app:AppButton Content="저장"
                                    Style="{StaticResource SettingsActionButtonStyle}"
                                    Click="SaveClaudeApiKeyButton_Click" />
                            <app:AppButton Content="삭제"
                                    Style="{StaticResource SettingsActionButtonStyle}"
                                    Click="ClearClaudeApiKeyButton_Click" />
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Border Padding="14"
                        Margin="0,0,0,8"
                        Style="{StaticResource ShellCardBorderStyle}"
                        Background="White">
                    <StackPanel>
                        <TextBlock FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="#22304A"
                                   Text="OpenAI API Key" />
                        <TextBlock Margin="0,6,0,10"
                                   Foreground="#617084"
                                   FontSize="11"
                                   Text="데이터 추론 (ChatGPT) 기능에서 사용할 OpenAI API 키입니다. 암호화하여 저장됩니다." />
                        <PasswordBox x:Name="OpenAiApiKeyBox"
                                     Margin="0,0,0,10"
                                     Padding="8,6"
                                     FontSize="12"
                                     BorderBrush="#D3DCEA"
                                     BorderThickness="1" />
                        <WrapPanel>
                            <app:AppButton Content="저장"
                                    Style="{StaticResource SettingsActionButtonStyle}"
                                    Click="SaveOpenAiApiKeyButton_Click" />
                            <app:AppButton Content="삭제"
                                    Style="{StaticResource SettingsActionButtonStyle}"
                                    Click="ClearOpenAiApiKeyButton_Click" />
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- ── Database Paths ─────────────────────────────────── -->
                <Border Padding="14"
                        Margin="0,0,0,8"
                        Style="{StaticResource ShellCardBorderStyle}"
                        Background="White">
                    <StackPanel>
                        <TextBlock FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="#22304A"
                                   Text="Database Paths" />
                        <TextBlock Margin="0,6,0,16"
                                   Foreground="#617084"
                                   FontSize="11"
                                   Text="현재 앱이 실제로 사용 중인 경로가 표시됩니다. 웹 앱과 같은 경로를 지정해야 데이터를 공유할 수 있습니다." />

                        <!-- Schedule DB -->
                        <TextBlock FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="#22304A"
                                   Text="Schedule DB (schedule.db)" />
                        <TextBlock Margin="0,4,0,8"
                                   Foreground="#617084"
                                   FontSize="11"
                                   Text="스케쥴 데이터베이스 파일 경로." />
                        <app:AppTextBox x:Name="ScheduleDbPathTextBox"
                                        Margin="0,0,0,8"
                                        TextWrapping="Wrap" />
                        <WrapPanel Margin="0,0,0,16">
                            <app:AppButton Content="Browse"
                                           Style="{StaticResource SettingsActionButtonStyle}"
                                           Click="BrowseScheduleDbButton_Click" />
                            <app:AppButton Content="Save Path"
                                           Style="{StaticResource SettingsActionButtonStyle}"
                                           Click="SaveScheduleDbButton_Click" />
                            <app:AppButton Content="Reset Default"
                                           Style="{StaticResource SettingsActionButtonStyle}"
                                           Click="ResetScheduleDbButton_Click" />
                            <app:AppButton Content="Open Folder"
                                           Style="{StaticResource SettingsActionButtonStyle}"
                                           Click="OpenScheduleDbFolderButton_Click" />
                        </WrapPanel>

                        <!-- Process-review DB -->
                        <TextBlock FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="#22304A"
                                   Text="Process Review DB (process-review.db)" />
                        <TextBlock Margin="0,4,0,8"
                                   Foreground="#617084"
                                   FontSize="11"
                                   Text="Data Inference / Report 데이터베이스 파일 경로." />
                        <app:AppTextBox x:Name="ProcessReviewDbPathTextBox"
                                        Margin="0,0,0,8"
                                        TextWrapping="Wrap" />
                        <WrapPanel>
                            <app:AppButton Content="Browse"
                                           Style="{StaticResource SettingsActionButtonStyle}"
                                           Click="BrowseProcessReviewDbButton_Click" />
                            <app:AppButton Content="Save Path"
                                           Style="{StaticResource SettingsActionButtonStyle}"
                                           Click="SaveProcessReviewDbButton_Click" />
                            <app:AppButton Content="Reset Default"
                                           Style="{StaticResource SettingsActionButtonStyle}"
                                           Click="ResetProcessReviewDbButton_Click" />
                            <app:AppButton Content="Open Folder"
                                           Style="{StaticResource SettingsActionButtonStyle}"
                                           Click="OpenProcessReviewDbFolderButton_Click" />
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Border Padding="14"
                        Style="{StaticResource ShellCardBorderStyle}"
                        Background="White">
                    <StackPanel>
                        <DockPanel LastChildFill="True">
                            <TextBlock DockPanel.Dock="Left"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="#22304A"
                                       Text="Registered Setting Files" />
                            <app:AppButton DockPanel.Dock="Right"
                                    Content="Refresh"
                                    Style="{StaticResource SettingsActionButtonStyle}"
                                    Margin="8,0,0,0"
                                    Click="RefreshButton_Click" />
                        </DockPanel>

                        <ItemsControl x:Name="SettingsItemsControl" Margin="0,12,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8"
                                            Padding="12"
                                            BorderThickness="1"
                                            BorderBrush="#D3DCEA"
                                            Background="#F8FAFD"
                                            CornerRadius="6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold"
                                                           Foreground="#22304A"
                                                           Text="{Binding Name}" />
                                                <TextBlock Margin="0,4,0,6"
                                                           FontSize="11"
                                                           Foreground="#617084"
                                                           Text="{Binding Description}"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Foreground="#33435C"
                                                           Text="{Binding Path}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                            <app:AppButton Grid.Column="1"
                                                    Content="Open"
                                                    Style="{StaticResource SettingsActionButtonStyle}"
                                                    Margin="10,0,0,0"
                                                    VerticalAlignment="Top"
                                                    Click="OpenEntryButton_Click"
                                                    Tag="{Binding Path}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2"
                Margin="10,0,10,10"
                Padding="10,8"
                Style="{StaticResource ShellCardBorderStyle}"
                Background="#F8FAFD">
            <TextBlock x:Name="StatusTextBlock"
                       Foreground="#4E5A6C"
                       FontSize="11"
                       Text="Ready." />
        </Border>
    </Grid>
</UserControl>
