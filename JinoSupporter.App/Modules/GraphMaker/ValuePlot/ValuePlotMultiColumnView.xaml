<UserControl x:Class="GraphMaker.ValuePlotMultiColumnView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:GraphMaker"
             mc:Ignorable="d"
             d:DesignHeight="850"
             d:DesignWidth="1650">
    <Grid Style="{StaticResource GraphMakerPageRootGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <GroupBox Grid.Row="0" Header="Workflow" Style="{StaticResource FilesSectionGroupBoxStyle}">
            <Grid Style="{StaticResource FilesSectionInnerGridStyle}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.2*" />
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Style="{StaticResource DropZoneBorderStyle}"
                        Margin="0,0,8,0"
                        MinHeight="88"
                        AllowDrop="True"
                        Drop="DropZone_Drop"
                        DragEnter="DropZone_DragEnter"
                        DragLeave="DropZone_DragLeave"
                        DragOver="DropZone_DragOver">
                    <StackPanel>
                        <TextBlock x:Name="DropZoneText"
                                   Style="{StaticResource FileDropHintTextStyle}"
                                   Text="Drag .txt / .csv files"
                                   />
                        <Button Content="Browse"
                                Width="120"
                                Margin="0,8,0,0"
                                HorizontalAlignment="Center"
                                Click="BrowseButton_Click" />
                    </StackPanel>
                </Border>

                <GroupBox Grid.Column="1"
                          Header="Preview"
                          Margin="0,0,8,0"
                          Style="{StaticResource PreviewGroupBoxStyle}">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock>
                                <Run Text="Selected File: " FontWeight="SemiBold" />
                                <Run Text="{Binding SelectedItem.Name, ElementName=FileListBox, FallbackValue=(None)}" />
                            </TextBlock>
                            <TextBlock Margin="0,4,0,0"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Text="Loaded files for the current workflow." />
                        </StackPanel>

                        <ListBox Grid.Row="1"
                                 x:Name="FileListBox"
                                 Margin="0,8,0,0"
                                 MinHeight="88"
                                 SelectionChanged="FileListBox_SelectionChanged"
                                 DisplayMemberPath="Name" />
                    </Grid>
                </GroupBox>

                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <Button Content="Remove Selected" Width="130" Click="RemoveFileButton_Click" />
                    <Button Content="Generate Graph"
                            Width="130"
                            Margin="0,8,0,0"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="GenerateGraphButton_Click" />
                </StackPanel>
            </Grid>
        </GroupBox>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <GroupBox Grid.Row="0" Header="Data Grid" Style="{StaticResource PreviewGroupBoxStyle}">
                    <local:InteractiveDataGrid x:Name="DataPreviewGrid"
                                               CanUserAddRows="False"
                                               CanUserDeleteRows="False"
                                               PreviewKeyDown="DataPreviewGrid_PreviewKeyDown"
                                               AutoGeneratingColumn="DataPreviewGrid_AutoGeneratingColumn"
                                               BeginningEdit="DataPreviewGrid_BeginningEdit"
                                               CellEditEnding="DataPreviewGrid_CellEditEnding" />
                </GroupBox>
            </Grid>

            <GroupBox Grid.Column="1" Header="Settings" Style="{StaticResource SettingsGroupBoxStyle}">
                    <ScrollViewer Style="{StaticResource SettingsScrollViewerStyle}">
                        <StackPanel Style="{StaticResource SettingsStackPanelStyle}">
                            <StackPanel Visibility="Collapsed">
                                <TextBlock x:Name="CurrentFileNameText" Text="(Select a file)" />
                                <TextBlock x:Name="RowCountText" Text="0" />
                                <TextBlock x:Name="ColumnCountText" Text="0" />
                            </StackPanel>

                            <TextBlock Text="File Format" Style="{StaticResource SettingsSectionHeaderTextStyle}" />
                            <WrapPanel Style="{StaticResource DelimiterWrapPanelStyle}">
                                <RadioButton x:Name="TabDelimiterRadio" Content="Tab" IsChecked="True" GroupName="Delimiter" Margin="0,0,10,0" Checked="DelimiterChanged" />
                                <RadioButton x:Name="CommaDelimiterRadio" Content="Comma" GroupName="Delimiter" Margin="0,0,10,0" Checked="DelimiterChanged" />
                                <RadioButton x:Name="SpaceDelimiterRadio" Content="Space" GroupName="Delimiter" Checked="DelimiterChanged" />
                            </WrapPanel>

                            <DockPanel Style="{StaticResource SettingsFieldDockPanelStyle}">
                                <TextBlock Text="Header Row" Style="{StaticResource SettingsFieldLabelTextStyle}" />
                                <TextBox x:Name="HeaderRowTextBox" Width="70" Text="1" TextChanged="HeaderRowChanged" />
                            </DockPanel>

                            <Separator Margin="0,8,0,8" />

                            <CheckBox x:Name="ApplyToAllColumnsCheckBox"
                                      Content="Apply same limits to all columns"
                                      IsChecked="True" />

                            <DockPanel Style="{StaticResource SettingsFieldDockPanelStyle}">
                                <TextBlock Text="Spec" Style="{StaticResource SettingsFieldLabelTextStyle}" Width="70" />
                                <TextBox x:Name="SpecValueTextBox" Height="28" />
                            </DockPanel>
                            <DockPanel Style="{StaticResource SettingsFieldDockPanelStyle}">
                                <TextBlock Text="Upper" Style="{StaticResource SettingsFieldLabelTextStyle}" Width="70" />
                                <TextBox x:Name="UpperLimitValueTextBox" Height="28" />
                            </DockPanel>
                            <DockPanel Style="{StaticResource SettingsFieldDockPanelStyle}">
                                <TextBlock Text="Lower" Style="{StaticResource SettingsFieldLabelTextStyle}" Width="70" />
                                <TextBox x:Name="LowerLimitValueTextBox" Height="28" />
                            </DockPanel>
                            <Button Content="Apply Limits"
                                    Margin="0,8,0,0"
                                    Click="ApplyLimitsToAllColumnsButton_Click" />

                            <Separator Margin="0,10,0,8" />

                            <TextBlock Text="Columns To Plot" Style="{StaticResource SettingsSectionHeaderTextStyle}" />
                            <ListBox x:Name="ColumnOptionListBox"
                                     Margin="0,6,0,0"
                                     MaxHeight="340"
                                     Style="{StaticResource ColumnSelectionListBoxStyle}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <DockPanel Style="{StaticResource ColumnOptionItemDockPanelStyle}">
                                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding ColumnName}" Margin="8,0,0,0" VerticalAlignment="Center" />
                                        </DockPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </ScrollViewer>
            </GroupBox>
        </Grid>
    </Grid>
</UserControl>
