<Window x:Class="GraphMaker.ValuePlotMultiColumnFileSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:app="clr-namespace:JinoSupporter.Controls;assembly=JinoSupporter.Controls"
        Title="Value Multi-Column File Settings"
        Width="980"
        Height="620"
        MinWidth="900"
        MinHeight="520"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="3*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" Grid.Column="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <GroupBox Header="File Format" Margin="0,0,0,8">
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Delimiter:" VerticalAlignment="Center" />
                        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
                            <RadioButton x:Name="TabDelimiterRadio" Content="Tab" GroupName="Delimiter" Margin="0,0,10,0" Checked="PreviewSettingChanged" />
                            <RadioButton x:Name="CommaDelimiterRadio" Content="Comma" GroupName="Delimiter" Margin="0,0,10,0" Checked="PreviewSettingChanged" />
                            <RadioButton x:Name="SpaceDelimiterRadio" Content="Space" GroupName="Delimiter" Checked="PreviewSettingChanged" />
                        </StackPanel>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Header Row:" VerticalAlignment="Center" Margin="0,8,0,0" />
                        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,8,0,0">
                            <app:AppTextBox x:Name="HeaderRowTextBox" Width="70" TextChanged="HeaderRowTextBox_TextChanged" />
                            <app:AppButton Content="Reload Columns" Margin="8,0,0,0" Padding="12,4" Click="ReloadColumnsButton_Click" />
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <GroupBox Header="Limits" Margin="0,0,0,8">
                    <StackPanel Margin="10">
                        <app:AppCheckBox x:Name="ApplyToAllColumnsCheckBox"
                                  Content="Apply same limits to all columns"
                                  IsChecked="True" />
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Spec:" VerticalAlignment="Center" />
                            <app:AppTextBox Grid.Row="0" Grid.Column="1" x:Name="SpecValueTextBox" />
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Upper:" VerticalAlignment="Center" Margin="0,8,0,0" />
                            <app:AppTextBox Grid.Row="1" Grid.Column="1" x:Name="UpperLimitValueTextBox" Margin="0,8,0,0" />
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Lower:" VerticalAlignment="Center" Margin="0,8,0,0" />
                            <app:AppTextBox Grid.Row="2" Grid.Column="1" x:Name="LowerLimitValueTextBox" Margin="0,8,0,0" />
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Columns To Plot">
                    <StackPanel Margin="10">
                        <StackPanel Orientation="Horizontal">
                            <app:AppButton Content="Select All" Width="90" Click="SelectAllButton_Click" />
                            <app:AppButton Content="Clear" Width="90" Margin="8,0,0,0" Click="ClearAllButton_Click" />
                        </StackPanel>
                        <app:AppListBox x:Name="ColumnListBox"
                                 Margin="0,8,0,0"
                                 MaxHeight="280"
                                 BorderBrush="#D1D5DB"
                                 BorderThickness="1">
                            <app:AppListBox.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel Margin="4,2">
                                        <app:AppCheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding Name}" Margin="8,0,0,0" VerticalAlignment="Center" />
                                    </DockPanel>
                                </DataTemplate>
                            </app:AppListBox.ItemTemplate>
                        </app:AppListBox>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <GroupBox Grid.Row="0" Grid.Column="2" Header="Data Preview">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock x:Name="PreviewSummaryTextBlock"
                           Text="Preview will appear here."
                           Margin="0,0,0,8"
                           Foreground="#6B7280" />

                <app:AppDataGrid Grid.Row="1"
                          x:Name="PreviewDataGrid"
                          IsReadOnly="True"
                          AutoGenerateColumns="True"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          HeadersVisibility="All"
                          GridLinesVisibility="Horizontal"
                          RowHeaderWidth="0"
                          SelectionMode="Single"
                          SelectionUnit="CellOrRowHeader" />
            </Grid>
        </GroupBox>

        <StackPanel Grid.Row="1" Grid.ColumnSpan="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <app:AppButton Content="Cancel" Width="90" Margin="0,0,8,0" Click="CancelButton_Click" />
            <app:AppButton Content="Save" Width="90" Click="SaveButton_Click" />
        </StackPanel>
    </Grid>
</Window>
