<Window x:Class="GraphMaker.DailyDataTrendSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Data Load Setup"
        Width="1180"
        Height="760"
        MinWidth="1040"
        MinHeight="680"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="1.2*" />
            <RowDefinition Height="1.8*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.05*" />
            <ColumnDefinition Width="1.2*" />
        </Grid.ColumnDefinitions>

        <GroupBox Grid.Row="0" Grid.Column="0" Header="Files" Margin="0,0,10,10">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal">
                    <Button Width="120" Content="Browse Files" Click="BrowseFilesButton_Click" />
                    <Button Width="100" Margin="8,0,0,0" Content="Remove" Click="RemoveFileButton_Click" />
                    <Button Width="120" Margin="8,0,0,0" Content="Clear All" Click="ClearFilesButton_Click" />
                </StackPanel>
                <ListBox x:Name="FileListBox"
                         Grid.Row="1"
                         Margin="0,10,0,0"
                         MinHeight="140"
                         DisplayMemberPath="." />
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="0" Grid.Column="1" Header="Load Options" Margin="0,0,0,10">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           VerticalAlignment="Center"
                           Text="Delimiter" />
                <ComboBox x:Name="DelimiterComboBox"
                          Grid.Row="0"
                          Grid.Column="1"
                          SelectionChanged="DelimiterComboBox_SelectionChanged"
                          SelectedValuePath="Tag"
                          DisplayMemberPath="Content" />

                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           Margin="0,10,0,0"
                           VerticalAlignment="Center"
                           Text="Header Row" />
                <TextBox x:Name="HeaderRowTextBox"
                         Grid.Row="1"
                         Grid.Column="1"
                         Margin="0,10,0,0"
                         Width="120"
                         HorizontalAlignment="Left"
                         TextChanged="HeaderRowTextBox_TextChanged"
                         Text="1" />

                <Border Grid.Row="2"
                        Grid.ColumnSpan="2"
                        Margin="0,14,0,0"
                        Padding="12"
                        Background="#F8FAFC"
                        BorderBrush="#D0D5DD"
                        BorderThickness="1"
                        CornerRadius="6">
                    <TextBlock Foreground="#475467"
                               TextWrapping="Wrap"
                               Text="Select one or more TXT/CSV files, then adjust delimiter and header row. The preview below updates automatically and column names can be edited before applying the data." />
                </Border>
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="1" Grid.Column="0" Header="Column Rename" Margin="0,0,10,10">
            <DataGrid x:Name="ColumnRenameDataGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      Margin="8">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Original Column"
                                        Binding="{Binding OriginalName}"
                                        IsReadOnly="True"
                                        Width="*" />
                    <DataGridTextColumn Header="New Column"
                                        Binding="{Binding NewName, UpdateSourceTrigger=PropertyChanged}"
                                        Width="*" />
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <GroupBox Grid.Row="1" Grid.Column="1" Header="Data Preview" Margin="0,0,0,10">
            <DataGrid x:Name="PreviewDataGrid"
                      Margin="8"
                      AutoGenerateColumns="True"
                      IsReadOnly="True"
                      EnableRowVirtualization="True"
                      EnableColumnVirtualization="True"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling" />
        </GroupBox>

        <Grid Grid.Row="2" Grid.ColumnSpan="2" Margin="0,0,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="StatusTextBlock"
                       VerticalAlignment="Center"
                       Foreground="#667085"
                       Text="Select files to preview." />
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Width="90" Content="OK" IsDefault="True" Click="OkButton_Click" />
                <Button Width="90" Margin="8,0,0,0" Content="Cancel" IsCancel="True" Click="CancelButton_Click" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
