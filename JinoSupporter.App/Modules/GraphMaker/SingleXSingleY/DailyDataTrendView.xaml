<UserControl x:Class="GraphMaker.DailyDataTrendView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:GraphMaker"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="800"
             d:DesignWidth="1600">
    <Grid Style="{StaticResource GraphMakerPageRootGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <GroupBox Grid.Row="0" Header="Workflow" Style="{StaticResource FilesSectionGroupBoxStyle}">
            <Grid Style="{StaticResource FilesSectionInnerGridStyle}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.2*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="2*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Style="{StaticResource DropZoneBorderStyle}"
                        Margin="0,0,8,0"
                        MinHeight="88">
                    <StackPanel>
                        <TextBlock Text="Drag data file"
                                   Style="{StaticResource FileDropHintTextStyle}" />
                        <Button Content="Browse"
                                Width="120"
                                Margin="0,8,0,0"
                                HorizontalAlignment="Center"
                                Click="BrowseButton_Click" />
                    </StackPanel>
                </Border>

                <StackPanel Grid.Column="1">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Plot Color:" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <ComboBox x:Name="PlotColorComboBox"
                                  MinWidth="120"
                                  Width="150" />
                    </StackPanel>
                    <StackPanel Margin="0,8,0,0">
                        <Button Content="Load Report"
                                Width="110"
                                Click="LoadReportButton_Click" />
                        <Button Content="Save Report"
                                Width="110"
                                Margin="0,6,0,0"
                                Click="SaveReportButton_Click" />
                        <Button Content="Remove File"
                                Width="110"
                                Margin="0,6,0,0"
                                Click="RemoveFileButton_Click" />
                    </StackPanel>
                </StackPanel>

                <GroupBox Grid.Column="3"
                          Header="Preview"
                          Style="{StaticResource PreviewGroupBoxStyle}">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock>
                            <Run Text="File: " FontWeight="SemiBold" />
                            <Run x:Name="CurrentFileNameText" Text="(No file)" />
                        </TextBlock>
                        <TextBlock Grid.Row="1" Margin="0,4,0,0">
                            <Run Text="Rows: " FontWeight="SemiBold" />
                            <Run x:Name="RowCountText" Text="0" />
                            <Run Text=" | Cols: " FontWeight="SemiBold" />
                            <Run x:Name="ColumnCountText" Text="0" />
                        </TextBlock>
                        <TextBlock Grid.Row="2"
                                   x:Name="StatusText"
                                   Margin="0,4,0,0"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Text="Drag and drop data files into the workflow area." />
                    </Grid>
                </GroupBox>
            </Grid>
        </GroupBox>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3.2*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="1.4*" />
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0" Header="Data Grid" Style="{StaticResource PreviewGroupBoxStyle}">
                <local:InteractiveDataGrid x:Name="DataPreviewGrid"
                                           Margin="8" />
            </GroupBox>

            <GroupBox Grid.Column="2" Header="Settings" Style="{StaticResource SettingsGroupBoxStyle}">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="Set USL / SPEC / LSL for the single Value series."
                           TextWrapping="Wrap"
                           Foreground="{StaticResource TextSecondaryBrush}" />

                <ScrollViewer Grid.Row="1" Margin="0,10,0,0" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="LimitItemsPanel" />
                </ScrollViewer>

                <Button Grid.Row="2"
                        Content="Generate Trend"
                        Width="140"
                        Margin="0,12,0,0"
                        HorizontalAlignment="Right"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="GenerateTrendButton_Click" />
            </Grid>
            </GroupBox>
        </Grid>
    </Grid>
</UserControl>
