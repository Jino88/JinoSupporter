<local:GraphViewBase x:Class="GraphMaker.DailyDataTrendView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:GraphMaker"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="800"
             d:DesignWidth="1600">
    <Grid Style="{StaticResource GraphMakerPageRootGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <GroupBox Grid.Row="0" Header="Workflow" Style="{StaticResource FilesSectionGroupBoxStyle}">
            <Grid Style="{StaticResource FilesSectionInnerGridStyle}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.2*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="2*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Style="{StaticResource DropZoneBorderStyle}"
                        Margin="0,0,8,0"
                        MinHeight="88"
                        AllowDrop="True"
                        Drop="DropZone_Drop"
                        DragEnter="DropZone_DragEnter"
                        DragLeave="DropZone_DragLeave"
                        DragOver="DropZone_DragOver">
                    <StackPanel>
                        <TextBlock Text="Drag data files"
                                   Style="{StaticResource FileDropHintTextStyle}" />
                        <Button Content="Browse"
                                Width="120"
                                Margin="0,8,0,0"
                                HorizontalAlignment="Center"
                                Click="BrowseButton_Click" />
                    </StackPanel>
                </Border>

                <StackPanel Grid.Column="1">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Plot Color:" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <ComboBox x:Name="PlotColorComboBox"
                                  MinWidth="120"
                                  Width="150" />
                    </StackPanel>
                    <StackPanel Margin="0,8,0,0">
                        <Button Content="Load Report"
                                Width="110"
                                Click="LoadReportButton_Click" />
                        <Button Content="Save Report"
                                Width="110"
                                Margin="0,6,0,0"
                                Click="SaveReportButton_Click" />
                        <Button Content="Remove File"
                                Width="110"
                                Margin="0,6,0,0"
                                Click="RemoveFileButton_Click" />
                    </StackPanel>
                </StackPanel>

                <GroupBox Grid.Column="3"
                          Header="Preview"
                          Style="{StaticResource PreviewGroupBoxStyle}">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock>
                            <Run Text="File: " FontWeight="SemiBold" />
                            <Run x:Name="CurrentFileNameText" Text="(No file)" />
                        </TextBlock>
                        <TextBlock Grid.Row="1" Margin="0,4,0,0">
                            <Run Text="Rows: " FontWeight="SemiBold" />
                            <Run x:Name="RowCountText" Text="0" />
                            <Run Text=" | Cols: " FontWeight="SemiBold" />
                            <Run x:Name="ColumnCountText" Text="0" />
                        </TextBlock>
                        <TextBlock Grid.Row="2"
                                   x:Name="StatusText"
                                   Margin="0,4,0,0"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Text="Drag and drop data files into the workflow area." />
                    </Grid>
                </GroupBox>
            </Grid>
        </GroupBox>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3.2*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="1.4*" />
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0" Header="Data Grid" Style="{StaticResource PreviewGroupBoxStyle}">
                <local:InteractiveDataGrid x:Name="DataPreviewGrid"
                                           Margin="8" />
            </GroupBox>

            <GroupBox Grid.Column="2" Header="Settings" Style="{StaticResource SettingsGroupBoxStyle}">
                <ScrollViewer Style="{StaticResource SettingsScrollViewerStyle}"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Style="{StaticResource SettingsStackPanelStyle}">

                        <TextBlock Text="File Format"
                                   Style="{StaticResource SettingsSectionHeaderTextStyle}" />
                        <WrapPanel Style="{StaticResource DelimiterWrapPanelStyle}">
                            <RadioButton x:Name="TabDelimiterRadio" Content="Tab" IsChecked="True" GroupName="Delimiter" Margin="0,0,10,0" Checked="DelimiterChanged" />
                            <RadioButton x:Name="CommaDelimiterRadio" Content="Comma" GroupName="Delimiter" Margin="0,0,10,0" Checked="DelimiterChanged" />
                            <RadioButton x:Name="SpaceDelimiterRadio" Content="Space" GroupName="Delimiter" Checked="DelimiterChanged" />
                        </WrapPanel>
                        <DockPanel Style="{StaticResource SettingsFieldDockPanelStyle}">
                            <TextBlock Text="Header Row" Style="{StaticResource SettingsFieldLabelTextStyle}" />
                            <TextBox x:Name="HeaderRowTextBox" Width="60" Text="1" TextChanged="HeaderRowChanged" />
                        </DockPanel>

                        <Separator Margin="0,8,0,8" />

                        <TextBlock Text="Limits"
                                   Style="{StaticResource SettingsSectionHeaderTextStyle}" />
                        <TextBlock Text="Set USL / SPEC / LSL for the single Value series."
                                   Margin="0,0,0,8"
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource TextSecondaryBrush}" />

                        <StackPanel x:Name="LimitItemsPanel" />

                        <Button Content="Generate Trend"
                                Margin="0,12,0,0"
                                HorizontalAlignment="Right"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="GenerateTrendButton_Click" />
                    </StackPanel>
                </ScrollViewer>
            </GroupBox>
        </Grid>
    </Grid>
</local:GraphViewBase>
