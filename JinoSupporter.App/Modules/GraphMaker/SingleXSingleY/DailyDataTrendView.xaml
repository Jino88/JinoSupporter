<local:GraphViewBase x:Class="GraphMaker.DailyDataTrendView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:app="clr-namespace:JinoSupporter.Controls;assembly=JinoSupporter.Controls"
             xmlns:local="clr-namespace:GraphMaker"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="800"
             d:DesignWidth="1600">
    <Grid Style="{StaticResource GraphMakerPageRootGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.72*" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="1.28*" />
        </Grid.ColumnDefinitions>

        <GroupBox Grid.Row="0" Grid.Column="0" Header="Workflow" Style="{StaticResource FilesSectionGroupBoxStyle}">
            <Grid Style="{StaticResource FilesSectionInnerGridStyle}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.65*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <app:AppFileDropBox Grid.Column="0"
                                    Margin="0,0,8,0"
                                    HintText="Drag data files"
                                    BrowseButtonText="Browse"
                                    AllowMultiple="True"
                                    FileFilter="Text/CSV files (*.txt;*.csv)|*.txt;*.csv|All files (*.*)|*.*"
                                    FilesSelected="FileDropBox_FilesSelected" />

                <StackPanel Grid.Column="1">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Plot Color:" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <app:AppComboBox x:Name="PlotColorComboBox"
                                  MinWidth="120"
                                  Width="150" />
                    </StackPanel>
                    <StackPanel Visibility="Collapsed">
                        <TextBlock>
                            <Run Text="File: " FontWeight="SemiBold" />
                            <Run x:Name="CurrentFileNameText" Text="(No file)" />
                        </TextBlock>
                        <TextBlock>
                            <Run Text="Rows: " FontWeight="SemiBold" />
                            <Run x:Name="RowCountText" Text="0" />
                            <Run Text=" | Cols: " FontWeight="SemiBold" />
                            <Run x:Name="ColumnCountText" Text="0" />
                        </TextBlock>
                        <TextBlock x:Name="StatusText"
                                   Text="Drag and drop data files into the workflow area." />
                    </StackPanel>
                    <StackPanel Margin="0,8,0,0">
                        <app:AppButton Content="Load Report"
                                Width="110"
                                Click="LoadReportButton_Click" />
                        <app:AppButton Content="Save Report"
                                Width="110"
                                Margin="0,6,0,0"
                                Click="SaveReportButton_Click" />
                        <app:AppButton Content="Remove File"
                                Width="110"
                                Margin="0,6,0,0"
                                Click="RemoveFileButton_Click" />
                    </StackPanel>
                </StackPanel>

            </Grid>
        </GroupBox>

        <Grid Grid.Row="1" Grid.Column="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0" Header="Data Grid" Style="{StaticResource PreviewGroupBoxStyle}">
                <local:InteractiveDataGrid x:Name="DataPreviewGrid"
                                           Margin="8" />
            </GroupBox>
        </Grid>

        <GroupBox Grid.Row="0" Grid.RowSpan="2" Grid.Column="2" Header="Settings" Style="{StaticResource SettingsGroupBoxStyle}">
            <ScrollViewer Style="{StaticResource SettingsScrollViewerStyle}"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Style="{StaticResource SettingsStackPanelStyle}">

                    <TextBlock Text="File Format"
                               Style="{StaticResource SettingsSectionHeaderTextStyle}" />
                    <WrapPanel Style="{StaticResource DelimiterWrapPanelStyle}">
                        <RadioButton x:Name="TabDelimiterRadio" Content="Tab" IsChecked="True" GroupName="Delimiter" Margin="0,0,10,0" Checked="DelimiterChanged" />
                        <RadioButton x:Name="CommaDelimiterRadio" Content="Comma" GroupName="Delimiter" Margin="0,0,10,0" Checked="DelimiterChanged" />
                        <RadioButton x:Name="SpaceDelimiterRadio" Content="Space" GroupName="Delimiter" Checked="DelimiterChanged" />
                    </WrapPanel>
                    <DockPanel Style="{StaticResource SettingsFieldDockPanelStyle}">
                        <TextBlock Text="Header Row" Style="{StaticResource SettingsFieldLabelTextStyle}" />
                        <app:AppTextBox x:Name="HeaderRowTextBox" Width="60" Text="1" TextChanged="HeaderRowChanged" />
                    </DockPanel>

                    <Separator Margin="0,8,0,8" />

                    <TextBlock Text="Limits"
                               Style="{StaticResource SettingsSectionHeaderTextStyle}" />
                    <TextBlock Text="Set USL / SPEC / LSL for the single Value series."
                               Margin="0,0,0,8"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource TextSecondaryBrush}" />

                    <StackPanel x:Name="LimitItemsPanel" />

                    <app:AppButton Content="Generate Trend"
                            Margin="0,12,0,0"
                            HorizontalAlignment="Right"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="GenerateTrendButton_Click" />
                </StackPanel>
            </ScrollViewer>
        </GroupBox>
    </Grid>
</local:GraphViewBase>
