<Window x:Class="GraphMaker.ColumnLimitSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:app="clr-namespace:JinoSupporter.Controls;assembly=JinoSupporter.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Column Spec/Limit Settings"
        Width="700"
        Height="560"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <app:AppDataGrid x:Name="ColumnLimitDataGrid"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  Margin="0,0,0,8">
            <app:AppDataGrid.Columns>
                <DataGridTextColumn Header="Column Name"
                                    Binding="{Binding ColumnName}"
                                    IsReadOnly="True"
                                    Width="2*" />
                <DataGridTextColumn Header="SPEC"
                                    Binding="{Binding SpecValue, UpdateSourceTrigger=PropertyChanged}"
                                    Width="*" />
                <DataGridTextColumn Header="Upper Limit"
                                    Binding="{Binding UpperValue, UpdateSourceTrigger=PropertyChanged}"
                                    Width="*" />
                <DataGridTextColumn Header="Lower Limit"
                                    Binding="{Binding LowerValue, UpdateSourceTrigger=PropertyChanged}"
                                    Width="*" />
            </app:AppDataGrid.Columns>
        </app:AppDataGrid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
            <app:AppButton Content="OK" Width="90" Click="OkButton_Click" />
            <app:AppButton Content="Cancel" Width="90" Margin="8,0,0,0" Click="CancelButton_Click" />
        </StackPanel>
    </Grid>
</Window>
