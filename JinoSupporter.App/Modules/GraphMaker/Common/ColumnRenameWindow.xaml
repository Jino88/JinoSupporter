<Window x:Class="GraphMaker.ColumnRenameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:app="clr-namespace:JinoSupporter.Controls;assembly=JinoSupporter.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Rename Columns"
        Width="720"
        Height="560"
        MinWidth="620"
        MinHeight="460"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <GroupBox Header="Columns">
            <app:AppDataGrid x:Name="ColumnDataGrid"
                      Margin="8"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False">
                <app:AppDataGrid.Columns>
                    <DataGridTextColumn Header="Current Column"
                                        Binding="{Binding OriginalName}"
                                        IsReadOnly="True"
                                        Width="*" />
                    <DataGridTextColumn Header="New Column"
                                        Binding="{Binding NewName, UpdateSourceTrigger=PropertyChanged}"
                                        Width="*" />
                </app:AppDataGrid.Columns>
            </app:AppDataGrid>
        </GroupBox>

        <Grid Grid.Row="1" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="StatusTextBlock"
                       VerticalAlignment="Center"
                       Foreground="#667085"
                       Text="Edit all column names in one place, then apply." />

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <app:AppButton Width="90" Content="OK" IsDefault="True" Click="OkButton_Click" />
                <app:AppButton Width="90" Margin="8,0,0,0" Content="Cancel" IsCancel="True" Click="CancelButton_Click" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
