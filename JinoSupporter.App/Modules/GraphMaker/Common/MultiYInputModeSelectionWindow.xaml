<Window x:Class="GraphMaker.MultiYInputModeSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:app="clr-namespace:JinoSupporter.Controls;assembly=JinoSupporter.Controls"
        xmlns:oxy="http://oxyplot.org/wpf"
        Title="Select Multi Y Mode"
        Width="1320"
        Height="760"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="380" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Choose how the file should be interpreted. Preview uses the first 100 rows of the selected file."
                   FontSize="15"
                   FontWeight="SemiBold" />

        <StackPanel Grid.Row="1" Margin="0,14,0,0">
            <GroupBox Header="Read Options">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Delimiter"
                               VerticalAlignment="Center" />
                    <app:AppComboBox x:Name="DelimiterComboBox"
                              Grid.Column="1"
                              Width="160"
                              SelectionChanged="PreviewSettingChanged">
                        <ComboBoxItem Content="Auto" Tag="AUTO" IsSelected="True" />
                        <ComboBoxItem Content="Tab" Tag="&#x9;" />
                        <ComboBoxItem Content="Comma" Tag="," />
                    </app:AppComboBox>

                    <app:AppCheckBox x:Name="HasHeaderCheckBox"
                              Grid.Row="1"
                              Grid.ColumnSpan="2"
                              Margin="0,10,0,0"
                              Content="File has header row"
                              IsChecked="True"
                              Checked="PreviewSettingChanged"
                              Unchecked="PreviewSettingChanged" />

                    <StackPanel Grid.Row="2"
                                Grid.ColumnSpan="2"
                                Orientation="Horizontal"
                                Margin="0,10,0,0">
                        <TextBlock Text="Header row"
                                   Width="120"
                                   VerticalAlignment="Center" />
                        <app:AppTextBox x:Name="HeaderRowTextBox"
                                 Width="80"
                                 Text="1"
                                 TextChanged="PreviewSettingChanged" />
                    </StackPanel>
                </Grid>
            </GroupBox>

            <GroupBox Header="Mode"
                      Margin="0,12,0,0">
                <StackPanel Margin="10">
                    <RadioButton x:Name="HeaderModeRadioButton"
                                 Content="SingleX(No) - Multi Y"
                                 IsChecked="True"
                                 Margin="0,0,0,12"
                                 Checked="ModeRadioButton_Checked" />
                    <TextBlock x:Name="HeaderModeDescriptionTextBlock"
                               Margin="20,-8,0,12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Text="Use when the file has a normal header row and multiple Y columns." />

                    <RadioButton x:Name="DateSingleYModeRadioButton"
                                 Content="SingleX(Date) - SingleY"
                                 Margin="0,0,0,12"
                                 Checked="ModeRadioButton_Checked" />
                    <TextBlock x:Name="DateSingleYModeDescriptionTextBlock"
                               Margin="20,-8,0,12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Text="Use when the first column is Date and one Y column should be shown as a trend graph." />

                    <RadioButton x:Name="DateNoHeaderModeRadioButton"
                                 Content="SingleX(Date) - Multi Y (No Header)"
                                 Margin="0,0,0,12"
                                 Checked="ModeRadioButton_Checked" />
                    <TextBlock x:Name="DateNoHeaderModeDescriptionTextBlock"
                               Margin="20,-8,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Text="Use when the first column is Date and the file does not have a normal header row." />
                </StackPanel>
            </GroupBox>
        </StackPanel>

        <GroupBox Grid.Column="2"
                  Grid.Row="0"
                  Grid.RowSpan="2"
                  Header="Preview">
            <Grid Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="220" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock x:Name="PreviewSummaryTextBlock"
                           TextWrapping="Wrap"
                           Margin="0,0,0,8"
                           Foreground="{StaticResource TextSecondaryBrush}" />

                <app:AppDataGrid x:Name="PreviewDataGrid"
                          Grid.Row="1"
                          AutoGenerateColumns="True"
                          IsReadOnly="True"
                          HeadersVisibility="All"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          SelectionMode="Extended"
                          GridLinesVisibility="All" />

                <oxy:PlotView x:Name="PreviewPlotView"
                              Grid.Row="3" />
                <TextBlock Grid.Row="4"
                           x:Name="PreviewDescriptionTextBlock"
                           Margin="0,8,0,0"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource TextSecondaryBrush}" />
            </Grid>
        </GroupBox>

        <StackPanel Grid.Row="2"
                    Grid.ColumnSpan="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <app:AppButton Content="Cancel"
                    Width="100"
                    Margin="0,0,8,0"
                    Click="CancelButton_Click" />
            <app:AppButton Content="OK"
                    Width="100"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="OkButton_Click" />
        </StackPanel>
    </Grid>
</Window>
