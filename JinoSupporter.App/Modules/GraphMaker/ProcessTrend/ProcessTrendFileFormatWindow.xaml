<Window x:Class="GraphMaker.ProcessTrendFileFormatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:app="clr-namespace:JinoSupporter.Controls;assembly=JinoSupporter.Controls"
        Title="File Format"
        Width="320"
        Height="260"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Delimiter" FontWeight="SemiBold" />
            <StackPanel Margin="0,8,0,0">
                <RadioButton x:Name="TabDelimiterRadio"
                             Content="Tab"
                             IsChecked="True"
                             GroupName="DelimiterChoice"
                             Margin="0,0,0,6" />
                <RadioButton x:Name="CommaDelimiterRadio"
                             Content="Comma"
                             GroupName="DelimiterChoice"
                             Margin="0,0,0,6" />
                <RadioButton x:Name="SpaceDelimiterRadio"
                             Content="Space"
                             GroupName="DelimiterChoice" />
            </StackPanel>

            <TextBlock Text="Header Row" Margin="0,14,0,0" FontWeight="SemiBold" />
            <app:AppTextBox x:Name="HeaderRowTextBox"
                     Width="80"
                     Margin="0,8,0,0"
                     Text="1"
                     HorizontalAlignment="Left" />
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <app:AppButton Content="Cancel" Width="80" Margin="0,0,8,0" Click="CancelButton_Click" />
            <app:AppButton Content="OK" Width="80" Click="OkButton_Click" />
        </StackPanel>
    </Grid>
</Window>
