<local:GraphViewBase x:Class="GraphMaker.DailyDataTrendExtraView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:app="clr-namespace:JinoSupporter.Controls;assembly=JinoSupporter.Controls"
             xmlns:local="clr-namespace:GraphMaker"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="800"
             d:DesignWidth="1600">
    <Grid Style="{StaticResource GraphMakerPageRootGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="2.1*" />
            <RowDefinition Height="3*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.72*" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="1.28*" />
        </Grid.ColumnDefinitions>

        <GroupBox Grid.Row="0" Grid.Column="0" Header="Workflow" Style="{StaticResource FilesSectionGroupBoxStyle}">
            <Grid Style="{StaticResource FilesSectionInnerGridStyle}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.65*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <app:AppFileDropBox Grid.Column="0"
                        Margin="0,0,8,0"
                        HintText="Drag data file"
                        BrowseButtonText="Browse"
                        AllowMultiple="True"
                        FilesSelected="FileDropBox_FilesSelected" />

                <StackPanel Grid.Column="1">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Plot Color:" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <app:AppComboBox x:Name="PlotColorComboBox" MinWidth="120" Width="150" />
                    </StackPanel>
                    <StackPanel Visibility="Collapsed">
                        <TextBlock>
                            <Run Text="File: " FontWeight="SemiBold" />
                            <Run x:Name="CurrentFileNameText" Text="(No file)" />
                        </TextBlock>
                        <TextBlock>
                            <Run Text="Rows: " FontWeight="SemiBold" />
                            <Run x:Name="RowCountText" Text="0" />
                            <Run Text=" | Cols: " FontWeight="SemiBold" />
                            <Run x:Name="ColumnCountText" Text="0" />
                        </TextBlock>
                        <TextBlock x:Name="StatusText"
                                   Text="Drop file into the workflow area or click Browse to load data." />
                    </StackPanel>
                    <StackPanel Margin="0,8,0,0">
                        <app:AppButton Content="Load Report"
                                Width="110"
                                Click="LoadReportButton_Click" />
                        <app:AppButton Content="Save Report"
                                Width="110"
                                Margin="0,6,0,0"
                                Click="SaveReportButton_Click" />
                        <app:AppButton Content="Remove File"
                                Width="110"
                                Margin="0,6,0,0"
                                Click="RemoveFileButton_Click" />
                    </StackPanel>
                </StackPanel>

            </Grid>
        </GroupBox>

        <Grid Grid.Row="1" Grid.Column="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0" Header="Data Grid" Style="{StaticResource PreviewGroupBoxStyle}">
                <local:InteractiveDataGrid x:Name="DataPreviewGrid" />
            </GroupBox>

        </Grid>

        <GroupBox Grid.Row="0" Grid.RowSpan="2" Grid.Column="2" Header="Settings">
            <Grid Margin="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="1.1*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="1.35*" />
                </Grid.ColumnDefinitions>

            <GroupBox Header="X Axis" Grid.Column="0">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Select one or more category columns to build the X-axis key."
                               Foreground="#667085"
                               TextWrapping="Wrap" />
                    <app:AppListBox x:Name="XAxisListBox"
                             Grid.Row="1"
                             Margin="0,8,0,0"
                             SelectionMode="Extended"
                             SelectionChanged="AxisSelectionChanged" />
                </Grid>
            </GroupBox>

            <GroupBox Header="Y Axis" Grid.Column="2">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Select one or more numeric measure columns to plot as separate series."
                               Foreground="#667085"
                               TextWrapping="Wrap" />
                    <app:AppListBox x:Name="YAxisListBox"
                             Grid.Row="1"
                             Margin="0,8,0,0"
                             SelectionMode="Extended"
                             SelectionChanged="AxisSelectionChanged" />
                </Grid>
            </GroupBox>

            <GroupBox Header="Limit" Grid.Column="4">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                        <TextBlock Text="Set USL / LSL for the selected Y-axis series."
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource TextSecondaryBrush}" />

                        <app:AppCheckBox x:Name="ApplySameLimitCheckBox"
                                  Grid.Row="1"
                                  Margin="0,10,0,0"
                                  Content="Apply same limit to all selected Y"
                                  Checked="ApplySameLimitCheckBox_Changed"
                                  Unchecked="ApplySameLimitCheckBox_Changed" />

                        <ScrollViewer Grid.Row="2" Margin="0,10,0,0" VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="LimitItemsPanel" />
                        </ScrollViewer>

                        <app:AppButton Grid.Row="3"
                                Content="Generate Trend"
                                Width="140"
                                Margin="0,12,0,0"
                                HorizontalAlignment="Right"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="GenerateTrendButton_Click" />
                </Grid>
            </GroupBox>
            </Grid>
        </GroupBox>
    </Grid>
</local:GraphViewBase>
