<local:GraphViewBase x:Class="GraphMaker.DailyDataTrendExtraView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:GraphMaker"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="800"
             d:DesignWidth="1600">
    <Grid Style="{StaticResource GraphMakerPageRootGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="2.1*" />
            <RowDefinition Height="3*" />
        </Grid.RowDefinitions>

        <GroupBox Grid.Row="0" Header="Workflow" Style="{StaticResource FilesSectionGroupBoxStyle}">
            <Grid Style="{StaticResource FilesSectionInnerGridStyle}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.1*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="2*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Style="{StaticResource DropZoneBorderStyle}"
                        Margin="0,0,8,0"
                        MinHeight="88">
                    <StackPanel>
                        <TextBlock Text="Drag data file"
                                   Style="{StaticResource FileDropHintTextStyle}" />
                        <Button Content="Browse"
                                Width="120"
                                Margin="0,8,0,0"
                                HorizontalAlignment="Center"
                                Click="BrowseButton_Click" />
                    </StackPanel>
                </Border>

                <StackPanel Grid.Column="1">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Plot Color:" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <ComboBox x:Name="PlotColorComboBox" MinWidth="120" Width="150" />
                    </StackPanel>
                    <StackPanel Margin="0,8,0,0">
                        <Button Content="Load Report"
                                Width="110"
                                Click="LoadReportButton_Click" />
                        <Button Content="Save Report"
                                Width="110"
                                Margin="0,6,0,0"
                                Click="SaveReportButton_Click" />
                        <Button Content="Remove File"
                                Width="110"
                                Margin="0,6,0,0"
                                Click="RemoveFileButton_Click" />
                    </StackPanel>
                </StackPanel>

                <GroupBox Grid.Column="3"
                          Header="Preview"
                          Style="{StaticResource PreviewGroupBoxStyle}">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock>
                            <Run Text="File: " FontWeight="SemiBold" />
                            <Run x:Name="CurrentFileNameText" Text="(No file)" />
                        </TextBlock>
                        <TextBlock Grid.Row="1" Margin="0,4,0,0">
                            <Run Text="Rows: " FontWeight="SemiBold" />
                            <Run x:Name="RowCountText" Text="0" />
                            <Run Text=" | Cols: " FontWeight="SemiBold" />
                            <Run x:Name="ColumnCountText" Text="0" />
                        </TextBlock>
                        <TextBlock Grid.Row="2"
                                   x:Name="StatusText"
                                   Margin="0,4,0,0"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Text="Drop file into the workflow area or click Browse to load data." />
                    </Grid>
                </GroupBox>
            </Grid>
        </GroupBox>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="2.8*" />
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0" Header="Data Grid" Style="{StaticResource PreviewGroupBoxStyle}">
                <local:InteractiveDataGrid x:Name="DataPreviewGrid" />
            </GroupBox>

            <GroupBox Grid.Column="2" Header="Settings">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.1*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="1.1*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="1.35*" />
                    </Grid.ColumnDefinitions>

                <GroupBox Header="X Axis" Grid.Column="0">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="Select one or more category columns to build the X-axis key."
                                   Foreground="#667085"
                                   TextWrapping="Wrap" />
                        <ListBox x:Name="XAxisListBox"
                                 Grid.Row="1"
                                 Margin="0,8,0,0"
                                 SelectionMode="Extended"
                                 SelectionChanged="AxisSelectionChanged" />
                    </Grid>
                </GroupBox>

                <GroupBox Header="Y Axis" Grid.Column="2">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="Select one or more numeric measure columns to plot as separate series."
                                   Foreground="#667085"
                                   TextWrapping="Wrap" />
                        <ListBox x:Name="YAxisListBox"
                                 Grid.Row="1"
                                 Margin="0,8,0,0"
                                 SelectionMode="Extended"
                                 SelectionChanged="AxisSelectionChanged" />
                    </Grid>
                </GroupBox>

                <GroupBox Header="Limit" Grid.Column="4">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="Set USL / LSL for the selected Y-axis series."
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource TextSecondaryBrush}" />

                        <CheckBox x:Name="ApplySameLimitCheckBox"
                                  Grid.Row="1"
                                  Margin="0,10,0,0"
                                  Content="Apply same limit to all selected Y"
                                  Checked="ApplySameLimitCheckBox_Changed"
                                  Unchecked="ApplySameLimitCheckBox_Changed" />

                        <ScrollViewer Grid.Row="2" Margin="0,10,0,0" VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="LimitItemsPanel" />
                        </ScrollViewer>

                        <Button Grid.Row="3"
                                Content="Generate Trend"
                                Width="140"
                                Margin="0,12,0,0"
                                HorizontalAlignment="Right"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="GenerateTrendButton_Click" />
                    </Grid>
                </GroupBox>
                </Grid>
            </GroupBox>
        </Grid>
    </Grid>
</local:GraphViewBase>
