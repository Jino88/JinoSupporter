<local:GraphViewBase x:Class="GraphMaker.AudioBusDataView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:GraphMaker"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="800"
             d:DesignWidth="1600">
    <Grid Style="{StaticResource GraphMakerPageRootGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <GroupBox Grid.Row="0" Header="Workflow" Style="{StaticResource FilesSectionGroupBoxStyle}">
            <Grid Style="{StaticResource FilesSectionInnerGridStyle}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.2*" />
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Style="{StaticResource DropZoneBorderStyle}"
                        Margin="0,0,8,0"
                        MinHeight="88">
                    <StackPanel>
                        <TextBlock Text="Select folder"
                                   FontSize="12"
                                   HorizontalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                        <Button Content="Browse Folder"
                                Width="120"
                                Margin="0,8,0,0"
                                HorizontalAlignment="Center"
                                Click="SelectFolderButton_Click" />
                    </StackPanel>
                </Border>

                <GroupBox Grid.Column="1"
                          Header="Preview"
                          Margin="0,0,8,0"
                          Style="{StaticResource PreviewGroupBoxStyle}">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock>
                                <Run Text="Selected Folder: " FontWeight="SemiBold" />
                                <Run Text="{Binding SelectedItem.Name, ElementName=FileListBox, FallbackValue=(None)}" />
                            </TextBlock>
                            <TextBlock Margin="0,4,0,0"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Text="Loaded files from the selected workflow folder." />
                        </StackPanel>

                        <ListBox Grid.Row="1"
                                 x:Name="FileListBox"
                                 Margin="0,8,0,0"
                                 MinHeight="88"
                                 DisplayMemberPath="Name" />
                    </Grid>
                </GroupBox>

                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <TextBlock x:Name="FileCountText"
                               Text="Files: 0"
                               FontWeight="SemiBold"
                               Width="130"
                               TextAlignment="Center" />
                </StackPanel>
            </Grid>
        </GroupBox>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3.7*" />
                <ColumnDefinition Width="1.6*" />
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0" Header="Data Grid" Margin="0,0,8,0" Style="{StaticResource PreviewGroupBoxStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="4,0,4,8">
                        <TextBlock Text="Available sheets:" FontWeight="SemiBold" Margin="0,0,0,5" />
                        <TextBlock Text="Only selected sheets are extracted from each file."
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,5" />
                        <Separator Margin="0,8" />
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="SheetCheckBoxPanel" Margin="8" />
                    </ScrollViewer>
                </Grid>
            </GroupBox>

            <GroupBox Grid.Column="1" Header="Settings" Margin="8,0,0,0" Style="{StaticResource SettingsGroupBoxStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Button Grid.Row="0"
                            Content="Extract and Save"
                            Margin="0,0,0,8"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="ExtractDataButton_Click" />

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="4,0,4,8">
                        <TextBlock Text="Status: " FontWeight="SemiBold" />
                        <TextBlock x:Name="StatusText"
                                   Text="Select folder"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                    </StackPanel>

                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <TextBox x:Name="LogTextBox"
                                 Style="{StaticResource MonospaceLogTextBoxStyle}"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 BorderThickness="1"
                                 BorderBrush="{StaticResource BorderBrush}"
                                 Padding="8" />
                    </ScrollViewer>
                </Grid>
            </GroupBox>
        </Grid>
    </Grid>
</local:GraphViewBase>
