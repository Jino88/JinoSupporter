<local:GraphViewBase x:Class="GraphMaker.AudioBusDataView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:app="clr-namespace:JinoSupporter.Controls;assembly=JinoSupporter.Controls"
             xmlns:local="clr-namespace:GraphMaker"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="800"
             d:DesignWidth="1600">
    <Grid Style="{StaticResource GraphMakerPageRootGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.72*" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="1.28*" />
        </Grid.ColumnDefinitions>

        <GroupBox Grid.Row="0" Grid.Column="0" Header="Workflow" Style="{StaticResource FilesSectionGroupBoxStyle}">
            <Grid Style="{StaticResource FilesSectionInnerGridStyle}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                    <app:AppFolderDropBox x:Name="FolderDropBoxControl"
                                          HintText="Select folder"
                                          BrowseButtonText="Browse Folder"
                                          FolderSelected="FolderDropBox_FolderSelected" />
                    <TextBlock Margin="0,8,0,0"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource TextSecondaryBrush}">
                        <Run Text="Folder: " FontWeight="SemiBold" />
                        <Run x:Name="CurrentFolderText" Text="(No folder)" />
                    </TextBlock>
                    <TextBlock Margin="0,4,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}">
                        <Run Text="Files: " FontWeight="SemiBold" />
                        <Run x:Name="FileCountValueText" Text="0" />
                    </TextBlock>
                    <TextBlock Margin="0,4,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap"
                               Text="{Binding Text, ElementName=StatusText}" />
                    <app:AppListBox x:Name="FileListBox"
                             Visibility="Collapsed"
                             DisplayMemberPath="Name" />
                </StackPanel>

                <StackPanel Grid.Column="1" VerticalAlignment="Top">
                    <TextBlock x:Name="FileCountText"
                               Text="Files: 0"
                               FontWeight="SemiBold"
                               Width="130"
                               TextAlignment="Center" />
                </StackPanel>
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="1" Grid.Column="0" Header="Data Grid" Margin="0,0,0,8" Style="{StaticResource PreviewGroupBoxStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="4,0,4,8">
                    <TextBlock Text="Available sheets:" FontWeight="SemiBold" Margin="0,0,0,5" />
                    <TextBlock Text="Only selected sheets are extracted from each file."
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,5" />
                    <Separator Margin="0,8" />
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="SheetCheckBoxPanel" Margin="8" />
                </ScrollViewer>
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="0" Grid.RowSpan="2" Grid.Column="2" Header="Settings" Style="{StaticResource SettingsGroupBoxStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <app:AppButton Grid.Row="0"
                        Content="Extract and Save"
                        Margin="0,0,0,8"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="ExtractDataButton_Click" />

                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="4,0,4,8">
                    <TextBlock Text="Status: " FontWeight="SemiBold" />
                    <TextBlock x:Name="StatusText"
                               Text="Select folder"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>

                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <app:AppTextBox x:Name="LogTextBox"
                             Style="{StaticResource MonospaceLogTextBoxStyle}"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             BorderThickness="1"
                             BorderBrush="{StaticResource BorderBrush}"
                             Padding="8" />
                </ScrollViewer>
            </Grid>
        </GroupBox>
    </Grid>
</local:GraphViewBase>
