<Window x:Class="GraphMaker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:app="clr-namespace:JinoSupporter.Controls;assembly=JinoSupporter.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="GraphMaker"
        Height="900"
        Width="1600"
        MinHeight="780"
        MinWidth="1280"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Style="{StaticResource CardBorderStyle}"
                Background="{StaticResource SidebarBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                Padding="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="GraphMaker"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock Text="Data Explorer Suite"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,4,0,0" />
                </StackPanel>

                <Separator Grid.Row="1" Margin="0,14,0,18" Background="{StaticResource BorderBrush}" />

                <ScrollViewer Grid.Row="2"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <TextBlock Text="Workspace"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontWeight="SemiBold"
                                   Margin="2,0,0,10" />
                        <app:AppButton x:Name="ScatterPlotButton"
                                Content="SPL Graph Plot"
                                Style="{StaticResource NavButtonStyle}"
                                Click="ScatterPlotButton_Click" />
                        <app:AppButton x:Name="ValuePlotButton"
                                Content="Daily Sampling Scatter"
                                Style="{StaticResource NavButtonStyle}"
                                Click="ValuePlotButton_Click" />
                        <app:AppButton x:Name="UnifiedMultiYButton"
                                Content="SingleX / MultiY / SingleY"
                                Style="{StaticResource NavButtonStyle}"
                                Click="UnifiedMultiYButton_Click" />
                        <app:AppButton x:Name="HeatMapButton"
                                Content="Generate Heatmap"
                                Style="{StaticResource NavButtonStyle}"
                                Click="HeatMapButton_Click" />
                        <app:AppButton x:Name="AudioBusDataButton"
                                Content="AudioBus Data"
                                Style="{StaticResource NavButtonStyle}"
                                Click="AudioBusDataButton_Click" />
                    </StackPanel>
                </ScrollViewer>

                <TextBlock Grid.Row="3"
                           Text="vNext UI"
                           HorizontalAlignment="Right"
                           FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}" />
            </Grid>
        </Border>

        <Border Grid.Column="2"
                Style="{StaticResource CardBorderStyle}"
                Padding="16">
            <Grid>
                <ContentControl x:Name="ContentArea" />

                <Border x:Name="WelcomePanel"
                        Background="{StaticResource SurfaceMutedBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="0"
                        Padding="54"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        MaxWidth="680">
                    <StackPanel>
                        <TextBlock Text="Welcome to GraphMaker"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="Select a task from the left menu to open analysis view."
                                   FontSize="15"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,16,0,0"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>

