<Window x:Class="GraphMaker.NoXMultiYLimitRecommendationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="USL / LSL Recommendation"
        Height="820"
        Width="1280"
        MinHeight="700"
        MinWidth="1100">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="HeaderTextBlock"
                   FontSize="22"
                   FontWeight="Bold"
                   Margin="0,0,0,12" />

        <Border Grid.Row="1"
                Padding="12"
                BorderBrush="#CBD5E1"
                BorderThickness="1"
                CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="Target NG Rate (%)"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold" />
                <TextBox Grid.Column="1"
                         x:Name="TargetNgRateTextBox"
                         Margin="8,0,0,0"
                         VerticalContentAlignment="Center"
                         TextChanged="TargetNgRateTextBox_TextChanged" />
                <TextBlock Grid.Column="3"
                           VerticalAlignment="Center"
                           Foreground="#475569"
                           Text="All areas use the same recommended USL / LSL. Actual stats and linear trend estimates are shown together." />
            </Grid>
        </Border>

        <UniformGrid Grid.Row="2"
                     Columns="2"
                     Margin="0,12,0,12">
            <Border Margin="0,0,8,0"
                    Padding="14"
                    BorderBrush="#CBD5E1"
                    BorderThickness="1"
                    CornerRadius="6"
                    Background="#F8FAFC">
                <StackPanel>
                    <TextBlock Text="Actual Area Envelope"
                               FontWeight="Bold"
                               FontSize="16" />
                    <TextBlock x:Name="ActualSummaryTextBlock"
                               Margin="0,8,0,0"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Margin="8,0,0,0"
                    Padding="14"
                    BorderBrush="#CBD5E1"
                    BorderThickness="1"
                    CornerRadius="6"
                    Background="#F8FAFC">
                <StackPanel>
                    <TextBlock Text="Linear Trend Envelope"
                               FontWeight="Bold"
                               FontSize="16" />
                    <TextBlock x:Name="TrendSummaryTextBlock"
                               Margin="0,8,0,0"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <DataGrid Grid.Row="3"
                  x:Name="RecommendationGrid"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserResizeRows="False"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Area" Binding="{Binding ColumnName}" Width="140" />
                <DataGridTextColumn Header="Count" Binding="{Binding Count}" Width="80" />
                <DataGridTextColumn Header="Avg" Binding="{Binding Avg, StringFormat=F4}" Width="90" />
                <DataGridTextColumn Header="StdDev" Binding="{Binding StdDev, StringFormat=F4}" Width="90" />
                <DataGridTextColumn Header="Current NG %" Binding="{Binding CurrentNgRatePercent, StringFormat=F4}" Width="110" />
                <DataGridTextColumn Header="Need LSL (Actual)" Binding="{Binding RequiredLowerActual, StringFormat=F4}" Width="120" />
                <DataGridTextColumn Header="Need USL (Actual)" Binding="{Binding RequiredUpperActual, StringFormat=F4}" Width="120" />
                <DataGridTextColumn Header="Pred Avg" Binding="{Binding TrendAvg, StringFormat=F4}" Width="90" />
                <DataGridTextColumn Header="Pred StdDev" Binding="{Binding TrendStdDev, StringFormat=F4}" Width="100" />
                <DataGridTextColumn Header="Need LSL (Trend)" Binding="{Binding RequiredLowerTrend, StringFormat=F4}" Width="120" />
                <DataGridTextColumn Header="Need USL (Trend)" Binding="{Binding RequiredUpperTrend, StringFormat=F4}" Width="120" />
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="Close"
                    Width="100"
                    Click="CloseButton_Click" />
        </StackPanel>
    </Grid>
</Window>
