<local:GraphViewBase x:Class="GraphMaker.HeatMapView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:app="clr-namespace:JinoSupporter.Controls;assembly=JinoSupporter.Controls"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:GraphMaker"
             mc:Ignorable="d"
             d:DesignHeight="800"
             d:DesignWidth="1600">
    <Grid Style="{StaticResource GraphMakerPageRootGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.72*" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="1.28*" />
        </Grid.ColumnDefinitions>

        <GroupBox Grid.Row="0" Grid.Column="0" Header="Workflow" Style="{StaticResource FilesSectionGroupBoxStyle}">
            <Grid Style="{StaticResource FilesSectionInnerGridStyle}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                    <app:AppFileDropBox HintText="Drag TXT file"
                            BrowseButtonText="Browse"
                            AllowMultiple="False"
                            FilesSelected="FileDropBox_FilesSelected" />
                    <TextBlock Margin="0,8,0,0"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource TextSecondaryBrush}">
                        <Run Text="File: " FontWeight="SemiBold" />
                        <Run x:Name="CurrentFileNameText" Text="(No file)" />
                    </TextBlock>
                    <TextBlock Margin="0,4,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}">
                        <Run Text="Rows: " FontWeight="SemiBold" />
                        <Run x:Name="RowCountText" Text="0" />
                        <Run Text=" | Cols: " FontWeight="SemiBold" />
                        <Run x:Name="ColumnCountText" Text="0" />
                    </TextBlock>
                    <TextBlock x:Name="StatusText"
                               Margin="0,4,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap"
                               Text="Drop file into the workflow area or click Browse to load data." />
                </StackPanel>

                <StackPanel Grid.Column="1" VerticalAlignment="Top">
                    <app:AppButton Content="Remove File" Width="130" Click="RemoveFileButton_Click" />
                    <app:AppButton Content="Save Report"
                            Width="130"
                            Margin="0,8,0,0"
                            Click="SaveReportButton_Click" />
                    <app:AppButton Content="Load Report"
                            Width="130"
                            Margin="0,8,0,0"
                            Click="LoadReportButton_Click" />
                    <app:AppButton Content="Generate Heatmap"
                            Width="130"
                            Margin="0,8,0,0"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="GenerateHeatMapButton_Click" />
                </StackPanel>

            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="1" Grid.Column="0" Header="Data Grid" Margin="0,0,0,8" Style="{StaticResource PreviewGroupBoxStyle}">
            <local:InteractiveDataGrid x:Name="DataPreviewGrid"
                                       IsReadOnly="True"
                                       CanUserAddRows="False"
                                       CanUserDeleteRows="False" />
        </GroupBox>

        <GroupBox Grid.Row="0" Grid.RowSpan="2" Grid.Column="2" Header="Settings" Style="{StaticResource SettingsGroupBoxStyle}">
                <ScrollViewer Style="{StaticResource SettingsScrollViewerStyle}">
                    <StackPanel Style="{StaticResource SettingsStackPanelStyle}">
                        <GroupBox Header="File Format" Margin="0,0,0,8">
                            <Grid Margin="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="Delimiter:" VerticalAlignment="Center" Width="80" />
                                    <RadioButton x:Name="TabDelimiterRadio" Content="Tab" GroupName="HeatMapDelimiter" IsChecked="True" Margin="0,0,10,0" Checked="DelimiterChanged" />
                                    <RadioButton x:Name="CommaDelimiterRadio" Content="Comma" GroupName="HeatMapDelimiter" Margin="0,0,10,0" Checked="DelimiterChanged" />
                                    <RadioButton x:Name="SpaceDelimiterRadio" Content="Space" GroupName="HeatMapDelimiter" Margin="0,0,10,0" Checked="DelimiterChanged" />
                                </StackPanel>

                                <StackPanel Grid.Row="1" Orientation="Horizontal">
                                    <TextBlock Text="Header Row:" VerticalAlignment="Center" Width="80" />
                                    <app:AppTextBox x:Name="HeaderRowTextBox" Width="70" Text="1" TextChanged="HeaderRowChanged" />
                                </StackPanel>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="Columns" Margin="0,0,0,8">
                            <Grid Margin="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Condition 1:" VerticalAlignment="Center" />
                                <app:AppComboBox Grid.Row="0" Grid.Column="1" x:Name="Condition1ComboBox" SelectionChanged="ColumnSelectionChanged" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Condition 2:" Margin="0,8,0,0" VerticalAlignment="Center" />
                                <app:AppComboBox Grid.Row="1" Grid.Column="1" Margin="0,8,0,0" x:Name="Condition2ComboBox" SelectionChanged="ColumnSelectionChanged" />
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Extra 1:" Margin="0,8,0,0" VerticalAlignment="Center" />
                                <app:AppComboBox Grid.Row="2" Grid.Column="1" Margin="0,8,0,0" x:Name="ExtraCondition1ComboBox" SelectionChanged="ColumnSelectionChanged" />
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Extra 2:" Margin="0,8,0,0" VerticalAlignment="Center" />
                                <app:AppComboBox Grid.Row="3" Grid.Column="1" Margin="0,8,0,0" x:Name="ExtraCondition2ComboBox" SelectionChanged="ColumnSelectionChanged" />
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="Result" Margin="0,0,0,8">
                            <Grid Margin="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Mode:" VerticalAlignment="Center" />
                                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Vertical">
                                    <RadioButton x:Name="DirectResultRadio" Content="Use result column" IsChecked="True" GroupName="ResultMode" Checked="ResultModeChanged" />
                                    <RadioButton x:Name="FormulaResultRadio" Content="NG * 1000000 / INPUT" GroupName="ResultMode" Margin="0,4,0,0" Checked="ResultModeChanged" />
                                </StackPanel>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Result:" Margin="0,8,0,0" VerticalAlignment="Center" />
                                <app:AppComboBox Grid.Row="1" Grid.Column="1" Margin="0,8,0,0" x:Name="ResultColumnComboBox" SelectionChanged="ColumnSelectionChanged" />
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="NG:" Margin="0,8,0,0" VerticalAlignment="Center" />
                                <app:AppComboBox Grid.Row="2" Grid.Column="1" Margin="0,8,0,0" x:Name="NgColumnComboBox" SelectionChanged="ColumnSelectionChanged" />
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Input:" Margin="0,8,0,0" VerticalAlignment="Center" />
                                <app:AppComboBox Grid.Row="3" Grid.Column="1" Margin="0,8,0,0" x:Name="InputColumnComboBox" SelectionChanged="ColumnSelectionChanged" />
                            </Grid>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
        </GroupBox>
    </Grid>
</local:GraphViewBase>
