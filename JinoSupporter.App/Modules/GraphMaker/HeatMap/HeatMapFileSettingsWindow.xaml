<Window x:Class="GraphMaker.HeatMapFileSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HeatMap File Settings"
        Width="620"
        Height="560"
        MinWidth="560"
        MinHeight="500"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <GroupBox Header="File Format" Margin="0,0,0,8">
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Delimiter:" VerticalAlignment="Center" />
                        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
                            <RadioButton x:Name="TabDelimiterRadio" Content="Tab" GroupName="Delimiter" Margin="0,0,10,0" />
                            <RadioButton x:Name="CommaDelimiterRadio" Content="Comma" GroupName="Delimiter" Margin="0,0,10,0" />
                            <RadioButton x:Name="SpaceDelimiterRadio" Content="Space" GroupName="Delimiter" />
                        </StackPanel>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Header Row:" VerticalAlignment="Center" Margin="0,8,0,0" />
                        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,8,0,0">
                            <TextBox x:Name="HeaderRowTextBox" Width="70" />
                            <Button Content="Reload Columns" Margin="8,0,0,0" Padding="12,4" Click="ReloadColumnsButton_Click" />
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <GroupBox Header="Columns" Margin="0,0,0,8">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Condition 1:" VerticalAlignment="Center" />
                        <ComboBox Grid.Row="0" Grid.Column="1" x:Name="Condition1ComboBox" />
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Condition 2:" Margin="0,8,0,0" VerticalAlignment="Center" />
                        <ComboBox Grid.Row="1" Grid.Column="1" Margin="0,8,0,0" x:Name="Condition2ComboBox" />
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Extra 1:" Margin="0,8,0,0" VerticalAlignment="Center" />
                        <ComboBox Grid.Row="2" Grid.Column="1" Margin="0,8,0,0" x:Name="ExtraCondition1ComboBox" />
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Extra 2:" Margin="0,8,0,0" VerticalAlignment="Center" />
                        <ComboBox Grid.Row="3" Grid.Column="1" Margin="0,8,0,0" x:Name="ExtraCondition2ComboBox" />
                    </Grid>
                </GroupBox>

                <GroupBox Header="Result">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Mode:" VerticalAlignment="Center" />
                        <StackPanel Grid.Row="0" Grid.Column="1">
                            <RadioButton x:Name="DirectResultRadio" Content="Use result column" IsChecked="True" GroupName="ResultMode" Checked="ResultModeChanged" />
                            <RadioButton x:Name="FormulaResultRadio" Content="NG * 1000000 / INPUT" GroupName="ResultMode" Margin="0,4,0,0" Checked="ResultModeChanged" />
                        </StackPanel>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Result:" Margin="0,8,0,0" VerticalAlignment="Center" />
                        <ComboBox Grid.Row="1" Grid.Column="1" Margin="0,8,0,0" x:Name="ResultColumnComboBox" />
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="NG:" Margin="0,8,0,0" VerticalAlignment="Center" />
                        <ComboBox Grid.Row="2" Grid.Column="1" Margin="0,8,0,0" x:Name="NgColumnComboBox" />
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Input:" Margin="0,8,0,0" VerticalAlignment="Center" />
                        <ComboBox Grid.Row="3" Grid.Column="1" Margin="0,8,0,0" x:Name="InputColumnComboBox" />
                    </Grid>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Cancel" Width="90" Margin="0,0,8,0" Click="CancelButton_Click" />
            <Button Content="Save" Width="90" Click="SaveButton_Click" />
        </StackPanel>
    </Grid>
</Window>
