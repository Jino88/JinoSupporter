<Window x:Class="GraphMaker.ScatterFileSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SPL File Settings"
        Width="1280"
        Height="840"
        MinWidth="1080"
        MinHeight="740"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style TargetType="{x:Type ComboBox}"
               BasedOn="{StaticResource AppComboBoxBaseStyle}">
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="4,0" />
            <Setter Property="MinHeight" Value="22" />
        </Style>
        <Style TargetType="{x:Type ComboBoxItem}"
               BasedOn="{StaticResource AppComboBoxItemBaseStyle}">
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="4,0" />
            <Setter Property="MinHeight" Value="20" />
        </Style>
        <Style TargetType="{x:Type TextBox}">
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="4,0" />
            <Setter Property="MinHeight" Value="22" />
        </Style>
        <Style TargetType="{x:Type ListBox}">
            <Setter Property="Padding" Value="2" />
        </Style>
        <Style TargetType="{x:Type ListBoxItem}">
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="4,0" />
            <Setter Property="MinHeight" Value="22" />
        </Style>
    </Window.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="430" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <GroupBox Header="File Format" Margin="0,0,0,8">
                        <Grid Margin="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Delimiter:" VerticalAlignment="Center" />
                            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
                                <RadioButton x:Name="TabDelimiterRadio" Content="Tab" GroupName="Delimiter" Margin="0,0,10,0" />
                                <RadioButton x:Name="CommaDelimiterRadio" Content="Comma" GroupName="Delimiter" Margin="0,0,10,0" />
                                <RadioButton x:Name="SpaceDelimiterRadio" Content="Space" GroupName="Delimiter" />
                            </StackPanel>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Header Row:" VerticalAlignment="Center" Margin="0,8,0,0" />
                            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,8,0,0">
                                <TextBox x:Name="HeaderRowTextBox" Width="70" Text="1" />
                                <Button Content="Reload Columns"
                                        Margin="8,0,0,0"
                                        Padding="12,4"
                                        Click="ReloadColumnsButton_Click" />
                            </StackPanel>
                        </Grid>
                    </GroupBox>

                    <GroupBox Header="Axis Settings">
                        <Grid Margin="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="X Mode:" VerticalAlignment="Center" />
                            <ComboBox Grid.Row="0" Grid.Column="1"
                                      x:Name="XAxisModeComboBox"
                                      SelectionChanged="XAxisModeComboBox_SelectionChanged">
                                <ComboBoxItem Content="Column" />
                                <ComboBoxItem Content="None (Use Row Index)" />
                            </ComboBox>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="X Axis:" VerticalAlignment="Center" Margin="0,8,0,0" />
                            <ComboBox Grid.Row="1" Grid.Column="1" x:Name="XAxisComboBox" Margin="0,8,0,0" />

                            <CheckBox Grid.Row="2"
                                      Grid.Column="1"
                                      x:Name="XAxisLogScaleCheckBox"
                                      Margin="0,8,0,0"
                                      Content="Use Log Scale (X Axis)" />
                        </Grid>
                    </GroupBox>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <GroupBox Header="Column Groups + REF/UPPER/LOWER Limit">
                        <Grid Margin="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="320" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="Headers (Unassigned)"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,6" />
                                <ListBox x:Name="UnassignedColumnsListBox"
                                         Height="520"
                                         SelectionMode="Extended" />
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <GroupBox Header="Global REF / UPPER / LOWER" Margin="0,0,0,8">
                                    <Grid Margin="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="58" />
                                            <ColumnDefinition Width="36" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="92" />
                                            <ColumnDefinition Width="92" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Column" FontWeight="SemiBold" Margin="0,0,6,6" />
                                        <TextBlock Grid.Row="0" Grid.Column="3" Text="Color" FontWeight="SemiBold" Margin="0,0,6,6" />
                                        <TextBlock Grid.Row="0" Grid.Column="4" Text="Style" FontWeight="SemiBold" Margin="0,0,0,6" />

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="REF" VerticalAlignment="Center" Margin="0,0,6,6" />
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="UPPER" VerticalAlignment="Center" Margin="0,0,6,6" />
                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="LOWER" VerticalAlignment="Center" Margin="0,0,6,0" />

                                        <Button Grid.Row="1" Grid.Column="1"
                                                Content=">"
                                                Width="24"
                                                Height="22"
                                                Padding="5,0,0,0"
                                                FontSize="11"
                                                VerticalContentAlignment="Center"
                                                HorizontalContentAlignment="Left"
                                                VerticalAlignment="Center"
                                                Click="MoveToRefButton_Click" />
                                        <Button Grid.Row="2" Grid.Column="1"
                                                Content=">"
                                                Width="24"
                                                Height="22"
                                                Padding="5,0,0,0"
                                                FontSize="11"
                                                VerticalContentAlignment="Center"
                                                HorizontalContentAlignment="Left"
                                                VerticalAlignment="Center"
                                                Click="MoveToUpperButton_Click" />
                                        <Button Grid.Row="3" Grid.Column="1"
                                                Content=">"
                                                Width="24"
                                                Height="22"
                                                Padding="5,0,0,0"
                                                FontSize="11"
                                                VerticalContentAlignment="Center"
                                                HorizontalContentAlignment="Left"
                                                VerticalAlignment="Center"
                                                Click="MoveToLowerButton_Click" />

                                        <ListBox Grid.Row="1" Grid.Column="2" x:Name="RefLimitListBox" Height="20" Margin="0,0,6,6" VerticalContentAlignment="Center" />
                                        <ComboBox Grid.Row="1" Grid.Column="3" x:Name="SpecColorComboBox" Margin="0,0,6,6" />
                                        <ComboBox Grid.Row="1" Grid.Column="4" x:Name="SpecLineStyleComboBox" Margin="0,0,0,6" />

                                        <ListBox Grid.Row="2" Grid.Column="2" x:Name="UpperLimitListBox" Height="20" Margin="0,0,6,6" VerticalContentAlignment="Center" />
                                        <ComboBox Grid.Row="2" Grid.Column="3" x:Name="UpperLimitColorComboBox" Margin="0,0,6,6" />
                                        <ComboBox Grid.Row="2" Grid.Column="4" x:Name="UpperLimitLineStyleComboBox" Margin="0,0,0,6" />

                                        <ListBox Grid.Row="3" Grid.Column="2" x:Name="LowerLimitListBox" Height="20" Margin="0,0,6,0" VerticalContentAlignment="Center" />
                                        <ComboBox Grid.Row="3" Grid.Column="3" x:Name="LowerLimitColorComboBox" Margin="0,0,6,0" />
                                        <ComboBox Grid.Row="3" Grid.Column="4" x:Name="LowerLimitLineStyleComboBox" Margin="0,0,0,0" />
                                    </Grid>
                                </GroupBox>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="Groups"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                    <Button x:Name="AddGroupButton"
                                            Content="+ Add Group"
                                            Margin="10,0,0,0"
                                            Padding="12,4"
                                            Click="AddGroupButton_Click" />
                                </StackPanel>

                                <StackPanel x:Name="GroupRowsHost" />
                            </StackPanel>
                        </Grid>
                    </GroupBox>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button Content="Cancel" Width="90" Margin="0,0,8,0" Click="CancelButton_Click" />
            <Button Content="Save" Width="90" Click="SaveButton_Click" />
        </StackPanel>
    </Grid>
</Window>
