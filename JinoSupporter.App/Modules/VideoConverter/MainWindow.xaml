<Window x:Class="VideoConverter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Video HEVC Converter"
        Width="1320"
        Height="820"
        MinWidth="1100"
        MinHeight="700"
        FontFamily="Segoe UI, Malgun Gothic"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        TextOptions.TextHintingMode="Fixed"
        Foreground="#1A1D26"
        Background="{StaticResource ShellCanvasBrush}">
    <Window.Resources>
        <SolidColorBrush x:Key="VcSurfaceBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="VcPanelBrush" Color="#F0F1F5" />
        <SolidColorBrush x:Key="VcBorderBrush" Color="#E4E5EB" />
        <SolidColorBrush x:Key="VcAccentBrush" Color="#4F6BED" />
        <SolidColorBrush x:Key="VcTextSubBrush" Color="#6B7280" />

        <Style TargetType="Button"
               BasedOn="{StaticResource AppButtonBaseStyle}">
            <Setter Property="BorderBrush" Value="{StaticResource VcBorderBrush}" />
            <Setter Property="Background" Value="{StaticResource VcPanelBrush}" />
            <Setter Property="Foreground" Value="#1A1D26" />
        </Style>

        <Style x:Key="AccentButtonStyle" TargetType="Button" BasedOn="{StaticResource AppButtonBaseStyle}">
            <Setter Property="Background" Value="{StaticResource VcAccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource VcAccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style TargetType="TextBox"
               BasedOn="{StaticResource AppTextBoxBaseStyle}">
            <Setter Property="Background" Value="{StaticResource VcSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource VcBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#1A1D26" />
        </Style>

        <Style TargetType="ComboBox" BasedOn="{StaticResource AppComboBoxBaseStyle}">
            <Setter Property="Height" Value="20" />
            <Setter Property="MinHeight" Value="20" />
            <Setter Property="Padding" Value="4,0" />
            <Setter Property="Background" Value="{StaticResource VcSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource VcBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style TargetType="DataGrid"
               BasedOn="{StaticResource AppDataGridBaseStyle}">
            <Setter Property="Background" Value="{StaticResource VcSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource VcBorderBrush}" />
            <Setter Property="RowBackground" Value="#FFFFFF" />
            <Setter Property="AlternatingRowBackground" Value="#F8F9FC" />
            <Setter Property="HorizontalGridLinesBrush" Value="#E4E5EB" />
            <Setter Property="VerticalGridLinesBrush" Value="#EDEEF3" />
        </Style>

        <Style TargetType="DataGridColumnHeader"
               BasedOn="{StaticResource AppDataGridColumnHeaderBaseStyle}">
            <Setter Property="Background" Value="{StaticResource VcPanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource VcBorderBrush}" />
        </Style>

        <Style TargetType="TextBlock"
               BasedOn="{StaticResource AppTextBlockBaseStyle}">
            <Setter Property="Foreground" Value="#1A1D26" />
        </Style>

        <Style x:Key="SubTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#4B5563" />
        </Style>
    </Window.Resources>
    <Grid Margin="14"
          RenderOptions.ClearTypeHint="Enabled">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource ShellCardBorderStyle}" Padding="10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <Button Content="Add Files" Width="100" Margin="0,0,6,0" Click="AddFilesButton_Click" />
                    <Button Content="Add Folder" Width="100" Margin="0,0,6,0" Click="AddFolderButton_Click" />
                    <Button Content="Remove Selected" Width="120" Margin="0,0,6,0" Click="RemoveSelectedButton_Click" />
                    <Button Content="Clear" Width="90" Click="ClearButton_Click" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="StartButton" Content="Start Encoding" Width="130" Margin="0,0,8,0" Style="{StaticResource AccentButtonStyle}" Click="StartButton_Click" />
                    <Button x:Name="CancelButton" Content="Cancel" Width="100" IsEnabled="False" Click="CancelButton_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.35*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0,0,10,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="1.25*" />
                    <RowDefinition Height="0.75*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource ShellCardBorderStyle}" Padding="10" Margin="0,0,0,10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="Video Queue" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,6" Foreground="{StaticResource ShellTextPrimaryBrush}" />
                        <TextBlock Grid.Row="1"
                                   Text="Drag and drop video files/folders here"
                                   Margin="0,0,0,10"
                                   Foreground="{StaticResource ShellTextSecondaryBrush}" />
                        <DataGrid x:Name="QueueDataGrid"
                                  Grid.Row="2"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  SelectionMode="Extended"
                                  AllowDrop="True"
                                  DragOver="QueueDataGrid_DragOver"
                                  Drop="QueueDataGrid_Drop"
                                  SelectionChanged="QueueDataGrid_SelectionChanged">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="File" Binding="{Binding FileName}" Width="190" />
                                <DataGridTextColumn Header="Codec" Binding="{Binding VideoCodec}" Width="90" />
                                <DataGridTextColumn Header="HEVC" Binding="{Binding IsHevcDisplay}" Width="70" />
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="110" />
                                <DataGridTemplateColumn Header="Progress" Width="180">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <ProgressBar Minimum="0" Maximum="100" Value="{Binding Progress}" Height="16" />
                                                <TextBlock Text="{Binding ProgressText}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           FontSize="10"
                                                           FontWeight="SemiBold" />
                                            </Grid>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Input Path" Binding="{Binding InputPath}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource ShellCardBorderStyle}" Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0"
                                   Text="Selected Video Details"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8"
                                   Foreground="{StaticResource ShellTextPrimaryBrush}" />
                        <TextBlock Grid.Row="1" Text="File" FontWeight="SemiBold" Foreground="{StaticResource ShellTextSecondaryBrush}" />
                        <TextBlock x:Name="DetailFileNameTextBlock" Grid.Row="2" Margin="0,0,0,8" TextWrapping="Wrap" />
                        <TextBlock Grid.Row="3" Text="Path" FontWeight="SemiBold" Foreground="{StaticResource ShellTextSecondaryBrush}" />
                        <TextBlock x:Name="DetailPathTextBlock" Grid.Row="4" Margin="0,0,0,8" TextWrapping="Wrap" />
                        <TextBlock x:Name="DetailSummaryTextBlock" Grid.Row="5" Margin="0,0,0,8" TextWrapping="Wrap" />
                        <TextBlock x:Name="DetailVideoTextBlock" Grid.Row="6" Margin="0,0,0,8" TextWrapping="Wrap" />
                        <TextBlock x:Name="DetailAudioTextBlock" Grid.Row="7" TextWrapping="Wrap" />
                    </Grid>
                </Border>
            </Grid>

            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Style="{StaticResource ShellCardBorderStyle}" Padding="10" Margin="0,0,0,8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Encoding Codec / Resolution" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <Grid Grid.Row="1" Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Codec" />
                                <ComboBox x:Name="CodecComboBox" Grid.Column="1" Margin="6,0,12,0" />
                                <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="Resolution" />
                                <ComboBox x:Name="ResolutionComboBox" Grid.Column="3" Margin="6,0,0,0" />
                            </Grid>
                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Preset" />
                                <ComboBox x:Name="PresetComboBox" Grid.Column="1" Margin="6,0,0,0" />
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource ShellCardBorderStyle}" Padding="10" Margin="0,0,0,8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Encoding Quality" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="70" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="CRF (0-51)" />
                                <Slider x:Name="CrfSlider" Grid.Column="1" Minimum="0" Maximum="51" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="CrfSlider_ValueChanged" />
                                <TextBox x:Name="CrfTextBox" Grid.Column="2" Margin="8,0,0,0" VerticalContentAlignment="Center" TextChanged="CrfTextBox_TextChanged" />
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource ShellCardBorderStyle}" Padding="10" Margin="0,0,0,8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Crop Option / Thumbnail" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <StackPanel Grid.Row="1">
                                <CheckBox x:Name="EnableCropCheckBox" Content="Enable Crop" Margin="0,0,0,8" Checked="CropSetting_Changed" Unchecked="CropSetting_Changed" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="24" />
                                        <ColumnDefinition Width="72" />
                                        <ColumnDefinition Width="24" />
                                        <ColumnDefinition Width="72" />
                                        <ColumnDefinition Width="24" />
                                        <ColumnDefinition Width="72" />
                                        <ColumnDefinition Width="24" />
                                        <ColumnDefinition Width="72" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="X" />
                                    <TextBox x:Name="CropXTextBox" Grid.Column="1" Text="0" VerticalContentAlignment="Center" Margin="4,0,8,0" TextChanged="CropSetting_Changed" />
                                    <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="Y" />
                                    <TextBox x:Name="CropYTextBox" Grid.Column="3" Text="0" VerticalContentAlignment="Center" Margin="4,0,8,0" TextChanged="CropSetting_Changed" />
                                    <TextBlock Grid.Column="4" VerticalAlignment="Center" Text="W" />
                                    <TextBox x:Name="CropWTextBox" Grid.Column="5" Text="0" VerticalContentAlignment="Center" Margin="4,0,8,0" TextChanged="CropSetting_Changed" />
                                    <TextBlock Grid.Column="6" VerticalAlignment="Center" Text="H" />
                                    <TextBox x:Name="CropHTextBox" Grid.Column="7" Text="0" VerticalContentAlignment="Center" Margin="4,0,8,0" TextChanged="CropSetting_Changed" />
                                </Grid>
                            </StackPanel>
                            <Grid Grid.Row="2" Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="6" Width="150" Height="90" Background="#111827">
                                    <Image x:Name="ThumbnailPreviewImage" Stretch="UniformToFill" />
                                </Border>
                                <TextBlock x:Name="ThumbnailInfoText"
                                           Grid.Column="1"
                                           Margin="10,0,0,0"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap"
                                           Foreground="#334155"
                                           Text="Select a video from the left list to preview thumbnail." />
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource ShellCardBorderStyle}" Padding="10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Misc Options" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <Grid Grid.Row="1" Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="FFmpeg Folder" />
                                <TextBox x:Name="FfmpegFolderTextBox" Grid.Column="1" Margin="6,0,12,0" VerticalContentAlignment="Center" TextChanged="FfmpegFolderTextBox_TextChanged" />
                                <Button Grid.Column="2" HorizontalAlignment="Left" Width="100" Content="Browse..." Click="BrowseFfmpegFolderButton_Click" />
                            </Grid>
                            <Grid Grid.Row="2" Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Output Folder" />
                                <TextBox x:Name="OutputFolderTextBox" Grid.Column="1" Margin="6,0,12,0" VerticalContentAlignment="Center" />
                                <Button Grid.Column="2" HorizontalAlignment="Left" Width="100" Content="Browse..." Click="BrowseOutputFolderButton_Click" />
                            </Grid>
                            <Grid Grid.Row="3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <CheckBox x:Name="DisableAudioCheckBox" Grid.Column="0" VerticalAlignment="Center" Content="Disable Audio" />
                                <CheckBox x:Name="OverwriteCheckBox" Grid.Column="1" VerticalAlignment="Center" Content="Overwrite Output" IsChecked="True" />
                                <CheckBox x:Name="HevcOnlyModeCheckBox" Grid.Column="2" VerticalAlignment="Center" Content="HEVC only compatibility mode" IsChecked="True" />
                                <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="Audio Bitrate" />
                                <ComboBox x:Name="AudioBitrateComboBox" Grid.Column="4" Margin="8,0,0,0" />
                            </Grid>
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Border Grid.Row="2" Margin="0,10,0,0" Style="{StaticResource ShellCardBorderStyle}" Padding="10">
            <TextBlock x:Name="StateTextBlock"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold"
                       Text="Queued: 0, Completed: 0, Failed: 0, Total: 0" />
        </Border>
    </Grid>
</Window>
