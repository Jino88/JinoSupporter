<UserControl x:Class="JinoSupporter.App.Modules.FileTransfer.FileTransferView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:app="clr-namespace:JinoSupporter.Controls;assembly=JinoSupporter.Controls">
    <Grid Background="#F4F7FB">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Margin="10,10,10,0"
                Padding="12,8"
                Background="White"
                BorderBrush="#D9E2EC"
                BorderThickness="1"
                CornerRadius="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="File Transfer"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="#102A43"
                           VerticalAlignment="Center" />
                <TextBlock x:Name="StatusTextBlock"
                           Grid.Column="1"
                           VerticalAlignment="Center"
                           Foreground="#486581"
                           FontWeight="SemiBold"
                           Text="Starting runtime..." />
            </Grid>
        </Border>

        <Grid Grid.Row="1"
              Margin="10,0,10,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <Grid Margin="0,0,10,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Padding="14"
                        Background="White"
                        BorderBrush="#D9E2EC"
                        BorderThickness="1"
                        CornerRadius="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Local Device" Foreground="#486581" />
                            <TextBlock x:Name="LocalDeviceTextBlock"
                                       Margin="0,6,0,0"
                                       FontSize="18"
                                       FontWeight="SemiBold" />
                            <TextBlock x:Name="LocalUrlTextBlock"
                                       Margin="0,6,0,0"
                                       Foreground="#486581"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                            <app:AppButton Content="Refresh"
                                    Padding="12,7"
                                    Margin="0,0,8,0"
                                    Click="RefreshButton_Click" />
                            <app:AppButton Content="Choose Destination"
                                    Padding="12,7"
                                    Click="ChooseDestinationButton_Click" />
                        </WrapPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="1"
                      Margin="0,10,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Margin="0,0,10,0"
                            Padding="14"
                            Background="White"
                            BorderBrush="#D9E2EC"
                            BorderThickness="1"
                            CornerRadius="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="Android Devices"
                                       FontSize="16"
                                       FontWeight="SemiBold" />
                            <app:AppListBox x:Name="DeviceListBox"
                                     Grid.Row="1"
                                     Margin="0,10,0,0" />
                        </Grid>
                    </Border>

                    <Border Grid.Column="1"
                            Padding="14"
                            Background="White"
                            BorderBrush="#D9E2EC"
                            BorderThickness="1"
                            CornerRadius="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="Send To Android"
                                       FontSize="16"
                                       FontWeight="SemiBold" />
                            <WrapPanel Grid.Row="1"
                                       Margin="0,10,0,10">
                                <app:AppButton Content="Choose Files"
                                        Padding="12,7"
                                        Margin="0,0,8,0"
                                        Click="ChooseFilesButton_Click" />
                                <app:AppButton Content="Send"
                                        Padding="12,7"
                                        Click="SendFilesButton_Click" />
                            </WrapPanel>
                            <app:AppListBox x:Name="SelectedFileListBox"
                                     Grid.Row="2" />
                        </Grid>
                    </Border>
                </Grid>

                <Border Grid.Row="2"
                        Padding="14"
                        Background="White"
                        BorderBrush="#D9E2EC"
                        BorderThickness="1"
                        CornerRadius="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="Inbound Sessions"
                                   FontSize="16"
                                   FontWeight="SemiBold" />
                        <app:AppListBox x:Name="InboundSessionListBox"
                                 Grid.Row="1"
                                 Margin="0,10,0,0" />
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Column="1"
                    Padding="14"
                    Background="White"
                    BorderBrush="#D9E2EC"
                    BorderThickness="1"
                    CornerRadius="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Transfer History"
                               FontSize="16"
                               FontWeight="SemiBold" />
                    <app:AppListBox x:Name="HistoryListBox"
                             Grid.Row="1"
                             Margin="0,10,0,0" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
