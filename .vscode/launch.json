{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "WPF App",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/JinoSupporter.App/bin/Debug/net8.0-windows/JinoSupporter.App.exe",
      "cwd": "${workspaceFolder}/JinoSupporter.App",
      "console": "internalConsole",
      "stopAtEntry": false
    },
    {
      "name": "Web Server",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "kill-and-build",
      "program": "${workspaceFolder}/JinoSupporter.Web/bin/Debug/net8.0/JinoSupporter.Web.dll",
      "args": [],
      "cwd": "${workspaceFolder}/JinoSupporter.Web",
      "stopAtEntry": false,
      "console": "integratedTerminal",
      "justMyCode": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://*:5080"
      },
      "exceptionOptions": [
        {
          "exceptionNames": ["Microsoft.AspNetCore.Components.NavigationException"],
          "throwAction": "ignore"
        }
      ]
    },
    {
      "name": "Snapshot (publish & run @5050)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "kill-and-publish-snapshot",
      "program": "D:/temp/jino-web-snapshot/JinoSupporter.Web.dll",
      "args": [],
      "cwd": "D:/temp/jino-web-snapshot",
      "stopAtEntry": false,
      "console": "integratedTerminal",
      "justMyCode": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      },
      "exceptionOptions": [
        {
          "exceptionNames": ["Microsoft.AspNetCore.Components.NavigationException"],
          "throwAction": "ignore"
        }
      ]
    },
    {
      "name": "Snapshot (run only @5050)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "kill-snapshot",
      "program": "D:/temp/jino-web-snapshot/JinoSupporter.Web.dll",
      "args": [],
      "cwd": "D:/temp/jino-web-snapshot",
      "stopAtEntry": false,
      "console": "integratedTerminal",
      "justMyCode": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      },
      "exceptionOptions": [
        {
          "exceptionNames": ["Microsoft.AspNetCore.Components.NavigationException"],
          "throwAction": "ignore"
        }
      ]
    },
    {
      "name": "Web Server (watch)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "kill-web-server",
      "program": "dotnet",
      "args": ["watch", "run", "--non-interactive"],
      "cwd": "${workspaceFolder}/JinoSupporter.Web",
      "stopAtEntry": false,
      "console": "integratedTerminal",
      "justMyCode": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://*:5080",
        "DOTNET_WATCH_RESTART_ON_RUDE_EDIT": "true",
        "DOTNET_USE_POLLING_FILE_WATCHER": "true"
      },
      "exceptionOptions": [
        {
          "exceptionNames": ["Microsoft.AspNetCore.Components.NavigationException"],
          "throwAction": "ignore"
        }
      ]
    }
  ],
  "compounds": [
    {
      "name": "Launch All",
      "configurations": ["WPF App", "Web Server"],
      "stopAll": true
    }
  ]
}
